/* 分类列表页面样式 */
.page-container {
  background-color: #f7f5f0;
  min-height: 100vh;
  padding: 20rpx;
}

/* 顶部标题栏 */
.header-section {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 20rpx 0 40rpx;
  position: relative;
}

.header-title {
  background: linear-gradient(135deg, #000000 0%, #1A1A1A 100%);
  padding: 20rpx 60rpx;
  border-radius: 50rpx;
  position: relative;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.header-title::before,
.header-title::after {
  content: '';
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 40rpx;
  height: 40rpx;
  background: #D4A017;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #1A365D;
  font-weight: bold;
}

.header-title::before {
  left: -20rpx;
  content: '卍';
}

.header-title::after {
  right: -20rpx;
  content: '卍';
}

.main-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #D4A017;
  font-family: "STKaiti", "KaiTi", serif;
  letter-spacing: 8rpx;
  text-shadow: 2rpx 2rpx 4rpx rgba(0,0,0,0.2);
}

/* 分类信息 */
.category-info {
  background: #F8F0E3;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  border: 2rpx solid #D4A017;
  margin-bottom: 30rpx;
}

.category-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #1A365D;
  font-family: "STKaiti", "KaiTi", serif;
  margin-bottom: 10rpx;
  text-align: center;
}

.category-desc {
  font-size: 24rpx;
  color: #666;
  font-family: "STKaiti", "KaiTi", serif;
  line-height: 1.4;
  text-align: center;
}

/* 作品列表 */
.works-list {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  margin-bottom: 30rpx;
}

.works-item {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  transition: all 0.3s ease;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
  background: #f9f9f9;
  border: 1rpx solid #f0f0f0;
}

.works-item:last-child {
  margin-bottom: 0;
}

.works-item:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
  background: #f0f0f0;
}

.works-image {
  width: 160rpx;
  height: 200rpx;
  border-radius: 10rpx;
  object-fit: cover;
  border: 1rpx solid #f0f0f0;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.08);
}

.works-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.works-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  font-family: "STKaiti", "KaiTi", serif;
  line-height: 1.3;
  margin-bottom: 8rpx;
}

.works-desc {
  font-size: 22rpx;
  color: #666;
  line-height: 1.4;
  font-family: "STKaiti", "KaiTi", serif;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.works-meta {
  display: flex;
  align-items: center;
  gap: 15rpx;
  flex-wrap: wrap;
}

.works-craftsman {
  font-size: 20rpx;
  color: #999;
  font-family: "STKaiti", "KaiTi", serif;
  background: #f0f0f0;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

.works-era {
  font-size: 20rpx;
  color: #999;
  font-family: "STKaiti", "KaiTi", serif;
  background: #f0f0f0;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 30rpx;
  margin-top: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  font-size: 24rpx;
  color: #8B4513;
  font-weight: 500;
  font-family: "STKaiti", "KaiTi", serif;
  transition: all 0.3s ease;
}

.load-more:active {
  transform: scale(0.98);
  background: #f8f4e9;
}

/* 底部空间 */
.bottom-space {
  height: 40rpx;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .main-title {
    font-size: 40rpx;
  }
  
  .works-image {
    width: 140rpx;
    height: 180rpx;
  }
  
  .works-title {
    font-size: 26rpx;
  }
  
  .works-desc {
    font-size: 20rpx;
  }
}