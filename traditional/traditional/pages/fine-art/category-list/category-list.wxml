<!-- 分类列表页面 -->
<view class="page-container">
  
  <!-- 顶部标题栏 -->
  <view class="header-section">
    <view class="header-title">
      <text class="main-title">{{categoryName}}</text>
    </view>
  </view>
  
  <!-- 分类信息 -->
  <view class="category-info">
    <text class="category-name">{{categoryName}}</text>
    <text class="category-desc">{{categoryDesc}}</text>
  </view>
  
  <!-- 作品列表 -->
  <view class="works-list">
    <view class="works-item" wx:for="{{worksList}}" wx:key="id" data-id="{{item.id}}" bindtap="navigateToDetail">
      <image class="works-image" src="{{item.image}}" mode="aspectFill" />
      <view class="works-info">
        <text class="works-title">{{item.title}}</text>
        <text class="works-desc">{{item.desc}}</text>
        <view class="works-meta">
          <text class="works-craftsman">匠人：{{item.craftsman}}</text>
          <text class="works-era">{{item.era}}</text>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 加载更多 -->
  <view class="load-more" bindtap="loadMore">
    <text>加载更多</text>
  </view>
  
  <!-- 底部空间 -->
  <view class="bottom-space"></view>
</view>