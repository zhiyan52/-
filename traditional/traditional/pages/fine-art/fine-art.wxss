/* 传统美术页面样式 - 高端极简风格 */
.page-container {
  background-color: #f8f9fa;
  min-height: 100vh;
  padding: 0 24rpx;
  font-family: 'SF Pro Display', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

/* 顶部标题栏 */
.header-section {
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 40rpx 0 60rpx;
  position: relative;
}

.header-title {
  background: #ffffff;
  padding: 24rpx 64rpx;
  border-radius: 56rpx;
  position: relative;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
  border: 1rpx solid #eaeaea;
}

.main-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #2c3e50;
  letter-spacing: 4rpx;
  text-align: center;
}

/* 子分类标签栏 */
.subcategory-bar {
  display: flex;
  gap: 12rpx;
  padding: 16rpx;
  background: #ffffff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  margin-bottom: 40rpx;
  overflow-x: auto;
  white-space: nowrap;
  border: 1rpx solid #f0f0f0;
}

.subcategory-item {
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  background: #f5f7fa;
  font-size: 24rpx;
  color: #64748b;
  transition: all 0.3s ease;
  flex-shrink: 0;
  font-weight: 500;
}

.subcategory-item.active {
  background: #2c3e50;
  color: #ffffff;
  box-shadow: 0 2rpx 8rpx rgba(44, 62, 80, 0.3);
}

.subcategory-item:active {
  transform: translateY(1rpx);
}

/* 非遗品类宫格 */
.categories-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  margin-bottom: 60rpx;
}

.category-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 40rpx 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  border: 1rpx solid #f0f0f0;
  transition: all 0.3s ease;
  display: flex;
  flex-direction: column;
  align-items: center;
  cursor: pointer;
  position: relative;
  overflow: hidden;
}

.category-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #a8b8c8, #64748b);
  opacity: 0;
  transition: opacity 0.3s ease;
}

.category-card:active {
  transform: translateY(4rpx);
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.08);
}

.category-card:hover::before {
  opacity: 1;
}

.category-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 1rpx solid #eaeaea;
  margin-bottom: 24rpx;
  object-fit: cover;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  transition: transform 0.3s ease;
}

.category-card:active .category-icon {
  transform: scale(0.96);
}

.category-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #2c3e50;
  text-align: center;
  margin-bottom: 12rpx;
  letter-spacing: 1rpx;
}

.category-desc {
  font-size: 20rpx;
  color: #64748b;
  text-align: center;
  line-height: 1.5;
  opacity: 0.8;
}

/* 热门推荐 */
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2c3e50;
  margin: 60rpx 0 32rpx;
  display: block;
  text-align: center;
  position: relative;
  padding-bottom: 16rpx;
  letter-spacing: 2rpx;
}

.section-title::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 80rpx;
  height: 3rpx;
  background: #a8b8c8;
  border-radius: 2rpx;
}

.recommendation-list {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  margin-bottom: 40rpx;
  border: 1rpx solid #f0f0f0;
}

.recommendation-item {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f7fa;
  transition: all 0.3s ease;
  align-items: center;
}

.recommendation-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.recommendation-item:first-child {
  padding-top: 0;
}

.recommendation-item:active {
  background: #f8f9fa;
  border-radius: 12rpx;
  margin: 0 -24rpx;
  padding-left: 24rpx;
  padding-right: 24rpx;
}

.recommendation-image {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  object-fit: cover;
  border: 1rpx solid #f0f0f0;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  flex-shrink: 0;
}

.recommendation-info {
  flex: 1;
  min-width: 0;
}

.recommendation-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #2c3e50;
  line-height: 1.3;
  margin-bottom: 8rpx;
}

.recommendation-desc {
  font-size: 20rpx;
  color: #64748b;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 12rpx;
  opacity: 0.8;
}

.recommendation-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.recommendation-craftsman {
  font-size: 18rpx;
  color: #94a3b8;
}

/* 匠人故事入口 */
.craftsman-entry {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
  border: 1rpx solid #f0f0f0;
  margin-bottom: 60rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.craftsman-entry::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #a8b8c8, #64748b);
}

.craftsman-entry:active {
  transform: translateY(4rpx);
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.08);
}

.craftsman-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2c3e50;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
}

.craftsman-desc {
  font-size: 20rpx;
  color: #64748b;
  margin-bottom: 24rpx;
  line-height: 1.5;
  opacity: 0.8;
}

.craftsman-btn {
  display: inline-block;
  background: #2c3e50;
  color: #ffffff;
  padding: 14rpx 40rpx;
  border-radius: 28rpx;
  font-size: 22rpx;
  font-weight: 500;
  transition: all 0.3s ease;
  letter-spacing: 1rpx;
}

.craftsman-btn:active {
  transform: scale(0.96);
  background: #1e293b;
}

/* 底部空间 */
.bottom-space {
  height: 60rpx;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .categories-grid {
    grid-template-columns: 1fr;
    gap: 20rpx;
  }
  
  .header-section {
    margin: 30rpx 0 40rpx;
  }
  
  .header-title {
    padding: 20rpx 48rpx;
  }
  
  .main-title {
    font-size: 36rpx;
  }
  
  .category-card {
    padding: 32rpx 20rpx;
  }
  
  .category-icon {
    width: 100rpx;
    height: 100rpx;
  }
  
  .recommendation-image {
    width: 120rpx;
    height: 120rpx;
  }
  
  .section-title {
    font-size: 28rpx;
    margin: 40rpx 0 24rpx;
  }
  
  .craftsman-entry {
    padding: 32rpx;
  }
}

/* 滚动条样式 */
.subcategory-bar::-webkit-scrollbar {
  height: 4rpx;
}

.subcategory-bar::-webkit-scrollbar-track {
  background: #f1f5f9;
  border-radius: 2rpx;
}

.subcategory-bar::-webkit-scrollbar-thumb {
  background: #cbd5e1;
  border-radius: 2rpx;
}

.subcategory-bar::-webkit-scrollbar-thumb:hover {
  background: #94a3b8;
}
