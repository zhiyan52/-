/* 传统美术页面样式 - 传统温暖风格 */
.page-container {
  background-color: #f5f0e6;
  min-height: 100vh;
  padding: 0 24rpx;
  font-family: 'KaiTi', 'STKaiti', 'PingFang SC', sans-serif;
}

/* 顶部标题栏 */
.header-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin: 40rpx 0 40rpx;
  position: relative;
}

.header-title {
  background: #ffffff;
  padding: 24rpx 64rpx;
  border-radius: 56rpx;
  position: relative;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
  border: 2rpx solid #d4af37;
}

.main-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #5c3a21;
  letter-spacing: 8rpx;
  text-align: center;
}

.header-title::after {
  content: '';
  position: absolute;
  bottom: -20rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 120rpx;
  height: 4rpx;
  background: linear-gradient(90deg, #d4af37, #b8860b, #d4af37);
  border-radius: 2rpx;
}

/* 子分类标签栏 */
.subcategory-bar {
  display: flex;
  gap: 16rpx;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.85);
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  margin-bottom: 40rpx;
  overflow-x: auto;
  white-space: nowrap;
  border: 2rpx solid #d4af37;
}

.subcategory-item {
  padding: 14rpx 28rpx;
  border-radius: 28rpx;
  background: #faf8f5;
  font-size: 26rpx;
  color: #6b4423;
  transition: all 0.3s ease;
  flex-shrink: 0;
  font-weight: 500;
  border: 1rpx solid #e8dcc8;
}

.subcategory-item.active {
  background: linear-gradient(135deg, #d4af37 0%, #b8860b 100%);
  color: #ffffff;
  box-shadow: 0 2rpx 8rpx rgba(212, 175, 55, 0.4);
  border: none;
}

.subcategory-item:active {
  transform: translateY(1rpx);
}

/* 非遗品类宫格 */
.categories-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  margin-bottom: 60rpx;
}

.category-card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 0;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
  border: 2rpx solid #d4af37;
  transition: all 0.3s ease;
  display: flex;
  flex-direction: column;
  align-items: center;
  cursor: pointer;
  position: relative;
  overflow: hidden;
}

.category-card:active {
  transform: translateY(4rpx);
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.1);
}

.category-icon {
  width: 100%;
  height: 180rpx;
  margin-bottom: 0;
  object-fit: cover;
  transition: transform 0.3s ease;
}

.category-card:active .category-icon {
  transform: scale(0.98);
}

.category-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #5c3a21;
  text-align: center;
  margin: 20rpx 0 8rpx;
  letter-spacing: 4rpx;
}

.category-desc {
  font-size: 20rpx;
  color: #8b7355;
  text-align: center;
  line-height: 1.5;
  opacity: 0.9;
  padding: 0 16rpx 24rpx;
}

/* 热门推荐 */
.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #5c3a21;
  margin: 60rpx 0 40rpx;
  display: block;
  text-align: center;
  position: relative;
  padding-bottom: 20rpx;
  letter-spacing: 4rpx;
}

.section-title::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 100rpx;
  height: 4rpx;
  background: linear-gradient(90deg, #d4af37, #b8860b, #d4af37);
  border-radius: 2rpx;
}

.recommendation-list {
  background: rgba(255, 255, 255, 0.85);
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  margin-bottom: 40rpx;
  border: 2rpx solid #d4af37;
}

.recommendation-item {
  display: flex;
  gap: 24rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #e8dcc8;
  transition: all 0.3s ease;
  align-items: center;
}

.recommendation-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.recommendation-item:first-child {
  padding-top: 0;
}

.recommendation-item:active {
  background: #faf8f5;
  border-radius: 12rpx;
  margin: 0 -24rpx;
  padding-left: 24rpx;
  padding-right: 24rpx;
}

.recommendation-image {
  width: 150rpx;
  height: 150rpx;
  border-radius: 16rpx;
  object-fit: cover;
  border: 2rpx solid #d4af37;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  flex-shrink: 0;
}

.recommendation-info {
  flex: 1;
  min-width: 0;
}

.recommendation-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #5c3a21;
  line-height: 1.3;
  margin-bottom: 10rpx;
  letter-spacing: 2rpx;
}

.recommendation-desc {
  font-size: 22rpx;
  color: #8b7355;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 12rpx;
  opacity: 0.9;
}

.recommendation-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.recommendation-craftsman {
  font-size: 20rpx;
  color: #a08060;
}

/* 匠人故事入口 */
.craftsman-entry {
  background: rgba(255, 255, 255, 0.85);
  border-radius: 24rpx;
  padding: 48rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.08);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
  border: 2rpx solid #d4af37;
  margin-bottom: 60rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.craftsman-entry::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #d4af37, #b8860b, #d4af37);
}

.craftsman-entry:active {
  transform: translateY(4rpx);
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.1);
}

.craftsman-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #5c3a21;
  margin-bottom: 16rpx;
  letter-spacing: 4rpx;
}

.craftsman-desc {
  font-size: 22rpx;
  color: #8b7355;
  margin-bottom: 28rpx;
  line-height: 1.6;
  opacity: 0.9;
}

.craftsman-btn {
  display: inline-block;
  background: linear-gradient(135deg, #d4af37 0%, #b8860b 100%);
  color: #ffffff;
  padding: 16rpx 48rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  font-weight: 500;
  transition: all 0.3s ease;
  letter-spacing: 2rpx;
  box-shadow: 0 2rpx 8rpx rgba(212, 175, 55, 0.4);
}

.craftsman-btn:active {
  transform: scale(0.96);
  background: linear-gradient(135deg, #b8860b 0%, #a07000 100%);
}

/* 底部空间 */
.bottom-space {
  height: 60rpx;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .categories-grid {
    grid-template-columns: 1fr;
    gap: 20rpx;
  }
  
  .header-section {
    margin: 30rpx 0 40rpx;
  }
  
  .header-title {
    padding: 20rpx 48rpx;
  }
  
  .main-title {
    font-size: 36rpx;
  }
  
  .category-card {
    padding: 32rpx 20rpx;
  }
  
  .category-icon {
    width: 100rpx;
    height: 100rpx;
  }
  
  .recommendation-image {
    width: 120rpx;
    height: 120rpx;
  }
  
  .section-title {
    font-size: 28rpx;
    margin: 40rpx 0 24rpx;
  }
  
  .craftsman-entry {
    padding: 32rpx;
  }
}

/* 滚动条样式 */
.subcategory-bar::-webkit-scrollbar {
  height: 4rpx;
}

.subcategory-bar::-webkit-scrollbar-track {
  background: #f1f5f9;
  border-radius: 2rpx;
}

.subcategory-bar::-webkit-scrollbar-thumb {
  background: #cbd5e1;
  border-radius: 2rpx;
}

.subcategory-bar::-webkit-scrollbar-thumb:hover {
  background: #94a3b8;
}
