<!-- 匠人故事页面 -->
<view class="page-container">
  
  <!-- 顶部标题栏 -->
  <view class="header-section">
    <view class="header-title">
      <text class="main-title">匠人故事</text>
    </view>
  </view>
  
  <!-- 匠人故事列表 -->
  <view class="craftsman-list">
    <view class="craftsman-card" wx:for="{{craftsmen}}" wx:key="id" data-id="{{item.id}}" bindtap="navigateToCraftsmanDetail">
      <image class="craftsman-avatar" src="{{item.avatar}}" mode="aspectFill" />
      <view class="craftsman-info">
        <text class="craftsman-name">{{item.name}}</text>
        <text class="craftsman-title">{{item.title}}</text>
        <text class="craftsman-desc">{{item.desc}}</text>
        <view class="craftsman-meta">
          <text class="craftsman-age">{{item.age}}岁</text>
          <text class="craftsman-experience">{{item.experience}}年经验</text>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 底部空间 -->
  <view class="bottom-space"></view>
</view>