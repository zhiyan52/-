/* 详情页面样式 */
.page-container {
  background-color: #f7f5f0;
  min-height: 100vh;
}

/* 头部区 */
.header-section {
  position: relative;
  height: 500rpx;
  overflow: hidden;
}

.header-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.header-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(to bottom, rgba(0,0,0,0.3), rgba(0,0,0,0.7));
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 40rpx;
  color: #fff;
}

.artwork-title {
  font-size: 48rpx;
  font-weight: bold;
  font-family: "STKaiti", "KaiTi", serif;
  margin-bottom: 10rpx;
  text-shadow: 2rpx 2rpx 4rpx rgba(0,0,0,0.5);
}

.artwork-craftsman {
  font-size: 28rpx;
  font-family: "STKaiti", "KaiTi", serif;
  margin-bottom: 10rpx;
  text-shadow: 2rpx 2rpx 4rpx rgba(0,0,0,0.5);
}

.artwork-meta {
  font-size: 24rpx;
  font-family: "STKaiti", "KaiTi", serif;
  text-shadow: 2rpx 2rpx 4rpx rgba(0,0,0,0.5);
}

/* 内容区 */
.content-section {
  padding: 30rpx 20rpx;
  margin-top: -30rpx;
  background: #f7f5f0;
  border-radius: 30rpx 30rpx 0 0;
  position: relative;
  z-index: 10;
}

/* 知识科普区 */
.knowledge-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  margin-bottom: 30rpx;
  border: 2rpx solid #D4A017;
}

.section-subtitle {
  font-size: 32rpx;
  font-weight: bold;
  color: #1A365D;
  font-family: "STKaiti", "KaiTi", serif;
  margin-bottom: 20rpx;
  position: relative;
  padding-left: 20rpx;
}

.section-subtitle::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 10rpx;
  height: 30rpx;
  background: #D4A017;
  border-radius: 5rpx;
}

.knowledge-content {
  font-size: 24rpx;
  color: #333;
  font-family: "STKaiti", "KaiTi", serif;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

/* 工艺流程 */
.process-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  margin-bottom: 30rpx;
  border: 2rpx solid #D4A017;
}

.process-steps {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.process-step {
  display: flex;
  gap: 20rpx;
  align-items: flex-start;
}

.process-step-number {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #D4A017;
  color: #1A365D;
  font-size: 24rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.process-step-content {
  flex: 1;
}

.process-step-title {
  font-size: 26rpx;
  font-weight: 500;
  color: #1A365D;
  font-family: "STKaiti", "KaiTi", serif;
  margin-bottom: 8rpx;
}

.process-step-desc {
  font-size: 22rpx;
  color: #666;
  font-family: "STKaiti", "KaiTi", serif;
  line-height: 1.4;
}

.process-step-image {
  width: 100%;
  height: 200rpx;
  border-radius: 10rpx;
  object-fit: cover;
  margin-top: 12rpx;
  border: 1rpx solid #f0f0f0;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.08);
}

/* 文化价值 */
.value-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  margin-bottom: 30rpx;
  border: 2rpx solid #D4A017;
}

/* AI讲解 */
.ai-section {
  background: linear-gradient(135deg, #1A365D 0%, #2C5282 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(26, 54, 93, 0.3);
  margin-bottom: 30rpx;
  border: 2rpx solid #D4A017;
}

.ai-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #D4A017;
  font-family: "STKaiti", "KaiTi", serif;
  margin-bottom: 20rpx;
  text-align: center;
  text-shadow: 2rpx 2rpx 4rpx rgba(0,0,0,0.2);
}

.ai-content {
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.ai-text {
  font-size: 24rpx;
  color: #F8F0E3;
  font-family: "STKaiti", "KaiTi", serif;
  line-height: 1.6;
}

.ai-btn {
  display: block;
  background: #D4A017;
  color: #1A365D;
  padding: 16rpx;
  border-radius: 25rpx;
  font-size: 26rpx;
  font-weight: bold;
  font-family: "STKaiti", "KaiTi", serif;
  text-align: center;
  transition: all 0.3s ease;
}

.ai-btn:active {
  transform: scale(0.98);
  background: #C09015;
}

/* 分享按钮 */
.share-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  margin-bottom: 30rpx;
  border: 2rpx solid #D4A017;
  text-align: center;
}

.share-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #1A365D;
  font-family: "STKaiti", "KaiTi", serif;
  margin-bottom: 20rpx;
}

.share-buttons {
  display: flex;
  justify-content: center;
  gap: 40rpx;
}

.share-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  background: #f8f9fa;
  transition: all 0.3s ease;
}

.share-btn:active {
  transform: scale(0.95);
  background: #e9ecef;
}

.share-icon {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #D4A017;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #1A365D;
}

.share-text {
  font-size: 20rpx;
  color: #666;
  font-family: "STKaiti", "KaiTi", serif;
}

/* 底部空间 */
.bottom-space {
  height: 40rpx;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .header-section {
    height: 400rpx;
  }
  
  .artwork-title {
    font-size: 40rpx;
  }
  
  .artwork-craftsman {
    font-size: 24rpx;
  }
  
  .artwork-meta {
    font-size: 20rpx;
  }
  
  .content-section {
    padding: 20rpx 16rpx;
  }
  
  .knowledge-section,
  .process-section,
  .value-section,
  .ai-section,
  .share-section {
    padding: 20rpx;
  }
  
  .section-subtitle {
    font-size: 28rpx;
  }
  
  .knowledge-content {
    font-size: 22rpx;
  }
  
  .process-step-title {
    font-size: 24rpx;
  }
  
  .process-step-desc {
    font-size: 20rpx;
  }
  
  .process-step-image {
    height: 160rpx;
  }
}