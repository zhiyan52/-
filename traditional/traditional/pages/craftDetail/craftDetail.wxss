 /* pages/traditional/traditional/stepDetail/stepDetail.wxss */
page {
  background: #f5f5f5;
  font-size: 28rpx;
  color: #333;
}
.container {
  padding: 20rpx;
  padding-bottom: 60rpx;
}
.head-title {
  text-align: center;
  margin: 30rpx 0;
}
.step-name {
  font-size: 40rpx;
  font-weight: bold;
  display: block;
}
.step-sub {
  font-size: 26rpx;
  color: #666;
  margin-top: 10rpx;
}
.card {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
}
.card-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  color: #222;
}
.info-item {
  line-height: 1.8;
  margin-bottom: 6rpx;
}
.long-text {
  line-height: 1.8;
  color: #555;
}
.quote-card {
  background: #faf8f2;
}
.quote-text {
  font-style: italic;
  line-height: 1.8;
}
.quote-author {
  text-align: right;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #777;
}
.ques {
  font-weight: bold;
  margin-bottom: 20rpx;
}
.option {
  display: flex;
  align-items: center;
  border: 1rpx solid #eee;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 15rpx;
}
.option.active {
  border-color: #8B4513;
  background: #fff8f0;
}
.opt-id {
  width: 48rpx;
  height: 48rpx;
  line-height: 48rpx;
  text-align: center;
  border-radius: 50%;
  background: #eee;
  margin-right: 20rpx;
}
.opt-label {
  display: block;
}
.opt-desc {
  font-size: 24rpx;
  color: #666;
  margin-top: 4rpx;
}
.feedback {
  padding: 20rpx;
  border-radius: 12rpx;
  margin: 15rpx 0;
  line-height: 1.7;
}
.right {
  background: #edf7ee;
  color: #27ae60;
}
.wrong {
  background: #fef0f0;
  color: #e74c3c;
}
.tip {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #888;
}

/* 轻量AI模块样式 */
.ai-card {
  background: #f8f8f8;
  border-radius: 16rpx;
  padding: 25rpx;
  margin-bottom: 30rpx;
}
.ai-title {
  font-size: 28rpx;
  margin-bottom: 15rpx;
}
.ai-content {
  margin-top: 15rpx;
  line-height: 1.7;
  font-size: 26rpx;
  color: #555;
}