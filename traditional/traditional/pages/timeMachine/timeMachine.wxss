/* traditional/traditional/pages/timeMachine/timeMachine.wxss */
page {
  background: linear-gradient(135deg, #f7f5f0 0%, #f0ede5 100%);
  font-family: "STKaiti", "KaiTi", serif;
}

.page-container {
  min-height: 100vh;
  padding: 30rpx;
  position: relative;
}

/* 页面标题 */
.page-header {
  text-align: center;
  padding: 40rpx 0;
}

.page-title {
  display: block;
  font-size: 52rpx;
  font-weight: bold;
  color: #1A365D;
  margin-bottom: 12rpx;
  text-shadow: 2rpx 2rpx 4rpx rgba(0,0,0,0.1);
}

.page-subtitle {
  display: block;
  font-size: 26rpx;
  color: #8B7355;
}

/* 步骤指示器 */
.step-indicator {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 50rpx;
}

.step-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #e0e0e0;
  border: 4rpx solid #fff;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
  transition: all 0.3s ease;
}

.step-dot.active {
  background: #D4A017;
  transform: scale(1.2);
}

.step-line {
  width: 80rpx;
  height: 4rpx;
  background: #e0e0e0;
  margin: 0 10rpx;
  transition: all 0.3s ease;
}

.step-line.active {
  background: #D4A017;
}

/* 区块标题 */
.section-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.section-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #1A365D;
  margin-bottom: 12rpx;
}

.section-desc {
  display: block;
  font-size: 26rpx;
  color: #8B7355;
}

/* 非遗列表 */
.heritage-list {
  height: 65vh;
}

.heritage-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
  border: 2rpx solid #f0f0f0;
  transition: all 0.3s ease;
}

.heritage-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
  border-color: #D4A017;
}

.heritage-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
}

.heritage-icon text {
  font-size: 48rpx;
  color: #fff;
}

.heritage-info {
  flex: 1;
}

.heritage-name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #1A365D;
  margin-bottom: 8rpx;
}

.heritage-desc {
  display: block;
  font-size: 24rpx;
  color: #8B7355;
}

.heritage-arrow {
  font-size: 48rpx;
  color: #D4A017;
  font-weight: bold;
}

/* 时间轴 */
.timeline-container {
  position: relative;
  padding: 20rpx 0;
  margin-bottom: 40rpx;
}

.timeline-line {
  position: absolute;
  left: 50%;
  top: 0;
  bottom: 0;
  width: 4rpx;
  background: linear-gradient(180deg, #D4A017 0%, #B8860B 100%);
  transform: translateX(-50%);
}

.timeline-item {
  display: flex;
  align-items: flex-start;
  margin-bottom: 50rpx;
  position: relative;
  z-index: 1;
}

.timeline-item.unlocked {
  opacity: 1;
}

.timeline-item.locked {
  opacity: 0.5;
}

.timeline-dot {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #fff;
  border: 4rpx solid #D4A017;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 30rpx;
  flex-shrink: 0;
}

.timeline-item.locked .timeline-dot {
  border-color: #ccc;
}

.dot-inner {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
  background: #D4A017;
}

.timeline-content {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  margin-right: 60rpx;
}

.timeline-item:nth-child(even) {
  flex-direction: row-reverse;
}

.timeline-item:nth-child(even) .timeline-content {
  margin-right: 0;
  margin-left: 60rpx;
}

.era-name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #1A365D;
  margin-bottom: 8rpx;
}

.era-year {
  display: block;
  font-size: 22rpx;
  color: #D4A017;
  margin-bottom: 12rpx;
}

.era-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.era-tag {
  font-size: 20rpx;
  color: #8B7355;
  background: #f5f0e8;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

/* 返回按钮 */
.back-btn {
  width: 100%;
  background: #fff;
  border: 2rpx solid #1A365D;
  border-radius: 16rpx;
  color: #1A365D;
  font-size: 28rpx;
  font-family: "STKaiti", "KaiTi", serif;
  padding: 24rpx;
  margin-top: 20rpx;
}

/* 时光穿越动画 */
.time-travel-animation {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 70vh;
}

.time-vortex {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: conic-gradient(#D4A017, #B8860B, #1A365D, #2C5282, #D4A017);
  animation: vortex 2s linear infinite;
  margin-bottom: 40rpx;
}

@keyframes vortex {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.travel-text {
  font-size: 32rpx;
  color: #1A365D;
  margin-bottom: 16rpx;
}

.travel-era {
  font-size: 48rpx;
  font-weight: bold;
  color: #D4A017;
}

/* 场景内容 */
.scene-content {
  padding: 20rpx 0;
}

.scene-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.era-badge {
  background: linear-gradient(135deg, #D4A017 0%, #B8860B 100%);
  color: #fff;
  padding: 12rpx 28rpx;
  border-radius: 30rpx;
  font-size: 28rpx;
  font-weight: bold;
}

.scene-progress {
  font-size: 24rpx;
  color: #8B7355;
}

.scene-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
  border: 2rpx solid #f0f0f0;
}

.scene-role {
  display: inline-block;
  background: linear-gradient(135deg, #1A365D 0%, #2C5282 100%);
  color: #D4A017;
  padding: 10rpx 24rpx;
  border-radius: 25rpx;
  font-size: 24rpx;
  margin-bottom: 20rpx;
}

.scene-description {
  display: block;
  font-size: 30rpx;
  color: #333;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.scene-question {
  background: #f9f7f3;
  border-left: 6rpx solid #D4A017;
  padding: 20rpx;
  border-radius: 0 12rpx 12rpx 0;
}

.scene-question text {
  font-size: 28rpx;
  color: #1A365D;
  font-weight: 500;
}

/* 选项容器 */
.options-container {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.option-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.06);
  border: 3rpx solid transparent;
  transition: all 0.3s ease;
}

.option-card.selected {
  border-color: #D4A017;
  background: #fef9f3;
}

.option-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #1A365D 0%, #2C5282 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  font-size: 40rpx;
}

.option-text {
  flex: 1;
}

.option-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #1A365D;
  margin-bottom: 8rpx;
}

.option-desc {
  display: block;
  font-size: 24rpx;
  color: #8B7355;
}

/* 确认按钮 */
.confirm-btn {
  width: 100%;
  background: linear-gradient(135deg, #1A365D 0%, #2C5282 100%);
  color: #D4A017;
  border: none;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: bold;
  font-family: "STKaiti", "KaiTi", serif;
  padding: 28rpx;
  transition: all 0.3s ease;
}

.confirm-btn[disabled] {
  background: #ccc;
  color: #fff;
}

/* 结果展示 */
.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.result-era {
  background: linear-gradient(135deg, #D4A017 0%, #B8860B 100%);
  color: #fff;
  padding: 14rpx 32rpx;
  border-radius: 30rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.result-badge {
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.result-badge.cache {
  background: #e8f5e9;
  color: #2e7d32;
}

.result-badge.local {
  background: #e3f2fd;
  color: #1565c0;
}

.result-badge.ai {
  background: #fff3e0;
  color: #ef6c00;
}

.result-cards {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 30rpx;
}

.result-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
  border-left: 8rpx solid;
}

.result-card.narrative {
  border-left-color: #D4A017;
}

.result-card.consequence {
  border-left-color: #1A365D;
}

.result-card.reference {
  border-left-color: #2C5282;
}

.result-card.insight {
  border-left-color: #8B7355;
}

.card-label {
  display: inline-block;
  font-size: 24rpx;
  color: #fff;
  background: #D4A017;
  padding: 6rpx 20rpx;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
}

.result-card.narrative .card-label { background: #D4A017; }
.result-card.consequence .card-label { background: #1A365D; }
.result-card.reference .card-label { background: #2C5282; }
.result-card.insight .card-label { background: #8B7355; }

.card-content {
  display: block;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

/* 结果操作 */
.result-actions {
  display: flex;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.action-btn {
  flex: 1;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-family: "STKaiti", "KaiTi", serif;
  padding: 24rpx;
}

.action-btn.primary {
  background: linear-gradient(135deg, #1A365D 0%, #2C5282 100%);
  color: #D4A017;
  border: none;
}

.action-btn.secondary {
  background: #fff;
  color: #1A365D;
  border: 2rpx solid #1A365D;
}

/* 文心先生咨询面板 */
.wenxin-panel {
  background: #fff;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
  overflow: hidden;
  border: 2rpx solid #D4A017;
}

.wenxin-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  background: linear-gradient(135deg, #1A365D 0%, #2C5282 100%);
}

.wenxin-title-row {
  display: flex;
  align-items: center;
}

.wenxin-avatar {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #D4A017 0%, #B8860B 100%);
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.wenxin-info {
  display: flex;
  flex-direction: column;
}

.wenxin-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #fff;
}

.wenxin-status {
  font-size: 22rpx;
  color: rgba(255,255,255,0.7);
}

.wenxin-toggle {
  font-size: 36rpx;
  color: #D4A017;
}

.wenxin-body {
  padding: 24rpx 30rpx;
}

.wenxin-messages {
  height: 300rpx;
  margin-bottom: 20rpx;
}

.wenxin-welcome {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 20rpx;
  background: #f9f7f3;
  border-radius: 16rpx;
}

.wenxin-welcome text {
  font-size: 26rpx;
  color: #1A365D;
  line-height: 1.5;
}

.wenxin-message {
  padding: 20rpx;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.wenxin-message.user {
  background: #e3f2fd;
  margin-left: 40rpx;
}

.wenxin-message.ai {
  background: #fef9f3;
  margin-right: 40rpx;
  border-left: 4rpx solid #D4A017;
}

.message-content {
  font-size: 26rpx;
  color: #333;
  line-height: 1.5;
}

.wenxin-input-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.wenxin-input {
  flex: 1;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 26rpx;
  font-family: "STKaiti", "KaiTi", serif;
}

.wenxin-send {
  background: linear-gradient(135deg, #D4A017 0%, #B8860B 100%);
  color: #fff;
  border: none;
  border-radius: 12rpx;
  padding: 20rpx 32rpx;
  font-size: 26rpx;
  font-family: "STKaiti", "KaiTi", serif;
}

.wenxin-suggestions {
  margin-top: 20rpx;
}

.suggestion-title {
  font-size: 24rpx;
  color: #8B7355;
  margin-bottom: 12rpx;
  display: block;
}

.suggestion-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.suggestion-tag {
  font-size: 22rpx;
  color: #1A365D;
  background: #f5f0e8;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  border: 1rpx solid #D4A017;
}

/* 加载状态 */
.loading-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #fff;
  border-top-color: #D4A017;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #fff;
}