/* 非遗地图页面样式 - 高端极简风格 */
.page-container {
  background-color: #f8f9fa;
  min-height: 100vh;
  padding: 0 24rpx;
  font-family: 'SF Pro Display', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

/* 头部区域 */
.header-section {
  padding: 32rpx 0 24rpx;
  text-align: center;
  border-bottom: 1rpx solid #eaeaea;
  margin-bottom: 32rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #2c3e50;
  letter-spacing: 2rpx;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 20rpx;
  color: #64748b;
  opacity: 0.8;
}

/* 地图容器 */
.map-container {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  margin-bottom: 32rpx;
  border: 1rpx solid #f0f0f0;
  position: relative;
  overflow: hidden;
}

.map-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.map-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2c3e50;
}

.map-controls {
  display: flex;
  gap: 12rpx;
}

.control-btn {
  padding: 10rpx 20rpx;
  background: #f5f7fa;
  border-radius: 20rpx;
  font-size: 20rpx;
  color: #64748b;
  transition: all 0.3s ease;
}

.control-btn.active {
  background: #2c3e50;
  color: #ffffff;
}

/* 地图画布 */
.map-canvas {
  width: 100%;
  height: 400rpx;
  background: #f1f5f9;
  border-radius: 16rpx;
  position: relative;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.map-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 16rpx;
}

/* 地图标记 */
.map-marker {
  position: absolute;
  width: 32rpx;
  height: 32rpx;
  background: #2c3e50;
  border-radius: 50%;
  transform: translate(-50%, -50%);
  box-shadow: 0 4rpx 12rpx rgba(44, 62, 80, 0.3);
  cursor: pointer;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 16rpx;
  font-weight: 600;
}

.map-marker:active {
  transform: translate(-50%, -50%) scale(1.2);
}

.map-marker.highlighted {
  background: #64748b;
  box-shadow: 0 6rpx 16rpx rgba(100, 116, 139, 0.4);
}

/* 非遗项目列表 */
.heritage-list {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  margin-bottom: 32rpx;
  border: 1rpx solid #f0f0f0;
}

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.list-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2c3e50;
}

.filter-btn {
  padding: 8rpx 16rpx;
  background: #f5f7fa;
  border-radius: 16rpx;
  font-size: 18rpx;
  color: #64748b;
}

.heritage-item {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f7fa;
  transition: all 0.3s ease;
  align-items: center;
}

.heritage-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.heritage-item:first-child {
  padding-top: 0;
}

.heritage-item:active {
  background: #f8f9fa;
  border-radius: 12rpx;
  margin: 0 -24rpx;
  padding-left: 24rpx;
  padding-right: 24rpx;
}

.heritage-info {
  flex: 1;
  min-width: 0;
}

.heritage-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #2c3e50;
  margin-bottom: 4rpx;
  line-height: 1.3;
}

.heritage-meta {
  font-size: 18rpx;
  color: #64748b;
  margin-bottom: 8rpx;
}

.heritage-desc {
  font-size: 18rpx;
  color: #94a3b8;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 详情卡片 */
.detail-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  margin-bottom: 32rpx;
  border: 1rpx solid #f0f0f0;
  position: relative;
  overflow: hidden;
}

.detail-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #a8b8c8, #64748b);
}

.detail-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2c3e50;
  margin-bottom: 20rpx;
}

.detail-section {
  margin-bottom: 24rpx;
}

.detail-section:last-child {
  margin-bottom: 0;
}

.section-label {
  font-size: 20rpx;
  font-weight: 600;
  color: #64748b;
  margin-bottom: 12rpx;
}

.section-content {
  font-size: 20rpx;
  color: #475569;
  line-height: 1.5;
}

/* AI 辅助按钮 */
.ai-assist {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  margin-bottom: 60rpx;
  border: 1rpx solid #f0f0f0;
  text-align: center;
}

.ai-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #2c3e50;
  margin-bottom: 16rpx;
}

.ai-btn {
  display: inline-block;
  background: #2c3e50;
  color: #ffffff;
  padding: 14rpx 40rpx;
  border-radius: 28rpx;
  font-size: 22rpx;
  font-weight: 500;
  transition: all 0.3s ease;
  letter-spacing: 1rpx;
}

.ai-btn:active {
  transform: scale(0.96);
  background: #1e293b;
}

/* 加载状态 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
  color: #64748b;
  font-size: 20rpx;
}

.loading-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 2rpx solid #e2e8f0;
  border-top: 2rpx solid #2c3e50;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-right: 16rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 响应式调整 */
@media (max-width: 375px) {
  .map-canvas {
    height: 300rpx;
  }
  
  .header-title {
    font-size: 32rpx;
  }
  
  .map-title,
  .list-title,
  .detail-title {
    font-size: 24rpx;
  }
  
  .heritage-name {
    font-size: 22rpx;
  }
  
  .map-container,
  .heritage-list,
  .detail-card,
  .ai-assist {
    padding: 16rpx;
  }
}
