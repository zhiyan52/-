/* traditional/pages/craftDetail/craftDetail.wxss */

/* 容器样式 */
.intangible-heritage-map-container {
  min-height: 100vh;
  background-color: #f8f5f0;
  padding: 20rpx;
  font-family: 'STKaiti', 'KaiTi', serif;
}

/* 顶部导航 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding-top: 20rpx;
}

.header-left, .header-right {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-icon {
  font-size: 32rpx;
  color: #7a4a19;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #7a4a19;
  letter-spacing: 4rpx;
}

.share-icon {
  font-size: 32rpx;
  color: #7a4a19;
}

/* 区域标题 */
.section-title {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
  border-left: 4rpx solid #d2b48c;
}

.title-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #7a4a19;
}

/* 地图区域 */
.map-section {
  margin-bottom: 40rpx;
}

.map-container {
  background-color: #fff;
  border: 1rpx solid #e0d0b0;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(122, 74, 25, 0.08);
  position: relative;
  overflow: hidden;
}

.map-container::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #d2b48c, #c19a6b, #d2b48c);
}

.china-map {
  width: 100%;
  height: 400rpx;
  position: relative;
  background-color: #f8f5f0;
  border-radius: 12rpx;
  overflow: hidden;
}

.china-map::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: url('https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=china%20map%20simplified%20style%20light%20background&image_size=landscape_16_9');
  background-size: cover;
  background-position: center;
  opacity: 0.5;
}

/* 地标样式 */
.landmark {
  position: absolute;
  display: flex;
  flex-direction: column;
  align-items: center;
  cursor: pointer;
  z-index: 1;
  transition: all 0.3s ease;
}

.landmark:hover {
  transform: scale(1.1);
}

.landmark-point {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: #d2b48c;
  border: 2rpx solid #7a4a19;
  position: relative;
  transition: all 0.3s ease;
}

.landmark-point.active {
  background-color: #7a4a19;
  box-shadow: 0 0 10rpx rgba(122, 74, 25, 0.6);
}

.landmark-point::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background-color: rgba(122, 74, 25, 0.2);
  animation: pulse 2s infinite;
}

.landmark-label {
  font-size: 20rpx;
  color: #7a4a19;
  margin-top: 8rpx;
  font-weight: bold;
  text-shadow: 0 1rpx 2rpx rgba(255, 255, 255, 0.8);
}

/* 非遗项目详情区域 */
.heritage-detail-section {
  margin-bottom: 40rpx;
}

.heritage-detail-card {
  background-color: #fff;
  border: 1rpx solid #e0d0b0;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(122, 74, 25, 0.08);
  position: relative;
  overflow: hidden;
}

.heritage-detail-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #d2b48c, #c19a6b, #d2b48c);
}

.region-image {
  width: 100%;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.region-image image {
  width: 100%;
  height: 100%;
}

.heritage-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.heritage-item {
  background-color: #f8f5f0;
  border: 1rpx solid #e0d0b0;
  border-radius: 12rpx;
  padding: 20rpx;
  transition: all 0.3s ease;
}

.heritage-item:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 4rpx 12rpx rgba(122, 74, 25, 0.1);
}

.heritage-header {
  margin-bottom: 12rpx;
}

.heritage-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #7a4a19;
}

.heritage-description {
  font-size: 24rpx;
  color: #6a5a4a;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.geo-background-section {
  margin-bottom: 16rpx;
}

.geo-background-title {
  font-size: 24rpx;
  font-weight: bold;
  color: #7a4a19;
  margin-bottom: 12rpx;
}

.geo-background-items {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.geo-background-item {
  display: flex;
  align-items: flex-start;
  font-size: 22rpx;
  color: #6a5a4a;
  line-height: 1.4;
}

.geo-label {
  font-weight: bold;
  color: #7a4a19;
  margin-right: 8rpx;
  min-width: 80rpx;
}

.geo-value {
  flex: 1;
}

.heritage-image {
  width: 100%;
  height: 180rpx;
  border-radius: 10rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.heritage-image image {
  width: 100%;
  height: 100%;
}

.learn-more-btn {
  background-color: #7a4a19;
  color: #fff;
  border: none;
  border-radius: 10rpx;
  padding: 16rpx;
  font-size: 24rpx;
  font-family: 'STKaiti', 'KaiTi', serif;
  width: 100%;
  transition: all 0.3s ease;
}

.learn-more-btn:hover {
  background-color: #6a3a09;
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 8rpx rgba(122, 74, 25, 0.3);
}

/* 弹窗样式 */
.region-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  width: 85%;
  max-height: 80vh;
  overflow-y: auto;
  position: relative;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #e0d0b0;
}

.modal-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #7a4a19;
}

.modal-close {
  font-size: 32rpx;
  color: #7a4a19;
  cursor: pointer;
  padding: 8rpx;
}

.modal-body {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.modal-image {
  width: 100%;
  height: 180rpx;
  border-radius: 10rpx;
}

.modal-heritage-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.modal-heritage-item {
  background-color: #f8f5f0;
  border: 1rpx solid #e0d0b0;
  border-radius: 10rpx;
  padding: 16rpx;
}

.modal-heritage-name {
  font-size: 26rpx;
  font-weight: bold;
  color: #7a4a19;
  margin-bottom: 8rpx;
  display: block;
}

.modal-heritage-description {
  font-size: 22rpx;
  color: #6a5a4a;
  line-height: 1.4;
  margin-bottom: 12rpx;
  display: block;
}

.modal-learn-more-btn {
  background-color: #7a4a19;
  color: #fff;
  border: none;
  border-radius: 8rpx;
  padding: 12rpx;
  font-size: 22rpx;
  font-family: 'STKaiti', 'KaiTi', serif;
  width: 100%;
  transition: all 0.3s ease;
}

.modal-learn-more-btn:hover {
  background-color: #6a3a09;
}

/* 动画效果 */
@keyframes pulse {
  0% {
    transform: translate(-50%, -50%) scale(1);
    opacity: 1;
  }
  100% {
    transform: translate(-50%, -50%) scale(2);
    opacity: 0;
  }
}

/* 响应式设计 */
@media (max-width: 375px) {
  .china-map {
    height: 350rpx;
  }
  
  .region-image {
    height: 180rpx;
  }
  
  .heritage-image {
    height: 160rpx;
  }
}

@media (min-width: 768px) {
  .china-map {
    height: 500rpx;
  }
  
  .region-image {
    height: 240rpx;
  }
  
  .heritage-image {
    height: 220rpx;
  }
}