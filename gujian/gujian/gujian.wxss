.footer-buttons {
  display: flex;
  justify-content: space-between;
  gap: 30rpx;
  padding: 0 30rpx;
  margin-top: 40rpx;
}

.btn {
  flex: none;
  width: 200rpx;
  height: 100rpx;
  border-radius: 50rpx / 25rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: bold;
  font-family: "KaiTi", "STKaiti", sans-serif;
  color: #fff;
  border: 3rpx solid #e7e74d;
  box-shadow: 0 6rpx 12rpx rgba(0, 0, 0, 0.15);
  position: relative;
  overflow: hidden;
  transition: background 0.2s ease; /* 加个过渡更丝滑 */
}

/* 默认全是红色 */
.btn.primary,
.btn.secondary {
  background: linear-gradient(135deg, #912626, #a83232);
}

/* 点击时变成绿色 */
.btn.primary:active,
.btn.secondary:active {
  background: linear-gradient(135deg, #115a58, #115550);
}

.btn::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  border-radius: inherit;
  box-shadow: inset 0 2rpx 4rpx rgba(255, 255, 255, 0.1);
  pointer-events: none;
}