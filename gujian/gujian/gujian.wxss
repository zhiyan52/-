.container {
  background-color: #b6e8cc;
  min-height: 100vh;
  padding: 20rpx;
  font-family: "KaiTi", "楷体", serif;
}
.main-title-bar{
  position: relative;
  top: -150rpx;
  width: 780rpx;
  height: 190rpx;
  margin-top: 0%;
}
.title-img {
  width: 780rpx;
  max-width: 90%;
  display: block;
  margin: 0 auto;
  }
/* 分类列表 */
 /* 整体容器：垂直排列 */
.category-list {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
  padding: 30rpx;
  margin-top: 0rpx;
}

/* 每个分类项：占满一行，居中 */
.category-item {
  height: 175rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 图片：宽度占满，高度自适应 */
.category-img {
  width: 650rpx;
  height: 170rpx;
  border-radius: 12rpx;
}
