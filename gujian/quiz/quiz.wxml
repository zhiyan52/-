<!-- 古建知识竞赛页面 -->
<view class="quiz-container">
  <!-- 顶部信息栏 -->
  <view class="top-bar">
    <view class="score-info">
      <text class="score-label">当前积分</text>
      <text class="score-num">{{totalScore}}</text>
    </view>
    <view class="streak-info">
      <text class="streak-icon">🔥</text>
      <text class="streak-num">连续{{streak}}天</text>
    </view>
  </view>

  <!-- 答题卡片 -->
  <view class="quiz-card" wx:if="{{!showResult}}">
    <view class="quiz-header">
      <view class="question-num">第 {{currentIndex + 1}}/{{questions.length}} 题</view>
      <view class="timer">{{timeLeft}}s</view>
    </view>
    
    <view class="question-text">{{currentQuestion.question}}</view>
    
    <view class="options-list">
      <view 
        class="option-item {{selectedOption === index ? 'selected' : ''}} {{showAnswer && index === currentQuestion.correctIndex ? 'correct' : ''}} {{showAnswer && selectedOption === index && index !== currentQuestion.correctIndex ? 'wrong' : ''}}"
        wx:for="{{currentQuestion.options}}"
        wx:key="index"
        bindtap="selectOption"
        data-index="{{index}}"
      >
        <view class="option-letter">{{['A', 'B', 'C', 'D'][index]}}</view>
        <view class="option-text">{{item}}</view>
        <view class="option-icon" wx:if="{{showAnswer}}">
          <text wx:if="{{index === currentQuestion.correctIndex}}">✓</text>
          <text wx:elif="{{selectedOption === index}}">✗</text>
        </view>
      </view>
    </view>

    <view class="answer-explain" wx:if="{{showAnswer}}">
      <view class="explain-title">解析</view>
      <view class="explain-text">{{currentQuestion.explain}}</view>
    </view>

    <view class="action-btn" bindtap="nextQuestion" wx:if="{{showAnswer}}">
      <text>{{currentIndex < questions.length - 1 ? '下一题' : '查看结果'}}</text>
    </view>
  </view>

  <!-- 结果页面 -->
  <view class="result-card" wx:if="{{showResult}}">
    <view class="result-header">
      <text class="result-title">答题完成！</text>
      <view class="result-score">
        <text class="score-big">{{correctCount}}</text>
        <text class="score-small">/{{questions.length}}</text>
      </view>
    </view>

    <view class="result-stats">
      <view class="stat-item">
        <text class="stat-icon">✓</text>
        <text class="stat-label">正确</text>
        <text class="stat-value">{{correctCount}}</text>
      </view>
      <view class="stat-item">
        <text class="stat-icon">✗</text>
        <text class="stat-label">错误</text>
        <text class="stat-value">{{questions.length - correctCount}}</text>
      </view>
      <view class="stat-item">
        <text class="stat-icon">⏱</text>
        <text class="stat-label">用时</text>
        <text class="stat-value">{{usedTime}}s</text>
      </view>
    </view>

    <view class="reward-section">
      <view class="reward-title">获得奖励</view>
      <view class="reward-items">
        <view class="reward-item">
          <text class="reward-icon">💎</text>
          <text class="reward-value">+{{correctCount * 10}} 积分</text>
        </view>
        <view class="reward-item">
          <text class="reward-icon">🏅</text>
          <text class="reward-value">+{{correctCount}} 经验</text>
        </view>
      </view>
    </view>

    <view class="result-actions">
      <view class="action-btn secondary" bindtap="restartQuiz">
        <text>再来一次</text>
      </view>
      <view class="action-btn primary" bindtap="shareResult">
        <text>分享成绩</text>
      </view>
    </view>
  </view>

  <!-- 排行榜入口 -->
  <view class="leaderboard-entry" bindtap="goToLeaderboard">
    <view class="entry-icon">🏆</view>
    <view class="entry-text">
      <view class="entry-title">排行榜</view>
      <view class="entry-desc">查看您的排名</view>
    </view>
    <view class="entry-arrow">▶</view>
  </view>
</view>