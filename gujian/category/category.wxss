/* gujian/category/category.wxss */
.container {
  background: linear-gradient(180deg, #b6e8cc 0%, #a8d5ba 100%);
  min-height: 100vh;
  padding: 20rpx;
  font-family: "KaiTi", "楷体", serif;
}

.main-title-bar {
  position: relative;
  top: -150rpx;
  width: 780rpx;
  height: 190rpx;
  margin-top: 0;
}

.title-img {
  width: 780rpx;
  max-width: 90%;
  display: block;
  margin: 0 auto;
  filter: drop-shadow(0 4rpx 8rpx rgba(0,0,0,0.15));
}

/* 分类列表 */
.category-list {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
  padding: 30rpx;
  margin-top: 0rpx;
}

/* 分类项 */
.category-item {
  position: relative;
  height: 175rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.12);
  transition: transform 0.15s ease, box-shadow 0.15s ease;
  transform: scale(1);
}

/* 按压状态 */
.category-item.pressed {
  transform: scale(0.96) translateY(4rpx);
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.08);
}

/* 加载完成动画 */
.category-item.loaded .category-img {
  opacity: 1;
  transform: scale(1);
}

/* 骨架屏 */
.skeleton {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, #e0e0e0 25%, #f0f0f0 50%, #e0e0e0 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  z-index: 2;
}

@keyframes shimmer {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* 分类图片 */
.category-img {
  width: 650rpx;
  height: 175rpx;
  border-radius: 16rpx;
  opacity: 0;
  transform: scale(1.05);
  transition: opacity 0.4s ease, transform 0.4s ease;
}

/* 悬停提示 */
.hover-hint {
  position: absolute;
  right: 40rpx;
  top: 50%;
  transform: translateY(-50%);
  background: rgba(201, 162, 39, 0.95);
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  animation: pulse-hint 1.2s ease-in-out infinite;
  z-index: 3;
}

@keyframes pulse-hint {
  0%, 100% { opacity: 1; transform: translateY(-50%) scale(1); }
  50% { opacity: 0.85; transform: translateY(-50%) scale(1.05); }
}

.hint-text {
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
}

/* 底部按钮区 */
.footer-buttons {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 0 30rpx;
  margin-top: 40rpx;
}

.btn {
  flex: 1;
  height: 100rpx;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  font-size: 32rpx;
  font-weight: bold;
  font-family: "KaiTi", "STKaiti", sans-serif;
  color: #fff;
  border: 3rpx solid #e7e74d;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.18);
  position: relative;
  overflow: hidden;
  transition: all 0.15s ease;
}

.btn:active {
  transform: scale(0.95) translateY(2rpx);
  box-shadow: 0 3rpx 8rpx rgba(0, 0, 0, 0.12);
}

.btn-icon {
  font-size: 36rpx;
}

.btn-text {
  font-size: 30rpx;
}

.btn.primary,
.btn.secondary {
  background: linear-gradient(135deg, #912626 0%, #b83232 100%);
}

.btn.primary:active,
.btn.secondary:active {
  background: linear-gradient(135deg, #115a58 0%, #1a7a75 100%);
}

/* 涟漪效果 */
.btn::after {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  width: 0;
  height: 0;
  background: rgba(255,255,255,0.3);
  border-radius: 50%;
  transform: translate(-50%, -50%);
  transition: width 0.3s, height 0.3s;
}

.btn:active::after {
  width: 200%;
  height: 200%;
}
