/* 营造技艺页面样式 - 古雅文轩风格 */
.zaoyi-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8f5f0 0%, #efe9df 50%, #e8e0d4 100%);
  padding: 20rpx;
}

/* 顶部装饰区域 */
.header-section {
  padding: 30rpx 20rpx;
}

.decoration-top {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.decoration-line {
  flex: 1;
  height: 4rpx;
  background: linear-gradient(90deg, transparent, #8b6f47, transparent);
}

.decoration-icon {
  font-size: 36rpx;
  margin: 0 20rpx;
}

.title-box {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.main-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #5c4a32;
  letter-spacing: 6rpx;
  margin-bottom: 12rpx;
}

.sub-title {
  font-size: 24rpx;
  color: #8b7355;
  letter-spacing: 2rpx;
}

/* 选择区域卡片 */
.selection-card {
  background: linear-gradient(135deg, #fff 0%, #f8f4ed 100%);
  border-radius: 24rpx;
  padding: 30rpx;
  margin: 20rpx 10rpx;
  box-shadow: 0 8rpx 30rpx rgba(139, 111, 71, 0.15);
  border: 2rpx solid #e8dcc8;
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #e8dcc8;
}

.card-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.card-label {
  font-size: 30rpx;
  font-weight: bold;
  color: #5c4a32;
}

.select-item {
  margin-bottom: 24rpx;
}

.select-label {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.label-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.label-text {
  font-size: 26rpx;
  color: #8b7355;
  font-weight: 500;
}

.picker-box {
  background: linear-gradient(135deg, #f8f4e9 0%, #f0e8dd 100%);
  border: 2rpx solid #d9c7a8;
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.picker-value {
  font-size: 28rpx;
  color: #5c4a32;
}

.picker-arrow {
  font-size: 20rpx;
  color: #8b6f47;
}

/* 细节补充区域 */
.detail-section {
  margin-top: 24rpx;
}

.detail-input-box {
  background: linear-gradient(135deg, #f8f4e9 0%, #f0e8dd 100%);
  border: 2rpx solid #d9c7a8;
  border-radius: 16rpx;
  padding: 20rpx;
}

.detail-input {
  width: 100%;
  min-height: 80rpx;
  font-size: 26rpx;
  color: #5c4a32;
  line-height: 1.6;
  background: transparent;
}

.char-counter {
  display: block;
  text-align: right;
  font-size: 22rpx;
  color: #a69070;
  margin-top: 8rpx;
}

/* 生成按钮区域 */
.generate-section {
  display: flex;
  align-items: center;
  padding: 20rpx 10rpx;
}

.btn-decoration-left,
.btn-decoration-right {
  width: 80rpx;
  height: 4rpx;
  background: linear-gradient(90deg, #8b6f47, transparent);
}

.btn-decoration-right {
  background: linear-gradient(90deg, transparent, #8b6f47);
}

.generate-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #8b6f47 0%, #725a39 100%);
  color: #fff;
  border-radius: 40rpx;
  padding: 24rpx 40rpx;
  font-size: 30rpx;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(139, 111, 71, 0.3);
  margin: 0 20rpx;
}

.generate-btn[disabled] {
  opacity: 0.7;
}

.btn-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.btn-text {
  font-size: 30rpx;
  font-weight: bold;
  letter-spacing: 2rpx;
}

/* 结果展示区域 */
.result-section {
  margin-top: 40rpx;
}

.result-divider {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.divider-line {
  flex: 1;
  height: 3rpx;
  background: linear-gradient(90deg, transparent, #d9c7a8, transparent);
}

.divider-text {
  font-size: 26rpx;
  color: #8b7355;
  padding: 0 24rpx;
  font-weight: 500;
}

/* 图片卡片 */
.image-card {
  margin: 20rpx 10rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 40rpx rgba(139, 111, 71, 0.2);
}

.result-image {
  width: 100%;
  display: block;
}

.image-shadow {
  height: 8rpx;
  background: linear-gradient(180deg, rgba(0,0,0,0.1) 0%, transparent 100%);
}

/* 知识卡片 */
.knowledge-card {
  background: linear-gradient(135deg, #fff 0%, #f8f4ed 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 20rpx 10rpx;
  box-shadow: 0 8rpx 30rpx rgba(139, 111, 71, 0.12);
  border: 2rpx solid #e8dcc8;
}

.knowledge-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #e8dcc8;
}

.knowledge-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.knowledge-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #5c4a32;
}

.knowledge-content {
  margin-bottom: 24rpx;
}

.knowledge-text {
  font-size: 26rpx;
  color: #6b5a42;
  line-height: 1.8;
}

.knowledge-footer {
  display: flex;
  justify-content: center;
}

.save-btn {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #d4a574 0%, #c49464 100%);
  color: #fff;
  border-radius: 30rpx;
  padding: 18rpx 36rpx;
  font-size: 26rpx;
  border: none;
}

.save-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.save-text {
  font-size: 26rpx;
  font-weight: 500;
}

/* 底部装饰 */
.footer-decoration {
  padding: 40rpx 20rpx;
  text-align: center;
}

.footer-quote {
  font-size: 24rpx;
  color: #8b7355;
  font-style: italic;
  letter-spacing: 2rpx;
}
