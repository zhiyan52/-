/* 古建雅韵 - 简约版样式 */
.home-container {
  background-color: #ffffff;
  min-height: 100vh;
  padding: 20rpx 30rpx;
}

/* 顶部标题 */
.header {
  text-align: center;
  padding: 40rpx 0 30rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 500;
  color: #333;
  letter-spacing: 2rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #888;
  margin-top: 10rpx;
  display: block;
}

/* 主视觉区 */
.hero {
  margin: 20rpx 0 40rpx;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.hero-image {
  width: 100%;
  height: 400rpx;
  display: block;
}

/* 功能入口 */
.features {
  margin: 40rpx 0;
}

.feature-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 40rpx;
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 45%;
}

.feature-icon {
  width: 100rpx;
  height: 100rpx;
  margin-bottom: 20rpx;
}

.feature-item text {
  font-size: 28rpx;
  color: #444;
  font-weight: 400;
}

/* 精选推荐 */
.section {
  margin-top: 50rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 30rpx;
  display: block;
}

.recommendations {
  display: flex;
  justify-content: space-between;
}

.recommend-item {
  width: 48%;
}

.rec-image {
  width: 100%;
  height: 240rpx;
  border-radius: 8rpx;
  margin-bottom: 15rpx;
}

.rec-title {
  font-size: 28rpx;
  color: #555;
  text-align: center;
}

/* 底部导航 */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
  display: flex;
  justify-content: space-around;
  align-items: center;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 33.33%;
}

.tab-item image {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 8rpx;
}

.tab-item text {
  font-size: 24rpx;
  color: #999;
}

.tab-item.active text {
  color: #333;
  font-weight: 500;
}