/* gujianSub/minju/minju.wxss */page {
  background: #f5f7f6;
  font-family: "PingFang SC", "Helvetica Neue", "宋体", sans-serif;
}

.container {
  min-height: 100vh;
}

/* 轮播 */
.banner {
  width: 100%;
  height: 360rpx;
}
.banner-img {
  width: 100%;
  height: 100%;
}

/* 搜索 + 地图 同一行 */
.search-map-row {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background: #fff;
  gap: 20rpx;
}
.search-input {
  flex: 1;
  height: 76rpx;
  background: #f1f4f3;
  border-radius: 40rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
  color: #666;
  border: none;
}
.map-btn {
  width: 100rpx;
  height: 76rpx;
  line-height: 76rpx;
  text-align: center;
  background: #3e5b57;
  color: #fff;
  border-radius: 38rpx;
  font-size: 26rpx;
  border: none;
}

/* 卡片列表 */
.list {
  padding: 0 30rpx 30rpx;
}
.card {
  background: #fff;
  border-radius: 28rpx;
  overflow: hidden;
  margin-bottom: 26rpx;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.05);
}
.card-img {
  width: 100%;
  height: 280rpx;
}
.card-body {
  padding: 30rpx;
}
.card-title {
  display: block;
  font-size: 36rpx;
  color: #2c3634;
  margin-bottom: 10rpx;
}
.card-desc {
  display: block;
  font-size: 26rpx;
  color: #777;
  line-height: 1.5;
  margin-bottom: 14rpx;
}
.card-loc {
  font-size: 24rpx;
  color: #5a7470;
}