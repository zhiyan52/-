 /* gujianSub/building3d/building3d.wxss */
page {
  width: 100%;
  height: 100%;
}

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  position: relative;
  overflow: hidden;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* 顶部栏 */
.header {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  position: relative;
  z-index: 100;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  color: #fff;
  font-size: 36rpx;
}

.title-wrap {
  flex: 1;
  text-align: center;
}

.building-name {
  display: block;
  font-size: 36rpx;
  color: #d4af37;
  font-weight: bold;
  letter-spacing: 4rpx;
}

.building-meta {
  font-size: 22rpx;
  color: #a0a0a0;
  display: block;
  margin-top: 4rpx;
}

.share-btn {
  width: 80rpx;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  color: #d4af37;
  font-size: 24rpx;
  background: transparent;
  padding: 0;
  margin: 0;
}

.share-btn::after {
  border: none;
}

/* 3D舞台 */
.stage {
  height: 560rpx;
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

/* 背景网格 */
.grid-floor {
  position: absolute;
  bottom: 80rpx;
  width: 600rpx;
  height: 300rpx;
  background: 
    linear-gradient(90deg, rgba(212,175,55,0.1) 1px, transparent 1px),
    linear-gradient(rgba(212,175,55,0.1) 1px, transparent 1px);
  background-size: 40rpx 40rpx;
  transform: rotateX(60deg);
  -webkit-transform: rotateX(60deg);
  animation: gridMove 20s linear infinite;
}

@keyframes gridMove {
  0% { background-position: 0 0; }
  100% { background-position: 40rpx 40rpx; }
}

/* 建筑容器 */
.building-wrap {
  position: relative;
  width: 400rpx;
  height: 400rpx;
  will-change: transform;
}

/* 部件样式 */
.part {
  position: absolute;
  left: 50%;
  margin-left: -160rpx;
  border-radius: 12rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.4);
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  box-sizing: border-box;
}

/* 部件纹理 */
.part-texture {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  opacity: 0.3;
  pointer-events: none;
}

.part-texture.platform {
  background: repeating-linear-gradient(
    90deg,
    transparent,
    transparent 10rpx,
    rgba(0,0,0,0.1) 10rpx,
    rgba(0,0,0,0.1) 12rpx
  );
}

.part-texture.column {
  background: repeating-linear-gradient(
    0deg,
    transparent,
    transparent 8rpx,
    rgba(139,69,19,0.2) 8rpx,
    rgba(139,69,19,0.2) 10rpx
  );
}

.part-texture.dougong {
  background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.3) 0%, transparent 50%);
}

.part-texture.roof {
  background: repeating-linear-gradient(
    135deg,
    transparent,
    transparent 15rpx,
    rgba(0,0,0,0.1) 15rpx,
    rgba(0,0,0,0.1) 17rpx
  );
}

/* 部件标签 */
.part-label {
  text-align: center;
  color: rgba(255,255,255,0.9);
  position: relative;
  z-index: 2;
}

.label-en {
  display: block;
  font-size: 18rpx;
  letter-spacing: 2rpx;
  opacity: 0.8;
  margin-bottom: 4rpx;
}

.label-cn {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  letter-spacing: 4rpx;
}

/* 高亮效果 */
.part.highlight {
  box-shadow: 0 0 40rpx #d4af37, 0 8rpx 32rpx rgba(0,0,0,0.4);
}

.highlight-border {
  position: absolute;
  top: -4rpx;
  left: -4rpx;
  right: -4rpx;
  bottom: -4rpx;
  border: 4rpx solid #d4af37;
  border-radius: 16rpx;
  animation: borderPulse 1.5s ease-in-out infinite;
  pointer-events: none;
}

@keyframes borderPulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

/* 拆解状态 */
.part.exploded {
  box-shadow: 0 20rpx 60rpx rgba(0,0,0,0.3);
}

/* 手势提示 */
.gesture-hint {
  position: absolute;
  bottom: 30rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: rgba(0,0,0,0.5);
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
}

.hint-icon {
  font-size: 32rpx;
}

.hint-text {
  color: #fff;
  font-size: 22rpx;
}

/* 控制面板 */
.control-panel {
  padding: 30rpx;
  background: rgba(255,255,255,0.05);
  margin: 0 20rpx 20rpx;
  border-radius: 20rpx;
}

/* 拆解控制 */
.explode-control {
  margin-bottom: 24rpx;
}

.control-label {
  display: block;
  color: #d4af37;
  font-size: 26rpx;
  margin-bottom: 16rpx;
  letter-spacing: 2rpx;
}

.explode-steps {
  display: flex;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.step {
  flex: 1;
  height: 6rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 3rpx;
  transition: background 0.3s;
}

.step.active {
  background: #d4af37;
}

.explode-btn {
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
  background: linear-gradient(90deg, #d4af37, #c9a227);
  border-radius: 36rpx;
  color: #1a1a2e;
  font-size: 28rpx;
  font-weight: bold;
  letter-spacing: 2rpx;
}

.explode-btn.disabled {
  opacity: 0.6;
}

.explode-btn:active {
  transform: scale(0.98);
}

/* 视角控制 */
.view-control {
  display: flex;
  gap: 16rpx;
}

.control-btn {
  flex: 1;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: rgba(255,255,255,0.1);
  border-radius: 32rpx;
  color: #fff;
  font-size: 24rpx;
}

.control-btn.active {
  background: #d4af37;
  color: #1a1a2e;
}

.control-btn:active {
  background: rgba(255,255,255,0.2);
}

.btn-icon {
  font-size: 28rpx;
}

/* 信息面板 */
.info-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.6);
  opacity: 0;
  visibility: hidden;
  transition: all 0.3s;
  z-index: 200;
}

.info-mask.show {
  opacity: 1;
  visibility: visible;
}

.info-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 30rpx 30rpx 0 0;
  transform: translateY(100%);
  transition: transform 0.35s ease-out;
  z-index: 201;
  max-height: 50vh;
}

.info-panel.show {
  transform: translateY(0);
}

.info-header {
  padding: 30rpx;
  border-radius: 30rpx 30rpx 0 0;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.info-title {
  font-size: 32rpx;
  color: #fff;
  font-weight: bold;
}

.close-btn {
  width: 50rpx;
  height: 50rpx;
  line-height: 46rpx;
  text-align: center;
  background: rgba(255,255,255,0.3);
  border-radius: 50%;
  color: #fff;
  font-size: 36rpx;
}

.info-body {
  padding: 30rpx;
}

.info-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.7;
  display: block;
  margin-bottom: 24rpx;
}

.tech-tag {
  background: #f5f0e8;
  padding: 20rpx;
  border-radius: 12rpx;
  border-left: 4rpx solid #d4af37;
}

.tag-label {
  display: block;
  font-size: 22rpx;
  color: #d4af37;
  margin-bottom: 8rpx;
  font-weight: bold;
}

.tag-content {
  font-size: 26rpx;
  color: #666;
}

/* 底部说明 */
.footer-info {
  padding: 20rpx 30rpx;
  text-align: center;
}

.footer-info text {
  font-size: 24rpx;
  color: #a0a0a0;
  line-height: 1.5;
}
