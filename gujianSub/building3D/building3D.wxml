 <!-- gujianSub/building3d/building3d.wxml -->
<view class="container">
  <!-- 顶部信息栏 -->
  <view class="header">
    <view class="back-btn" bindtap="goBack">←</view>
    <view class="title-wrap">
      <text class="building-name">{{building.name}}</text>
      <text class="building-meta">{{building.dynasty}}</text>
    </view>
    <button class="share-btn" open-type="share">分享</button>
  </view>

  <!-- 3D交互区域 -->
  <view class="stage" 
        bindtouchstart="onTouchStart"
        bindtouchmove="onTouchMove"
        bindtouchend="onTouchEnd">
    
    <!-- 背景网格 -->
    <view class="grid-floor"></view>
    
    <!-- 建筑部件（从下到上渲染） -->
    <view class="building-wrap" 
          style="transform: translate({{translateX}}px, {{translateY}}px) scale({{scale}}) rotate({{rotation}}deg);">
      
      <view class="part {{item.highlight ? 'highlight' : ''}} {{item.exploded ? 'exploded' : ''}}"
            wx:for="{{parts}}" 
            wx:key="id"
            data-id="{{item.id}}"
            bindtap="onPartTap"
            style="width: {{item.width}}rpx;height: {{item.height}}rpx;background-color: {{item.color}};transform: translateY({{item.currentY}}rpx); z-index: {{item.zIndex}};transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);">
        
        <!-- 部件纹理 -->
        <view class="part-texture {{item.id}}"></view>
        
        <!-- 部件标签 -->
        <view class="part-label">
          <text class="label-en">{{item.nameEn}}</text>
          <text class="label-cn">{{item.name}}</text>
        </view>
        
        <!-- 高亮边框 -->
        <view class="highlight-border" wx:if="{{item.highlight}}"></view>
      </view>
    </view>

    <!-- 操作提示 -->
    <view class="gesture-hint" wx:if="{{!isGesturing && explosionLevel === 0}}">
      <text class="hint-icon">👆</text>
      <text class="hint-text">单指拖动 · 双指缩放旋转</text>
    </view>
  </view>

  <!-- 控制面板 -->
  <view class="control-panel">
    <!-- 拆解滑块 -->
    <view class="explode-control">
      <text class="control-label">拆解层级</text>
      <view class="explode-steps">
        <view class="step {{explosionLevel >= index ? 'active' : ''}}" 
              wx:for="{{[0,1,2,3,4]}}" 
              wx:key="*this"></view>
      </view>
      <view class="explode-btn {{isAnimating ? 'disabled' : ''}}" 
            bindtap="toggleExplosion">
        <text>{{explosionLevel === 0 ? '🔨 拆解' : explosionLevel === 4 ? '⬇️ 还原' : '⬆️ 继续拆解'}}</text>
      </view>
    </view>

    <!-- 视角控制 -->
    <view class="view-control">
      <view class="control-btn" bindtap="resetView">
        <text class="btn-icon">🎯</text>
        <text>重置</text>
      </view>
      <view class="control-btn {{isAutoRotating ? 'active' : ''}}" bindtap="autoRotate">
        <text class="btn-icon">{{isAutoRotating ? '⏸' : '🔄'}}</text>
        <text>{{isAutoRotating ? '停止' : '旋转'}}</text>
      </view>
    </view>
  </view>

  <!-- 部件信息面板 -->
  <view class="info-mask {{showInfo ? 'show' : ''}}" bindtap="closeInfo"></view>
  <view class="info-panel {{showInfo ? 'show' : ''}}">
    <view class="info-header" style="background-color: {{selectedPart.color}}">
      <text class="info-title">{{selectedPart.info.title}}</text>
      <view class="close-btn" bindtap="closeInfo">×</view>
    </view>
    <view class="info-body">
      <text class="info-content">{{selectedPart.info.content}}</text>
      <view class="tech-tag">
        <text class="tag-label">营造技艺</text>
        <text class="tag-content">{{selectedPart.info.tech}}</text>
      </view>
    </view>
  </view>

  <!-- 底部说明 -->
  <view class="footer-info">
    <text>{{building.description}}</text>
  </view>
</view>
