/* gujianSub/wenda2/wenda2.wxss */
page {
  background: linear-gradient(180deg, #f8f4e9 0%, #e8e0d0 100%);
}

.result-container {
  min-height: 100vh;
  padding: 40rpx;
  position: relative;
  overflow: hidden;
}

/* 彩纸特效 */
.confetti-layer {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  height: 100vh;
  pointer-events: none;
  z-index: 10;
}

.confetti {
  position: absolute;
  top: -20rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 4rpx;
  animation: fall 3s ease-out forwards;
}

@keyframes fall {
  0% { transform: translateY(0) rotate(0deg); opacity: 1; }
  100% { transform: translateY(100vh) rotate(720deg); opacity: 0; }
}

/* 结果卡片 */
.result-card {
  background: #fff;
  border-radius: 32rpx;
  padding: 60rpx 40rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 16rpx 60rpx rgba(139, 69, 19, 0.12);
  position: relative;
  text-align: center;
}

/* 段位徽章 */
.rank-badge {
  position: absolute;
  top: -30rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.2);
  overflow: hidden;
}

.rank-text {
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
  text-shadow: 2rpx 2rpx 4rpx rgba(0,0,0,0.3);
}

.rank-shine {
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: linear-gradient(45deg, transparent 40%, rgba(255,255,255,0.4) 50%, transparent 60%);
  animation: shine 2s infinite;
}

@keyframes shine {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 分数 */
.score-wrap {
  margin-top: 80rpx;
  margin-bottom: 40rpx;
  display: flex;
  align-items: baseline;
  justify-content: center;
}

.score-num {
  font-size: 120rpx;
  font-weight: bold;
  color: #8b4513;
  line-height: 1;
}

.score-total {
  font-size: 48rpx;
  color: #a08060;
  margin-left: 10rpx;
}

/* 正确率环 */
.rate-ring {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  margin: 0 auto 40rpx;
}

.ring-bg {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: #f0e6d0;
}

.ring-fill {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  mask: radial-gradient(transparent 55%, black 56%);
  -webkit-mask: radial-gradient(transparent 55%, black 56%);
}

.ring-inner {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  text-align: center;
}

.rate-num {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  display: block;
}

.rate-label {
  font-size: 24rpx;
  color: #999;
}

/* 数据标签 */
.stats-row {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 60rpx;
  padding-top: 30rpx;
  border-top: 2rpx solid #f0e6d0;
}

.stat-item {
  text-align: center;
}

.stat-num {
  font-size: 44rpx;
  font-weight: bold;
  color: #c9a227;
  display: block;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

.stat-divider {
  width: 2rpx;
  height: 60rpx;
  background: #e0d5c0;
}

/* 成就提示 */
.achievement-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  background: linear-gradient(90deg, #fff3e0, #ffe0b2);
  padding: 24rpx 40rpx;
  border-radius: 50rpx;
  margin-bottom: 40rpx;
}

.tip-icon {
  font-size: 40rpx;
}

.tip-text {
  font-size: 30rpx;
  color: #e65100;
  font-weight: bold;
}

/* 操作网格 */
.action-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.action-btn {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
  transition: transform 0.2s;
}

.action-btn:active {
  transform: scale(0.96);
}

.btn-icon {
  font-size: 48rpx;
  display: block;
  margin-bottom: 16rpx;
}

.btn-label {
  font-size: 28rpx;
  color: #666;
}

/* 底部栏 */
.bottom-bar {
  display: flex;
  gap: 20rpx;
}

.share-btn, .back-btn {
  flex: 1;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  border-radius: 48rpx;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.share-btn {
  background: linear-gradient(90deg, #07c160, #10b981);
  color: #fff;
}

.share-btn::after {
  border: none;
}

.back-btn {
  background: #e0d5c0;
  color: #666;
}

.share-icon {
  font-size: 36rpx;
}
