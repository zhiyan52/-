/* gujianSub/wenda2/wenda2.wxss */ 
.result-container {
  min-height: 100vh;
  background: #f8f4e9; /* 宣纸米白底色 */
  padding: 60rpx 30rpx;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
}

.score-card {
  background: #fff;
  border: 2rpx solid #c8a067; /* 檀棕边框 */
  border-radius: 20rpx;
  padding: 80rpx 40rpx;
  text-align: center;
  margin-bottom: 50rpx;
  box-shadow: 0 8rpx 24rpx rgba(170, 140, 100, 0.15);
}

.score-num {
  font-size: 100rpx;
  font-weight: bold;
  color: #a63c3a; /* 朱红主色 */
  line-height: 1;
  margin-bottom: 24rpx;
}

.score-label {
  font-size: 32rpx;
  color: #6b5b47;
  display: block;
  margin-bottom: 40rpx;
}

.rate {
  font-size: 36rpx;
  color: #333;
}

.level-tag {
  text-align: center;
  margin-bottom: 80rpx;
}

.level-tag text {
  padding: 16rpx 40rpx;
  border-radius: 60rpx;
  font-size: 32rpx;
  color: #fff;
  letter-spacing: 2rpx;
}

.level-tag.gold text {
  background: linear-gradient(135deg, #ffd700, #ffb300);
}

.level-tag.silver text {
  background: linear-gradient(135deg, #e8e8e8, #c0c0c0);
}

.level-tag.copper text {
  background: linear-gradient(135deg, #b87333, #cd7f32);
}

.btn-group {
  display: flex;
  gap: 30rpx;
}

.btn {
  flex: 1;
  padding: 32rpx 0;
  border-radius: 60rpx;
  font-size: 34rpx;
  border: none;
  letter-spacing: 4rpx;
}

.btn.primary {
  background: #a63c3a; /* 朱红主色 */
  color: #fff;
}

.btn.secondary {
  background: #c8a067; /* 檀棕辅色 */
  color: #fff;
}