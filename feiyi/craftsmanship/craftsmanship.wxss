 /* pages/craftsmanship/craftsmanship.wxss */
page {
  background-color: #f5f0e8;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

.container {
  padding-bottom: 120rpx;
}

/* 顶部标题 */
.header {
  text-align: center;
  padding: 40rpx 0 20rpx;
  background: linear-gradient(180deg, #2c1810 0%, #4a3728 100%);
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #d4a574;
  letter-spacing: 8rpx;
}

.subtitle {
  display: block;
  font-size: 24rpx;
  color: #a08060;
  margin-top: 10rpx;
  letter-spacing: 4rpx;
}

/* 项目选择器 */
.project-selector {
  white-space: nowrap;
  padding: 20rpx 30rpx;
  background: #fff;
  border-bottom: 2rpx solid #e8e0d0;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.project-tab {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 30rpx;
  margin-right: 20rpx;
  border-radius: 16rpx;
  transition: all 0.3s;
  cursor: pointer;
}

.project-tab:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.project-tab.active {
  background: #f5ebe0;
  border: 2rpx solid #d4a574;
  box-shadow: 0 4rpx 12rpx rgba(212, 165, 116, 0.3);
  transform: translateY(-2rpx);
}

.tab-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #f5f0e8;
  transition: all 0.3s;
  display: flex;
  align-items: center;
  justify-content: center;
}

.project-tab.active .tab-icon {
  background: #d4a574;
  transform: scale(1.1);
}

.tab-name {
  font-size: 24rpx;
  color: #666;
  margin-top: 10rpx;
  transition: all 0.3s;
}

.project-tab.active .tab-name {
  color: #8b4513;
  font-weight: bold;
  transform: scale(1.05);
}

/* 简介卡片 */
.intro-card {
  position: relative;
  margin: 20rpx 30rpx;
  height: 300rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
}

.intro-bg {
  width: 100%;
  height: 100%;
}

.intro-mask {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 30rpx;
  background: linear-gradient(transparent, rgba(0,0,0,0.7));
}

.intro-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 10rpx;
}

.intro-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  line-height: 1.6;
}

/* 时间轴区域 */
.timeline-section {
  margin: 30rpx;
  padding: 30rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #2c1810;
  border-left: 6rpx solid #d4a574;
  padding-left: 20rpx;
}

.step-counter {
  font-size: 24rpx;
  color: #999;
}

/* 时间轴轨道 */
.timeline-track {
  position: relative;
  height: 60rpx;
  margin-bottom: 30rpx;
}

.timeline-progress {
  position: absolute;
  top: 50%;
  left: 0;
  height: 4rpx;
  background: #d4a574;
  transform: translateY(-50%);
  transition: width 0.5s ease;
  box-shadow: 0 0 8rpx rgba(212, 165, 116, 0.5);
}

.timeline-track::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 0;
  right: 0;
  height: 4rpx;
  background: #e8e0d0;
  transform: translateY(-50%);
}

.timeline-dots {
  display: flex;
  justify-content: space-between;
  position: relative;
  z-index: 2;
}

.dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #e8e0d0;
  border: 4rpx solid #fff;
  transition: all 0.3s;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
}

.dot:hover {
  transform: scale(1.2);
  box-shadow: 0 0 8rpx rgba(0,0,0,0.2);
}

.dot.active {
  background: #d4a574;
  box-shadow: 0 0 8rpx rgba(212, 165, 116, 0.5);
}

.dot.current {
  transform: scale(1.5);
  box-shadow: 0 0 12rpx rgba(212, 165, 116, 0.8);
  background: #8b4513;
  border-color: #d4a574;
}

.dot.current::after {
  content: '';
  position: absolute;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(212, 165, 116, 0.2);
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0% { transform: scale(0.8); opacity: 1; }
  100% { transform: scale(1.5); opacity: 0; }
}

/* 滑动卡片 */
.step-swiper {
  height: 800rpx;
}

.step-card {
  height: 100%;
  padding: 20rpx;
  position: relative;
}

.step-header {
  margin-bottom: 20rpx;
}

.step-number {
  display: inline-block;
  background: #d4a574;
  color: #fff;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  margin-bottom: 10rpx;
}

.step-name {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #2c1810;
  margin-top: 10rpx;
}

/* 动画演示区 */
.animation-area {
  position: relative;
  width: 100%;
  height: 400rpx;
  background: #f5f0e8;
  border-radius: 16rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}

.step-image {
  width: 100%;
  height: 100%;
  transition: all 0.5s;
}

.step-image.animate-slow {
  animation: slowMotion 3s ease-in-out infinite;
}

@keyframes slowMotion {
  0% { transform: scale(1); filter: brightness(1); }
  50% { transform: scale(1.05); filter: brightness(1.1) contrast(1.1); }
  100% { transform: scale(1); filter: brightness(1); }
}

.play-hint {
  position: absolute;
  bottom: 20rpx;
  right: 20rpx;
  background: rgba(0,0,0,0.6);
  padding: 10rpx 20rpx;
  border-radius: 30rpx;
}

.hint-text {
  color: #fff;
  font-size: 22rpx;
}

/* 步骤描述 */
.step-description {
  margin-top: 20rpx;
  padding: 20rpx;
  background: #faf8f5;
  border-radius: 12rpx;
  border-left: 4rpx solid #d4a574;
}

.step-description text {
  font-size: 28rpx;
  color: #555;
  line-height: 1.8;
}

/* 关键工序标记 */
.key-step-badge {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  background: #c0392b;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.badge-text {
  color: #fff;
  font-size: 22rpx;
}

/* 细节放大镜区域 */
.magnifier-section {
  margin: 30rpx;
  padding: 30rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.subtitle-text {
  font-size: 24rpx;
  color: #999;
}

.detail-gallery {
  margin: 20rpx 0;
}

.detail-scroll {
  white-space: nowrap;
}

.detail-item {
  display: inline-block;
  width: 280rpx;
  height: 280rpx;
  margin-right: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
}

.detail-image {
  width: 100%;
  height: 100%;
  transition: transform 0.3s;
}

.detail-item:active .detail-image {
  transform: scale(1.1);
}

.detail-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 15rpx;
  background: linear-gradient(transparent, rgba(0,0,0,0.6));
}

.detail-hint {
  color: #fff;
  font-size: 22rpx;
}

.detail-desc {
  padding: 20rpx;
  background: #faf8f5;
  border-radius: 12rpx;
  margin-top: 20rpx;
}

.detail-desc text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
}

/* 底部导航 */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  padding: 20rpx 30rpx;
  background: #fff;
  border-top: 2rpx solid #e8e0d0;
  z-index: 100;
}

.nav-btn {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  margin: 0 15rpx;
  border-radius: 40rpx;
  background: #d4a574;
  transition: all 0.3s;
}

.nav-btn text {
  color: #fff;
  font-size: 30rpx;
  font-weight: bold;
}

.nav-btn.disabled {
  background: #ccc;
}

.nav-btn:active:not(.disabled) {
  opacity: 0.8;
  transform: scale(0.98);
}
