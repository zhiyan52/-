/* 智能导览页面样式 - 传统温暖风格 */
.container {
  background-color: #f5f0e6;
  min-height: 100vh;
  padding: 0 24rpx;
  font-family: 'KaiTi', 'STKaiti', 'PingFang SC', sans-serif;
}

/* 头部区域 */
.header-section {
  padding: 40rpx 0 40rpx;
  text-align: center;
  margin-bottom: 32rpx;
  position: relative;
}

.header-title {
  font-size: 40rpx;
  font-weight: 600;
  color: #5c3a21;
  letter-spacing: 8rpx;
  margin-bottom: 12rpx;
  display: inline-block;
  background: #fff;
  padding: 20rpx 60rpx;
  border-radius: 56rpx;
  border: 2rpx solid #d4af37;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
}

.header-subtitle {
  font-size: 24rpx;
  color: #8b7355;
  opacity: 0.9;
}

.header-section::after {
  content: '';
  position: absolute;
  bottom: 20rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 120rpx;
  height: 4rpx;
  background: linear-gradient(90deg, #d4af37, #b8860b, #d4af37);
  border-radius: 2rpx;
}

/* 品类选择器 */
.category-selector {
  background: rgba(255, 255, 255, 0.85);
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
  margin-bottom: 32rpx;
  border: 2rpx solid #d4af37;
}

.picker {
  font-size: 26rpx;
  color: #5c3a21;
  text-align: center;
  padding: 16rpx;
  background: #faf8f5;
  border-radius: 16rpx;
  border: 1rpx solid #e8dcc8;
}

/* 工序流程容器 */
.process-container {
  background: rgba(255, 255, 255, 0.85);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
  margin-bottom: 32rpx;
  border: 2rpx solid #d4af37;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #5c3a21;
  margin-bottom: 28rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #d4af37;
  letter-spacing: 4rpx;
  text-align: center;
}

/* 工序步骤 */
.process-steps {
  margin-bottom: 32rpx;
}

.step-card {
  display: flex;
  gap: 24rpx;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #e8dcc8;
  position: relative;
}

.step-card:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.step-number {
  width: 52rpx;
  height: 52rpx;
  background: linear-gradient(135deg, #d4af37 0%, #b8860b 100%);
  color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(212, 175, 55, 0.4);
}

.step-content {
  flex: 1;
  min-width: 0;
}

.step-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #5c3a21;
  margin-bottom: 10rpx;
  line-height: 1.3;
  letter-spacing: 1rpx;
}

.step-description {
  font-size: 22rpx;
  color: #6b5344;
  line-height: 1.6;
  margin-bottom: 14rpx;
  opacity: 0.9;
}

.step-tips {
  background: #faf8f5;
  border-radius: 16rpx;
  padding: 18rpx;
  border-left: 4rpx solid #d4af37;
}

.tips-label {
  font-size: 20rpx;
  font-weight: 600;
  color: #8b7355;
  margin-bottom: 10rpx;
}

.tips-content {
  font-size: 20rpx;
  color: #5c3a21;
  line-height: 1.5;
}

/* 信息卡片 */
.info-section {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.info-card {
  background: #faf8f5;
  border-radius: 16rpx;
  padding: 24rpx;
  border: 1rpx solid #e8dcc8;
}

.info-title {
  font-size: 22rpx;
  font-weight: 600;
  color: #8b7355;
  margin-bottom: 14rpx;
}

.info-content {
  font-size: 20rpx;
  color: #5c3a21;
  line-height: 1.6;
}

/* AI 辅助讲解 */
.ai-section {
  background: rgba(255, 255, 255, 0.85);
  border-radius: 24rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
  margin-bottom: 60rpx;
  border: 2rpx solid #d4af37;
}

.ai-input-section {
  display: flex;
  gap: 20rpx;
  margin-bottom: 28rpx;
}

.ai-input {
  flex: 1;
  padding: 18rpx 24rpx;
  background: #faf8f5;
  border: 1rpx solid #e8dcc8;
  border-radius: 16rpx;
  font-size: 22rpx;
  color: #5c3a21;
}

.ai-btn {
  padding: 18rpx 36rpx;
  background: linear-gradient(135deg, #d4af37 0%, #b8860b 100%);
  color: #ffffff;
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  white-space: nowrap;
  box-shadow: 0 4rpx 12rpx rgba(212, 175, 55, 0.4);
}

.ai-btn:active {
  transform: scale(0.96);
  background: linear-gradient(135deg, #b8860b 0%, #d4af37 100%);
}

.ai-response {
  background: #faf8f5;
  border-radius: 16rpx;
  padding: 24rpx;
  border: 1rpx solid #e8dcc8;
}

.ai-response-title {
  font-size: 22rpx;
  font-weight: 600;
  color: #8b7355;
  margin-bottom: 14rpx;
}

.ai-response-content {
  font-size: 20rpx;
  color: #5c3a21;
  line-height: 1.6;
  white-space: pre-wrap;
}

/* 加载状态 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
  flex-direction: column;
  gap: 20rpx;
}

.loading-spinner {
  width: 44rpx;
  height: 44rpx;
  border: 3rpx solid #e8dcc8;
  border-top: 3rpx solid #d4af37;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

.loading text {
  font-size: 22rpx;
  color: #8b7355;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 响应式调整 */
@media (max-width: 375px) {
  .header-title {
    font-size: 34rpx;
    padding: 16rpx 40rpx;
  }
  
  .process-container,
  .ai-section {
    padding: 24rpx;
  }
  
  .step-card {
    gap: 18rpx;
    padding: 22rpx 0;
  }
  
  .step-number {
    width: 44rpx;
    height: 44rpx;
    font-size: 22rpx;
  }
  
  .step-title {
    font-size: 24rpx;
  }
  
  .section-title {
    font-size: 26rpx;
  }
}
