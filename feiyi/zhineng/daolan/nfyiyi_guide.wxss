 /* pages/nfyiyi/guide/index.wxss */
.container {
  padding: 20rpx;
  font-family: "PingFang SC", sans-serif;
}

.picker {
  background: #f0f0f0;
  padding: 20rpx;
  border-radius: 12rpx;
  text-align: center;
  margin-bottom: 30rpx;
  font-size: 32rpx;
}

.guide-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.step-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-top: 20rpx;
  margin-bottom: 10rpx;
}

.step-content {
  font-size: 28rpx;
  line-height: 1.6;
  color: #666;
  margin-bottom: 20rpx;
  display: block;
}

.image-container {
  text-align: center;
  margin: 30rpx 0;
}

.step-image {
  width: 100%;
  max-width: 600rpx;
  border-radius: 12rpx;
}

.image-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.loading {
  text-align: center;
  padding: 100rpx 0;
  color: #999;
}