/* 智能导览页面样式 - 高端极简风格 */
.container {
  background-color: #f8f9fa;
  min-height: 100vh;
  padding: 0 24rpx;
  font-family: 'SF Pro Display', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

/* 头部区域 */
.header-section {
  padding: 32rpx 0 24rpx;
  text-align: center;
  border-bottom: 1rpx solid #eaeaea;
  margin-bottom: 32rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #2c3e50;
  letter-spacing: 2rpx;
  margin-bottom: 8rpx;
}

.header-subtitle {
  font-size: 20rpx;
  color: #64748b;
  opacity: 0.8;
}

/* 品类选择器 */
.category-selector {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  margin-bottom: 32rpx;
  border: 1rpx solid #f0f0f0;
}

.picker {
  font-size: 24rpx;
  color: #2c3e50;
  text-align: center;
  padding: 12rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
}

/* 工序流程容器 */
.process-container {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  margin-bottom: 32rpx;
  border: 1rpx solid #f0f0f0;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2c3e50;
  margin-bottom: 24rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #f0f0f0;
  letter-spacing: 1rpx;
}

/* 工序步骤 */
.process-steps {
  margin-bottom: 32rpx;
}

.step-card {
  display: flex;
  gap: 20rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f5f7fa;
  position: relative;
}

.step-card:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.step-number {
  width: 48rpx;
  height: 48rpx;
  background: #2c3e50;
  color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  flex-shrink: 0;
  box-shadow: 0 4rpx 12rpx rgba(44, 62, 80, 0.3);
}

.step-content {
  flex: 1;
  min-width: 0;
}

.step-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #2c3e50;
  margin-bottom: 8rpx;
  line-height: 1.3;
}

.step-description {
  font-size: 20rpx;
  color: #64748b;
  line-height: 1.5;
  margin-bottom: 12rpx;
  opacity: 0.9;
}

.step-tips {
  background: #f8f9fa;
  border-radius: 12rpx;
  padding: 16rpx;
  border-left: 4rpx solid #a8b8c8;
}

.tips-label {
  font-size: 18rpx;
  font-weight: 600;
  color: #64748b;
  margin-bottom: 8rpx;
}

.tips-content {
  font-size: 18rpx;
  color: #475569;
  line-height: 1.4;
}

/* 信息卡片 */
.info-section {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.info-card {
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 20rpx;
  border: 1rpx solid #f0f0f0;
}

.info-title {
  font-size: 20rpx;
  font-weight: 600;
  color: #64748b;
  margin-bottom: 12rpx;
}

.info-content {
  font-size: 18rpx;
  color: #475569;
  line-height: 1.5;
}

/* AI 辅助讲解 */
.ai-section {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  margin-bottom: 60rpx;
  border: 1rpx solid #f0f0f0;
}

.ai-input-section {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.ai-input {
  flex: 1;
  padding: 16rpx 20rpx;
  background: #f5f7fa;
  border: 1rpx solid #e2e8f0;
  border-radius: 12rpx;
  font-size: 20rpx;
  color: #2c3e50;
}

.ai-btn {
  padding: 16rpx 32rpx;
  background: #2c3e50;
  color: #ffffff;
  border-radius: 12rpx;
  font-size: 20rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  white-space: nowrap;
}

.ai-btn:active {
  transform: scale(0.96);
  background: #1e293b;
}

.ai-response {
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 20rpx;
  border: 1rpx solid #f0f0f0;
}

.ai-response-title {
  font-size: 20rpx;
  font-weight: 600;
  color: #64748b;
  margin-bottom: 12rpx;
}

.ai-response-content {
  font-size: 18rpx;
  color: #475569;
  line-height: 1.5;
  white-space: pre-wrap;
}

/* 加载状态 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx;
  flex-direction: column;
  gap: 16rpx;
}

.loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 3rpx solid #e2e8f0;
  border-top: 3rpx solid #2c3e50;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

.loading text {
  font-size: 20rpx;
  color: #64748b;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

/* 响应式调整 */
@media (max-width: 375px) {
  .header-title {
    font-size: 32rpx;
  }
  
  .process-container,
  .ai-section {
    padding: 20rpx;
  }
  
  .step-card {
    gap: 16rpx;
    padding: 20rpx 0;
  }
  
  .step-number {
    width: 40rpx;
    height: 40rpx;
    font-size: 20rpx;
  }
  
  .step-title {
    font-size: 22rpx;
  }
  
  .section-title {
    font-size: 24rpx;
  }
}
