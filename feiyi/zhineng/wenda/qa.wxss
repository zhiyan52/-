/* feiyi/zhineng/wenda/qa.wxss *//* 全局样式 */
.container {
  padding: 30rpx;
  background-color: #f8f5f0;
  height: 100vh;
  overflow: auto;
  -webkit-overflow-scrolling: touch;
}
.page-title {
  font-size: 38rpx;
  font-weight: bold;
  text-align: center;
  color: #8b6f47;
  margin-bottom: 40rpx;
  letter-spacing: 2rpx;
}
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #8b6f47;
  margin-bottom: 25rpx;
  display: flex;
  align-items: center;
}
/* 答题模块样式 */
.qa-section {
  background-color: #fff;
  padding: 30rpx;
  border-radius: 20rpx;
  margin-bottom: 40rpx;
  border: 2rpx solid #d9c7a8;
}
.question-box {
  font-size: 32rpx;
  font-weight: 500;
  line-height: 1.6;
  margin-bottom: 30rpx;
  color: #333;
}
.options-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 30rpx;
}
.option-item {
  padding: 24rpx;
  border: 2rpx solid #ddd;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333;
}
.option-item.correct {
  border-color: #27ae60;
  background-color: #f6ffed;
  color: #27ae60;
}
.option-item.error {
  border-color: #e74c37;
  background-color: #fff2f0;
  color: #e74c37;
}
.result-tip {
  margin-bottom: 25rpx;
  font-size: 30rpx;
  text-align: center;
}
.right-text {
  color: #27ae60;
  font-weight: bold;
}
.wrong-text {
  color: #e74c37;
  font-weight: bold;
}
.qa-btns {
  display: flex;
  gap: 15rpx;
}
.mini-btn {
  flex: 1;
  height: 70rpx;
  line-height: 70rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  border: none;
  color: #fff;
}
.next-btn {
  background-color: #8b6f47;
}
.ai-btn {
  background-color: #a58a67;
}
.img-btn {
  background-color: #c1a98a;
}

/* AI指导模块样式 */
.ai-section {
  background-color: #fff;
  padding: 30rpx;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  border: 2rpx solid #d9c7a8;
}
.input-box {
  width: 100%;
}
.input-area {
  width: 100%;
  height: 220rpx;
  padding: 20rpx;
  border: 2rpx solid #d9c7a8;
  border-radius: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  margin-bottom: 25rpx;
}
.ai-btns {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}
.action-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  border: none;
}
.primary-btn {
  background-color: #8b6f47;
  color: #fff;
}
.second-btn {
  background-color: #a58a67;
  color: #fff;
}

/* 结果展示样式 */
.result-section, .image-section {
  background-color: #fff;
  padding: 30rpx;
  border-radius: 20rpx;
  margin-bottom: 30rpx;
  border: 2rpx solid #d9c7a8;
}
.ai-result-content {
  font-size: 28rpx;
  line-height: 1.8;
  color: #333;
}
.result-img {
  width: 100%;
  border-radius: 16rpx;
}