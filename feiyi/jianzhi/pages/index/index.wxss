/* mingsu/jianzhi/pages/index/index.wxss */.home-container {
  min-height: 100vh;
  background: #2c1810;
  padding: 40rpx;
}

.brand-header {
  text-align: center;
  padding: 40rpx 0;
}

.brand-name {
  display: block;
  font-size: 56rpx;
  font-weight: bold;
  color: #f5f0e8;
  letter-spacing: 8rpx;
}

.sub-brand {
  display: block;
  font-size: 28rpx;
  color: #c0392b;
  margin-top: 12rpx;
}

.user-card {
  background: rgba(255, 255, 255, 0.05);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
}

.user-stats {
  display: flex;
  justify-content: space-around;
}

.stat-item {
  text-align: center;
}

.stat-num {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #e74c3c;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.seasonal-banner {
  display: flex;
  align-items: center;
  background: #c0392b;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 32rpx;
}

.seasonal-icon {
  font-size: 64rpx;
  margin-right: 24rpx;
}

.seasonal-name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

.seasonal-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.seasonal-arrow {
  margin-left: auto;
  font-size: 40rpx;
  color: #fff;
}

.main-actions {
  margin-bottom: 32rpx;
}

.action-btn {
  border-radius: 24rpx;
  padding: 40rpx;
  text-align: center;
}

.action-btn.primary {
  background: #e74c3c;
  margin-bottom: 24rpx;
}

.action-row {
  display: flex;
  gap: 24rpx;
}

.action-btn.secondary {
  flex: 1;
  background: rgba(255, 255, 255, 0.08);
}

.btn-icon {
  display: block;
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.btn-text {
  display: block;
  font-size: 32rpx;
  color: #f5f0e8;
  font-weight: bold;
}

.btn-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.recent-section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 28rpx;
  color: #f5f0e8;
  margin-bottom: 16rpx;
}

.recent-scroll {
  white-space: nowrap;
}

.recent-item {
  display: inline-block;
  width: 200rpx;
  margin-right: 16rpx;
  text-align: center;
}

.recent-thumb {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  background: #333;
}

.recent-stars {
  margin-top: 8rpx;
}

.daily-tip {
  background: rgba(241, 196, 15, 0.1);
  border-left: 6rpx solid #f1c40f;
  padding: 24rpx;
  border-radius: 0 16rpx 16rpx 0;
}

.tip-label {
  display: block;
  font-size: 24rpx;
  color: #f1c40f;
  margin-bottom: 8rpx;
}

.tip-content {
  font-size: 26rpx;
  color: #f5f0e8;
  line-height: 1.6;
}