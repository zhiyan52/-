<!-- 我的收藏页面 -->
<view class="collection-container">
  <!-- 顶部导航 -->
  <view class="nav-bar">
    <view class="nav-left" bindtap="goBack">
      <text class="back-icon">←</text>
    </view>
    <view class="nav-title">我的收藏</view>
    <view class="nav-right"></view>
  </view>

  <!-- 收藏列表 -->
  <view class="collection-list" wx:if="{{collections.length > 0}}">
    <view wx:for="{{collections}}" wx:key="id" class="collection-item">
      <image src="{{item.image}}" mode="aspectFill" class="collection-image"/>
      <view class="collection-info">
        <text class="collection-title">{{item.name}}</text>
        <text class="collection-category">{{item.category}}</text>
        <text class="collection-time">收藏于 {{item.time}}</text>
      </view>
      <view class="collection-actions">
        <view class="action-btn" bindtap="viewDetail" data-id="{{item.id}}">
          <text class="action-icon">👁️</text>
        </view>
        <view class="action-btn" bindtap="removeCollection" data-id="{{item.id}}">
          <text class="action-icon">🗑️</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:else>
    <text class="empty-icon">📭</text>
    <text class="empty-text">还没有收藏内容</text>
    <text class="empty-subtext">浏览文化内容时，点击收藏按钮添加到这里</text>
    <view class="empty-btn" bindtap="goExplore">
      <text class="btn-text">去探索</text>
    </view>
  </view>

  <!-- 底部信息 -->
  <view class="footer-info" wx:if="{{collections.length > 0}}">
    <text class="info-text">共 {{collections.length}} 个收藏</text>
  </view>
</view>