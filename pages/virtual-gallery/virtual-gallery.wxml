<view class="container">
  <!-- 页面标题 -->
  <view class="header">
    <text class="title">360°虚拟文化展厅</text>
    <text class="subtitle">左右滑动切换视角</text>
  </view>

  <!-- 360°全景图区域 -->
  <view 
    class="pano-box" 
    bindtouchstart="onTouchStart"
    bindtouchmove="onTouchMove"
    bindtouchend="onTouchEnd"
  >
    <image 
      src="{{panoList[current]}}" 
      class="pano-img" 
      mode="aspectFill"
      style="transition: transform 0.3s ease-in-out;"
    ></image>

    <!-- 热点：用 data-index 传参 -->
    <view class="spot" style="left:25%;top:40%" data-index="0" bindtap="openInfo">●</view>
    <view class="spot" style="left:50%;top:22%" data-index="1" bindtap="openInfo">●</view>
    <view class="spot" style="left:70%;top:55%" data-index="2" bindtap="openInfo">●</view>
    <view class="spot" style="left:40%;top:70%" data-index="3" bindtap="openInfo">●</view>
    <view class="spot" style="left:60%;top:15%" data-index="4" bindtap="openInfo">●</view>

    <!-- 视角指示器 -->
    <view class="indicator">
      <view wx:for="{{panoList}}" wx:key="index" class="indicator-dot {{current === index ? 'active' : ''}}"></view>
    </view>
  </view>

  <!-- 控制按钮 -->
  <view class="controls">
    <button class="control-btn" bindtap="prevImage">←</button>
    <button class="control-btn" bindtap="nextImage">→</button>
  </view>

  <!-- 说明文字 -->
  <view class="tips">
    <text class="tip-text">👆 左右滑动可360°浏览全景</text>
    <text class="tip-text">👆 点击金色热点查看建筑构件知识</text>
  </view>

  <!-- 知识弹窗 -->
  <view class="modal" wx:if="{{showModal}}" bindtap="closeModal">
    <view class="card" catchtap="">
      <view class="card-title">{{currentItem.name}}</view>
      <view class="card-desc">{{currentItem.desc}}</view>
      <view class="btns">
        <button class="btn ai-btn" bindtap="generateStruct">AI生成结构图</button>
        <button class="btn close-btn" bindtap="closeModal">关闭</button>
      </view>
    </view>
  </view>
</view>