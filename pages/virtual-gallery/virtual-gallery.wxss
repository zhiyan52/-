/* 360°虚拟文化展厅样式 */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #f5f0e1 0%, #e8ddc3 100%);
  font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif;
  padding: 20rpx;
}

/* 360°全景展示区 */
.pano-box {
  position: relative;
  width: 100%;
  height: 500rpx;
  margin: 20rpx 0;
  overflow: hidden;
  border-radius: 20rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.1);
  background: #000;
}

.pano-img {
  width: 100%;
  height: 100%;
  display: block;
  transition: transform 0.5s ease-in-out, opacity 0.3s ease;
}

/* 平滑过渡效果 */
.pano-box {
  transition: all 0.3s ease;
}

/* 热点标记 */
.spot {
  position: absolute;
  pointer-events: auto;
  transform: translate(-50%, -50%);
  z-index: 10;
  font-size: 40rpx;
  color: #ffd700;
  text-shadow: 0 0 10rpx rgba(255, 215, 0, 0.8);
  animation: pulse 1.5s infinite;
  cursor: pointer;
}

@keyframes pulse {
  0% {
    transform: translate(-50%, -50%) scale(1);
  }
  50% {
    transform: translate(-50%, -50%) scale(1.3);
  }
  100% {
    transform: translate(-50%, -50%) scale(1);
  }
}

/* 弹窗样式 */
.modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

.card {
  background: white;
  width: 80%;
  max-width: 600rpx;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.3);
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from {
    transform: translateY(50rpx);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.card-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #8b4513;
  margin-bottom: 20rpx;
  text-align: center;
}

.card-desc {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  margin-bottom: 30rpx;
}

.btns {
  display: flex;
  gap: 20rpx;
  justify-content: center;
}

.btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  text-align: center;
}

.ai-btn {
  background: linear-gradient(135deg, #8b4513 0%, #a0522d 100%);
  color: white;
}

.close-btn {
  background: #f0f0f0;
  color: #333;
}

.btn:active {
  opacity: 0.8;
  transform: scale(0.98);
}
