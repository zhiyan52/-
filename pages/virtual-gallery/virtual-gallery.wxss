/* 360°虚拟文化展厅样式 */
.gallery-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #f5f0e1 0%, #e8ddc3 100%);
  font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif;
}

/* 顶部导航 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 80rpx;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10rpx);
  border-bottom: 1rpx solid #e8ddc3;
  padding: 0 30rpx;
  position: sticky;
  top: 0;
  z-index: 100;
}

.nav-left {
  width: 60rpx;
}

.back-icon {
  font-size: 40rpx;
  color: #8b4513;
  font-weight: bold;
}

.nav-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #8b4513;
  text-align: center;
  flex: 1;
}

.nav-right {
  width: 60rpx;
}

/* 360°全景展示区 */
.panorama-container {
  position: relative;
  width: 100%;
  height: 500rpx;
  margin: 20rpx 0;
  overflow: hidden;
  border-radius: 20rpx;
  box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.1);
}

.panorama {
  width: 100%;
  height: 100%;
  transition: transform 0.3s ease;
}

/* 热点标记 */
.hotspots {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
}

.hotspot {
  position: absolute;
  pointer-events: auto;
  transform: translate(-50%, -50%);
  z-index: 10;
}

.hotspot-icon {
  font-size: 36rpx;
  animation: pulse 2s infinite;
}

.hotspot-label {
  position: absolute;
  top: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0, 0, 0, 0.7);
  color: white;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  white-space: nowrap;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.hotspot:hover .hotspot-label {
  opacity: 1;
}

@keyframes pulse {
  0% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.2);
  }
  100% {
    transform: scale(1);
  }
}

/* 视角指示器 */
.view-indicator {
  position: absolute;
  bottom: 20rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 10rpx;
  z-index: 5;
}

.indicator-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.5);
  transition: all 0.3s ease;
}

.indicator-dot.active {
  background: #8b4513;
  width: 40rpx;
  border-radius: 8rpx;
}

/* 控制按钮 */
.controls {
  display: flex;
  justify-content: center;
  gap: 30rpx;
  margin: 30rpx 0;
}

.control-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: white;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 5rpx 15rpx rgba(0, 0, 0, 0.1);
  font-size: 36rpx;
  color: #8b4513;
  font-weight: bold;
  transition: all 0.3s ease;
}

.control-btn:active {
  transform: scale(0.95);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

/* 展厅信息 */
.gallery-info {
  background: white;
  margin: 0 30rpx 30rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 5rpx 15rpx rgba(0, 0, 0, 0.05);
}

.info-item {
  display: flex;
  margin-bottom: 16rpx;
  align-items: center;
}

.info-item:last-child {
  margin-bottom: 0;
}

.info-label {
  font-size: 28rpx;
  color: #666;
  width: 150rpx;
}

.info-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #8b4513;
  flex: 1;
}

/* 展厅切换 */
.gallery-switcher {
  margin: 0 30rpx 30rpx;
}

.switcher-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #8b4513;
  margin-bottom: 20rpx;
}

.gallery-list {
  display: flex;
  gap: 20rpx;
  padding-bottom: 10rpx;
}

.gallery-item {
  width: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 5rpx 15rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}

.gallery-item.active {
  transform: translateY(-10rpx);
  box-shadow: 0 10rpx 25rpx rgba(0, 0, 0, 0.15);
}

.gallery-thumb {
  width: 100%;
  height: 120rpx;
  object-fit: cover;
}

.gallery-name {
  padding: 12rpx;
  background: white;
  font-size: 24rpx;
  text-align: center;
  color: #8b4513;
  font-weight: 500;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .panorama-container {
    height: 400rpx;
  }
  
  .gallery-item {
    width: 180rpx;
  }
  
  .gallery-thumb {
    height: 100rpx;
  }
}

/* 加载动画 */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.gallery-container {
  animation: fadeIn 0.5s ease-out;
}

/* 滚动条样式 */
::-webkit-scrollbar {
  height: 4rpx;
}

::-webkit-scrollbar-track {
  background: #f1f1f1;
  border-radius: 2rpx;
}

::-webkit-scrollbar-thumb {
  background: #8b4513;
  border-radius: 2rpx;
}

::-webkit-scrollbar-thumb:hover {
  background: #a0522d;
}