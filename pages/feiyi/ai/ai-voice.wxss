.voice-container {
  padding: 30rpx;
  padding-bottom: 200rpx;
  background: linear-gradient(180deg, #fef9f0 0%, #f5f0e6 100%);
  min-height: 100vh;
}

.header {
  text-align: center;
  margin-bottom: 30rpx;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #8b4513;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #a0522d;
}

.voice-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.voice-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}

.voice-cover {
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  margin-right: 20rpx;
}

.voice-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.voice-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.voice-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.voice-duration {
  background: #f0e6d3;
  color: #8b4513;
  padding: 6rpx 15rpx;
  border-radius: 15rpx;
  font-size: 22rpx;
}

.voice-desc {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.voice-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.play-status {
  font-size: 24rpx;
  color: #8b4513;
}

.voice-views {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 22rpx;
  color: #999;
}

.views-icon {
  font-size: 26rpx;
}

.play-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #8b4513 0%, #d2691e 100%);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-left: 15rpx;
}

.play-btn.playing {
  animation: pulse 1.5s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.7; }
}

.player-bar {
  position: fixed;
  bottom: 30rpx;
  left: 30rpx;
  right: 30rpx;
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.2);
}

.player-cover {
  width: 100rpx;
  height: 100rpx;
  border-radius: 12rpx;
  margin-right: 15rpx;
}

.player-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  margin-right: 15rpx;
}

.player-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 6rpx;
}

.player-desc {
  font-size: 22rpx;
  color: #666;
}

.player-controls {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.control-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #f0e6d3;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.control-btn.main {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #8b4513 0%, #d2691e 100%);
  color: #fff;
  font-size: 36rpx;
}