.guide-container {
  padding: 30rpx;
  background: linear-gradient(180deg, #fef9f0 0%, #f5f0e6 100%);
  min-height: 100vh;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #8b4513;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #a0522d;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #5d4037;
  margin-bottom: 20rpx;
}

.heritage-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.heritage-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  border: 3rpx solid transparent;
}

.heritage-item.active {
  border-color: #8b4513;
  background: #fffaf0;
}

.heritage-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.heritage-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.heritage-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.heritage-category {
  font-size: 24rpx;
  color: #8b4513;
}

.guide-content {
  margin-top: 40rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
}

.content-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #f0e6d3;
}

.content-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #5d4037;
}

.guide-tag {
  background: linear-gradient(135deg, #8b4513 0%, #d2691e 100%);
  color: #fff;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.loading {
  text-align: center;
  padding: 60rpx 0;
  color: #8b4513;
  font-size: 28rpx;
}

.guide-text {
  font-size: 28rpx;
  line-height: 1.8;
  color: #444;
}

.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #8b4513 0%, #a0522d 100%);
  color: #fff;
  padding: 30rpx 20rpx;
  border-radius: 16rpx;
}

.btn-icon {
  font-size: 40rpx;
  margin-bottom: 10rpx;
}