.qa-container {
  padding: 30rpx;
  padding-bottom: 150rpx;
  background: linear-gradient(180deg, #fef9f0 0%, #f5f0e6 100%);
  min-height: 100vh;
}

.header {
  text-align: center;
  margin-bottom: 30rpx;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #8b4513;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #a0522d;
}

.chat-area {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.chat-bubble {
  display: flex;
  gap: 20rpx;
  align-items: flex-start;
}

.chat-bubble.ai {
  flex-direction: row;
}

.chat-bubble.user {
  flex-direction: row-reverse;
}

.avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.ai-avatar {
  background: linear-gradient(135deg, #8b4513 0%, #d2691e 100%);
  color: #fff;
}

.user-avatar {
  background: linear-gradient(135deg, #4a90d9 0%, #67b8de 100%);
  color: #fff;
}

.message {
  background: #fff;
  padding: 20rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
  max-width: 500rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
}

.chat-bubble.user .message {
  background: linear-gradient(135deg, #4a90d9 0%, #67b8de 100%);
  color: #fff;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #5d4037;
  margin-bottom: 20rpx;
}

.faq-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.faq-item {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 20rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.faq-icon {
  font-size: 32rpx;
  margin-right: 15rpx;
}

.faq-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.input-area {
  position: fixed;
  bottom: 30rpx;
  left: 30rpx;
  right: 30rpx;
  display: flex;
  gap: 15rpx;
  background: #fff;
  padding: 15rpx;
  border-radius: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.15);
}

.question-input {
  flex: 1;
  padding: 15rpx 20rpx;
  font-size: 28rpx;
  background: #f5f5f5;
  border-radius: 25rpx;
}

.send-btn {
  background: linear-gradient(135deg, #8b4513 0%, #d2691e 100%);
  color: #fff;
  padding: 15rpx 35rpx;
  border-radius: 25rpx;
  font-size: 28rpx;
  font-weight: bold;
}