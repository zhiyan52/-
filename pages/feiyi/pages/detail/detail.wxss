/* pages/feiyi/pages/detail/detail.wxss */
.detail-container {
  min-height: 100vh;
  background: #f5f0e8;
}

/* 顶部大图 */
.hero-section {
  position: relative;
  height: 500rpx;
}

.image-swiper {
  height: 100%;
}

.hero-image {
  width: 100%;
  height: 100%;
}

.hero-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 40rpx;
  background: linear-gradient(to top, rgba(0,0,0,0.8), transparent);
}

.hero-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 16rpx;
  text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
}

.hero-meta {
  display: flex;
  align-items: center;
}

.meta-tag {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
  font-weight: 500;
}

.grade-national {
  background: #e74c3c;
  color: #fff;
}

.grade-human {
  background: #f39c12;
  color: #fff;
}

.meta-region {
  font-size: 26rpx;
  color: rgba(255,255,255,0.9);
}

.back-btn {
  position: absolute;
  top: 60rpx;
  left: 30rpx;
  width: 64rpx;
  height: 64rpx;
  background: rgba(0,0,0,0.3);
  backdrop-filter: blur(10rpx);
  border-radius: 32rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.back-btn text {
  color: #fff;
  font-size: 32rpx;
}

/* 内容滚动区 */
.content-scroll {
  height: calc(100vh - 500rpx - 100rpx);
}

/* 标签 */
.tags-section {
  display: flex;
  flex-wrap: wrap;
  padding: 20rpx 30rpx;
  gap: 12rpx;
}

.tag {
  font-size: 24rpx;
  color: #8B4513;
  background: rgba(139, 69, 19, 0.1);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

/* 卡片通用 */
.section-card {
  background: #fff;
  margin: 20rpx 30rpx;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05);
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.card-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.card-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.word-count {
  font-size: 24rpx;
  color: #999;
}

.section-text {
  font-size: 30rpx;
  color: #555;
  line-height: 1.8;
  text-align: justify;
}

/* 简介卡片 */
.intro-text {
  font-size: 32rpx;
  color: #444;
  line-height: 1.9;
  text-align: justify;
  margin-bottom: 30rpx;
}

/* 音频区 */
.audio-section {
  background: #f8f5f0;
  border-radius: 16rpx;
  padding: 20rpx;
}

.audio-player-btn {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.play-icon {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.play-icon text {
  color: #fff;
  font-size: 32rpx;
  margin-left: 4rpx;
}

.audio-player-btn.playing .play-icon {
  background: linear-gradient(135deg, #e74c3c 0%, #c0392b 100%);
}

.audio-info {
  flex: 1;
  min-width: 0;
}

.audio-title {
  display: block;
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.audio-desc {
  display: block;
  font-size: 26rpx;
  color: #8B4513;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.audio-duration {
  font-size: 28rpx;
  color: #999;
  font-variant-numeric: tabular-nums;
}

/* 传承人卡片 */
.inheritor-content {
  display: flex;
  background: linear-gradient(135deg, #f9f5f0 0%, #f0ebe3 100%);
  border-radius: 16rpx;
  padding: 24rpx;
}

.inheritor-photo {
  width: 160rpx;
  height: 200rpx;
  border-radius: 12rpx;
  margin-right: 24rpx;
  border: 4rpx solid #fff;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.inheritor-main {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.inheritor-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.inheritor-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-right: 16rpx;
}

.inheritor-badge {
  font-size: 22rpx;
  color: #fff;
  background: #e74c3c;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.inheritor-title {
  font-size: 26rpx;
  color: #8B4513;
  margin-bottom: 16rpx;
}

.inheritor-brief {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  flex: 1;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.inheritor-link {
  margin-top: 16rpx;
  text-align: right;
}

.inheritor-link text {
  font-size: 26rpx;
  color: #8B4513;
}

/* 元信息 */
.meta-section {
  margin: 30rpx;
  padding: 20rpx 30rpx;
  background: #fff;
  border-radius: 16rpx;
}

.meta-row {
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.meta-row:last-child {
  border-bottom: none;
}

.meta-label {
  font-size: 28rpx;
  color: #999;
}

.meta-value {
  font-size: 28rpx;
  color: #555;
}

.meta-value.highlight {
  color: #e74c3c;
  font-weight: 500;
}

/* 底部操作栏 */
.action-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #fff;
  display: flex;
  align-items: center;
  padding: 0 30rpx;
  box-shadow: 0 -4rpx 20rpx rgba(0,0,0,0.08);
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-right: 40rpx;
}

.action-icon {
  font-size: 36rpx;
  color: #666;
  margin-bottom: 4rpx;
}

.action-icon.favorite {
  color: #e74c3c;
}

.action-text {
  font-size: 22rpx;
  color: #666;
}

.action-primary {
  flex: 1;
  height: 72rpx;
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  border-radius: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-primary text {
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
}

.bottom-space {
  height: 140rpx;
}