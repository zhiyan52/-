<!--pages/feiyi/pages/index/index.wxml-->
<view class="container">
  <!-- 头部 -->
  <view class="header">
    <view class="header-content">
      <text class="main-title">非遗匠心</text>
      <text class="sub-title">传承千年技艺，守护文化根脉</text>
      <view class="stats-bar">
        <view class="stat-item">
          <text class="stat-num">{{stats.total}}</text>
          <text class="stat-label">非遗项目</text>
        </view>
        <view class="stat-item">
          <text class="stat-num">{{stats.withAudio}}</text>
          <text class="stat-label">可聆听</text>
        </view>
        <view class="stat-item">
          <text class="stat-num">{{stats.inheritors}}</text>
          <text class="stat-label">传承人</text>
        </view>
      </view>
    </view>
    <view class="header-bg"></view>
  </view>

  <!-- 搜索栏 -->
  <view class="search-section">
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <input 
        class="search-input" 
        placeholder="搜索非遗项目、传承人..." 
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearchConfirm"
        confirm-type="search"
      />
      <view class="search-clear" wx:if="{{searchKeyword}}" bindtap="clearSearch">
        <text>✕</text>
      </view>
    </view>
  </view>

  <!-- 分类导航 -->
  <category-nav 
    categories="{{categories}}" 
    activeId="{{currentCategory}}"
    bind:change="onCategoryChange"
  />

  <!-- 推荐位（仅在全部分类显示） -->
  <view class="recommend-section" wx:if="{{currentCategory === 'all' && !searchKeyword && hotList.length > 0}}">
    <view class="section-header">
      <text class="section-title">🔥 热门推荐</text>
      <text class="section-more" bindtap="viewAllHot">查看全部</text>
    </view>
    <scroll-view class="hot-scroll" scroll-x="true">
      <view 
        class="hot-item" 
        wx:for="{{hotList}}" 
        wx:key="id"
        bindtap="goToDetail"
        data-id="{{item.id}}"
      >
        <image class="hot-image" src="{{item.images.cover}}" mode="aspectFill"/>
        <text class="hot-name">{{item.name}}</text>
      </view>
    </scroll-view>
  </view>

  <!-- 列表内容 -->
  <view class="list-section">
    <view class="list-header">
      <text class="list-title">{{listTitle}}</text>
      <view class="sort-options" wx:if="{{!searchKeyword}}">
        <text 
          class="sort-item {{sortBy === 'sortOrder' ? 'active' : ''}}"
          bindtap="changeSort"
          data-type="sortOrder"
        >推荐</text>
        <text 
          class="sort-item {{sortBy === 'name' ? 'active' : ''}}"
          bindtap="changeSort"
          data-type="name"
        >名称</text>
        <text 
          class="sort-item {{sortBy === 'year' ? 'active' : ''}}"
          bindtap="changeSort"
          data-type="year"
        >年代</text>
      </view>
    </view>

    <!-- 非遗卡片列表 -->
    <view class="card-list">
      <heritage-card 
        wx:for="{{heritageList}}" 
        wx:key="id"
        heritage="{{item}}"
        playingId="{{currentPlayingId}}"
        bind:tap="goToDetail"
        bind:tapInheritor="goToInheritor"
        bind:audioPlay="onAudioPlay"
        bind:audioPause="onAudioPause"
        bind:audioEnd="onAudioEnd"
      />
    </view>

    <!-- 加载状态 -->
    <view class="loading-state" wx:if="{{loading}}">
      <view class="loading-spinner"></view>
      <text>加载中...</text>
    </view>

    <view class="no-more" wx:if="{{!hasMore && heritageList.length > 0}}">
      <text>—— 已经到底了 ——</text>
    </view>

    <view class="empty-state" wx:if="{{!loading && heritageList.length === 0}}">
      <image class="empty-icon" src="cloud://cloud1-8glc9jqob91870fc.636c-cloud1-8glc9jqob91870fc-1401141450/feiyi/5d57897bbb1c3b4426f02150ab4fb7e3.jpg"/>
      <text>暂无相关内容</text>
      <text class="empty-tip">试试其他分类或关键词</text>
    </view>
  </view>

  <!-- 底部间距（为音频播放器留空） -->
  <view class="bottom-space" wx:if="{{showAudioPlayer}}"></view>
</view>

<!-- 全局音频播放器 -->
<audio-player 
  show="{{showAudioPlayer}}"
  bind:change="onAudioChange"
  bind:close="onAudioClose"
  id="globalPlayer"
/>