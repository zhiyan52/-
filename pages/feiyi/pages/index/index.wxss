/* pages/feiyi/pages/index/index.wxss */
.container {
  min-height: 100vh;
  background-color: #f5f2e9;
  background-image: linear-gradient(rgba(245, 242, 233, 0.8), rgba(245, 242, 233, 0.8)), url('data:image/svg+xml,%3Csvg width="40" height="40" viewBox="0 0 40 40" xmlns="http://www.w3.org/2000/svg"%3E%3Cg fill="%23d4af37" fill-opacity="0.05" fill-rule="evenodd"%3E%3Cpath d="M0 38.59l2.83-2.83 1.41 1.41L1.41 40H0v-1.41zM0 1.4l2.83 2.83 1.41-1.41L1.41 0H0v1.41zM38.59 40l-2.83-2.83 1.41-1.41L40 38.59V40h-1.41zM40 1.41l-2.83 2.83-1.41-1.41L38.59 0H40v1.41zM20 18.6l2.83-2.83 1.41 1.41L21.41 20l2.83 2.83-1.41 1.41L20 21.41l-2.83 2.83-1.41-1.41L18.59 20l-2.83-2.83 1.41-1.41L20 18.59z"/%3E%3C/g%3E%3C/svg%3E');
  display: flex;
  flex-direction: column;
}

.header {
  background-color: #2C2621;
  padding: 20px;
  text-align: center;
}

.title {
  font-size: 24px;
  font-weight: bold;
  color: #d4af37;
  font-family: 'STSong', serif;
}

.content {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 20px;
}

.welcome {
  font-size: 18px;
  color: #2C2621;
  margin-bottom: 40px;
  text-align: center;
  font-family: 'STSong', serif;
}

.button-container {
  display: flex;
  justify-content: center;
}

.nav-button {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background-color: #d4af37;
  color: #2C2621;
  padding: 20px;
  border-radius: 12px;
  box-shadow: 0 4px 12px rgba(212, 175, 55, 0.3);
  transition: transform 0.3s ease;
  cursor: pointer;
  min-width: 200px;
}

.nav-button:active {
  transform: scale(0.95);
}

.button-icon {
  font-size: 48px;
  margin-bottom: 12px;
}

.button-text {
  font-size: 16px;
  font-weight: bold;
  text-align: center;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .title {
    font-size: 20px;
  }
  
  .welcome {
    font-size: 16px;
  }
  
  .nav-button {
    padding: 15px;
    min-width: 160px;
  }
  
  .button-icon {
    font-size: 36px;
  }
  
  .button-text {
    font-size: 14px;
  }
}
