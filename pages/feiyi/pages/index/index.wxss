/* pages/feiyi/pages/index/index.wxss */
.container {
  min-height: 100vh;
  background: #f5f0e8;
  padding-bottom: 40rpx;
}

/* 头部 */
.header {
  position: relative;
  padding: 60rpx 40rpx 40rpx;
  overflow: hidden;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 50%, #CD853F 100%);
  z-index: 0;
}

.header-bg::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.05'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
}

.header-content {
  position: relative;
  z-index: 1;
}

.main-title {
  display: block;
  font-size: 56rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 8rpx;
  text-shadow: 2px 2px 4px rgba(0,0,0,0.2);
  margin-bottom: 16rpx;
}

.sub-title {
  display: block;
  font-size: 28rpx;
  color: rgba(255,255,255,0.9);
  letter-spacing: 4rpx;
  margin-bottom: 30rpx;
}

/* 统计栏 */
.stats-bar {
  display: flex;
  background: rgba(255,255,255,0.15);
  backdrop-filter: blur(10rpx);
  border-radius: 16rpx;
  padding: 20rpx 0;
  margin-top: 20rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
  border-right: 1rpx solid rgba(255,255,255,0.2);
}

.stat-item:last-child {
  border-right: none;
}

.stat-num {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
}

/* 搜索栏 */
.search-section {
  padding: 20rpx 30rpx;
  background: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.05);
}

.search-box {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 40rpx;
  padding: 16rpx 30rpx;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 16rpx;
  color: #999;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.search-clear {
  width: 40rpx;
  height: 40rpx;
  background: #ddd;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.search-clear text {
  font-size: 24rpx;
  color: #fff;
}

/* 推荐位 */
.recommend-section {
  background: #fff;
  padding: 30rpx 0;
  margin-bottom: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.section-more {
  font-size: 26rpx;
  color: #8B4513;
}

.hot-scroll {
  white-space: nowrap;
  padding: 0 20rpx;
}

.hot-item {
  display: inline-block;
  width: 240rpx;
  margin-right: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
  position: relative;
}

.hot-image {
  width: 240rpx;
  height: 320rpx;
  display: block;
}

.hot-name {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.7), transparent);
  color: #fff;
  font-size: 28rpx;
  padding: 40rpx 16rpx 16rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 列表区 */
.list-section {
  padding: 20rpx 30rpx;
}

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.list-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.sort-options {
  display: flex;
  background: #fff;
  border-radius: 30rpx;
  padding: 6rpx;
}

.sort-item {
  font-size: 24rpx;
  color: #666;
  padding: 10rpx 20rpx;
  border-radius: 24rpx;
  transition: all 0.3s;
}

.sort-item.active {
  background: #8B4513;
  color: #fff;
}

.card-list {
  min-height: 400rpx;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}

.loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #8B4513;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 16rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.no-more {
  text-align: center;
  padding: 40rpx;
  color: #999;
  font-size: 26rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  opacity: 0.5;
  margin-bottom: 30rpx;
}

.empty-state text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.empty-tip {
  font-size: 24rpx !important;
  color: #bbb !important;
}

/* 底部空间 */
.bottom-space {
  height: 180rpx;
}