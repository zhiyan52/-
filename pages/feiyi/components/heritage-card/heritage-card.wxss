/* components/heritage-card/heritage-card.wxss */
.heritage-card {
  position: relative;
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
}

.heritage-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

/* 热度标识 */
.hot-badge {
  position: absolute;
  top: 0;
  right: 0;
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a5a 100%);
  padding: 8rpx 20rpx;
  border-bottom-left-radius: 20rpx;
  z-index: 10;
}

.hot-text {
  color: #fff;
  font-size: 20rpx;
  font-weight: bold;
  letter-spacing: 2rpx;
}

/* 音频标识 */
.audio-badge {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  width: 60rpx;
  height: 60rpx;
  background: rgba(139, 69, 19, 0.9);
  border-radius: 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
  backdrop-filter: blur(4rpx);
}

.audio-icon {
  font-size: 28rpx;
}

/* 图片区 */
.image-wrapper {
  position: relative;
  width: 100%;
  height: 320rpx;
  overflow: hidden;
}

.heritage-image {
  width: 100%;
  height: 100%;
  transition: transform 0.5s ease;
}

.heritage-card:active .heritage-image {
  transform: scale(1.05);
}

.image-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: linear-gradient(to top, rgba(0,0,0,0.3), transparent);
  pointer-events: none;
}

/* 内容区 */
.card-content {
  padding: 30rpx;
}

.title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.heritage-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.category-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
  margin-left: 16rpx;
  flex-shrink: 0;
}

.heritage-brief {
  display: block;
  font-size: 28rpx;
  color: #666;
  line-height: 1.7;
  margin-bottom: 24rpx;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-align: justify;
}

/* 底部栏 */
.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx dashed #e8e8e8;
}

.inheritor-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.inheritor-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 24rpx;
  margin-right: 12rpx;
  border: 2rpx solid #f0e6d2;
}

.inheritor-name {
  font-size: 26rpx;
  color: #555;
  margin-right: 8rpx;
  max-width: 140rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.inheritor-level {
  font-size: 20rpx;
  color: #8B4513;
  background: rgba(139, 69, 19, 0.1);
  padding: 4rpx 10rpx;
  border-radius: 8rpx;
}

/* 音频按钮 */
.audio-btn {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  padding: 12rpx 24rpx;
  border-radius: 30rpx;
  transition: all 0.3s ease;
}

.audio-btn.playing {
  background: linear-gradient(135deg, #ff6b6b 0%, #ee5a5a 100%);
  padding: 12rpx 20rpx;
}

.audio-icon-static {
  color: #fff;
  font-size: 24rpx;
  margin-right: 8rpx;
}

.audio-text {
  color: #fff;
  font-size: 24rpx;
}

/* 音频波形动画 */
.audio-wave {
  display: flex;
  align-items: center;
  height: 30rpx;
  margin-right: 10rpx;
}

.wave-bar {
  width: 4rpx;
  background: #fff;
  margin: 0 3rpx;
  border-radius: 2rpx;
  animation: wave 0.5s ease-in-out infinite;
}

.wave-bar:nth-child(1) {
  height: 12rpx;
  animation-delay: 0s;
}

.wave-bar:nth-child(2) {
  height: 20rpx;
  animation-delay: 0.1s;
}

.wave-bar:nth-child(3) {
  height: 16rpx;
  animation-delay: 0.2s;
}

@keyframes wave {
  0%, 100% { transform: scaleY(1); }
  50% { transform: scaleY(1.5); }
}

/* 进度条 */
.progress-bar {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 0 30rpx 20rpx;
}