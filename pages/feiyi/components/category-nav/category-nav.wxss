/* components/category-nav/category-nav.wxss */
.category-scroll {
  white-space: nowrap;
  background: #fff;
  padding: 20rpx 0;
}

.category-list {
  display: inline-flex;
  padding: 0 20rpx;
}

.category-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 30rpx;
  margin-right: 16rpx;
  border-radius: 20rpx;
  background: #f8f8f8;
  transition: all 0.3s ease;
  min-width: 140rpx;
  position: relative;
}

.category-item:last-child {
  margin-right: 40rpx;
}

.category-item.active {
  background: linear-gradient(135deg, var(--active-color, #8B4513) 0%, rgba(139,69,19,0.8) 100%);
  transform: scale(1.05);
  box-shadow: 0 4rpx 16rpx rgba(139, 69, 19, 0.3);
}

.icon-wrapper {
  position: relative;
  margin-bottom: 12rpx;
}

.category-icon {
  font-size: 48rpx;
  transition: transform 0.3s ease;
}

.category-item.active .category-icon {
  transform: scale(1.1);
}

.active-indicator {
  position: absolute;
  bottom: -8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 8rpx;
  height: 8rpx;
  background: #fff;
  border-radius: 4rpx;
}

.category-name {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
  transition: all 0.3s ease;
}

.category-item.active .category-name {
  color: #fff;
  font-weight: bold;
}

.category-desc {
  font-size: 20rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 8rpx;
  max-width: 200rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}