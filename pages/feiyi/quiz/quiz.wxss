.quiz-container {
  padding: 30rpx;
  background: linear-gradient(180deg, #fef9f0 0%, #f5f0e6 100%);
  min-height: 100vh;
}

.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding: 20rpx 30rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}

.score-info {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.score-label {
  font-size: 26rpx;
  color: #666;
}

.score-num {
  font-size: 36rpx;
  font-weight: bold;
  color: #8b4513;
}

.streak-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #ff8e53 100%);
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
}

.streak-icon {
  font-size: 28rpx;
}

.streak-num {
  font-size: 24rpx;
  color: #fff;
}

.quiz-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.1);
  margin-bottom: 30rpx;
}

.quiz-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.question-num {
  font-size: 28rpx;
  color: #8b4513;
  font-weight: bold;
}

.timer {
  background: linear-gradient(135deg, #8b4513 0%, #d2691e 100%);
  color: #fff;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 26rpx;
  font-weight: bold;
}

.question-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.6;
  margin-bottom: 40rpx;
}

.options-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.option-item {
  display: flex;
  align-items: center;
  padding: 25rpx 20rpx;
  background: #f8f5f0;
  border-radius: 16rpx;
  border: 3rpx solid transparent;
  transition: all 0.3s;
}

.option-item.selected {
  border-color: #8b4513;
  background: #fffaf0;
}

.option-item.correct {
  border-color: #4caf50;
  background: #e8f5e9;
}

.option-item.wrong {
  border-color: #f44336;
  background: #ffebee;
}

.option-letter {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background: #8b4513;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: bold;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.option-item.correct .option-letter {
  background: #4caf50;
}

.option-item.wrong .option-letter {
  background: #f44336;
}

.option-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.option-icon {
  font-size: 32rpx;
  margin-left: 15rpx;
}

.answer-explain {
  margin-top: 30rpx;
  padding: 25rpx;
  background: #f0e6d3;
  border-radius: 16rpx;
  border-left: 6rpx solid #8b4513;
}

.explain-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #8b4513;
  margin-bottom: 10rpx;
}

.explain-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.action-btn {
  margin-top: 40rpx;
  padding: 30rpx;
  background: linear-gradient(135deg, #8b4513 0%, #d2691e 100%);
  color: #fff;
  border-radius: 20rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 6rpx 16rpx rgba(139,69,19,0.3);
}

.result-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 50rpx 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.1);
  margin-bottom: 30rpx;
}

.result-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.result-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  display: block;
}

.result-score {
  display: flex;
  align-items: baseline;
  justify-content: center;
}

.score-big {
  font-size: 80rpx;
  font-weight: bold;
  color: #8b4513;
}

.score-small {
  font-size: 40rpx;
  color: #999;
  margin-left: 10rpx;
}

.result-stats {
  display: flex;
  justify-content: space-around;
  padding: 30rpx 0;
  border-top: 2rpx solid #f0e6d3;
  border-bottom: 2rpx solid #f0e6d3;
  margin-bottom: 30rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.stat-icon {
  font-size: 36rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.stat-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.reward-section {
  margin-bottom: 40rpx;
}

.reward-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  text-align: center;
}

.reward-items {
  display: flex;
  justify-content: center;
  gap: 40rpx;
}

.reward-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 15rpx 25rpx;
  background: linear-gradient(135deg, #fff9e6 0%, #ffe4b3 100%);
  border-radius: 20rpx;
}

.reward-icon {
  font-size: 32rpx;
}

.reward-value {
  font-size: 26rpx;
  font-weight: bold;
  color: #f57c00;
}

.result-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn.secondary {
  flex: 1;
  background: #f0e6d3;
  color: #8b4513;
  box-shadow: none;
}

.action-btn.primary {
  flex: 1;
}

.leaderboard-entry {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 25rpx 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}

.entry-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
}

.entry-text {
  flex: 1;
}

.entry-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 6rpx;
}

.entry-desc {
  font-size: 24rpx;
  color: #999;
}

.entry-arrow {
  font-size: 28rpx;
  color: #8b4513;
}