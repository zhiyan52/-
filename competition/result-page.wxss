.result-container {
  padding: 40rpx 30rpx;
  background: linear-gradient(180deg, #fff9e6 0%, #fff3cc 100%);
  min-height: 100vh;
}

.result-header {
  text-align: center;
  margin-bottom: 50rpx;
  padding-top: 40rpx;
}

.result-icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
}

.result-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
}

.stats-section {
  display: flex;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.stat-card {
  flex: 1;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx 20rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #667eea;
  display: block;
  margin-bottom: 10rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #999;
}

.score-section {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  text-align: center;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
}

.score-title {
  font-size: 28rpx;
  color: rgba(255,255,255,0.9);
  margin-bottom: 20rpx;
}

.score-number {
  margin-bottom: 30rpx;
}

.score-value {
  font-size: 72rpx;
  font-weight: bold;
  color: #fff;
}

.score-detail {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
  padding-top: 25rpx;
  border-top: 1rpx solid rgba(255,255,255,0.2);
}

.detail-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.detail-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
}

.detail-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #fff;
}

.daily-bonus {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 15rpx;
  background: linear-gradient(135deg, #ffd700 0%, #ffec8b 100%);
  border-radius: 20rpx;
  padding: 25rpx 30rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 215, 0, 0.3);
}

.bonus-icon {
  font-size: 36rpx;
}

.bonus-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #8b6914;
}

.share-section {
  text-align: center;
  margin-bottom: 40rpx;
}

.share-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: #fff;
  color: #667eea;
  padding: 25rpx 60rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
}

.share-icon {
  font-size: 32rpx;
}

.action-section {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  text-align: center;
  padding: 30rpx;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: bold;
}

.action-btn.secondary {
  background: #fff;
  color: #666;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.action-btn.primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.4);
}