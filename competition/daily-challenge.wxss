.daily-challenge-container {
  padding: 30rpx;
  background: linear-gradient(180deg, #fff9e6 0%, #fff3cc 100%);
  min-height: 100vh;
}

.countdown-section {
  background: linear-gradient(135deg, #ff6b6b 0%, #ff8e53 100%);
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  text-align: center;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.3);
}

.countdown-title {
  font-size: 28rpx;
  color: rgba(255,255,255,0.9);
  margin-bottom: 20rpx;
}

.countdown-timer {
  display: flex;
  align-items: baseline;
  justify-content: center;
}

.time-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.time-item text:first-child {
  font-size: 60rpx;
  font-weight: bold;
  color: #fff;
}

.time-unit {
  font-size: 22rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 5rpx;
}

.time-separator {
  font-size: 50rpx;
  font-weight: bold;
  color: #fff;
  margin: 0 15rpx;
}

.rules-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
}

.rules-header {
  margin-bottom: 25rpx;
}

.rules-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.rules-content {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.rule-item {
  display: flex;
  align-items: flex-start;
  gap: 15rpx;
}

.rule-num {
  width: 45rpx;
  height: 45rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ff6b6b 0%, #ff8e53 100%);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: bold;
  flex-shrink: 0;
}

.rule-text {
  flex: 1;
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.reward-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
}

.reward-header {
  margin-bottom: 25rpx;
}

.reward-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.reward-items {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.reward-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: linear-gradient(135deg, #fff9e6 0%, #fff3cc 100%);
  border-radius: 16rpx;
}

.reward-icon {
  font-size: 50rpx;
  margin-right: 20rpx;
}

.reward-info {
  flex: 1;
}

.reward-value {
  font-size: 28rpx;
  font-weight: bold;
  color: #ff6b6b;
  margin-bottom: 5rpx;
}

.reward-label {
  font-size: 22rpx;
  color: #999;
}

.start-section {
  text-align: center;
}

.start-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 15rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #ff8e53 100%);
  color: #fff;
  padding: 35rpx 80rpx;
  border-radius: 50rpx;
  font-size: 36rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 24rpx rgba(255, 107, 107, 0.4);
  margin-bottom: 25rpx;
}

.start-icon {
  font-size: 40rpx;
}

.start-text {
  font-size: 32rpx;
}

.challenge-history {
  font-size: 24rpx;
  color: #666;
  text-decoration: underline;
}