.quiz-container {
  padding: 30rpx;
  background: linear-gradient(180deg, #f8f9fa 0%, #e9ecef 100%);
  min-height: 100vh;
}

.quiz-header {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.progress-bar {
  flex: 1;
  height: 12rpx;
  background: #e0e0e0;
  border-radius: 6rpx;
  overflow: hidden;
  margin-right: 20rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #667eea 0%, #764ba2 100%);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.progress-text {
  font-size: 26rpx;
  color: #666;
  margin-right: 20rpx;
}

.progress-text text:first-child {
  font-weight: bold;
  color: #667eea;
}

.timer {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 20rpx;
  background: #fff;
  border-radius: 25rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
}

.timer-icon {
  font-size: 26rpx;
}

.timer-text {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
}

.timer-text.warning {
  color: #ff6b6b;
  animation: pulse 0.5s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.battle-score {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #fff;
  border-radius: 20rpx;
  padding: 25rpx 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
}

.score-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.score-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-bottom: 10rpx;
  border: 3rpx solid #667eea;
}

.score-name {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 5rpx;
}

.score-num {
  font-size: 32rpx;
  font-weight: bold;
  color: #667eea;
}

.score-vs {
  font-size: 28rpx;
  font-weight: bold;
  color: #999;
  padding: 0 20rpx;
}

.question-section {
  background: #fff;
  border-radius: 24rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
}

.question-tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 20rpx;
  font-size: 22rpx;
  margin-bottom: 20rpx;
}

.question-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.6;
}

.options-section {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
  margin-bottom: 30rpx;
}

.option-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 25rpx 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
  border: 3rpx solid transparent;
  transition: all 0.2s ease;
}

.option-item:active {
  transform: scale(0.98);
}

.option-item.selected {
  border-color: #667eea;
  background: linear-gradient(135deg, #f3e5f5 0%, #e8eaf6 100%);
}

.option-item.correct {
  border-color: #4caf50;
  background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
}

.option-item.wrong {
  border-color: #f44336;
  background: linear-gradient(135deg, #ffebee 0%, #ffcdd2 100%);
}

.option-letter {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: bold;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.option-item.correct .option-letter {
  background: linear-gradient(135deg, #4caf50 0%, #66bb6a 100%);
}

.option-item.wrong .option-letter {
  background: linear-gradient(135deg, #f44336 0%, #ef5350 100%);
}

.option-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
}

.option-icon {
  font-size: 32rpx;
  margin-left: 15rpx;
}

.explain-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
}

.explain-header {
  margin-bottom: 15rpx;
}

.explain-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.explain-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.action-section {
  text-align: center;
}

.action-btn {
  display: inline-block;
  padding: 30rpx 100rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-radius: 50rpx;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 24rpx rgba(102, 126, 234, 0.4);
}

.result-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}