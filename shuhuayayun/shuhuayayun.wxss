/* shuhuayayun/shuhuayayun.wxss */

.container {
  background-color: #F5F2E9;
  min-height: 100vh;
  padding: 30rpx;
  font-family: '楷体', 'STKaiti', serif;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
  padding: 40rpx 0;
  background: linear-gradient(135deg, #F5F2E9 0%, #E8E4D8 100%);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
  border: 1rpx solid #D7D3C8;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  text-shadow: 2rpx 2rpx 4rpx rgba(0,0,0,0.1);
}

.subtitle {
  font-size: 28rpx;
  color: #666;
  letter-spacing: 4rpx;
}

.function-section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 32rpx;
  text-align: center;
  position: relative;
}

.section-title::after {
  content: '';
  position: absolute;
  bottom: -10rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 120rpx;
  height: 4rpx;
  background: linear-gradient(90deg, transparent, #8B4513, transparent);
  border-radius: 2rpx;
}

.function-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 30rpx;
}

.function-card {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 20rpx;
  text-align: center;
  box-shadow: 0 6rpx 24rpx rgba(0,0,0,0.08);
  border: 1rpx solid #E8E4D8;
  transition: all 0.3s ease;
  background: linear-gradient(135deg, #FFF9E6 0%, #FFF5D6 100%);
}

.function-card:hover {
  transform: translateY(-8rpx);
  box-shadow: 0 12rpx 32rpx rgba(0,0,0,0.12);
}

.card-image {
  width: 100%;
  height: 200rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  object-fit: cover;
  border: 1rpx solid #E8E4D8;
}

.card-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
  font-family: '楷体', 'STKaiti', serif;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .function-grid {
    grid-template-columns: 1fr;
  }
  
  .header {
    margin-bottom: 40rpx;
    padding: 30rpx 0;
  }
  
  .title {
    font-size: 40rpx;
  }
  
  .subtitle {
    font-size: 24rpx;
  }
  
  .function-card {
    padding: 16rpx;
  }
  
  .card-image {
    height: 180rpx;
  }
  
  .card-title {
    font-size: 26rpx;
  }
}