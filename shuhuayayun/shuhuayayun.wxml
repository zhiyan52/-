<!-- shuhuayayun/shuhuayayun.wxml -->
<view class="container">
  <view class="header">
    <view class="title">书画雅韵</view>
    <view class="subtitle">中国书法 · 国画艺术</view>
  </view>
  
  <view class="function-section">
    <view class="section-title">精彩功能</view>
    <view class="function-grid">
      <!-- 书画名家图鉴 -->
      <view class="function-card" bindtap="navigateToMasters">
        <image class="card-image" src="cloud://cloud1-8glc9jqob91870fc.636c-cloud1-8glc9jqob91870fc-1401141450/shuhua/master.png" mode="aspectFill"/>
        <view class="card-title">知识图鉴</view>
      </view>
      <!-- 传世书画赏析 -->
      <view class="function-card" bindtap="navigateToWorks">
        <image class="card-image" src="cloud://cloud1-8glc9jqob91870fc.636c-cloud1-8glc9jqob91870fc-1401141450/shuhua/works.png" mode="aspectFill"/>
        <view class="card-title">时间轴</view>
      </view>
      <!-- AI智能讲解 -->
      <view class="function-card" bindtap="navigateToAiExplain">
        <image class="card-image" src="cloud://cloud1-8glc9jqob91870fc.636c-cloud1-8glc9jqob91870fc-1401141450/shuhua/ai-explain.png" mode="aspectFill"/>
        <view class="card-title">fa</view>
      </view>
      <!-- AI意境生图 -->
      <view class="function-card" bindtap="navigateToAiGenerate">
        <image class="card-image" src="cloud://cloud1-8glc9jqob91870fc.636c-cloud1-8glc9jqob91870fc-1401141450/shuhua/ai-generate.png" mode="aspectFill"/>
        <view class="card-title">传统音乐</view>
      </view>
    </view>
  </view>
</view>