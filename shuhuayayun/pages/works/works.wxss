/* shuhuayayun/pages/works/works.wxss */

.container {
  background-color: #F5F2E9;
  min-height: 100vh;
  padding: 30rpx;
  font-family: '楷体', 'STKaiti', serif;
}

.tab-container {
  display: flex;
  background-color: #FFFFFF;
  border-radius: 12rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  border: 1rpx solid #E8E4D8;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 32rpx;
  color: #666;
  transition: all 0.3s ease;
  border-radius: 12rpx;
}

.tab-item.active {
  background-color: #8B4513;
  color: #FFFFFF;
  font-weight: bold;
}

.work-list {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.work-card {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 6rpx 24rpx rgba(0,0,0,0.08);
  border: 1rpx solid #E8E4D8;
  transition: all 0.3s ease;
}

.work-card:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 12rpx 32rpx rgba(0,0,0,0.12);
}

.work-image {
  width: 100%;
  height: 300rpx;
  overflow: hidden;
  background-color: #F5F2E9;
}

.work-image image {
  width: 100%;
  height: 100%;
  transition: transform 0.3s ease;
}

.work-card:hover .work-image image {
  transform: scale(1.05);
}

.work-info {
  padding: 30rpx;
}

.work-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #E8E4D8;
}

.work-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.work-year {
  font-size: 28rpx;
  color: #8B4513;
  background-color: #F5F2E9;
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
}

.work-author {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.work-background {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.work-features {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.work-status {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .container {
    padding: 20rpx;
  }
  
  .tab-item {
    font-size: 28rpx;
    padding: 20rpx 0;
  }
  
  .work-image {
    height: 240rpx;
  }
  
  .work-info {
    padding: 24rpx;
  }
  
  .work-name {
    font-size: 32rpx;
  }
  
  .work-year {
    font-size: 24rpx;
  }
  
  .work-author,
  .work-background,
  .work-features,
  .work-status {
    font-size: 24rpx;
  }
}