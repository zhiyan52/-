/* shuhuayayun/pages/blind-box/blind-box.wxss */

.container {
  background-color: #F5F2E9;
  min-height: 100vh;
  padding: 30rpx;
  font-family: '楷体', 'STKaiti', serif;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
  padding: 30rpx 0;
  background: linear-gradient(135deg, #F5F2E9 0%, #E8E4D8 100%);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
  border: 1rpx solid #D7D3C8;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #666;
}

.box-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.blind-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.15);
  border: 1rpx solid #D7D3C8;
  margin-bottom: 40rpx;
  width: 90%;
  max-width: 500rpx;
}

.box-image {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
  animation: shake 2s infinite;
}

.box-image image {
  width: 100%;
  height: 100%;
}

.box-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #8B4513;
  margin-bottom: 16rpx;
  text-align: center;
}

.box-hint {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
  text-align: center;
}

.button-section {
  text-align: center;
  margin-bottom: 40rpx;
}

.open-btn,
.again-btn {
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: bold;
  padding: 24rpx 0;
  border-radius: 24rpx;
  border: none;
  width: 80%;
  font-family: '楷体', 'STKaiti', serif;
  box-shadow: 0 6rpx 24rpx rgba(139, 69, 19, 0.3);
  transition: all 0.3s ease;
}

.open-btn:hover,
.again-btn:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 8rpx 32rpx rgba(139, 69, 19, 0.4);
}

.open-btn:disabled {
  background: #D7D3C8;
  color: #999;
  box-shadow: none;
}

.result-section {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.result-item {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 6rpx 24rpx rgba(0,0,0,0.08);
  border: 1rpx solid #D7D3C8;
}

.item-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #8B4513;
  margin-bottom: 20rpx;
  padding-bottom: 12rpx;
  border-bottom: 1rpx solid #E8E4D8;
}

.work-container {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.work-container image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  border: 1rpx solid #E8E4D8;
}

.work-info {
  flex: 1;
}

.work-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.work-author {
  font-size: 24rpx;
  color: #666;
}

.quote-container {
  background-color: #F5F2E9;
  padding: 24rpx;
  border-radius: 16rpx;
  border: 1rpx solid #E8E4D8;
}

.quote-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  text-align: center;
  font-style: italic;
}

.fact-container,
.technique-container {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  text-align: justify;
}

@keyframes shake {
  0%, 100% {
    transform: rotate(0deg);
  }
  25% {
    transform: rotate(2deg);
  }
  75% {
    transform: rotate(-2deg);
  }
}

/* 响应式设计 */
@media (max-width: 375px) {
  .container {
    padding: 20rpx;
  }
  
  .blind-box {
    width: 95%;
    padding: 30rpx;
  }
  
  .box-image {
    width: 160rpx;
    height: 160rpx;
  }
  
  .box-text {
    font-size: 32rpx;
  }
  
  .box-hint {
    font-size: 22rpx;
  }
  
  .open-btn,
  .again-btn {
    width: 90%;
    font-size: 28rpx;
    padding: 20rpx 0;
  }
  
  .result-item {
    padding: 24rpx;
  }
  
  .item-title {
    font-size: 28rpx;
  }
  
  .work-container image {
    width: 100rpx;
    height: 100rpx;
  }
  
  .work-name {
    font-size: 26rpx;
  }
  
  .work-author {
    font-size: 22rpx;
  }
  
  .quote-text {
    font-size: 26rpx;
  }
  
  .fact-container,
  .technique-container {
    font-size: 24rpx;
  }
}