/* shuhuayayun/pages/calligraphy/calligraphy.wxss */

.container {
  background-color: #F5F2E9;
  min-height: 100vh;
  padding: 30rpx;
  font-family: '楷体', 'STKaiti', serif;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
  padding: 30rpx 0;
  background: linear-gradient(135deg, #F5F2E9 0%, #E8E4D8 100%);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
  border: 1rpx solid #D7D3C8;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #666;
}

.script-selector {
  display: flex;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  border: 1rpx solid #E8E4D8;
  overflow: hidden;
}

.script-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 32rpx;
  color: #666;
  transition: all 0.3s ease;
  border-radius: 16rpx;
}

.script-item.active {
  background-color: #8B4513;
  color: #FFFFFF;
  font-weight: bold;
}

.script-detail {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 6rpx 24rpx rgba(0,0,0,0.08);
  border: 1rpx solid #E8E4D8;
  overflow: hidden;
}

.detail-header {
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  padding: 24rpx;
  text-align: center;
}

.script-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.detail-content {
  padding: 30rpx;
}

.script-image {
  width: 100%;
  height: 300rpx;
  overflow: hidden;
  border-radius: 12rpx;
  margin-bottom: 30rpx;
  background-color: #F5F2E9;
}

.script-image image {
  width: 100%;
  height: 100%;
  transition: transform 0.3s ease;
}

.script-image:hover image {
  transform: scale(1.05);
}

.detail-section {
  margin-bottom: 30rpx;
  padding-bottom: 30rpx;
  border-bottom: 1rpx solid #E8E4D8;
}

.detail-section:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #8B4513;
  margin-bottom: 16rpx;
  position: relative;
  padding-left: 20rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 8rpx;
  height: 24rpx;
  background-color: #8B4513;
  border-radius: 4rpx;
}

.section-content {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.content-item {
  margin-bottom: 16rpx;
  display: flex;
  align-items: flex-start;
}

.item-label {
  font-weight: bold;
  color: #333;
  margin-right: 12rpx;
  min-width: 80rpx;
}

.item-text {
  flex: 1;
  text-align: justify;
}

.representative-item {
  margin-bottom: 20rpx;
}

.representative-item:last-child {
  margin-bottom: 0;
}

.rep-name {
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.rep-works {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.work-tag {
  background-color: #F5F2E9;
  color: #8B4513;
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  border: 1rpx solid #E8E4D8;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .container {
    padding: 20rpx;
  }
  
  .script-item {
    font-size: 28rpx;
    padding: 20rpx 0;
  }
  
  .detail-content {
    padding: 24rpx;
  }
  
  .script-image {
    height: 240rpx;
  }
  
  .script-name {
    font-size: 32rpx;
  }
  
  .section-title {
    font-size: 28rpx;
  }
  
  .section-content {
    font-size: 24rpx;
  }
  
  .work-tag {
    font-size: 22rpx;
    padding: 6rpx 12rpx;
  }
}