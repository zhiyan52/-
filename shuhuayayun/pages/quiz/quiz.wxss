/* shuhuayayun/pages/quiz/quiz.wxss */

.container {
  background-color: #F5F2E9;
  min-height: 100vh;
  padding: 30rpx;
  font-family: '楷体', 'STKaiti', serif;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
  padding: 30rpx 0;
  background: linear-gradient(135deg, #F5F2E9 0%, #E8E4D8 100%);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
  border: 1rpx solid #D7D3C8;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #666;
}

.quiz-section {
  margin-bottom: 40rpx;
}

.question-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding: 20rpx;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  border: 1rpx solid #E8E4D8;
}

.question-number {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.score-info {
  font-size: 28rpx;
  color: #8B4513;
}

.question-card {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 6rpx 24rpx rgba(0,0,0,0.08);
  border: 1rpx solid #E8E4D8;
  margin-bottom: 30rpx;
}

.question-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.6;
  margin-bottom: 30rpx;
  text-align: center;
}

.options-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.option-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background-color: #F5F2E9;
  border-radius: 16rpx;
  border: 2rpx solid #E8E4D8;
  transition: all 0.3s ease;
  cursor: pointer;
}

.option-item:hover {
  background-color: #E8E4D8;
  transform: translateY(-2rpx);
}

.option-item.selected {
  background-color: #8B4513;
  border-color: #8B4513;
  color: #FFFFFF;
}

.option-letter {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #FFFFFF;
  color: #8B4513;
  border-radius: 50%;
  font-size: 28rpx;
  font-weight: bold;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.option-item.selected .option-letter {
  background-color: #FFFFFF;
  color: #8B4513;
}

.option-text {
  flex: 1;
  font-size: 28rpx;
  line-height: 1.5;
}

.result-display {
  margin-top: 30rpx;
  padding: 30rpx;
  background-color: #F5F2E9;
  border-radius: 16rpx;
  text-align: center;
  border: 1rpx solid #E8E4D8;
}

.result-icon {
  font-size: 64rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.result-icon.correct {
  color: #4CAF50;
}

.result-icon.wrong {
  color: #F44336;
}

.result-text {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 16rpx;
  color: #333;
}

.correct-answer {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
}

.button-section {
  text-align: center;
}

.submit-btn,
.next-btn {
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: bold;
  padding: 24rpx 0;
  border-radius: 24rpx;
  border: none;
  width: 80%;
  font-family: '楷体', 'STKaiti', serif;
  box-shadow: 0 6rpx 24rpx rgba(139, 69, 19, 0.3);
  transition: all 0.3s ease;
}

.submit-btn:hover,
.next-btn:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 8rpx 32rpx rgba(139, 69, 19, 0.4);
}

.submit-btn:disabled {
  background: #D7D3C8;
  color: #999;
  box-shadow: none;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .container {
    padding: 20rpx;
  }
  
  .question-card {
    padding: 24rpx;
  }
  
  .question-text {
    font-size: 28rpx;
  }
  
  .option-item {
    padding: 20rpx;
  }
  
  .option-text {
    font-size: 26rpx;
  }
  
  .submit-btn,
  .next-btn {
    width: 90%;
    font-size: 28rpx;
    padding: 20rpx 0;
  }
  
  .result-text {
    font-size: 28rpx;
  }
  
  .correct-answer {
    font-size: 24rpx;
  }
}