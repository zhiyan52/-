/* shuhuayayun/pages/ai-explain/ai-explain.wxss */

.container {
  background-color: #F5F2E9;
  min-height: 100vh;
  padding: 30rpx;
  font-family: '楷体', 'STKaiti', serif;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
  padding: 30rpx 0;
  background: linear-gradient(135deg, #F5F2E9 0%, #E8E4D8 100%);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
  border: 1rpx solid #D7D3C8;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #666;
}

.work-section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  text-align: center;
  position: relative;
}

.section-title::after {
  content: '';
  position: absolute;
  bottom: -8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 100rpx;
  height: 3rpx;
  background: linear-gradient(90deg, transparent, #8B4513, transparent);
  border-radius: 2rpx;
}

.work-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.work-item {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  border: 1rpx solid #E8E4D8;
  transition: all 0.3s ease;
}

.work-item:hover {
  transform: translateY(-4rpx);
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.12);
}

.work-item.selected {
  background-color: #8B4513;
  border-color: #8B4513;
  color: #FFFFFF;
}

.work-name {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.work-author {
  font-size: 24rpx;
  color: #666;
}

.work-item.selected .work-author {
  color: rgba(255,255,255,0.9);
}

.button-section {
  margin-bottom: 40rpx;
  text-align: center;
}

.generate-btn {
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: bold;
  padding: 24rpx 0;
  border-radius: 24rpx;
  border: none;
  width: 80%;
  font-family: '楷体', 'STKaiti', serif;
  box-shadow: 0 6rpx 24rpx rgba(139, 69, 19, 0.3);
  transition: all 0.3s ease;
}

.generate-btn:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 8rpx 32rpx rgba(139, 69, 19, 0.4);
}

.generate-btn:disabled {
  background: #D7D3C8;
  color: #999;
  box-shadow: none;
}

.explanation-section {
  margin-bottom: 40rpx;
}

.explanation-card {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 6rpx 24rpx rgba(0,0,0,0.08);
  border: 1rpx solid #E8E4D8;
}

.explanation-item {
  margin-bottom: 30rpx;
  padding-bottom: 30rpx;
  border-bottom: 1rpx solid #E8E4D8;
}

.explanation-item:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.item-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #8B4513;
  margin-bottom: 16rpx;
}

.item-content {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  text-align: justify;
}

.error-section {
  margin-top: 20rpx;
}

.error-message {
  background-color: #FFF0F0;
  color: #FF4D4F;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  text-align: center;
  border: 1rpx solid #FFB3B3;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .container {
    padding: 20rpx;
  }
  
  .work-grid {
    grid-template-columns: 1fr;
  }
  
  .generate-btn {
    width: 90%;
    font-size: 28rpx;
    padding: 20rpx 0;
  }
  
  .explanation-card {
    padding: 24rpx;
  }
  
  .item-title {
    font-size: 26rpx;
  }
  
  .item-content {
    font-size: 24rpx;
  }
}