/* shuhuayayun/pages/ai-generate/ai-generate.wxss */

.container {
  background-color: #F5F2E9;
  min-height: 100vh;
  padding: 30rpx;
  font-family: '楷体', 'STKaiti', serif;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
  padding: 30rpx 0;
  background: linear-gradient(135deg, #F5F2E9 0%, #E8E4D8 100%);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
  border: 1rpx solid #D7D3C8;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #666;
}

.input-section {
  margin-bottom: 40rpx;
}

.input-prompt {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #333;
  min-height: 160rpx;
  border: 1rpx solid #E8E4D8;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  font-family: '楷体', 'STKaiti', serif;
}

.input-prompt::placeholder {
  color: #999;
  font-family: '楷体', 'STKaiti', serif;
}

.examples-section {
  margin-top: 20rpx;
}

.examples-title {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.examples-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.example-item {
  background-color: #FFFFFF;
  color: #8B4513;
  padding: 12rpx 20rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  border: 1rpx solid #E8E4D8;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
  transition: all 0.3s ease;
}

.example-item:hover {
  background-color: #8B4513;
  color: #FFFFFF;
  transform: translateY(-2rpx);
}

.button-section {
  margin-bottom: 40rpx;
  text-align: center;
}

.generate-btn {
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: bold;
  padding: 24rpx 0;
  border-radius: 24rpx;
  border: none;
  width: 80%;
  font-family: '楷体', 'STKaiti', serif;
  box-shadow: 0 6rpx 24rpx rgba(139, 69, 19, 0.3);
  transition: all 0.3s ease;
}

.generate-btn:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 8rpx 32rpx rgba(139, 69, 19, 0.4);
}

.generate-btn:disabled {
  background: #D7D3C8;
  color: #999;
  box-shadow: none;
}

.result-section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  text-align: center;
  position: relative;
}

.section-title::after {
  content: '';
  position: absolute;
  bottom: -8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 100rpx;
  height: 3rpx;
  background: linear-gradient(90deg, transparent, #8B4513, transparent);
  border-radius: 2rpx;
}

.image-container {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 20rpx;
  text-align: center;
  box-shadow: 0 6rpx 24rpx rgba(0,0,0,0.08);
  border: 1rpx solid #E8E4D8;
  margin-bottom: 30rpx;
}

.image-container image {
  width: 100%;
  height: 400rpx;
  border-radius: 12rpx;
}

.save-section {
  text-align: center;
}

.save-btn {
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: bold;
  padding: 20rpx 0;
  border-radius: 20rpx;
  border: none;
  width: 60%;
  font-family: '楷体', 'STKaiti', serif;
  box-shadow: 0 4rpx 16rpx rgba(76, 175, 80, 0.3);
  transition: all 0.3s ease;
}

.save-btn:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 24rpx rgba(76, 175, 80, 0.4);
}

.error-section {
  margin-top: 20rpx;
}

.error-message {
  background-color: #FFF0F0;
  color: #FF4D4F;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 26rpx;
  text-align: center;
  border: 1rpx solid #FFB3B3;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .container {
    padding: 20rpx;
  }
  
  .input-prompt {
    min-height: 140rpx;
    padding: 20rpx;
    font-size: 26rpx;
  }
  
  .generate-btn {
    width: 90%;
    font-size: 28rpx;
    padding: 20rpx 0;
  }
  
  .image-container image {
    height: 300rpx;
  }
  
  .save-btn {
    width: 80%;
    font-size: 26rpx;
    padding: 18rpx 0;
  }
}