<!-- 民俗百味 - 传统中国风 -->
<view class="home-container">
  <!-- 搜索区域 -->
  <view class="search-section">
    <view class="search-box" bindtap="goToSearch">
      <text class="search-icon">🔍</text>
      <text class="search-placeholder">搜索民俗文化、美食...</text>
    </view>
  </view>

  <!-- Banner轮播 -->
  <view class="hero">
    <swiper class="hero-swiper" indicator-dots="true" autoplay="true" interval="3000" duration="500" circular="true">
      <swiper-item wx:for="{{bannerList}}" wx:key="id">
        <image src="{{item.imageUrl}}" class="hero-image" mode="aspectFill" />
        <view class="banner-overlay">
          <view class="banner-title">{{item.title}}</view>
          <view class="banner-subtitle">{{item.subtitle}}</view>
        </view>
      </swiper-item>
    </swiper>
  </view>

  <!-- 四大分类 -->
  <view class="features">
    <view class="feature-row">
      <view class="feature-item" bindtap="goToCategory" data-type="seasons">
        <text class="feature-icon">🌱</text>
        <text>时令食俗</text>
      </view>
      <view class="feature-item" bindtap="goToCategory" data-type="regions">
        <text class="feature-icon">🗺️</text>
        <text>地域珍味</text>
      </view>
    </view>
    <view class="feature-row">
      <view class="feature-item" bindtap="goToCategory" data-type="intangible">
        <text class="feature-icon">🏆</text>
        <text>非遗食韵</text>
      </view>
      <view class="feature-item" bindtap="goToCategory" data-type="cakes">
        <text class="feature-icon">🎂</text>
        <text>传统糕饼</text>
      </view>
    </view>
  </view>

  <!-- 时令食俗推荐区 -->
  <view class="section">
    <text class="section-title">时令食俗</text>
    <view class="section-more" bindtap="goToCategory" data-type="seasons">
      更多 <text>▶</text>
    </view>
    <view class="seasonal-list">
      <view class="seasonal-item" wx:for="{{seasonalList}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
        <image class="seasonal-img" src="{{item.imageUrl}}" mode="aspectFill" />
        <view class="seasonal-info">
          <view class="seasonal-title">{{item.title}}</view>
          <view class="seasonal-desc">{{item.desc}}</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 民俗美食文化瀑布流 -->
  <view class="section">
    <text class="section-title">民俗美食文化</text>
    <view class="section-more" bindtap="goToCategory" data-type="all">
      更多 <text>▶</text>
    </view>
    <view class="waterfall-grid">
      <view class="waterfall-item" wx:for="{{waterfallList}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
        <image class="waterfall-img" src="{{item.imageUrl}}" mode="aspectFill" />
        <view class="waterfall-info">
          <view class="waterfall-title">{{item.title}}</view>
          <view class="waterfall-tags">
            <view class="tag" wx:for="{{item.tags}}" wx:key="*this">{{item}}</view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 食文化小课堂入口 -->
  <view class="section">
    <text class="section-title">食文化小课堂</text>
    <view class="classroom-card" bindtap="goToClassroom">
      <view class="classroom-content">
        <view class="classroom-icon">📚</view>
        <view class="classroom-info">
          <view class="classroom-title">食文化小课堂</view>
          <view class="classroom-desc">了解民俗美食背后的文化故事</view>
        </view>
        <view class="classroom-arrow">🏆</view>
      </view>
    </view>
  </view>
  
  <!-- 民俗资讯 -->
  <view class="news-section">
    <view class="news-title">民俗资讯</view>
    <view class="news-item">
      <text class="news-icon">📢</text>
      <view class="news-content">
        <view class="news-item-title">传统节日美食文化展</view>
        <view class="news-item-desc">展示各地特色节日美食</view>
      </view>
    </view>
    <view class="news-item">
      <text class="news-icon">🍲</text>
      <view class="news-content">
        <view class="news-item-title">地方小吃传承保护项目</view>
        <view class="news-item-desc">保护和传承民间传统美食</view>
      </view>
    </view>
    <view class="news-item">
      <text class="news-icon">🎯</text>
      <view class="news-content">
        <view class="news-item-title">民俗美食文化研讨会</view>
        <view class="news-item-desc">探讨传统美食的现代传承</view>
      </view>
    </view>
  </view>
  
  <!-- 底部信息 -->
  <view class="footer">
    <view class="footer-text">传承中华民俗文化</view>
    <view class="footer-text">品味传统美食之美</view>
    <view class="footer-copyright">© 2026 民俗百味</view>
  </view>
  
  <!-- 底部空间 -->
  <view class="bottom-space"></view>

  <!-- 底部导航 -->
  <view class="tab-bar">
    <view class="tab-item active" bindtap="goToHome">
      <image src="/components/shou.png" class="tab-image"></image>
      <text>首页</text>
    </view>
    <view class="tab-item" bindtap="goToCategoryList">
      <image src="/components/zonglan.png" class="tab-image"></image>
      <text>分类</text>
    </view>
    <view class="tab-item" bindtap="goToProfile">
      <image src="/components/yonghu.png" class="tab-image"></image>
      <text>我的</text>
    </view>
  </view>
</view>
