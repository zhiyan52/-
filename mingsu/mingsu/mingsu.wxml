<!--mingsu/mingsu/mingsu.wxml-->

<!-- 搜索区域 -->
<view class="search-section">
  <view class="search-box" bindtap="goToSearch">
    <text class="search-icon">🔍</text>
    <text class="search-placeholder">搜索民俗文化、美食...</text>
  </view>
</view>

<!-- Banner轮播（文化主题） -->
<swiper class="banner-swiper" indicator-dots circular autoplay interval="3000" duration="500">
  <swiper-item wx:for="{{bannerList}}" wx:key="id">
    <image class="banner-img" src="{{item.imageUrl}}" mode="widthFix" alt="{{item.title}}"></image>
    <view class="banner-overlay">
      <view class="banner-title">{{item.title}}</view>
      <view class="banner-subtitle">{{item.subtitle}}</view>
    </view>
  </swiper-item>
</swiper>

<!-- 四大分类图标区 -->
<view class="category-icons">
  <view class="category-item" bindtap="goToCategory" data-type="seasons">
    <view class="category-icon">🌱</view>
    <view class="category-name">时令食俗</view>
  </view>
  <view class="category-item" bindtap="goToCategory" data-type="regions">
    <view class="category-icon">🗺️</view>
    <view class="category-name">地域珍味</view>
  </view>
  <view class="category-item" bindtap="goToCategory" data-type="intangible">
    <view class="category-icon">🏆</view>
    <view class="category-name">非遗食韵</view>
  </view>
  <view class="category-item" bindtap="goToCategory" data-type="cakes">
    <view class="category-icon">🎂</view>
    <view class="category-name">传统糕饼</view>
  </view>
</view>

<!-- 时令食俗推荐区 -->
<view class="seasonal-section">
  <view class="section-header">
    <view class="section-title">时令食俗</view>
    <view class="section-more" bindtap="goToCategory" data-type="seasons">
      更多 <text>▶</text>
    </view>
  </view>
  <view class="seasonal-list">
    <view class="seasonal-item" wx:for="{{seasonalList}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
      <image class="seasonal-img" src="{{item.imageUrl}}" mode="aspectFill" alt="{{item.title}}"></image>
      <view class="seasonal-info">
        <view class="seasonal-title">{{item.title}}</view>
        <view class="seasonal-desc">{{item.desc}}</view>
      </view>
    </view>
  </view>
</view>

<!-- 民俗美食文化瀑布流 -->
<view class="waterfall-section">
  <view class="section-header">
    <view class="section-title">民俗美食文化</view>
    <view class="section-more" bindtap="goToCategory" data-type="all">
      更多 <text>▶</text>
    </view>
  </view>
  <view class="waterfall-grid">
    <view class="waterfall-item" wx:for="{{waterfallList}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
      <image class="waterfall-img" src="{{item.imageUrl}}" mode="aspectFill" alt="{{item.title}}"></image>
      <view class="waterfall-info">
        <view class="waterfall-title">{{item.title}}</view>
        <view class="waterfall-tags">
          <view class="tag" wx:for="{{item.tags}}" wx:key="*this">{{item}}</view>
        </view>
      </view>
    </view>
  </view>
</view>

<!-- 食文化小课堂入口 -->
<view class="classroom-section" bindtap="goToClassroom">
  <view class="classroom-content">
    <view class="classroom-icon">📚</view>
    <view class="classroom-info">
      <view class="classroom-title">食文化小课堂</view>
      <view class="classroom-desc">了解民俗美食背后的文化故事</view>
    </view>
    <view class="classroom-arrow">▶</view>
  </view>
</view>

<!-- 底部导航 -->
<view class="bottom-nav">
  <view class="nav-item active" bindtap="goToHome">
    <text class="nav-icon">🏠</text>
    <text class="nav-name">首页</text>
  </view>
  <view class="nav-item" bindtap="goToCategoryList">
    <text class="nav-icon">📋</text>
    <text class="nav-name">分类</text>
  </view>
  <view class="nav-item" bindtap="goToCheckin">
    <text class="nav-icon">📅</text>
    <text class="nav-name">打卡</text>
  </view>
  <view class="nav-item" bindtap="goToProfile">
    <text class="nav-icon">👤</text>
    <text class="nav-name">我的</text>
  </view>
</view>