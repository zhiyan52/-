<view class="mingsu-container">
  <!-- 顶部品牌 -->
  <view class="brand-header">
    <view class="brand-content">
      <image class="brand-bg" src="cloud://cloud1-8glc9jqob91870fc.636c-cloud1-8glc9jqob91870fc-1401141450/mingsu/new/zhou.jpg"></image>
      
    </view>
  </view>

  <!-- 功能模块 -->
  <view class="modules-section">
    <view class="section-title">
      <text>民俗功能</text>
    </view>
    <view class="modules-grid">
      <view class="module-card" wx:for="{{modules}}" wx:key="id" bindtap="navigateToModule" data-id="{{item.id}}">
        <image class="module-icon" src="{{item.image}}" mode="aspectFill" bindtap="navigateToModule" data-id="{{item.id}}"></image>
        <view class="module-content">
          <text class="module-name">{{item.name}}</text>
          <text class="module-desc">{{item.desc}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 精选民俗 -->
  <view class="featured-section">
    <view class="section-title">
      <text>精选民俗</text>
    </view>
    <view class="featured-grid">
      <view class="featured-card" wx:for="{{featuredItems}}" wx:key="id" bindtap="viewFeatured" data-id="{{item.id}}">
        <image class="featured-image" src="{{item.image}}" mode="aspectFill" bindtap="viewFeatured" data-id="{{item.id}}"></image>
        <text class="featured-name">{{item.name}}</text>
        <text class="featured-desc">{{item.desc}}</text>
      </view>
    </view>
  </view>

  <!-- 智能功能 -->
  <view class="smart-section">
    <view class="section-title">
      <text>智能功能</text>
    </view>
    <view class="smart-feature-item" bindtap="navigateToAI">
      <text class="smart-feature-icon">🧭</text>
      <view class="smart-feature-content">
        <text class="smart-feature-title">智能导览</text>
        <text class="smart-feature-desc">智能路线规划，深度解说</text>
      </view>
      <text class="smart-feature-arrow">→</text>
    </view>
    
    <view class="smart-feature-item" bindtap="navigateToQA">
      <text class="smart-feature-icon">❓</text>
      <view class="smart-feature-content">
        <text class="smart-feature-title">文化问答</text>
        <text class="smart-feature-desc">解答民俗相关问题</text>
      </view>
      <text class="smart-feature-arrow">→</text>
    </view>
    <view class="smart-feature-item" bindtap="navigateToRecommend">
      <text class="smart-feature-icon">🎯</text>
      <view class="smart-feature-content">
        <text class="smart-feature-title">个性化推荐</text>
        <text class="smart-feature-desc">根据兴趣推荐民俗内容</text>
      </view>
      <text class="smart-feature-arrow">→</text>
    </view>
    <view class="smart-feature-item" bindtap="navigateToVoice">
      <text class="smart-feature-icon">🎙️</text>
      <view class="smart-feature-content">
        <text class="smart-feature-title">语音讲解</text>
        <text class="smart-feature-desc">沉浸式语音导览体验</text>
      </view>
      <text class="smart-feature-arrow">→</text>
    </view>
  </view>

  <!-- 底部装饰 -->
  <view class="footer-section">
    <text class="footer-text">传承中华传统文化</text>
    <text class="footer-subtext">感受民俗风物之美</text>
    <text class="footer-copyright">© 2026  民俗百味</text>
  </view>
</view>