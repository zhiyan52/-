/* mingsu/mingsu/pages/calendar/calendar.wxss */
.calendar-container {
  background: linear-gradient(to bottom, #f8f0e3, #fff8f0);
  min-height: 100vh;
  padding: 20rpx;
  font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif;
}

.decoration-top {
  height: 8rpx;
  background: linear-gradient(90deg, #8B4513, #D4A017, #8B4513);
  border-radius: 4rpx;
  margin-bottom: 20rpx;
}

.page-title {
  text-align: center;
  padding: 30rpx 0;
  margin-bottom: 20rpx;
}

.title-text {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #8B4513;
  margin-bottom: 10rpx;
}

.subtitle-text {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.tab-container {
  display: flex;
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  transition: all 0.3s ease;
  position: relative;
}

.tab-item.active {
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40rpx;
  height: 4rpx;
  background: #D4A017;
  border-radius: 2rpx;
}

.tab-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #666;
  transition: all 0.3s ease;
}

.tab-item.active .tab-text {
  color: white;
  font-weight: bold;
}

.list-container {
  padding-bottom: 30rpx;
}

.season-tabs {
  display: flex;
  justify-content: space-between;
  margin-bottom: 30rpx;
  padding: 0 10rpx;
}

.season-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  margin: 0 8rpx;
  background: white;
  border-radius: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
}

.season-tab.active {
  background: linear-gradient(135deg, #D4A017 0%, #B8860B 100%);
  box-shadow: 0 4rpx 12rpx rgba(212, 160, 23, 0.3);
}

.season-text {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
}

.season-tab.active .season-text {
  color: white;
  font-weight: bold;
}

.solar-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  padding: 0 10rpx;
}

.solar-card {
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
}

.solar-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.solar-card-header {
  padding: 20rpx 20rpx 10rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.solar-card-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #8B4513;
}

.solar-card-date {
  font-size: 22rpx;
  color: #999;
}

.solar-card-image {
  width: 100%;
  height: 200rpx;
  object-fit: cover;
  display: block;
}

.solar-card-footer {
  padding: 15rpx 20rpx 20rpx;
}

.solar-card-desc {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

.festival-item {
  display: flex;
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
}

.festival-item:active {
  transform: scale(0.98);
}

.festival-image {
  width: 200rpx;
  height: 200rpx;
  object-fit: cover;
  flex-shrink: 0;
}

.festival-content {
  flex: 1;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.festival-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #8B4513;
  margin-bottom: 8rpx;
}

.festival-date {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.festival-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 12rpx;
}

.festival-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.tag {
  font-size: 20rpx;
  color: #D4A017;
  background: rgba(212, 160, 23, 0.1);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.culture-section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #8B4513;
  margin-bottom: 24rpx;
  padding-left: 20rpx;
  border-left: 6rpx solid #D4A017;
}

.culture-card {
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
}

.culture-card:active {
  transform: scale(0.98);
}

.culture-card-header {
  margin-bottom: 15rpx;
}

.culture-card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.culture-card-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.detail-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 40rpx;
}

.detail-content {
  background: white;
  border-radius: 30rpx;
  width: 100%;
  max-height: 85vh;
  overflow-y: auto;
  padding-bottom: 40rpx;
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #eee;
  position: sticky;
  top: 0;
  background: white;
  border-radius: 30rpx 30rpx 0 0;
}

.detail-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #8B4513;
}

.detail-close {
  font-size: 50rpx;
  color: #999;
  padding: 0 20rpx;
  line-height: 1;
}

.detail-image {
  width: 100%;
  height: 400rpx;
  object-fit: cover;
}

.detail-info {
  padding: 30rpx;
}

.info-item {
  margin-bottom: 24rpx;
}

.info-label {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  color: #8B4513;
  margin-bottom: 10rpx;
}

.info-value {
  display: block;
  font-size: 28rpx;
  color: #333;
  line-height: 1.7;
}

.info-value.poetry {
  font-style: italic;
  color: #666;
  padding: 20rpx;
  background: #faf8f5;
  border-radius: 12rpx;
  border-left: 4rpx solid #D4A017;
}

.activities-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.activity-tag {
  font-size: 24rpx;
  color: #D4A017;
  background: rgba(212, 160, 23, 0.1);
  padding: 10rpx 20rpx;
  border-radius: 25rpx;
}