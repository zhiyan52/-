/* mingsu/mingsu/pages/calendar/calendar.wxss */
.calendar-container {
  background: linear-gradient(to bottom, #f8f0e3, #f5e6d3);
  min-height: 100vh;
  padding: 20rpx;
  font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif;
}

.decoration-top {
  height: 20rpx;
  background-image: url('https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=traditional%20chinese%20pattern%20decoration%2C%20ink%20painting%20style&image_size=square_hd');
  background-size: contain;
  background-repeat: repeat-x;
  margin-bottom: 30rpx;
}

.decoration-bottom {
  height: 20rpx;
  background-image: url('https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=traditional%20chinese%20pattern%20decoration%2C%20ink%20painting%20style&image_size=square_hd');
  background-size: contain;
  background-repeat: repeat-x;
  margin-top: 30rpx;
  transform: rotate(180deg);
}

.tab-container {
  display: flex;
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  transition: all 0.3s ease;
}

.tab-item.active {
  background: #8B4513;
}

.tab-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  transition: all 0.3s ease;
}

.tab-item.active .tab-text {
  color: white;
}

.section-title {
  text-align: center;
  margin: 30rpx 0;
}

.section-title text {
  font-size: 36rpx;
  font-weight: bold;
  color: #8B4513;
  padding: 0 20rpx;
  background: linear-gradient(to right, transparent, #8B4513, transparent);
  background-size: 100% 2rpx;
  background-position: bottom;
  background-repeat: no-repeat;
  padding-bottom: 10rpx;
}

.featured-festivals {
  margin-bottom: 40rpx;
}

.festival-grid {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.festival-item {
  flex: 1;
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}

.festival-item:hover {
  transform: translateY(-5rpx);
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.15);
}

.festival-image {
  width: 100%;
  height: 150rpx;
  object-fit: cover;
}

.festival-name {
  display: block;
  text-align: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin: 15rpx 0 5rpx;
}

.festival-desc {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #666;
  margin-bottom: 15rpx;
  padding: 0 10rpx;
}

.content-container {
  margin-bottom: 30rpx;
}

.festival-list,
.solar-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.festival-card,
.solar-card {
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}

.festival-card:hover,
.solar-card:hover {
  transform: translateY(-5rpx);
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.15);
}

.card-image {
  width: 100%;
  height: 180rpx;
  object-fit: cover;
}

.card-content {
  padding: 15rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.card-desc {
  font-size: 22rpx;
  color: #666;
  line-height: 1.4;
}

@media (max-width: 750rpx) {
  .festival-list,
  .solar-list {
    grid-template-columns: 1fr;
  }
  
  .festival-grid {
    flex-direction: column;
  }
  
  .festival-item {
    flex-direction: row;
  }
  
  .festival-image {
    width: 120rpx;
    height: 100%;
  }
  
  .festival-name,
  .festival-desc {
    text-align: left;
    margin-left: 15rpx;
  }
}