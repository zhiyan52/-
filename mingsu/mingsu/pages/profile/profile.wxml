<!-- 民俗百味个人中心页面 -->
<view class="profile-container">
  <!-- 顶部用户信息 -->
  <view class="user-header">
    <image class="user-avatar" src="{{userInfo.avatarUrl || '/components/yonghu.png'}}"></image>
    <view class="user-info">
      <text class="user-name">{{userInfo.nickName || '用户'}}</text>
      <text class="user-level">等级：{{userData.level || '1'}}</text>
    </view>
    <view class="user-score">
      <text class="score-label">积分</text>
      <text class="score-value">{{userData.score || '0'}}</text>
    </view>
  </view>
  
  <!-- 签到打卡 -->
  <view class="checkin-section">
    <view class="section-title">
      <text class="title-text">每日签到</text>
      <text class="checkin-days">已连续签到 {{userData.checkinDays || '0'}} 天</text>
    </view>
    <view class="checkin-btn" bindtap="checkin">
      <text class="btn-icon">📅</text>
      <text class="btn-text">{{isCheckedIn ? '已签到' : '立即签到'}}</text>
      <text class="reward-text">+{{checkinReward || '10'}}积分</text>
    </view>
  </view>
  
  <!-- 个人数据报告 -->
  <view class="data-section">
    <view class="section-title">
      <text class="title-text">个人数据报告</text>
      <text class="more-btn" bindtap="viewMoreData">查看更多 →</text>
    </view>
    <view class="data-cards">
      <view class="data-card">
        <text class="data-icon">🍲</text>
        <text class="data-value">{{userData.viewCount || '0'}}</text>
        <text class="data-label">浏览民俗项目</text>
      </view>
      <view class="data-card">
        <text class="data-icon">⭐</text>
        <text class="data-value">{{userData.collectionCount || '0'}}</text>
        <text class="data-label">收藏</text>
      </view>
      <view class="data-card">
        <text class="data-icon">💬</text>
        <text class="data-value">{{userData.commentCount || '0'}}</text>
        <text class="data-label">评论</text>
      </view>
      <view class="data-card">
        <text class="data-icon">🏆</text>
        <text class="data-value">{{userData.achievementCount || '0'}}</text>
        <text class="data-label">成就</text>
      </view>
    </view>
  </view>
  
  <!-- 微信好友排行榜 -->
  <view class="ranking-section">
    <view class="section-title">
      <text class="title-text">微信好友排行榜</text>
      <text class="refresh-btn" bindtap="refreshRanking">刷新</text>
    </view>
    <view class="ranking-list">
      <view class="ranking-item" wx:for="{{rankingList}}" wx:key="index">
        <view class="ranking-number {{index < 3 ? 'top-ranking' : ''}}">{{index + 1}}</view>
        <image class="ranking-avatar" src="{{item.avatarUrl}}"></image>
        <text class="ranking-name">{{item.nickName}}</text>
        <text class="ranking-score">{{item.score}} 积分</text>
      </view>
      <view class="ranking-item my-ranking">
        <view class="ranking-number">我的排名</view>
        <image class="ranking-avatar" src="{{userInfo.avatarUrl || '/components/yonghu.png'}}"></image>
        <text class="ranking-name">{{userInfo.nickName || '用户'}}</text>
        <text class="ranking-score">{{userData.score || '0'}} 积分</text>
      </view>
    </view>
  </view>
  
  <!-- 积分体系 -->
  <view class="points-section">
    <view class="section-title">
      <text class="title-text">积分体系</text>
    </view>
    <view class="points-rules">
      <view class="rule-item">
        <text class="rule-icon">📅</text>
        <text class="rule-text">每日签到 +10 积分</text>
      </view>
      <view class="rule-item">
        <text class="rule-icon">🍲</text>
        <text class="rule-text">浏览民俗项目 +2 积分/次</text>
      </view>
      <view class="rule-item">
        <text class="rule-icon">⭐</text>
        <text class="rule-text">收藏民俗项目 +5 积分/次</text>
      </view>
      <view class="rule-item">
        <text class="rule-icon">💬</text>
        <text class="rule-text">发表评论 +3 积分/次</text>
      </view>
      <view class="rule-item">
        <text class="rule-icon">🏆</text>
        <text class="rule-text">完成成就 +20 积分/个</text>
      </view>
    </view>
  </view>
  
  <!-- 问答小游戏 -->
  <view class="game-section">
    <view class="section-title">
      <text class="title-text">民俗知识问答</text>
      <text class="more-btn" bindtap="viewMoreGames">更多游戏 →</text>
    </view>
    <view class="game-cards">
      <view class="game-card" bindtap="startQuiz">
        <view class="game-icon">🎯</view>
        <view class="game-info">
          <text class="game-title">每日答题</text>
          <text class="game-desc">答对3题即可获得积分奖励</text>
          <view class="game-reward">+15 积分</view>
        </view>
        <view class="game-status {{quizCompleted ? 'completed' : ''}}">
          {{quizCompleted ? '已完成' : '去答题'}}
        </view>
      </view>
      <view class="game-card" bindtap="startChallenge">
        <view class="game-icon">⚔️</view>
        <view class="game-info">
          <text class="game-title">民俗挑战赛</text>
          <text class="game-desc">限时挑战，答对越多积分越多</text>
          <view class="game-reward">+30 积分</view>
        </view>
        <view class="game-status">去挑战</view>
      </view>
      <view class="game-card" bindtap="startGuess">
        <view class="game-icon">🖼️</view>
        <view class="game-info">
          <text class="game-title">看图识民俗</text>
          <text class="game-desc">识别民俗项目图片，测试你的知识</text>
          <view class="game-reward">+20 积分</view>
        </view>
        <view class="game-status">去识别</view>
      </view>
    </view>
  </view>
  
  <!-- 积分任务 -->
  <view class="task-section">
    <view class="section-title">
      <text class="title-text">积分任务</text>
      <text class="task-progress">今日已完成 {{completedTasks}}/{{totalTasks}}</text>
    </view>
    <view class="task-list">
      <view class="task-item" wx:for="{{taskList}}" wx:key="id">
        <view class="task-icon">{{item.icon}}</view>
        <view class="task-info">
          <text class="task-title">{{item.title}}</text>
          <text class="task-desc">{{item.desc}}</text>
          <view class="task-progress-bar">
            <view class="task-progress-fill" style="width: {{(item.current/item.target)*100}}%"></view>
          </view>
          <text class="task-progress-text">{{item.current}}/{{item.target}}</text>
        </view>
        <view class="task-reward {{item.completed ? 'completed' : ''}}" bindtap="claimTaskReward" data-id="{{item.id}}">
          <text class="reward-points">+{{item.reward}}</text>
          <text class="reward-status">{{item.completed ? '已领取' : '领取'}}</text>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 返回总个人中心 -->
  <view class="back-btn" bindtap="backToMainProfile">
    <text class="btn-icon">🏠</text>
    <text class="btn-text">返回总个人中心</text>
  </view>
</view>