/* mingsu/mingsu/pages/3d-model/3d-model.wxss */

/* 顶部导航栏 */
.top-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  background-color: #8B4513;
  color: white;
  position: sticky;
  top: 0;
  z-index: 100;
}

.back-btn {
  font-size: 32rpx;
  padding: 8rpx;
}

.nav-title {
  font-size: 32rpx;
  font-weight: bold;
  font-family: '楷体', 'STKaiti', serif;
  flex: 1;
  text-align: center;
  margin: 0 32rpx;
}

.action-btn {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.action-btn:hover {
  background-color: rgba(255, 255, 255, 0.3);
}

/* 模型名称 */
.model-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin: 32rpx 0;
  font-family: '楷体', 'STKaiti', serif;
}

/* 模型展示区域 */
.model-container {
  width: 90%;
  height: 500rpx;
  margin: 0 auto 40rpx;
  background-color: white;
  border-radius: 16rpx;
  border: 1rpx solid #e8ddd1;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  position: relative;
  overflow: hidden;
}

.model-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

.model-icon {
  font-size: 128rpx;
  margin-bottom: 24rpx;
  animation: float 3s ease-in-out infinite;
}

.model-status {
  font-size: 28rpx;
  color: #8B4513;
  font-weight: bold;
  margin-bottom: 32rpx;
}

/* 模型部件 */
.model-parts {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  transition: all 1s ease;
}

.model-part {
  width: 200rpx;
  height: 60rpx;
  background-color: #f8f5f0;
  border: 1rpx solid #e8ddd1;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #333;
  transition: all 1s ease;
}

.model-parts.disassembled .model-part {
  margin: 40rpx 0;
}

/* 注解触发点 */
.annotation-trigger {
  position: absolute;
  top: 30%;
  left: 50%;
  transform: translateX(-50%);
  width: 24rpx;
  height: 24rpx;
  background-color: #8B4513;
  border-radius: 50%;
  border: 4rpx solid white;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
  cursor: pointer;
  transition: all 0.3s ease;
}

.annotation-trigger.middle {
  top: 50%;
}

.annotation-trigger.bottom {
  top: 70%;
}

.annotation-trigger:hover {
  transform: translateX(-50%) scale(1.2);
}

/* 注解浮层 */
.annotation-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.annotation-content {
  background-color: white;
  border-radius: 16rpx;
  padding: 32rpx;
  width: 80%;
  max-width: 500rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.3);
}

.annotation-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #8B4513;
  margin-bottom: 16rpx;
}

.annotation-desc {
  font-size: 24rpx;
  color: #666;
  line-height: 1.4;
}

/* 控制按钮 */
.control-buttons {
  display: flex;
  gap: 24rpx;
  justify-content: center;
  margin-bottom: 40rpx;
}

.control-btn {
  padding: 16rpx 48rpx;
  background-color: #8B4513;
  color: white;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: bold;
  transition: all 0.3s ease;
  border: 1rpx solid #8B4513;
}

.control-btn:hover {
  background-color: white;
  color: #8B4513;
}

/* 操作提示 */
.operation-tips {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 24rpx 32rpx;
  background-color: white;
  border-top: 1rpx solid #e8ddd1;
  margin-top: 40rpx;
}

.tip-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-size: 24rpx;
  color: #666;
}

.tip-icon {
  font-size: 32rpx;
}

/* 动画 */
@keyframes float {
  0% {
    transform: translateY(0);
  }
  50% {
    transform: translateY(-20rpx);
  }
  100% {
    transform: translateY(0);
  }
}

/* 响应式适配 */
@media (max-width: 375px) {
  .model-container {
    height: 400rpx;
  }
  
  .model-icon {
    font-size: 96rpx;
  }
  
  .control-buttons {
    flex-direction: column;
    align-items: center;
  }
  
  .control-btn {
    width: 200rpx;
    text-align: center;
  }
}