<!--mingsu/mingsu/pages/3d-model/3d-model.wxml-->

<!-- 模型名称 -->
<view class="model-name">{{modelName}}</view>

<!-- 3D模型展示区域 -->
<view class="model-container">
  <view class="model-placeholder">
    <view class="model-icon">📦</view>
    <view class="model-status">{{modelStatus}}</view>
    
    <!-- 模拟模型拆解状态 -->
    <view class="model-parts" wx:if="{{modelStatus === '完整'}}">
      <view class="model-part part-top">提梁</view>
      <view class="model-part part-middle">盒盖</view>
      <view class="model-part part-bottom">盒身</view>
    </view>
    
    <view class="model-parts disassembled" wx:if="{{modelStatus === '已拆解'}}">
      <view class="model-part part-top disassembled">提梁</view>
      <view class="model-part part-middle disassembled">盒盖</view>
      <view class="model-part part-bottom disassembled">盒身</view>
    </view>
    
    <!-- 注解触发区域 -->
    <view class="annotation-trigger" bindtap="showAnnotation" data-id="1">
      <view class="annotation-dot"></view>
    </view>
    <view class="annotation-trigger middle" bindtap="showAnnotation" data-id="2">
      <view class="annotation-dot"></view>
    </view>
    <view class="annotation-trigger bottom" bindtap="showAnnotation" data-id="3">
      <view class="annotation-dot"></view>
    </view>
  </view>
  
  <!-- 注解浮层 -->
  <view class="annotation-overlay" wx:if="{{currentAnnotation}}" bindtap="hideAnnotation">
    <view class="annotation-content">
      <view class="annotation-title">{{currentAnnotation.name}}</view>
      <view class="annotation-desc">{{currentAnnotation.desc}}</view>
    </view>
  </view>
</view>

<!-- 动画控制按钮 -->
<view class="control-buttons">
  <view class="control-btn" bindtap="toggleAnimation">
    <text>{{isPlaying ? '暂停' : '播放'}}</text>
  </view>
  <view class="control-btn" bindtap="resetModel">
    <text>重置</text>
  </view>
</view>

<!-- 操作提示 -->
<view class="operation-tips">
  <view class="tip-item">
    <text class="tip-icon">👆</text>
    <text class="tip-text">单指旋转模型</text>
  </view>
  <view class="tip-item">
    <text class="tip-icon">👌</text>
    <text class="tip-text">双指缩放模型</text>
  </view>
  <view class="tip-item">
    <text class="tip-icon">💡</text>
    <text class="tip-text">点击模型查看注解</text>
  </view>
</view>
