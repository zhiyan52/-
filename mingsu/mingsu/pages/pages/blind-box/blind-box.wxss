.blind-box-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #f8f4e9 0%, #e8e0d0 100%);
  font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif;
  padding: 32rpx;
}

.page-header {
  text-align: center;
  margin-bottom: 48rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  display: block;
}

.header-subtitle {
  font-size: 24rpx;
  color: #666;
  display: block;
}

.blind-box-section {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 400rpx;
  margin-bottom: 48rpx;
}

.blind-box-wrapper {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.blind-box {
  position: relative;
  width: 300rpx;
  height: 400rpx;
  cursor: pointer;
  transition: all 0.3s ease;
}

.blind-box:active {
  transform: scale(0.98);
}

.box-image {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

.box-text {
  position: absolute;
  bottom: 40rpx;
  left: 0;
  right: 0;
  text-align: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #8B4513;
  text-shadow: 0 2rpx 4rpx rgba(255, 255, 255, 0.8);
}

.opening-animation {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 300rpx;
  height: 400rpx;
}

.opening-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #8B4513;
  margin-bottom: 24rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #f3f3f3;
  border-top: 6rpx solid #d4a76a;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.result-section {
  width: 100%;
  max-width: 500rpx;
}

.result-card {
  background: white;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
  overflow: hidden;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background: #d4a76a;
  color: white;
}

.result-title {
  font-size: 28rpx;
  font-weight: bold;
}

.result-close {
  font-size: 32rpx;
  line-height: 1;
  padding: 8rpx;
}

.result-content {
  padding: 32rpx;
}

.result-image {
  width: 100%;
  height: 200rpx;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  object-fit: cover;
}

.result-text {
  font-size: 24rpx;
  color: #333;
  line-height: 1.5;
  margin-bottom: 24rpx;
}

.result-description {
  font-size: 20rpx;
  color: #666;
  font-style: italic;
  text-align: right;
}

.info-section {
  text-align: center;
  margin-top: 32rpx;
}

.info-text {
  font-size: 22rpx;
  color: #666;
  margin-bottom: 8rpx;
  display: block;
  line-height: 1.4;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .blind-box-container {
    padding: 20rpx;
  }
  
  .blind-box {
    width: 250rpx;
    height: 350rpx;
  }
  
  .result-card {
    margin: 0 20rpx;
  }
}