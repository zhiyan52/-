<view class="blind-box-container">
  <!-- 页面标题 -->
  <view class="page-header">
    <text class="header-title">民俗风物盲盒</text>
    <text class="header-subtitle">每日随机获得民俗知识</text>
  </view>

  <!-- 盲盒展示 -->
  <view class="blind-box-section">
    <view class="blind-box-wrapper" wx:if="{{!openedBox}}">
      <view class="blind-box" bindtap="openBlindBox" wx:if="{{!isOpening}}">
        <image class="box-image" src="https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=traditional%20Chinese%20blind%20box%2C%20red%20and%20gold%20colors%2C%20ink%20painting%20style&image_size=square_hd" mode="aspectFit"></image>
        <text class="box-text">点击开盒</text>
      </view>
      <view class="opening-animation" wx:if="{{isOpening}}">
        <text class="opening-text">开盒中...</text>
        <view class="loading-spinner"></view>
      </view>
    </view>

    <!-- 开盒结果 -->
    <view class="result-section" wx:if="{{openedBox}}">
      <view class="result-card">
        <view class="result-header">
          <text class="result-title">{{openedBox.title}}</text>
          <view class="result-close" bindtap="closeResult">×</view>
        </view>
        <view class="result-content">
          <image class="result-image" src="{{openedBox.content}}" mode="aspectFill" wx:if="{{openedBox.type === 'image'}}"></image>
          <text class="result-text" wx:if="{{openedBox.type !== 'image'}}">{{openedBox.content}}</text>
          <text class="result-description">{{openedBox.description}}</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 说明文字 -->
  <view class="info-section">
    <text class="info-text">每日打开盲盒，随机获得：</text>
    <text class="info-text">• 一句节气古诗</text>
    <text class="info-text">• 一个民俗小知识</text>
    <text class="info-text">• 一张古风节气小图</text>
    <text class="info-text">• 一段传统习俗介绍</text>
  </view>
</view>