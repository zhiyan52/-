<view class="ai-lecture-container">
  <!-- 页面标题 -->
  <view class="page-header">
    <text class="header-title">AI民俗讲堂</text>
    <text class="header-subtitle">了解传统节日与节气的文化内涵</text>
  </view>

  <!-- 主题选择 -->
  <view class="topic-section">
    <text class="section-title">选择民俗主题</text>
    <view class="topic-grid">
      <view class="topic-item {{selectedTopic && selectedTopic.id === item.id ? 'selected' : ''}}" wx:for="{{topics}}" wx:key="id" bindtap="selectTopic" data-topic="{{item}}">
        <text class="topic-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 获取讲解按钮 -->
  <view class="action-section">
    <button class="get-lecture-btn" bindtap="getLecture" loading="{{isLoading}}">
      {{isLoading ? '获取中...' : '获取AI讲解'}}
    </button>
  </view>

  <!-- 讲解内容 -->
  <view class="content-section" wx:if="{{lectureContent}}">
    <text class="content-title">AI讲解</text>
    <view class="content-card">
      <view class="content-item">
        <text class="content-label">来历与起源：</text>
        <text class="content-text">{{lectureContent.origin}}</text>
      </view>
      <view class="content-item">
        <text class="content-label">传统习俗：</text>
        <text class="content-text">{{lectureContent.customs}}</text>
      </view>
      <view class="content-item">
        <text class="content-label">相关诗词：</text>
        <text class="content-text poem">{{lectureContent.poems}}</text>
      </view>
      <view class="content-item">
        <text class="content-label">文化意义：</text>
        <text class="content-text">{{lectureContent.meaning}}</text>
      </view>
    </view>
  </view>
</view>