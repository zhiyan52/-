.card-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #f8f4e9 0%, #e8e0d0 100%);
  font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif;
  padding: 32rpx;
}

.page-header {
  text-align: center;
  margin-bottom: 48rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  display: block;
}

.header-subtitle {
  font-size: 24rpx;
  color: #666;
  display: block;
}

.card-display {
  display: flex;
  justify-content: center;
  margin-bottom: 48rpx;
}

.card-wrapper {
  position: relative;
  width: 360rpx;
  height: 480rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.15);
}

.card-background {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.card-content {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10rpx);
}

.card-quote {
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  line-height: 1.5;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.2);
}

.action-buttons {
  display: flex;
  gap: 16rpx;
  margin-bottom: 48rpx;
}

.generate-btn,
.save-btn {
  flex: 1;
  padding: 24rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: bold;
  transition: all 0.3s ease;
}

.generate-btn {
  background: #d4a76a;
  color: white;
  border: none;
}

.generate-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(212, 167, 106, 0.3);
}

.save-btn {
  background: #8B4513;
  color: white;
  border: none;
}

.save-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(139, 69, 19, 0.3);
}

.info-section {
  text-align: center;
  margin-top: 32rpx;
}

.info-text {
  font-size: 22rpx;
  color: #666;
  margin-bottom: 8rpx;
  display: block;
  line-height: 1.4;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .card-container {
    padding: 20rpx;
  }
  
  .card-wrapper {
    width: 300rpx;
    height: 400rpx;
  }
  
  .card-quote {
    font-size: 28rpx;
  }
  
  .action-buttons {
    flex-direction: column;
  }
}