.ai-image-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #f8f4e9 0%, #e8e0d0 100%);
  font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif;
  padding: 32rpx;
}

.page-header {
  text-align: center;
  margin-bottom: 48rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  display: block;
}

.header-subtitle {
  font-size: 24rpx;
  color: #666;
  display: block;
}

.keyword-section {
  margin-bottom: 48rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  text-align: center;
  position: relative;
}

.section-title::after {
  content: '';
  position: absolute;
  bottom: -8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 80rpx;
  height: 4rpx;
  background: #d4a76a;
  border-radius: 2rpx;
}

.keyword-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.keyword-item {
  background: white;
  border: 2rpx solid #d4a76a;
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
  transition: all 0.3s ease;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.keyword-item:active {
  transform: scale(0.98);
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.1);
}

.keyword-item.selected {
  background: #d4a76a;
  color: white;
}

.keyword-text {
  font-size: 24rpx;
  font-weight: bold;
  transition: all 0.3s ease;
}

.keyword-item.selected .keyword-text {
  color: white;
}

.action-section {
  margin-bottom: 48rpx;
}

.generate-btn {
  background: #d4a76a;
  color: white;
  border: none;
  border-radius: 16rpx;
  padding: 24rpx;
  font-size: 28rpx;
  font-weight: bold;
  width: 100%;
  box-shadow: 0 4rpx 12rpx rgba(212, 167, 106, 0.3);
  transition: all 0.3s ease;
}

.generate-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(212, 167, 106, 0.4);
}

.result-section {
  margin-top: 32rpx;
}

.result-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 24rpx;
  text-align: center;
}

.image-container {
  background: white;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.generated-image {
  width: 400rpx;
  height: 400rpx;
  border-radius: 16rpx;
  margin-bottom: 32rpx;
  object-fit: cover;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.save-btn {
  background: #8B4513;
  color: white;
  border: none;
  border-radius: 16rpx;
  padding: 16rpx 48rpx;
  font-size: 24rpx;
  font-weight: bold;
  transition: all 0.3s ease;
}

.save-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(139, 69, 19, 0.3);
}

/* 响应式调整 */
@media (max-width: 375px) {
  .keyword-grid {
    grid-template-columns: 1fr;
  }
  
  .ai-image-container {
    padding: 20rpx;
  }
  
  .generated-image {
    width: 300rpx;
    height: 300rpx;
  }
}