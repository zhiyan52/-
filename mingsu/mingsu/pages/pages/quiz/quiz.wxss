.quiz-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #f8f4e9 0%, #e8e0d0 100%);
  font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif;
  padding: 32rpx;
}

.page-header {
  text-align: center;
  margin-bottom: 48rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  display: block;
}

.header-subtitle {
  font-size: 24rpx;
  color: #666;
  display: block;
}

.quiz-section {
  margin-bottom: 48rpx;
}

.question-info {
  margin-bottom: 24rpx;
  text-align: center;
}

.question-number {
  font-size: 24rpx;
  color: #666;
}

.question-card {
  background: white;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 32rpx;
}

.question-text {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 32rpx;
  line-height: 1.5;
}

.options-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.option-item {
  background: #f8f4e9;
  border: 2rpx solid #d4a76a;
  border-radius: 12rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
  transition: all 0.3s ease;
  cursor: pointer;
}

.option-item:active {
  transform: scale(0.98);
}

.option-item.selected {
  background: #d4a76a;
  color: white;
}

.option-item.correct {
  background: #4CAF50;
  color: white;
  border-color: #4CAF50;
}

.option-item.incorrect {
  background: #f44336;
  color: white;
  border-color: #f44336;
}

.option-letter {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #d4a76a;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: bold;
  margin-right: 16rpx;
  font-size: 24rpx;
}

.option-item.selected .option-letter,
.option-item.correct .option-letter,
.option-item.incorrect .option-letter {
  background: white;
  color: inherit;
}

.option-text {
  flex: 1;
  font-size: 24rpx;
}

.action-buttons {
  display: flex;
  gap: 16rpx;
}

.submit-btn,
.next-btn {
  flex: 1;
  padding: 20rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: bold;
  transition: all 0.3s ease;
}

.submit-btn {
  background: #d4a76a;
  color: white;
  border: none;
}

.submit-btn:disabled {
  background: #ccc;
  color: #999;
}

.next-btn {
  background: #8B4513;
  color: white;
  border: none;
}

.next-btn:disabled {
  background: #ccc;
  color: #999;
}

.result-section {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 60vh;
}

.result-card {
  background: white;
  border-radius: 16rpx;
  padding: 48rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  text-align: center;
  width: 100%;
  max-width: 500rpx;
}

.result-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 32rpx;
}

.score-container {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-bottom: 24rpx;
}

.score-number {
  font-size: 80rpx;
  font-weight: bold;
  color: #d4a76a;
}

.score-total {
  font-size: 32rpx;
  color: #666;
  margin-left: 8rpx;
}

.score-desc {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 48rpx;
  line-height: 1.5;
}

.restart-btn {
  background: #d4a76a;
  color: white;
  border: none;
  border-radius: 12rpx;
  padding: 20rpx 48rpx;
  font-size: 24rpx;
  font-weight: bold;
  transition: all 0.3s ease;
}

.restart-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(212, 167, 106, 0.3);
}

/* 响应式调整 */
@media (max-width: 375px) {
  .quiz-container {
    padding: 20rpx;
  }
  
  .question-card {
    padding: 24rpx;
  }
  
  .action-buttons {
    flex-direction: column;
  }
}