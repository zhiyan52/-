<!--mingsu/mingsu/pages/search/search.wxml-->

<!-- 搜索框 -->
<view class="search-header">
  <view class="search-input-wrapper">
    <input class="search-input" placeholder="搜索民俗文化、美食..." value="{{keyword}}" bindinput="onInput" confirm-type="search" bindconfirm="onSearch" />
  </view>
  <view class="search-btn" bindtap="onSearch">
    <text>搜索</text>
  </view>
</view>

<!-- 搜索历史 -->
<view class="history-section" wx:if="{{!hasResult && history.length > 0}}">
  <view class="section-header">
    <view class="section-title">搜索历史</view>
    <view class="clear-btn" bindtap="clearHistory">清除</view>
  </view>
  <view class="history-list">
    <view class="history-item" wx:for="{{history}}" wx:key="*this" bindtap="searchByHistory" data-keyword="{{item}}">
      {{item}}
    </view>
  </view>
</view>

<!-- 热门搜索 -->
<view class="hot-section" wx:if="{{!hasResult}}">
  <view class="section-title">热门搜索</view>
  <view class="hot-list">
    <view class="hot-item" wx:for="{{hotKeywords}}" wx:key="id" bindtap="searchByHot" data-keyword="{{item.name}}">
      <text class="hot-rank {{index < 3 ? 'top' : ''}}">{{index + 1}}</text>
      <text class="hot-name">{{item.name}}</text>
    </view>
  </view>
</view>

<!-- 搜索结果 -->
<view class="result-section" wx:if="{{hasResult}}">
  <view class="result-header">
    <view class="result-count">找到 {{results.length}} 个结果</view>
    <view class="filter-btn" bindtap="showFilter">筛选</view>
  </view>
  <view class="result-list">
    <view class="result-item" wx:for="{{results}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
      <image class="result-img" src="{{item.imageUrl}}" mode="aspectFill"></image>
      <view class="result-info">
        <view class="result-title">{{item.title}}</view>
        <view class="result-desc">{{item.desc}}</view>
        <view class="result-tags">
          <view class="tag" wx:for="{{item.tags}}" wx:key="*this">{{item}}</view>
        </view>
      </view>
    </view>
  </view>
</view>

<!-- 无结果提示 -->
<view class="no-result" wx:if="{{hasResult && results.length === 0}}">
  <view class="no-result-icon">🔍</view>
  <view class="no-result-text">未找到相关内容</view>
  <view class="no-result-tip">换个关键词试试吧</view>
</view>