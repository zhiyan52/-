/* mingsu/mingsu/pages/search/search.wxss */

page {
  background-color: #f8f5f0;
  font-family: '楷体', 'STKaiti', serif;
}

/* 搜索头部 */
.search-header {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  background-color: #2E7D32;
}

.search-input-wrapper {
  flex: 1;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  padding: 16rpx 24rpx;
}

.search-input {
  font-size: 28rpx;
  color: white;
}

.search-input::placeholder {
  color: rgba(255, 255, 255, 0.7);
}

.search-btn {
  font-size: 28rpx;
  margin-left: 20rpx;
  color: white;
}

/* 搜索历史 */
.history-section {
  padding: 32rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2E7D32;
}

.clear-btn {
  font-size: 24rpx;
  color: #666;
}

.history-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.history-item {
  padding: 12rpx 24rpx;
  background-color: white;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #333;
  border: 1rpx solid #2E7D32;
}

/* 热门搜索 */
.hot-section {
  padding: 32rpx;
}

.hot-list {
  margin-top: 24rpx;
}

.hot-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #e8ddd1;
}

.hot-rank {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background-color: #f0f0f0;
  font-size: 24rpx;
  color: #666;
  margin-right: 20rpx;
}

.hot-rank.top {
  background-color: #2E7D32;
  color: white;
}

.hot-name {
  font-size: 28rpx;
  color: #333;
}

/* 搜索结果 */
.result-section {
  padding: 32rpx;
}

.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.result-count {
  font-size: 28rpx;
  color: #666;
}

.filter-btn {
  font-size: 28rpx;
  color: #2E7D32;
}

.result-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.result-item {
  display: flex;
  background-color: white;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid #2E7D32;
}

.result-img {
  width: 200rpx;
  height: 200rpx;
  object-fit: cover;
}

.result-info {
  flex: 1;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.result-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
}

.result-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.result-tags {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
}

.tag {
  padding: 4rpx 12rpx;
  background-color: #f8f5f0;
  border-radius: 12rpx;
  font-size: 20rpx;
  color: #2E7D32;
  border: 1rpx solid #2E7D32;
}

/* 无结果提示 */
.no-result {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 32rpx;
}

.no-result-icon {
  font-size: 120rpx;
  margin-bottom: 32rpx;
}

.no-result-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
}

.no-result-tip {
  font-size: 28rpx;
  color: #666;
}