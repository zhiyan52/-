/* mingsu/mingsu/pages/checkin/checkin.wxss */

/* 顶部导航栏 */
.top-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  background-color: #8B4513;
  color: white;
  position: sticky;
  top: 0;
  z-index: 100;
}

.back-btn {
  font-size: 32rpx;
  padding: 8rpx;
}

.nav-title {
  font-size: 32rpx;
  font-weight: bold;
  font-family: '楷体', 'STKaiti', serif;
  flex: 1;
  text-align: center;
  margin: 0 32rpx;
}

.placeholder {
  width: 40rpx;
}

/* 打卡状态卡片 */
.checkin-card {
  margin: 24rpx;
  background-color: white;
  border-radius: 16rpx;
  padding: 32rpx;
  border: 1rpx solid #e8ddd1;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.checkin-status {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-bottom: 24rpx;
}

.status-icon {
  font-size: 64rpx;
}

.status-info {
  flex: 1;
}

.status-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.status-desc {
  font-size: 24rpx;
  color: #666;
}

.checkin-btn {
  padding: 12rpx 32rpx;
  background-color: #8B4513;
  color: white;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: bold;
  transition: all 0.3s ease;
}

.checkin-btn:hover {
  background-color: #6B340F;
}

.checked-btn {
  padding: 12rpx 32rpx;
  background-color: #f8f5f0;
  color: #8B4513;
  border-radius: 24rpx;
  font-size: 24rpx;
  font-weight: bold;
  border: 1rpx solid #e8ddd1;
}

.points-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0e6d8;
}

.points-label {
  font-size: 24rpx;
  color: #666;
}

.points-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #8B4513;
}

/* 通用区域样式 */
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #8B4513;
  margin: 40rpx 32rpx 24rpx;
  font-family: '楷体', 'STKaiti', serif;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

/* 今日任务 */
.task-section {
  margin-bottom: 32rpx;
}

.task-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin: 0 32rpx 16rpx;
  background-color: white;
  border-radius: 16rpx;
  padding: 24rpx;
  border: 1rpx solid #e8ddd1;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
}

.task-item:hover {
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
  transform: translateY(-4rpx);
}

.task-checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #e8ddd1;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.3s ease;
}

.task-checkbox.checked {
  background-color: #8B4513;
  border-color: #8B4513;
  color: white;
}

.task-info {
  flex: 1;
  min-width: 0;
}

.task-title {
  font-size: 28rpx;
  color: #333;
  margin-bottom: 4rpx;
}

.task-points {
  font-size: 24rpx;
  color: #8B4513;
  font-weight: bold;
}

.task-arrow {
  font-size: 24rpx;
  color: #999;
  flex-shrink: 0;
}

/* 任务列表 */
.tasks-section {
  margin-bottom: 32rpx;
}

.tasks-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* 证书区域 */
.certificate-section {
  margin-bottom: 40rpx;
}

.generate-btn {
  padding: 8rpx 24rpx;
  background-color: #8B4513;
  color: white;
  border-radius: 16rpx;
  font-size: 20rpx;
  font-weight: bold;
  transition: all 0.3s ease;
}

.generate-btn:hover {
  background-color: #6B340F;
}

.certificates-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 0 32rpx;
}

.certificate-item {
  background-color: white;
  border-radius: 16rpx;
  overflow: hidden;
  border: 1rpx solid #e8ddd1;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
}

.certificate-item:hover {
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
  transform: translateY(-4rpx);
}

.certificate-img {
  width: 100%;
  height: 200rpx;
  object-fit: cover;
}

.certificate-info {
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.certificate-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.certificate-desc {
  font-size: 24rpx;
  color: #666;
}

.save-btn {
  align-self: flex-start;
  padding: 8rpx 24rpx;
  background-color: #f8f5f0;
  color: #8B4513;
  border-radius: 16rpx;
  font-size: 20rpx;
  font-weight: bold;
  border: 1rpx solid #e8ddd1;
  transition: all 0.3s ease;
}

.save-btn:hover {
  background-color: #8B4513;
  color: white;
}

/* 响应式适配 */
@media (max-width: 375px) {
  .checkin-card {
    margin: 16rpx;
    padding: 24rpx;
  }
  
  .task-item {
    margin: 0 16rpx 16rpx;
  }
  
  .certificates-list {
    padding: 0 16rpx;
  }
  
  .certificate-img {
    height: 160rpx;
  }
}