/* mingsu/mingsu/pages/categories/regions.wxss */

/* 顶部导航栏 */
.top-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  background-color: #8B4513;
  color: white;
  position: sticky;
  top: 0;
  z-index: 100;
}

.back-btn {
  font-size: 32rpx;
  padding: 8rpx;
}

.nav-title {
  font-size: 32rpx;
  font-weight: bold;
  font-family: '楷体', 'STKaiti', serif;
}

.placeholder {
  width: 40rpx;
}

/* 地区选择器 */
.region-selector {
  margin: 24rpx 0;
  padding: 0 32rpx;
}

.region-list {
  display: flex;
  gap: 24rpx;
  padding-bottom: 16rpx;
}

.region-item {
  padding: 12rpx 32rpx;
  background-color: white;
  border-radius: 24rpx;
  font-size: 28rpx;
  color: #666;
  border: 1rpx solid #e8ddd1;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
}

.region-item.active {
  background-color: #8B4513;
  color: white;
  border-color: #8B4513;
}

/* 通用区域样式 */
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #8B4513;
  margin: 40rpx 32rpx 24rpx;
  font-family: '楷体', 'STKaiti', serif;
}

/* 省份列表 */
.provinces-list {
  padding: 0 32rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 32rpx;
}

.province-item {
  padding: 12rpx 24rpx;
  background-color: white;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #666;
  border: 1rpx solid #e8ddd1;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 地方美食列表 */
.regional-foods-list {
  padding: 0 32rpx;
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.regional-food-item {
  display: flex;
  gap: 24rpx;
  background-color: white;
  border-radius: 16rpx;
  padding: 24rpx;
  border: 1rpx solid #e8ddd1;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
}

.regional-food-item:hover {
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
  transform: translateY(-4rpx);
}

.food-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  object-fit: cover;
  flex-shrink: 0;
}

.food-info {
  flex: 1;
  min-width: 0;
}

.food-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 4rpx;
}

.food-province {
  font-size: 24rpx;
  color: #8B4513;
  margin-bottom: 8rpx;
}

.food-desc {
  font-size: 24rpx;
  color: #666;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* 响应式适配 */
@media (max-width: 375px) {
  .regional-food-item {
    flex-direction: column;
  }
  
  .food-img {
    width: 100%;
    height: 200rpx;
  }
}