/* mingsu/mingsu/pages/categories/categories.wxss */

/* 顶部导航栏 */
.top-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  background-color: #8B4513;
  color: white;
  position: sticky;
  top: 0;
  z-index: 100;
}

.back-btn {
  font-size: 32rpx;
  padding: 8rpx;
}

.nav-title {
  font-size: 32rpx;
  font-weight: bold;
  font-family: '楷体', 'STKaiti', serif;
}

.placeholder {
  width: 40rpx;
}

/* 分类列表 */
.category-list {
  padding: 24rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.category-item {
  position: relative;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid #e8ddd1;
}

.category-img {
  width: 100%;
  height: 240rpx;
  object-fit: cover;
}

.category-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.7));
  padding: 32rpx 24rpx;
  color: white;
}

.category-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.category-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.category-desc {
  font-size: 24rpx;
  opacity: 0.9;
  line-height: 1.4;
}

/* 响应式适配 */
@media (max-width: 375px) {
  .category-list {
    grid-template-columns: 1fr;
  }
  
  .category-img {
    height: 200rpx;
  }
}