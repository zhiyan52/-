<!--mingsu/mingsu/pages/categories/regions.wxml-->

<!-- 地区选择器 -->
<scroll-view class="region-selector" scroll-x scroll-with-animation>
  <view class="region-list">
    <view 
      class="region-item {{currentRegion === item.id ? 'active' : ''}}" 
      wx:for="{{regions}}" 
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="changeRegion"
    >
      {{item.name}}
    </view>
  </view>
</scroll-view>

<!-- 省份列表 -->
<view class="provinces-section">
  <view class="section-title">省份列表</view>
  <view class="provinces-list">
    <view class="province-item" wx:for="{{currentProvinces}}" wx:key="*this">
      {{item}}
    </view>
  </view>
</view>

<!-- 地方美食 -->
<view class="regional-foods-section">
  <view class="section-title">地方美食</view>
  <view class="regional-foods-list">
    <view class="regional-food-item" wx:for="{{currentFoods}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
      <image class="food-img" src="{{item.imageUrl}}" mode="aspectFill" alt="{{item.name}}"></image>
      <view class="food-info">
        <view class="food-name">{{item.name}}</view>
        <view class="food-province">{{item.province}}</view>
        <view class="food-desc">{{item.desc}}</view>
      </view>
    </view>
  </view>
</view>