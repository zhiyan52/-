/* mingsu/mingsu/pages/categories/seasons.wxss */

/* 容器 */
.container {
  min-height: 100vh;
  background-color: #f8f4f0;
}

/* 头部 */
.header {
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx;
  background-color: #8B4513;
  color: white;
  position: sticky;
  top: 0;
  z-index: 100;
}

.header-back {
  font-size: 32rpx;
  margin-right: 20rpx;
}

.header-title {
  font-size: 32rpx;
  font-weight: bold;
  font-family: '楷体', 'STKaiti', serif;
  flex: 1;
}

/* 内容区 */
.content {
  min-height: calc(100vh - 80rpx);
}

/* 时令食俗列表 */
.seasonal-list {
  display: flex;
  flex-direction: column;
  gap: 0;
  margin-bottom: 40rpx;
}

.seasonal-item {
  background-color: white;
  overflow: hidden;
  border-bottom: 1rpx solid #e8ddd1;
  transition: all 0.3s ease;
}

.seasonal-item:hover {
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.seasonal-img {
  width: 100%;
  height: 320rpx;
  object-fit: cover;
}

.seasonal-info {
  padding: 24rpx 32rpx;
}

.seasonal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.seasonal-desc {
  font-size: 24rpx;
  color: #666;
  line-height: 1.4;
  margin-bottom: 16rpx;
}

.seasonal-location {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.location-icon {
  font-size: 24rpx;
}

.location-text {
  font-size: 24rpx;
  color: #666;
}

.seasonal-season {
  padding: 4rpx 16rpx;
  background-color: #8B4513;
  color: white;
  border-radius: 12rpx;
  font-size: 20rpx;
  display: inline-block;
}

/* 响应式适配 */
@media (max-width: 375px) {
  .seasonal-img {
    height: 280rpx;
  }
  
  .seasonal-title {
    font-size: 28rpx;
  }
  
  .seasonal-desc {
    font-size: 22rpx;
  }
  
  .seasonal-location {
    font-size: 22rpx;
  }
  
  .seasonal-info {
    padding: 20rpx 24rpx;
  }
}