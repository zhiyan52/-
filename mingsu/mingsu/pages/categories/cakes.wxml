<!-- mingsu/mingsu/pages/categories/cakes.wxml -->
<view class="container">
  <view class="header">
    <view class="header-back" bindtap="goBack">
      <text class="back-icon">←</text>
    </view>
    <view class="header-title">传统糕饼</view>
  </view>
  
  <view class="content">
    <view class="cake-list">
      <view class="cake-item" wx:for="{{cakeList}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
        <image class="cake-img" src="{{item.imageUrl}}" mode="aspectFill" alt="{{item.title}}"></image>
        <view class="cake-info">
          <view class="cake-title">{{item.title}}</view>
          <view class="cake-desc">{{item.desc}}</view>
          <view class="cake-origin">{{item.origin}}</view>
        </view>
      </view>
    </view>
  </view>
</view>
