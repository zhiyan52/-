<!--mingsu/mingsu/pages/categories/categories.wxml-->

<!-- 分类网格 -->
<view class="category-list">
  <view class="category-item" wx:for="{{categories}}" wx:key="id" bindtap="goToCategory" data-id="{{item.id}}">
    <image class="category-img" src="{{item.imageUrl}}" mode="aspectFill" alt="{{item.title}}"></image>
    <view class="category-overlay">
      <view class="category-icon">{{item.icon}}</view>
      <view class="category-title">{{item.title}}</view>
      <view class="category-desc">{{item.desc}}</view>
    </view>
  </view>
</view>