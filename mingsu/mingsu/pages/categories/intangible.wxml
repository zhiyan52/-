<!-- mingsu/mingsu/pages/categories/intangible.wxml -->
<view class="container">
  <view class="header">
    <view class="header-back" bindtap="goBack">
      <text class="back-icon">←</text>
    </view>
    <view class="header-title">非遗食韵</view>
  </view>
  
  <view class="content">
    <view class="intangible-list">
      <view class="intangible-item" wx:for="{{intangibleList}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
        <image class="intangible-img" src="{{item.imageUrl}}" mode="aspectFill" alt="{{item.title}}"></image>
        <view class="intangible-info">
          <view class="intangible-title">{{item.title}}</view>
          <view class="intangible-desc">{{item.desc}}</view>
          <view class="intangible-location" wx:if="{{item.location}}">
            <text class="location-icon">📍</text>
            <text class="location-text">{{item.location}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>
