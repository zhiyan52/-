/* mingsu/mingsu/pages/categories/cakes.wxss */

.container {
  min-height: 100vh;
  background-color: #f9f5f0;
}

/* 顶部导航栏 */
.header {
  display: flex;
  align-items: center;
  padding: 20rpx 32rpx;
  background-color: #8B4513;
  color: white;
  position: sticky;
  top: 0;
  z-index: 100;
}

.header-back {
  font-size: 32rpx;
  padding: 8rpx;
  margin-right: 32rpx;
}

.back-icon {
  font-size: 32rpx;
  font-weight: bold;
}

.header-title {
  font-size: 32rpx;
  font-weight: bold;
  font-family: '楷体', 'STKaiti', serif;
  flex: 1;
}

/* 内容区域 */
.content {
  padding: 24rpx 32rpx;
}

/* 传统糕饼列表 */
.cake-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  margin-bottom: 40rpx;
}

.cake-item {
  background-color: white;
  border-radius: 16rpx;
  overflow: hidden;
  border: 1rpx solid #e8ddd1;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
}

.cake-item:active {
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
  transform: translateY(-4rpx);
}

.cake-img {
  width: 100%;
  height: 240rpx;
  object-fit: cover;
}

.cake-info {
  padding: 24rpx;
}

.cake-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
  font-family: '楷体', 'STKaiti', serif;
}

.cake-desc {
  font-size: 24rpx;
  color: #666;
  line-height: 1.4;
  margin-bottom: 16rpx;
}

.cake-origin {
  font-size: 22rpx;
  color: #999;
  display: flex;
  align-items: center;
}

.cake-origin::before {
  content: '📍';
  margin-right: 8rpx;
  font-size: 20rpx;
}

/* 响应式适配 */
@media (max-width: 375px) {
  .cake-img {
    height: 200rpx;
  }
  
  .header-title {
    font-size: 28rpx;
  }
  
  .cake-title {
    font-size: 28rpx;
  }
  
  .cake-desc {
    font-size: 22rpx;
  }
  
  .cake-origin {
    font-size: 20rpx;
  }
}
