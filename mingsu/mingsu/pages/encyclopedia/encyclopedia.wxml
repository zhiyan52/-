<!--mingsu/mingsu/pages/encyclopedia/encyclopedia.wxml-->

<!-- 头部横幅 -->
<view class="header-banner">
  <view class="banner-content">
    <view class="banner-title">探索中华饮食文化</view>
    <view class="banner-subtitle">节气食俗 · 地域特色 · 非遗技艺</view>
  </view>
</view>

<!-- 课程分类标签 -->
<view class="category-section">
  <scroll-view class="category-scroll" scroll-x scroll-with-animation>
    <view class="category-list">
      <view class="category-item {{currentTab === 'all' ? 'active' : ''}}" bindtap="switchTab" data-tab="all">
        <view class="category-icon">📚</view>
        <view class="category-name">全部</view>
      </view>
      <view class="category-item {{currentTab === 'seasons' ? 'active' : ''}}" bindtap="switchTab" data-tab="seasons">
        <view class="category-icon">🌸</view>
        <view class="category-name">节气</view>
      </view>
      <view class="category-item {{currentTab === 'regions' ? 'active' : ''}}" bindtap="switchTab" data-tab="regions">
        <view class="category-icon">🗺️</view>
        <view class="category-name">地域</view>
      </view>
      <view class="category-item {{currentTab === 'craft' ? 'active' : ''}}" bindtap="switchTab" data-tab="craft">
        <view class="category-icon">🏺</view>
        <view class="category-name">工艺</view>
      </view>
      <view class="category-item {{currentTab === 'history' ? 'active' : ''}}" bindtap="switchTab" data-tab="history">
        <view class="category-icon">📜</view>
        <view class="category-name">历史</view>
      </view>
    </view>
  </scroll-view>
</view>

<!-- 推荐课程 -->
<view class="featured-section" wx:if="{{currentTab === 'all'}}">
  <view class="section-header">
    <view class="section-icon">⭐</view>
    <view class="section-title">推荐课程</view>
  </view>
  <view class="featured-card" bindtap="goToCourseDetail" data-id="{{featuredCourse.id}}">
    <image class="featured-img" src="{{featuredCourse.imageUrl}}" mode="aspectFill"></image>
    <view class="featured-overlay">
      <view class="featured-tag">精品课程</view>
      <view class="featured-title">{{featuredCourse.title}}</view>
      <view class="featured-desc">{{featuredCourse.desc}}</view>
      <view class="featured-meta">
        <text class="meta-item">{{featuredCourse.duration}}</text>
        <text class="meta-item">{{featuredCourse.viewCount}}人学习</text>
      </view>
    </view>
  </view>
</view>

<!-- 课程列表 -->
<view class="course-section">
  <view class="section-header">
    <view class="section-icon">📖</view>
    <view class="section-title">{{currentTab === 'all' ? '全部课程' : categoryTitle}}</view>
    <view class="course-count">共 {{filteredCourses.length}} 门</view>
  </view>
  <view class="course-list">
    <view class="course-card" wx:for="{{filteredCourses}}" wx:key="id" bindtap="goToCourseDetail" data-id="{{item.id}}">
      <view class="course-image-wrapper">
        <image class="course-img" src="{{item.imageUrl}}" mode="aspectFill"></image>
        <view class="course-tag">{{item.category}}</view>
      </view>
      <view class="course-content">
        <view class="course-title">{{item.title}}</view>
        <view class="course-desc">{{item.desc}}</view>
        <view class="course-footer">
          <view class="course-meta">
            <text class="meta-icon">⏱️</text>
            <text class="meta-text">{{item.duration}}</text>
          </view>
          <view class="course-meta">
            <text class="meta-icon">👁️</text>
            <text class="meta-text">{{item.viewCount}}人学习</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>

<!-- 加载更多 -->
<view class="load-more" wx:if="{{hasMore}}">
  <view class="load-more-btn" bindtap="loadMore">
    <text>加载更多课程</text>
  </view>
</view>

<!-- 底部提示 -->
<view class="bottom-tip" wx:if="{{!hasMore}}">
  <text>已经到底啦，更多精彩课程敬请期待</text>
</view>
