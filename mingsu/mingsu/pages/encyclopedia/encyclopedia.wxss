/* mingsu/mingsu/pages/encyclopedia/encyclopedia.wxss */

page {
  background-color: #f8f5f0;
  font-family: '楷体', 'STKaiti', serif;
}

/* 顶部导航栏 */
.top-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  background-color: #2E7D32;
  color: white;
  position: sticky;
  top: 0;
  z-index: 100;
}

.back-btn {
  font-size: 36rpx;
  padding: 10rpx;
}

.back-icon {
  font-size: 40rpx;
}

.nav-title {
  font-size: 36rpx;
  font-weight: bold;
  font-family: '楷体', 'STKaiti', serif;
}

.placeholder {
  width: 60rpx;
}

/* 头部横幅 */
.header-banner {
  background: linear-gradient(135deg, #2E7D32 0%, #1B5E20 100%);
  padding: 60rpx 40rpx;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.header-banner::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: url('data:image/svg+xml,<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100"><circle cx="50" cy="50" r="40" fill="none" stroke="rgba(255,255,255,0.1)" stroke-width="0.5"/></svg>') repeat;
  opacity: 0.3;
}

.banner-content {
  position: relative;
  z-index: 1;
}

.banner-title {
  font-size: 48rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 16rpx;
  font-family: '楷体', 'STKaiti', serif;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

.banner-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  letter-spacing: 4rpx;
}

/* 课程分类标签 */
.category-section {
  background-color: white;
  padding: 24rpx 0;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.category-scroll {
  white-space: nowrap;
}

.category-list {
  display: flex;
  padding: 0 24rpx;
  gap: 20rpx;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 32rpx;
  border-radius: 16rpx;
  background-color: #f8f5f0;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
  min-width: 120rpx;
}

.category-item.active {
  background-color: #2E7D32;
  border-color: #2E7D32;
}

.category-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.category-name {
  font-size: 26rpx;
  color: #666;
  font-weight: bold;
}

.category-item.active .category-name {
  color: white;
}

/* 推荐课程 */
.featured-section {
  margin: 0 24rpx 32rpx;
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2E7D32;
  font-family: '楷体', 'STKaiti', serif;
}

.course-count {
  font-size: 24rpx;
  color: #999;
  margin-left: auto;
}

.featured-card {
  position: relative;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.featured-img {
  width: 100%;
  height: 400rpx;
  object-fit: cover;
}

.featured-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.8));
  padding: 40rpx 32rpx 32rpx;
  color: white;
}

.featured-tag {
  display: inline-block;
  background-color: #FFD700;
  color: #333;
  font-size: 22rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
  font-weight: bold;
}

.featured-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
  font-family: '楷体', 'STKaiti', serif;
}

.featured-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.5;
  margin-bottom: 16rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.featured-meta {
  display: flex;
  gap: 24rpx;
}

.meta-item {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 课程列表 */
.course-section {
  margin: 0 24rpx;
}

.course-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.course-card {
  display: flex;
  background-color: white;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid #e8ddd1;
  transition: transform 0.3s ease;
}

.course-card:active {
  transform: scale(0.98);
}

.course-image-wrapper {
  position: relative;
  width: 240rpx;
  height: 240rpx;
  flex-shrink: 0;
}

.course-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.course-tag {
  position: absolute;
  top: 12rpx;
  left: 12rpx;
  background-color: #2E7D32;
  color: white;
  font-size: 20rpx;
  padding: 6rpx 16rpx;
  border-radius: 12rpx;
}

.course-content {
  flex: 1;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.course-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
  font-family: '楷体', 'STKaiti', serif;
}

.course-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  margin-bottom: 16rpx;
}

.course-footer {
  display: flex;
  gap: 24rpx;
}

.course-meta {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.meta-icon {
  font-size: 24rpx;
}

.meta-text {
  font-size: 24rpx;
  color: #999;
}

/* 加载更多 */
.load-more {
  padding: 40rpx 24rpx;
  text-align: center;
}

.load-more-btn {
  display: inline-block;
  padding: 20rpx 60rpx;
  background-color: #2E7D32;
  color: white;
  font-size: 28rpx;
  border-radius: 40rpx;
  font-family: '楷体', 'STKaiti', serif;
}

/* 底部提示 */
.bottom-tip {
  text-align: center;
  padding: 40rpx 24rpx;
  color: #999;
  font-size: 26rpx;
}

/* 响应式适配 */
@media (max-width: 375px) {
  .category-item {
    padding: 16rpx 24rpx;
    min-width: 100rpx;
  }
  
  .category-icon {
    font-size: 40rpx;
  }
  
  .category-name {
    font-size: 24rpx;
  }
  
  .course-image-wrapper {
    width: 200rpx;
    height: 200rpx;
  }
}