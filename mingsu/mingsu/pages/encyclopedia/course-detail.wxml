<!--mingsu/mingsu/pages/encyclopedia/course-detail.wxml-->

<!-- 课程封面区域 -->
<view class="course-hero">
  <image class="hero-image" src="{{course.imageUrl}}" mode="aspectFill"></image>
  <view class="hero-overlay">
    <view class="hero-content">
      <view class="category-tag">{{course.category}}</view>
      <view class="hero-title">{{course.title}}</view>
      <view class="hero-meta">
        <view class="meta-item">
          <text class="meta-icon">⏱️</text>
          <text class="meta-text">{{course.duration}}</text>
        </view>
        <view class="meta-item">
          <text class="meta-icon">👁️</text>
          <text class="meta-text">{{course.viewCount}}人学习</text>
        </view>
        <view class="meta-item">
          <text class="meta-icon">📚</text>
          <text class="meta-text">{{course.content.length}}节内容</text>
        </view>
      </view>
    </view>
  </view>
</view>

<!-- 学习进度卡片 -->
<view class="progress-card">
  <view class="progress-info">
    <view class="progress-label">学习进度</view>
    <view class="progress-value">{{progress}}%</view>
  </view>
  <view class="progress-track">
    <view class="progress-fill" style="width: {{progress}}%"></view>
  </view>
  <view class="progress-status" wx:if="{{isCompleted}}">
    <text class="status-icon">🏆</text>
    <text class="status-text">恭喜！已完成本课程学习</text>
  </view>
</view>

<!-- 课程简介 -->
<view class="intro-section">
  <view class="section-title">课程简介</view>
  <view class="intro-text">{{course.desc}}</view>
</view>

<!-- 课程内容目录 -->
<view class="catalog-section">
  <view class="section-header">
    <view class="section-title">课程目录</view>
    <view class="section-count">共 {{course.content.length}} 节</view>
  </view>
  <view class="catalog-list">
    <view class="catalog-item {{item.type}} {{currentSection === index ? 'active' : ''}}" 
          wx:for="{{course.content}}" 
          wx:key="index"
          bindtap="scrollToSection"
          data-index="{{index}}">
      <view class="item-number">{{index + 1}}</view>
      <view class="item-content">
        <view class="item-title" wx:if="{{item.type === 'title'}}">{{item.content}}</view>
        <view class="item-text" wx:if="{{item.type === 'text'}}">{{item.content}}</view>
      </view>
      <view class="item-icon" wx:if="{{item.type === 'title'}}">📖</view>
      <view class="item-icon" wx:if="{{item.type === 'text'}}">📝</view>
    </view>
  </view>
</view>

<!-- 详细内容 -->
<view class="detail-section">
  <view class="section-title">详细内容</view>
  <view class="detail-content">
    <view class="content-block {{item.type}}" 
          wx:for="{{course.content}}" 
          wx:key="index"
          id="section-{{index}}">
      <view class="block-title" wx:if="{{item.type === 'title'}}">
        <view class="title-line"></view>
        <view class="title-text">{{item.content}}</view>
        <view class="title-line"></view>
      </view>
      <view class="block-text" wx:if="{{item.type === 'text'}}">
        <view class="text-indent"></view>
        <view class="text-content">{{item.content}}</view>
      </view>
    </view>
  </view>
</view>

<!-- 知识要点 -->
<view class="keypoints-section" wx:if="{{keyPoints.length > 0}}">
  <view class="section-title">知识要点</view>
  <view class="keypoints-list">
    <view class="keypoint-item" wx:for="{{keyPoints}}" wx:key="index">
      <view class="point-icon">💡</view>
      <view class="point-text">{{item}}</view>
    </view>
  </view>
</view>

<!-- 学习操作区 -->
<view class="action-area">
  <view class="action-btn primary" bindtap="completeLearning" wx:if="{{!isCompleted}}">
    <view class="btn-content">
      <text class="btn-icon">✓</text>
      <view class="btn-info">
        <text class="btn-title">完成学习</text>
        <text class="btn-subtitle">获得10积分奖励</text>
      </view>
    </view>
  </view>
  <view class="action-btn completed" wx:if="{{isCompleted}}">
    <view class="btn-content">
      <text class="btn-icon">✓</text>
      <view class="btn-info">
        <text class="btn-title">已完成学习</text>
        <text class="btn-subtitle">已获得10积分</text>
      </view>
    </view>
  </view>
  <view class="action-btn secondary" bindtap="shareCourse">
    <text class="btn-icon">↗️</text>
    <text class="btn-title">分享课程</text>
  </view>
</view>

<!-- 底部间距 -->
<view class="bottom-space"></view>
