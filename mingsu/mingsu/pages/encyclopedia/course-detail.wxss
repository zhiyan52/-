/* mingsu/mingsu/pages/encyclopedia/course-detail.wxss */

page {
  background-color: #f8f5f0;
  font-family: '楷体', 'STKaiti', serif;
}

/* 课程封面区域 */
.course-hero {
  position: relative;
  width: 100%;
  height: 450rpx;
}

.hero-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.hero-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.85));
  padding: 60rpx 32rpx 32rpx;
}

.hero-content {
  color: white;
}

.category-tag {
  display: inline-block;
  background-color: #2E7D32;
  color: white;
  font-size: 22rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  margin-bottom: 16rpx;
}

.hero-title {
  font-size: 44rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  font-family: '楷体', 'STKaiti', serif;
  line-height: 1.3;
}

.hero-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.9);
}

.meta-icon {
  font-size: 28rpx;
}

.meta-text {
  font-size: 26rpx;
}

/* 学习进度卡片 */
.progress-card {
  background-color: white;
  margin: 24rpx;
  padding: 32rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.progress-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.progress-label {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  font-family: '楷体', 'STKaiti', serif;
}

.progress-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #2E7D32;
}

.progress-track {
  width: 100%;
  height: 16rpx;
  background-color: #e0e0e0;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #2E7D32, #4CAF50);
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.progress-status {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 20rpx;
  background-color: #e8f5e9;
  border-radius: 12rpx;
}

.status-icon {
  font-size: 36rpx;
}

.status-text {
  font-size: 28rpx;
  color: #2E7D32;
  font-weight: bold;
}

/* 课程简介 */
.intro-section {
  background-color: white;
  margin: 24rpx;
  padding: 32rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #2E7D32;
  margin-bottom: 20rpx;
  font-family: '楷体', 'STKaiti', serif;
  border-left: 6rpx solid #2E7D32;
  padding-left: 16rpx;
}

.intro-text {
  font-size: 30rpx;
  color: #666;
  line-height: 1.8;
  text-align: justify;
}

/* 课程目录 */
.catalog-section {
  background-color: white;
  margin: 24rpx;
  padding: 32rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-count {
  font-size: 26rpx;
  color: #999;
}

.catalog-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.catalog-item {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background-color: #f8f5f0;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.catalog-item.active {
  background-color: #e8f5e9;
  border-color: #2E7D32;
}

.catalog-item.title {
  background-color: #fff3e0;
}

.item-number {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #2E7D32;
  color: white;
  border-radius: 50%;
  font-size: 24rpx;
  font-weight: bold;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.item-content {
  flex: 1;
  overflow: hidden;
}

.item-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  font-family: '楷体', 'STKaiti', serif;
}

.item-text {
  font-size: 28rpx;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-icon {
  font-size: 32rpx;
  margin-left: 16rpx;
}

/* 详细内容 */
.detail-section {
  background-color: white;
  margin: 24rpx;
  padding: 32rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.detail-content {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
}

.content-block {
  line-height: 1.8;
}

.block-title {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.title-line {
  flex: 1;
  height: 2rpx;
  background-color: #e8ddd1;
}

.title-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #2E7D32;
  font-family: '楷体', 'STKaiti', serif;
  white-space: nowrap;
}

.block-text {
  display: flex;
  gap: 16rpx;
}

.text-indent {
  width: 40rpx;
  height: 40rpx;
  background-color: #2E7D32;
  border-radius: 8rpx;
  flex-shrink: 0;
  margin-top: 8rpx;
}

.text-content {
  font-size: 30rpx;
  color: #333;
  line-height: 1.8;
  text-align: justify;
}

/* 知识要点 */
.keypoints-section {
  background-color: white;
  margin: 24rpx;
  padding: 32rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
}

.keypoints-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.keypoint-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 20rpx;
  background-color: #f8f5f0;
  border-radius: 12rpx;
  border-left: 6rpx solid #2E7D32;
}

.point-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

.point-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
}

/* 学习操作区 */
.action-area {
  margin: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.action-btn {
  padding: 32rpx;
  border-radius: 16rpx;
  text-align: center;
  transition: all 0.3s ease;
}

.action-btn.primary {
  background: linear-gradient(135deg, #2E7D32, #1B5E20);
  box-shadow: 0 8rpx 24rpx rgba(46, 125, 50, 0.3);
}

.action-btn.primary:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(46, 125, 50, 0.3);
}

.action-btn.completed {
  background-color: #e8f5e9;
  border: 2rpx solid #2E7D32;
}

.action-btn.secondary {
  background-color: #f8f5f0;
  border: 2rpx solid #e8ddd1;
}

.action-btn.secondary:active {
  background-color: #f0ebe3;
}

.btn-content {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
}

.btn-icon {
  font-size: 40rpx;
}

.btn-info {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.btn-title {
  font-size: 34rpx;
  font-weight: bold;
  color: white;
  font-family: '楷体', 'STKaiti', serif;
}

.action-btn.completed .btn-title {
  color: #2E7D32;
}

.action-btn.secondary .btn-title {
  color: #666;
}

.btn-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 4rpx;
}

.action-btn.completed .btn-subtitle {
  color: #666;
}

/* 底部间距 */
.bottom-space {
  height: 60rpx;
}

/* 响应式适配 */
@media (max-width: 375px) {
  .course-hero {
    height: 380rpx;
  }
  
  .hero-title {
    font-size: 38rpx;
  }
  
  .title-text {
    font-size: 32rpx;
  }
  
  .text-content {
    font-size: 28rpx;
  }
}
