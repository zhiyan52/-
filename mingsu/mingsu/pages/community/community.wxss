/* mingsu/mingsu/pages/community/community.wxss */

/* 顶部导航栏 */
.top-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx;
  background-color: #8B4513;
  color: white;
  position: sticky;
  top: 0;
  z-index: 100;
}

.back-btn {
  font-size: 32rpx;
  padding: 8rpx;
}

.nav-title {
  font-size: 32rpx;
  font-weight: bold;
  font-family: '楷体', 'STKaiti', serif;
  flex: 1;
  text-align: center;
  margin: 0 32rpx;
}

.publish-btn {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.publish-btn:hover {
  background-color: rgba(255, 255, 255, 0.3);
}

/* 话题列表 */
.posts-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 24rpx;
  margin-bottom: 40rpx;
}

.post-item {
  background-color: white;
  border-radius: 16rpx;
  padding: 24rpx;
  border: 1rpx solid #e8ddd1;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
}

.post-item:hover {
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.1);
  transform: translateY(-4rpx);
}

.post-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.user-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  object-fit: cover;
  border: 2rpx solid #e8ddd1;
}

.user-info {
  flex: 1;
}

.user-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 4rpx;
}

.post-time {
  font-size: 20rpx;
  color: #999;
}

.post-content {
  font-size: 24rpx;
  color: #333;
  line-height: 1.5;
  margin-bottom: 16rpx;
}

.post-images {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.post-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  object-fit: cover;
  border: 1rpx solid #e8ddd1;
}

.post-actions {
  display: flex;
  gap: 40rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0e6d8;
}

.action-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 24rpx;
  color: #666;
  transition: all 0.3s ease;
}

.action-item:hover {
  color: #8B4513;
}

.action-icon {
  font-size: 28rpx;
}

/* 发布话题弹窗 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
}

.post-modal {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: white;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx;
  z-index: 1001;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  font-family: '楷体', 'STKaiti', serif;
}

.close-btn {
  font-size: 40rpx;
  color: #999;
  padding: 8rpx;
  transition: all 0.3s ease;
}

.close-btn:hover {
  color: #333;
}

.post-input {
  width: 100%;
  min-height: 200rpx;
  font-size: 24rpx;
  color: #333;
  line-height: 1.5;
  padding: 20rpx;
  background-color: #f8f5f0;
  border: 1rpx solid #e8ddd1;
  border-radius: 12rpx;
  resize: none;
  margin-bottom: 24rpx;
}

.post-input::placeholder {
  color: #999;
}

.modal-footer {
  display: flex;
  gap: 24rpx;
}

.cancel-btn, .confirm-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: bold;
  transition: all 0.3s ease;
}

.cancel-btn {
  background-color: #f8f5f0;
  color: #666;
  border: 1rpx solid #e8ddd1;
}

.confirm-btn {
  background-color: #8B4513;
  color: white;
  border: 1rpx solid #8B4513;
}

.confirm-btn:hover {
  background-color: #6B340F;
}

/* 响应式适配 */
@media (max-width: 375px) {
  .posts-list {
    padding: 16rpx;
  }
  
  .post-item {
    padding: 20rpx;
  }
  
  .post-image {
    width: 140rpx;
    height: 140rpx;
  }
  
  .post-actions {
    gap: 32rpx;
  }
  
  .post-modal {
    padding: 24rpx;
  }
}