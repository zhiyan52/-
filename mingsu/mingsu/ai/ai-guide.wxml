<!-- 民俗智能导览页面 -->
<view class="guide-container">
  <view class="header">
    <text class="title">民俗智能导览</text>
    <text class="subtitle">AI带你探索民俗文化</text>
  </view>
  
  <view class="selection-section">
    <text class="section-title">选择民俗项目</text>
    <view class="folk-list">
      <view class="folk-item {{selectedFolk === item.id ? 'active' : ''}}" wx:for="{{folkList}}" wx:key="id" bindtap="selectFolk" data-id="{{item.id}}">
        <image class="folk-image" src="{{item.image}}" mode="aspectFill" />
        <view class="folk-info">
          <text class="folk-name">{{item.name}}</text>
          <text class="folk-category">{{item.category}}</text>
        </view>
      </view>
    </view>
  </view>
  
  <view class="guide-content" wx:if="{{selectedFolk}}">
    <view class="content-header">
      <text class="content-title">{{currentFolk.name}}</text>
      <view class="guide-tag">AI讲解</view>
    </view>
    
    <view class="loading" wx:if="{{loading}}">
      <text>AI正在生成讲解内容...</text>
    </view>
    
    <view class="guide-text" wx:else>
      <text>{{guideText}}</text>
    </view>
    
    <view class="action-buttons">
      <view class="action-btn" bindtap="playVoice">
        <text class="btn-icon">🔊</text>
        <text>播放语音</text>
      </view>
      <view class="action-btn" bindtap="regenerate">
        <text class="btn-icon">🔄</text>
        <text>重新生成</text>
      </view>
    </view>
  </view>
</view>