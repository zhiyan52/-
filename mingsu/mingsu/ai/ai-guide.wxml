<!-- 智能导览页面 -->
<view class="ai-guide-container">
  <view class="header">
    <text class="title">智能导览</text>
    <text class="subtitle">AI为您讲解民俗</text>
  </view>

  <view class="custom-list">
    <text class="section-title">选择民俗</text>
    <view class="custom-items">
      <view class="custom-item" bindtap="selectCustom" data-custom="spring-festival">
        <image src="cloud://cloud1-8glc9jqob91870fc.636c-cloud1-8glc9jqob91870fc-1401141450/mingsu/voi/1.jpg" class="custom-image" />
        <text class="custom-name">春节</text>
      </view>
      <view class="custom-item" bindtap="selectCustom" data-custom="mid-autumn">
        <image src="cloud://cloud1-8glc9jqob91870fc.636c-cloud1-8glc9jqob91870fc-1401141450/mingsu/voi/2.jpg" class="custom-image" />
        <text class="custom-name">中秋节</text>
      </view>
      <view class="custom-item" bindtap="selectCustom" data-custom="dragon-boat">
        <image src="cloud://cloud1-8glc9jqob91870fc.636c-cloud1-8glc9jqob91870fc-1401141450/mingsu/voi/3.jpg" class="custom-image" />
        <text class="custom-name">端午节</text>
      </view>
      <view class="custom-item" bindtap="selectCustom" data-custom="double-ninth">
        <image src="cloud://cloud1-8glc9jqob91870fc.636c-cloud1-8glc9jqob91870fc-1401141450/mingsu/voi/4.jpg" class="custom-image" />
        <text class="custom-name">重阳节</text>
      </view>
    </view>
  </view>

  <view class="ai-content" wx:if="{{selectedCustom}}">
    <text class="content-title">{{selectedCustom.name}}导览</text>
    <view class="ai-response">
      <view class="loading" wx:if="{{loading}}">
        <text>AI正在生成讲解...</text>
      </view>
      <view wx:else>
        <text class="ai-text">{{aiResponse}}</text>
      </view>
    </view>
    <view class="control-buttons">
      <button class="button" bindtap="startGuide">开始导览</button>
      <button class="button" bindtap="stopGuide">停止导览</button>
    </view>
  </view>
</view>
