/* ===== 民俗智能导览页面样式 ===== */

/* 页面容器 */
.page-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #f8f6f0 0%, #e8e0d0 100%);
  font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif;
}

/* 顶部标题 */
.page-title {
  padding: 32rpx 40rpx;
  text-align: center;
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(139, 69, 19, 0.3);
  position: relative;
  z-index: 10;
}

.page-title text {
  font-size: 36rpx;
  font-weight: bold;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.3);
  letter-spacing: 4rpx;
}

/* 地图上传区域 */
.map-upload-section {
  margin: 32rpx 40rpx;
  padding: 40rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
  border: 2rpx solid #D4A017;
}

.upload-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #8B4513;
  margin-bottom: 24rpx;
  text-align: center;
}

.upload-container {
  border: 2rpx dashed #D4A017;
  border-radius: 12rpx;
  padding: 40rpx;
  text-align: center;
  background: #faf8f3;
}

.upload-btn {
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  color: #fff;
  border: none;
  border-radius: 50rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(139, 69, 19, 0.3);
  transition: all 0.3s;
}

.upload-btn:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 16rpx rgba(139, 69, 19, 0.4);
}

/* 分区导航 */
.zone-nav {
  margin: 0 40rpx 32rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
  border: 2rpx solid #D4A017;
}

.zone-tabs {
  display: flex;
  overflow-x: auto;
  gap: 16rpx;
  padding: 8rpx 0;
}

.zone-tab {
  flex-shrink: 0;
  padding: 16rpx 32rpx;
  border-radius: 50rpx;
  font-size: 24rpx;
  font-weight: bold;
  transition: all 0.3s;
  border: 2rpx solid #D4A017;
}

.zone-tab.active {
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(139, 69, 19, 0.3);
}

.zone-tab:not(.active) {
  background: #faf8f3;
  color: #8B4513;
}

.zone-tab:not(.active):hover {
  background: #f0e8d8;
  transform: translateY(-2rpx);
}

/* 路线选择 */
.route-section {
  margin: 0 40rpx 32rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
  border: 2rpx solid #D4A017;
}

.route-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #8B4513;
  margin-bottom: 24rpx;
  text-align: center;
}

.route-options {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.route-option {
  padding: 20rpx;
  border: 2rpx solid #D4A017;
  border-radius: 12rpx;
  text-align: center;
  background: #faf8f3;
  transition: all 0.3s;
  cursor: pointer;
}

.route-option:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 12rpx rgba(212, 160, 23, 0.2);
}

.route-option.active {
  background: linear-gradient(135deg, #D4A017 0%, #E6C997 100%);
  color: #8B4513;
  box-shadow: 0 4rpx 12rpx rgba(212, 160, 23, 0.3);
}

.route-option loading {
  font-size: 20rpx;
  color: #888;
}

.route-name {
  font-size: 24rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.route-desc {
  font-size: 18rpx;
  color: #666;
}

/* 路线信息 */
.route-info {
  margin: 0 40rpx 32rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
  border: 2rpx solid #D4A017;
}

.route-info-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #8B4513;
  margin-bottom: 16rpx;
}

.route-stats {
  display: flex;
  justify-content: space-around;
  margin-top: 16rpx;
}

.stat-item {
  text-align: center;
}

.stat-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #8B4513;
}

.stat-label {
  font-size: 20rpx;
  color: #666;
  margin-top: 4rpx;
}

/* 热区编辑 */
.edit-section {
  margin: 0 40rpx 32rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
  border: 2rpx solid #D4A017;
}

.edit-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #8B4513;
  margin-bottom: 24rpx;
  text-align: center;
}

.edit-controls {
  display: flex;
  gap: 16rpx;
  justify-content: center;
}

.edit-btn {
  padding: 16rpx 32rpx;
  border-radius: 50rpx;
  font-size: 24rpx;
  font-weight: bold;
  transition: all 0.3s;
  border: 2rpx solid #D4A017;
}

.edit-btn.primary {
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(139, 69, 19, 0.3);
}

.edit-btn.secondary {
  background: #faf8f3;
  color: #8B4513;
}

.edit-btn:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 16rpx rgba(139, 69, 19, 0.4);
}

/* ===== 民俗场馆地图 ===== */
.map-container {
  position: relative;
  height: 600rpx;
  margin: 20rpx 40rpx;
  border-radius: 16rpx;
  overflow: hidden;
  background: #f0f7ff;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.15);
  border: 4rpx solid #D4A017;
}

.venue-map {
  width: 100%;
  height: 100%;
  object-fit: contain;
  position: absolute;
  top: 0;
  left: 0;
  z-index: 1;
}

.hotspots-layer {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 2;
  pointer-events: none;
}

.hotspot {
  position: absolute;
  pointer-events: auto;
  cursor: pointer;
  z-index: 3;
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: all 0.3s;
}

.hotspot:hover {
  transform: scale(1.1);
}

.hotspot-marker {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(139, 69, 19, 0.6);
  transition: all 0.3s;
  z-index: 2;
  border: 2rpx solid #D4A017;
}

.hotspot.active .hotspot-marker {
  transform: scale(1.2);
  background: linear-gradient(135deg, #D4A017 0%, #E6C997 100%);
  box-shadow: 0 0 24rpx rgba(212, 160, 23, 0.8);
}

.hotspot-label {
  margin-top: 8rpx;
  background: rgba(139, 69, 19, 0.9);
  color: #fff;
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  font-size: 20rpx;
  white-space: nowrap;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.3);
  z-index: 1;
}

.hotspot.edit-mode {
  cursor: move;
}

.hotspot.edit-mode .hotspot-marker {
  border: 4rpx dashed #D4A017;
  background: rgba(139, 69, 19, 0.7);
}

.route-path {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 2;
  pointer-events: none;
}

.route-canvas {
  width: 100%;
  height: 100%;
}

.map-controls {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  z-index: 10;
}

.control-btn {
  background: rgba(255, 255, 255, 0.9);
  border: 2rpx solid #D4A017;
  border-radius: 8rpx;
  padding: 12rpx 16rpx;
  font-size: 20rpx;
  font-weight: bold;
  color: #8B4513;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.2);
  transition: all 0.3s;
}

.control-btn:hover {
  background: #D4A017;
  color: #fff;
  transform: translateY(-2rpx);
}

/* 点位详情 */
.point-detail {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-top-left-radius: 32rpx;
  border-top-right-radius: 32rpx;
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.15);
  padding: 32rpx 40rpx;
  z-index: 100;
  max-height: 50vh;
  overflow-y: auto;
  border-top: 4rpx solid #D4A017;
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.detail-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #8B4513;
  flex: 1;
}

.close-btn {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: #666;
  transition: all 0.3s;
}

.close-btn:hover {
  background: #D4A017;
  color: #fff;
}

.detail-content {
  font-size: 24rpx;
  line-height: 1.6;
  color: #333;
  margin-bottom: 24rpx;
}

.ai-story {
  margin-top: 24rpx;
  padding: 24rpx;
  background: #faf8f3;
  border-radius: 12rpx;
  border-left: 4rpx solid #D4A017;
}

.ai-story-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #8B4513;
  margin-bottom: 16rpx;
}

.ai-story-content {
  font-size: 22rpx;
  line-height: 1.6;
  color: #555;
  font-style: italic;
}

.story-btn {
  margin-top: 16rpx;
  background: linear-gradient(135deg, #D4A017 0%, #E6C997 100%);
  color: #8B4513;
  border: none;
  border-radius: 50rpx;
  padding: 16rpx 32rpx;
  font-size: 24rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(212, 160, 23, 0.3);
  transition: all 0.3s;
}

.story-btn:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 16rpx rgba(212, 160, 23, 0.4);
}

/* AI生成弹窗 */
.ai-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 200;
}

.ai-modal-content {
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx;
  max-width: 80%;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(0,0,0,0.3);
  border: 4rpx solid #D4A017;
}

.ai-modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #8B4513;
  margin-bottom: 24rpx;
}

.ai-modal-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.ai-modal-message {
  font-size: 24rpx;
  color: #666;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  padding: 24rpx 40rpx;
  display: flex;
  gap: 16rpx;
  box-shadow: 0 -4rpx 16rpx rgba(139, 69, 19, 0.3);
  z-index: 50;
}

.action-btn {
  flex: 1;
  padding: 20rpx;
  border-radius: 50rpx;
  font-size: 24rpx;
  font-weight: bold;
  transition: all 0.3s;
  border: 2rpx solid #D4A017;
}

.action-btn.primary {
  background: #D4A017;
  color: #8B4513;
  box-shadow: 0 4rpx 12rpx rgba(212, 160, 23, 0.3);
}

.action-btn.secondary {
  background: rgba(255, 255, 255, 0.1);
  color: #fff;
}

.action-btn:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 16rpx rgba(0,0,0,0.2);
}

/* 加载动画 */
@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid #f3f3f3;
  border-top: 4rpx solid #8B4513;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

/* 响应式设计 */
@media (max-width: 768px) {
  .route-options {
    grid-template-columns: 1fr;
  }
  
  .map-container {
    height: 500rpx;
  }
  
  .point-detail {
    max-height: 60vh;
  }
}

/* 隐藏滚动条 */
::-webkit-scrollbar {
  display: none;
}

/* 提示样式 */
.toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  background: rgba(0, 0, 0, 0.7);
  color: #fff;
  padding: 16rpx 32rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  z-index: 300;
}
