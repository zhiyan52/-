/* 个性化推荐页面样式 */
.ai-recommend-container {
  background-color: #fafffe;
  min-height: 100vh;
  padding: 20rpx 30rpx;
}

.header {
  text-align: center;
  padding: 40rpx 0 30rpx;
}

.title {
  font-size: 48rpx;
  font-weight: 500;
  color: #333;
  letter-spacing: 2rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #888;
  margin-top: 10rpx;
  display: block;
}

.history-section {
  margin-top: 40rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 30rpx;
  display: block;
}

.history-list {
  background: #f8f9fa;
  border-radius: 16rpx;
  padding: 20rpx;
}

.history-item {
  display: flex;
  gap: 20rpx;
  padding: 20rpx;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 15rpx;
}

.history-image {
  width: 100rpx;
  height: 80rpx;
  border-radius: 8rpx;
}

.history-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.history-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 400;
}

.history-time {
  font-size: 22rpx;
  color: #999;
}

.empty-history {
  text-align: center;
  padding: 60rpx 0;
  color: #999;
  font-size: 28rpx;
}

.recommend-section {
  margin-top: 50rpx;
}

.recommend-list {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.recommend-item {
  background: #f8f9fa;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.recommend-image {
  width: 100%;
  height: 200rpx;
}

.recommend-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  padding: 15rpx;
  display: block;
}

.recommend-desc {
  font-size: 24rpx;
  color: #666;
  padding: 0 15rpx 10rpx;
  line-height: 1.4;
  display: block;
}

.recommend-tags {
  padding: 0 15rpx 15rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.tag {
  font-size: 20rpx;
  color: #666;
  padding: 4rpx 12rpx;
  background: #e8e8e8;
  border-radius: 8rpx;
}

.refresh-section {
  margin-top: 40rpx;
  text-align: center;
}

.refresh-button {
  width: 80%;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  background: #333;
  color: #fff;
  font-size: 28rpx;
}
