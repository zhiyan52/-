/* mingsu/mingsu/mingsu.wxss */
/* 全局样式 */
page {
  background-color: #f8f5f0;
  font-family: '楷体', 'STKaiti', serif;
}

/* 搜索区域 */
.search-section {
  padding: 24rpx 32rpx;
  background-color: #2E7D32;
}

.search-box {
  display: flex;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  padding: 16rpx 24rpx;
}

.search-icon {
  margin-right: 12rpx;
  font-size: 28rpx;
}

.search-placeholder {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* Banner轮播 */
.banner-swiper {
  width: 100%;
  height: 400rpx;
  position: relative;
}

.banner-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.banner-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.7));
  padding: 40rpx 32rpx;
  color: white;
}

.banner-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.banner-subtitle {
  font-size: 24rpx;
  opacity: 0.9;
}

/* 四大分类图标区 */
.category-icons {
  display: flex;
  justify-content: space-around;
  padding: 40rpx 0;
  background-color: white;
  margin: 24rpx 0;
}

.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.category-icon {
  font-size: 64rpx;
  width: 120rpx;
  height: 120rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #f8f5f0;
  border-radius: 24rpx;
  border: 1rpx solid #2E7D32;
}

.category-name {
  font-size: 24rpx;
  color: #333;
  font-weight: bold;
}

/* 通用区域样式 */
.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 32rpx;
  margin: 40rpx 0 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2E7D32;
  font-family: '楷体', 'STKaiti', serif;
}

.section-more {
  font-size: 24rpx;
  color: #2E7D32;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

/* 时令食俗推荐区 */
.seasonal-section {
  margin-bottom: 32rpx;
}

.seasonal-list {
  display: flex;
  gap: 24rpx;
  padding: 0 32rpx;
  overflow-x: auto;
  scrollbar-width: none;
}

.seasonal-list::-webkit-scrollbar {
  display: none;
}

.seasonal-item {
  flex: 0 0 280rpx;
  background-color: white;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid #2E7D32;
}

.seasonal-img {
  width: 100%;
  height: 200rpx;
  object-fit: cover;
}

.seasonal-info {
  padding: 20rpx;
}

.seasonal-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.seasonal-desc {
  font-size: 24rpx;
  color: #666;
  line-height: 1.4;
}

/* 民俗美食文化瀑布流 */
.waterfall-section {
  margin-bottom: 32rpx;
}

.waterfall-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
  padding: 0 32rpx;
}

.waterfall-item {
  background-color: white;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid #2E7D32;
}

.waterfall-img {
  width: 100%;
  height: 200rpx;
  object-fit: cover;
}

.waterfall-info {
  padding: 20rpx;
}

.waterfall-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.waterfall-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.tag {
  padding: 4rpx 12rpx;
  background-color: #f8f5f0;
  border-radius: 12rpx;
  font-size: 20rpx;
  color: #2E7D32;
  border: 1rpx solid #2E7D32;
}

/* 食文化小课堂入口 */
.classroom-section {
  margin: 32rpx;
  background-color: white;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid #2E7D32;
}

.classroom-content {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.classroom-icon {
  font-size: 64rpx;
}

.classroom-info {
  flex: 1;
}

.classroom-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2E7D32;
  margin-bottom: 8rpx;
}

.classroom-desc {
  font-size: 24rpx;
  color: #666;
}

.classroom-arrow {
  font-size: 32rpx;
  color: #2E7D32;
}

/* 底部导航 */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-around;
  align-items: center;
  background-color: white;
  padding: 16rpx 0;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.05);
  border-top: 1rpx solid #2E7D32;
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 0;
  color: #666;
  transition: all 0.3s ease;
}

.nav-item.active {
  color: #2E7D32;
  font-weight: bold;
}

.nav-icon {
  font-size: 32rpx;
}

.nav-name {
  font-size: 20rpx;
}

/* 响应式适配 */
@media (max-width: 375px) {
  .banner-swiper {
    height: 300rpx;
  }
  
  .waterfall-grid {
    grid-template-columns: 1fr;
  }
  
  .category-icons {
    flex-wrap: wrap;
  }
  
  .category-item {
    flex: 0 0 25%;
  }
}