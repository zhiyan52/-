 
/* 全局样式重置 + 国风基础规范 */
page {
  background-color: #F5F2E9;
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
  color: #333333;
  line-height: 1.5;
  box-sizing: border-box;
}

image {
  display: block;
}

/* 顶部轮播图样式 */
.banner-swiper {
  width: 100%;
  height: 360rpx;
  margin-bottom: 32rpx;
}

.banner-img {
  width: 100%;
  height: 100%;
  border-radius: 0 0 20rpx 20rpx;
}

/* 打卡+每日民俗双栏模块 */
.daily-box {
  display: flex;
  gap: 24rpx;
  padding: 0 24rpx;
  margin-bottom: 32rpx;
}

.sign-card, .folk-knowledge {
  flex: 1;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  display: flex;
  flex-direction: column;
}

/* 打卡卡片样式 */
.sign-card {
  justify-content: space-between;
}

.sign-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #2D7D58;
  margin-bottom: 8rpx;
}

.sign-days {
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 16rpx;
}

.sign-btn {
  width: 100%;
  height: 60rpx;
  line-height: 60rpx;
  text-align: center;
  border-radius: 30rpx;
  background: #2D7D58;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 500;
  transition: all 0.3s ease;
}

.sign-btn.signed {
  background: #E8F5EF;
  color: #2D7D58;
  border: 1rpx solid #2D7D58;
}

/* 每日民俗小知识样式 */
.folk-knowledge {
  justify-content: space-between;
}

.knowledge-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
}

.knowledge-desc {
  font-size: 24rpx;
  color: #666666;
  line-height: 36rpx;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 分类横向滚动导航 */
.category-scroll {
  width: 100%;
  white-space: nowrap;
  margin-bottom: 24rpx;
}

.category-list {
  display: flex;
  gap: 16rpx;
  padding: 0 24rpx;
}

.category-item {
  flex-shrink: 0;
  padding: 12rpx 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  font-size: 28rpx;
  color: #666666;
  transition: all 0.3s ease;
}

.category-item.active {
  background: #2D7D58;
  color: #ffffff;
  font-weight: 500;
}

/* 民俗主体列表 */
.folk-list {
  padding: 0 24rpx;
  margin-bottom: 40rpx;
}

/* 空状态/加载/无更多数据通用样式 */
.empty-box, .loading-box, .no-more-box {
  text-align: center;
  padding: 80rpx 0;
  font-size: 28rpx;
  color: #999999;
  line-height: 48rpx;
}

.no-more-box {
  padding: 40rpx 0;
  font-size: 24rpx;
}

/* 列表项卡片样式 */
.folk-item {
  display: flex;
  gap: 20rpx;
  padding: 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.folk-cover {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.folk-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.folk-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  line-height: 40rpx;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.folk-desc {
  font-size: 26rpx;
  color: #666666;
  line-height: 36rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.folk-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.count-item {
  font-size: 24rpx;
  color: #999999;
  margin-right: 20rpx;
}

.collect-btn {
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  border: 1rpx solid #2D7D58;
  color: #2D7D58;
  font-size: 24rpx;
  transition: all 0.3s ease;
}

.collect-btn.collected {
  background: #2D7D58;
  color: #ffffff;
}