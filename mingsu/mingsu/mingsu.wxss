/* 民俗百味 - 传统中国风样式 */
.home-container {
  background-color: #E8F5E8;
  min-height: 100vh;
  padding: 20rpx 30rpx 160rpx;
}

/* 搜索区域 */
.search-section {
  margin-bottom: 30rpx;
}

.search-box {
  display: flex;
  align-items: center;
  background: #F8F0E3;
  border-radius: 50rpx;
  padding: 20rpx 30rpx;
  border: 2rpx solid #D4A017;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  color: #1A365D;
}

.search-placeholder {
  font-size: 28rpx;
  color: #666;
  font-family: "STKaiti", "KaiTi", serif;
}

/* Banner轮播 */
.hero {
  margin-bottom: 30rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
  border: 4rpx solid #D4A017;
}

.hero-swiper {
  width: 100%;
  height: 400rpx;
}

.hero-image {
  width: 100%;
  height: 100%;
  display: block;
}

.banner-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(transparent, rgba(26, 54, 93, 0.8));
  padding: 40rpx 30rpx 20rpx;
}

.banner-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #D4A017;
  margin-bottom: 8rpx;
  font-family: "STKaiti", "KaiTi", serif;
  text-shadow: 2rpx 2rpx 4rpx rgba(0,0,0,0.3);
}

.banner-subtitle {
  font-size: 24rpx;
  color: #F8F0E3;
  font-family: "STKaiti", "KaiTi", serif;
}

/* 四大分类 */
.features {
  margin-bottom: 30rpx;
}

.feature-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.feature-row:last-child {
  margin-bottom: 0;
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 48%;
  background: #F8F0E3;
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  border: 2rpx solid #D4A017;
  transition: all 0.3s;
}

.feature-item:hover {
  transform: translateY(-5rpx);
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.15);
}

.feature-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.feature-item text {
  font-size: 28rpx;
  color: #1A365D;
  font-weight: 500;
  font-family: "STKaiti", "KaiTi", serif;
}

/* 通用区块样式 */
.section {
  margin-bottom: 30rpx;
  background: #F8F0E3;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
  border: 2rpx solid #D4A017;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1A365D;
  margin-bottom: 20rpx;
  display: block;
  text-align: center;
  font-family: "STKaiti", "KaiTi", serif;
  position: relative;
  padding-bottom: 12rpx;
}

.section-title::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 80rpx;
  height: 4rpx;
  background: #D4A017;
  border-radius: 2rpx;
}

.section-more {
  font-size: 24rpx;
  color: #D4A017;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  margin-bottom: 20rpx;
  font-family: "STKaiti", "KaiTi", serif;
}

.section-more text {
  margin-left: 8rpx;
}

/* 时令食俗推荐区 */
.seasonal-list {
  display: flex;
  gap: 20rpx;
  overflow-x: auto;
  scrollbar-width: none;
}

.seasonal-list::-webkit-scrollbar {
  display: none;
}

.seasonal-item {
  flex: 0 0 280rpx;
  background: #E8F5E8;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  border: 2rpx solid #D4A017;
  transition: all 0.3s;
}

.seasonal-item:hover {
  transform: translateY(-5rpx);
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.15);
}

.seasonal-img {
  width: 100%;
  height: 200rpx;
  display: block;
  border-bottom: 2rpx solid #D4A017;
}

.seasonal-info {
  padding: 16rpx;
}

.seasonal-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #1A365D;
  margin-bottom: 8rpx;
  font-family: "STKaiti", "KaiTi", serif;
}

.seasonal-desc {
  font-size: 24rpx;
  color: #666;
  line-height: 1.4;
  font-family: "STKaiti", "KaiTi", serif;
}

/* 民俗美食文化瀑布流 */
.waterfall-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.waterfall-item {
  background: #E8F5E8;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  border: 2rpx solid #D4A017;
  transition: all 0.3s;
}

.waterfall-item:hover {
  transform: translateY(-5rpx);
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.15);
}

.waterfall-img {
  width: 100%;
  height: 200rpx;
  display: block;
  border-bottom: 2rpx solid #D4A017;
}

.waterfall-info {
  padding: 16rpx;
}

.waterfall-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #1A365D;
  margin-bottom: 12rpx;
  font-family: "STKaiti", "KaiTi", serif;
}

.waterfall-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.tag {
  padding: 4rpx 12rpx;
  background: rgba(212, 160, 23, 0.2);
  border-radius: 12rpx;
  font-size: 20rpx;
  color: #1A365D;
  border: 1rpx solid #D4A017;
  font-family: "STKaiti", "KaiTi", serif;
}

/* 食文化小课堂入口 */
.classroom-card {
  background: linear-gradient(135deg, #1A365D 0%, #2C5282 100%);
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(26, 54, 93, 0.3);
  transition: transform 0.2s ease;
  border: 2rpx solid #D4A017;
}

.classroom-card:active {
  transform: scale(0.98);
}

.classroom-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.classroom-icon {
  font-size: 64rpx;
  margin-right: 20rpx;
}

.classroom-info {
  flex: 1;
}

.classroom-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #D4A017;
  margin-bottom: 8rpx;
  font-family: "STKaiti", "KaiTi", serif;
  text-shadow: 2rpx 2rpx 4rpx rgba(0,0,0,0.2);
}

.classroom-desc {
  font-size: 24rpx;
  color: #F8F0E3;
  font-family: "STKaiti", "KaiTi", serif;
}

.classroom-arrow {
  font-size: 48rpx;
  color: #D4A017;
}

/* 民俗资讯 */
.news-section {
  margin-top: 30rpx;
  padding: 30rpx;
  background: #F8F0E3;
  border-radius: 16rpx;
  border: 2rpx solid #D4A017;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}

.news-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1A365D;
  margin-bottom: 20rpx;
  text-align: center;
  font-family: "STKaiti", "KaiTi", serif;
  position: relative;
  padding-bottom: 12rpx;
}

.news-title::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 80rpx;
  height: 4rpx;
  background: #D4A017;
  border-radius: 2rpx;
}

.news-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #D4A017;
  transition: all 0.3s;
}

.news-item:last-child {
  border-bottom: none;
}

.news-item:hover {
  transform: translateX(10rpx);
}

.news-icon {
  font-size: 32rpx;
  margin-right: 20rpx;
  color: #D4A017;
}

.news-content {
  flex: 1;
}

.news-item-title {
  font-size: 28rpx;
  color: #1A365D;
  margin-bottom: 5rpx;
  font-family: "STKaiti", "KaiTi", serif;
}

.news-item-desc {
  font-size: 24rpx;
  color: #666;
  font-family: "STKaiti", "KaiTi", serif;
}

/* 底部信息 */
.footer {
  margin-top: 30rpx;
  padding: 30rpx;
  text-align: center;
  background: linear-gradient(135deg, #1A365D 0%, #2C5282 100%);
  border-radius: 16rpx 16rpx 0 0;
  border-top: 4rpx solid #D4A017;
}

.footer-text {
  font-size: 24rpx;
  color: #F8F0E3;
  margin-bottom: 10rpx;
  font-family: "STKaiti", "KaiTi", serif;
}

.footer-copyright {
  font-size: 20rpx;
  color: rgba(248, 240, 227, 0.8);
  font-family: "STKaiti", "KaiTi", serif;
}

/* 底部空间 */
.bottom-space {
  height: 40rpx;
}

/* 底部导航 */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: #F8F0E3;
  border-top: 2rpx solid #D4A017;
  display: flex;
  justify-content: space-around;
  align-items: center;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.1);
  z-index: 9999;
  pointer-events: auto;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 33.333%;
  height: 100%;
  justify-content: center;
  cursor: pointer;
  user-select: none;
  transition: all 0.3s;
}

.tab-item:hover {
  background: rgba(212, 160, 23, 0.1);
}

.tab-item.active text {
  color: #1A365D;
  font-weight: bold;
}

.tab-image {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 8rpx;
  display: block;
}

.tab-item text {
  font-size: 20rpx;
  color: #666;
  font-family: "STKaiti", "KaiTi", serif;
}

/* 响应式适配 */
@media (max-width: 375px) {
  .hero-swiper {
    height: 300rpx;
  }
  
  .waterfall-grid {
    grid-template-columns: 1fr;
  }
}
