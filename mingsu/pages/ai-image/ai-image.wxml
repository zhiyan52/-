<view class="ai-image-container">
  <!-- 页面标题 -->
  <view class="page-header">
    <text class="header-title">AI民俗意境生图</text>
    <text class="header-subtitle">生成水墨风格的民俗主题插画</text>
  </view>

  <!-- 关键词选择 -->
  <view class="keyword-section">
    <text class="section-title">选择关键词</text>
    <view class="keyword-grid">
      <view class="keyword-item {{selectedKeyword === item ? 'selected' : ''}}" wx:for="{{keywords}}" wx:key="*this" bindtap="selectKeyword" data-keyword="{{item}}">
        <text class="keyword-text">{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 生成按钮 -->
  <view class="action-section">
    <button class="generate-btn" bindtap="generateImage" loading="{{isGenerating}}">
      {{isGenerating ? '生成中...' : '生成意境图'}}
    </button>
  </view>

  <!-- 生成结果 -->
  <view class="result-section" wx:if="{{generatedImage}}">
    <text class="result-title">生成结果</text>
    <view class="image-container">
      <image class="generated-image" src="{{generatedImage}}" mode="aspectFill"></image>
      <button class="save-btn" bindtap="saveImage">保存图片</button>
    </view>
  </view>
</view>