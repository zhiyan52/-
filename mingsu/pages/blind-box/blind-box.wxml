<!-- 风物盲盒页面 -->
<view class="blind-box-container">
  <!-- 页面标题 -->
  <view class="page-header">
    <view class="page-title">风物盲盒</view>
    <view class="page-subtitle">每日随机获得民俗知识</view>
  </view>

  <!-- 盲盒展示区 -->
  <view class="blind-box-section">
    <view class="section-title">今日盲盒</view>
    <view class="blind-box-wrapper">
      <view wx:if="{{!hasOpenedToday}}" class="blind-box" bindtap="openBlindBox">
        <image class="blind-box-image" src="https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=Chinese%20traditional%20blind%20box%2C%20ink%20painting%20style&image_size=square_hd" mode="aspectFill"></image>
        <view class="blind-box-text">点击打开盲盒</view>
      </view>
      <view wx:else class="blind-box-opened">
        <view class="blind-box-opened-text">今日盲盒已打开</view>
        <view class="blind-box-tomorrow-text">明天再来哦～</view>
      </view>
    </view>
  </view>

  <!-- 详情区 -->
  <view wx:if="{{selectedItem}}" class="detail-section">
    <view class="section-title">民俗知识详情</view>
    <view class="detail-card">
      <view class="detail-header">
        <view class="detail-title">{{selectedItem.title}}</view>
      </view>
      <view class="detail-description">{{selectedItem.description}}</view>
      <view class="detail-meaning">{{selectedItem.meaning}}</view>
    </view>
    <view class="detail-actions">
      <button class="action-btn collect-btn {{selectedItem.collected ? 'collected' : ''}}" bindtap="collectItem">
        {{selectedItem.collected ? '已收藏' : '收藏'}}
      </button>
      <button class="action-btn share-btn" bindtap="shareItem">分享</button>
    </view>
  </view>

  <!-- 历史记录区 -->
  <view class="history-section">
    <view class="section-title">历史记录</view>
    <view class="history-card">
      <view wx:if="{{historyList.length > 0}}" class="history-list">
        <view wx:for="{{historyList}}" wx:key="id" class="history-item {{item.collected ? 'collected' : ''}}" bindtap="selectHistoryItem" data-item="{{item}}">
          <view class="history-item-info">
            <view class="history-title">{{item.title}}</view>
            <view class="history-date">{{item.date}}</view>
          </view>
          <view class="history-arrow">›</view>
        </view>
      </view>
      <view wx:else class="empty-history">
        <view class="empty-icon">📦</view>
        <view class="empty-text">暂无历史记录</view>
      </view>
    </view>
  </view>
</view>
