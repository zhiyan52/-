/* 风物盲盒页面样式 - 简约现代版 */
page {
  background: linear-gradient(180deg, #faf8f5 0%, #f5f0e8 100%);
  min-height: 100vh;
}

.blind-box-container {
  min-height: 100vh;
  padding: 60rpx 40rpx 40rpx;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  position: relative;
}

/* 页面标题区域 */
.page-header {
  text-align: center;
  margin-bottom: 60rpx;
}

.page-title {
  font-size: 52rpx;
  font-weight: 600;
  color: #2c2c2c;
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
}

.page-subtitle {
  font-size: 26rpx;
  color: #999;
  letter-spacing: 2rpx;
}

/* 盲盒展示区 */
.blind-box-section {
  margin-bottom: 50rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 30rpx;
  padding-left: 24rpx;
  border-left: 6rpx solid #d4a574;
}

.blind-box-wrapper {
  background: #fff;
  border-radius: 32rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.06);
  text-align: center;
  position: relative;
  overflow: hidden;
}

.blind-box-wrapper::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, #d4a574, #e8c9a8, #d4a574);
}

.blind-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 30rpx;
  transition: transform 0.3s ease;
}

.blind-box:active {
  transform: scale(0.98);
}

.blind-box-image {
  width: 280rpx;
  height: 280rpx;
  border-radius: 24rpx;
  box-shadow: 0 12rpx 40rpx rgba(212, 165, 116, 0.3);
  transition: all 0.3s ease;
}

.blind-box:active .blind-box-image {
  transform: scale(0.95);
  box-shadow: 0 6rpx 20rpx rgba(212, 165, 116, 0.2);
}

.blind-box-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #d4a574;
  letter-spacing: 4rpx;
  padding: 16rpx 40rpx;
  background: linear-gradient(135deg, #faf8f5 0%, #f5f0e8 100%);
  border-radius: 50rpx;
  border: 2rpx solid #e8c9a8;
}

.blind-box-opened {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 40rpx 0;
}

.blind-box-opened-text {
  font-size: 30rpx;
  font-weight: 500;
  color: #666;
}

.blind-box-tomorrow-text {
  font-size: 24rpx;
  color: #999;
}

/* 详情区 */
.detail-section {
  margin-bottom: 50rpx;
}

.detail-card {
  background: #fff;
  border-radius: 32rpx;
  padding: 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 30rpx;
}

.detail-header {
  margin-bottom: 30rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #f0ebe5;
}

.detail-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #2c2c2c;
  margin-bottom: 12rpx;
}

.detail-description {
  font-size: 28rpx;
  color: #666;
  line-height: 1.7;
  margin-bottom: 24rpx;
}

.detail-meaning {
  font-size: 26rpx;
  color: #888;
  line-height: 1.8;
  padding: 24rpx;
  background: #faf8f5;
  border-radius: 16rpx;
  border-left: 4rpx solid #d4a574;
}

.detail-actions {
  display: flex;
  gap: 24rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  transition: all 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.action-btn.collect-btn {
  background: linear-gradient(135deg, #d4a574 0%, #c49462 100%);
  color: #fff;
  box-shadow: 0 8rpx 24rpx rgba(212, 165, 116, 0.4);
}

.action-btn.collect-btn.collected {
  background: linear-gradient(135deg, #8b7355 0%, #6b5a47 100%);
  box-shadow: 0 8rpx 24rpx rgba(139, 115, 85, 0.4);
}

.action-btn.share-btn {
  background: #f5f0e8;
  color: #666;
}

.action-btn:active {
  transform: scale(0.96);
}

/* 历史记录区 */
.history-section {
  margin-bottom: 40rpx;
}

.history-card {
  background: #fff;
  border-radius: 32rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.06);
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.history-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 20rpx;
  border-radius: 16rpx;
  transition: all 0.2s ease;
  cursor: pointer;
}

.history-item:active {
  background: #faf8f5;
}

.history-item-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  flex: 1;
}

.history-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
}

.history-date {
  font-size: 22rpx;
  color: #aaa;
}

.history-arrow {
  font-size: 28rpx;
  color: #ccc;
  transition: transform 0.2s ease;
}

.history-item:active .history-arrow {
  transform: translateX(4rpx);
}

.history-item.collected .history-title::after {
  content: ' ♥';
  color: #e85d75;
  font-size: 24rpx;
}

.empty-history {
  text-align: center;
  padding: 60rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.3;
}

.empty-text {
  font-size: 26rpx;
  color: #bbb;
}

/* 简约分隔线 */
.divider {
  height: 1rpx;
  background: linear-gradient(90deg, transparent, #e8e0d8, transparent);
  margin: 40rpx 0;
}
