/* AI助手页面样式 - 古雅文轩风格 */
.ai-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8f5f0 0%, #efe9df 50%, #e8e0d4 100%);
  display: flex;
  flex-direction: column;
  padding: 20rpx;
}

/* 顶部装饰 */
.header-decoration {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx 20rpx;
}

.decoration-line {
  flex: 1;
  height: 4rpx;
  background: linear-gradient(90deg, transparent, #8b6f47, transparent);
}

.header-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 40rpx;
}

.header-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #5c4a32;
  letter-spacing: 8rpx;
}

.header-subtitle {
  font-size: 24rpx;
  color: #8b7355;
  margin-top: 8rpx;
}

/* 欢迎语卡片 */
.welcome-card {
  background: linear-gradient(135deg, #fff 0%, #f8f4ed 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 20rpx 10rpx;
  display: flex;
  align-items: flex-start;
  box-shadow: 0 4rpx 20rpx rgba(139, 111, 71, 0.1);
  border: 2rpx solid #e8dcc8;
}

.welcome-icon {
  font-size: 56rpx;
  margin-right: 24rpx;
}

.welcome-content {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.welcome-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #5c4a32;
  margin-bottom: 10rpx;
}

.welcome-desc {
  font-size: 26rpx;
  color: #8b7355;
  margin-bottom: 8rpx;
}

.welcome-tip {
  font-size: 24rpx;
  color: #a69070;
  line-height: 1.5;
}

/* 对话区域 */
.chat-area {
  flex: 1;
  padding: 20rpx 10rpx;
  min-height: 400rpx;
  max-height: 60vh;
}

.chat-section {
  margin-bottom: 30rpx;
}

.chat-header {
  margin-bottom: 12rpx;
}

.user-header {
  text-align: right;
}

.ai-header {
  text-align: left;
}

.chat-label {
  font-size: 24rpx;
  color: #8b7355;
  padding: 6rpx 16rpx;
  background: rgba(139, 115, 85, 0.1);
  border-radius: 20rpx;
}

.chat-bubble {
  max-width: 85%;
  padding: 24rpx 28rpx;
  border-radius: 20rpx;
  line-height: 1.6;
}

.user-bubble {
  background: linear-gradient(135deg, #d4a574 0%, #c49464 100%);
  color: #fff;
  margin-left: auto;
  border-bottom-right-radius: 8rpx;
}

.ai-bubble {
  background: linear-gradient(135deg, #fff 0%, #f8f4ed 100%);
  color: #5c4a32;
  border: 2rpx solid #e8dcc8;
  border-bottom-left-radius: 8rpx;
}

.chat-text {
  font-size: 28rpx;
  line-height: 1.6;
}

/* 加载中 */
.loading-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
}

.loading-dots {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  background: #8b6f47;
  border-radius: 50%;
  animation: bounce 1.4s infinite ease-in-out both;
}

.dot:nth-child(1) { animation-delay: -0.32s; }
.dot:nth-child(2) { animation-delay: -0.16s; }
.dot:nth-child(3) { animation-delay: 0s; }

@keyframes bounce {
  0%, 80%, 100% { transform: scale(0); }
  40% { transform: scale(1); }
}

.loading-text {
  font-size: 26rpx;
  color: #8b7355;
  font-style: italic;
}

/* 输入区域 */
.input-section {
  display: flex;
  align-items: center;
  padding: 20rpx 10rpx;
}

.input-decoration-left,
.input-decoration-right {
  width: 60rpx;
  height: 4rpx;
  background: linear-gradient(90deg, #8b6f47, transparent);
}

.input-decoration-right {
  background: linear-gradient(90deg, transparent, #8b6f47);
}

.input-box {
  flex: 1;
  background: linear-gradient(135deg, #fff 0%, #f8f4ed 100%);
  border-radius: 24rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(139, 111, 71, 0.15);
  border: 2rpx solid #e8dcc8;
}

.input-textarea {
  width: 100%;
  min-height: 80rpx;
  font-size: 28rpx;
  color: #5c4a32;
  line-height: 1.6;
  background: transparent;
  margin-bottom: 16rpx;
}

.input-actions {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.char-count {
  font-size: 22rpx;
  color: #a69070;
}

.send-btn {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #d4a574 0%, #c49464 100%);
  color: #fff;
  padding: 16rpx 32rpx;
  border-radius: 30rpx;
  font-size: 28rpx;
  border: none;
}

.send-btn.active {
  background: linear-gradient(135deg, #8b6f47 0%, #725a39 100%);
}

.send-btn[disabled] {
  opacity: 0.6;
}

.send-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.send-text {
  font-size: 28rpx;
}

/* 底部装饰 */
.footer-decoration {
  padding: 30rpx 20rpx;
  text-align: center;
}

.footer-quote {
  font-size: 24rpx;
  color: #8b7355;
  font-style: italic;
  letter-spacing: 2rpx;
}
