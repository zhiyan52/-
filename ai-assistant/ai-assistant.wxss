.container {
  padding: 20rpx;
}
.title {
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  margin-bottom: 30rpx;
}
.input-area {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
}
.input-area textarea {
  width: 100%;
  min-height: 120rpx;
  font-size: 28rpx;
}
.input-area button {
  margin-top: 20rpx;
  background: #8B4513;
  color: #fff;
  border-radius: 8rpx;
}
.answer-area {
  background: #f8f4e9;
  border-radius: 12rpx;
  padding: 20rpx;
}
.answer-title {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}
.answer-content {
  font-size: 28rpx;
  line-height: 1.6;
}