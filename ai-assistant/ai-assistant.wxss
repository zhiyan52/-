/* ai-assistant/ai-assistant.wxss */
.ai-assistant-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8f9fa 0%, #e9ecef 100%);
  display: flex;
  flex-direction: column;
}

/* 顶部导航 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: linear-gradient(135deg, #495057 0%, #343a40 100%);
  color: #fff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.header-left,
.header-right {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  transition: all 0.3s ease;
}

.header-left:hover,
.header-right:hover {
  background: rgba(255, 255, 255, 0.1);
}

.back-icon,
.settings-icon {
  font-size: 32rpx;
}

.header-title {
  font-size: 32rpx;
  font-weight: bold;
  font-family: "STKaiti", "KaiTi", serif;
}

/* 聊天区域 */
.chat-container {
  flex: 1;
  padding: 30rpx;
  overflow-y: auto;
}

.message-item {
  display: flex;
  margin-bottom: 30rpx;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.ai-message {
  align-items: flex-start;
}

.user-message {
  flex-direction: row-reverse;
  align-items: flex-start;
}

.message-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #e9ecef;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.user-avatar {
  margin-right: 0;
  margin-left: 20rpx;
  background: linear-gradient(135deg, #6c757d 0%, #495057 100%);
  color: #fff;
}

.message-content {
  flex: 1;
  max-width: 70%;
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  position: relative;
}

.user-content {
  background: linear-gradient(135deg, #6c757d 0%, #495057 100%);
  color: #fff;
}

.ai-message .message-content::before {
  content: '';
  position: absolute;
  left: -10rpx;
  top: 20rpx;
  width: 0;
  height: 0;
  border-top: 10rpx solid transparent;
  border-bottom: 10rpx solid transparent;
  border-right: 10rpx solid #fff;
}

.user-message .message-content::before {
  content: '';
  position: absolute;
  right: -10rpx;
  top: 20rpx;
  width: 0;
  height: 0;
  border-top: 10rpx solid transparent;
  border-bottom: 10rpx solid transparent;
  border-left: 10rpx solid #495057;
}

.message-text {
  font-size: 28rpx;
  line-height: 1.5;
  white-space: pre-wrap;
}

.message-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 15rpx;
  padding-top: 15rpx;
  border-top: 1rpx solid #e9ecef;
}

.action-item {
  background: #f8f9fa;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #495057;
  cursor: pointer;
  transition: all 0.3s ease;
}

.action-item:hover {
  background: #e9ecef;
  transform: translateY(-2rpx);
}

.user-content .message-actions {
  border-top-color: rgba(255, 255, 255, 0.2);
}

.user-content .action-item {
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
}

.user-content .action-item:hover {
  background: rgba(255, 255, 255, 0.3);
}

/* 加载中 */
.loading-indicator {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 20rpx 0;
}

.loading-dot {
  width: 12rpx;
  height: 12rpx;
  background: #6c757d;
  border-radius: 50%;
  animation: pulse 1.4s ease-in-out infinite;
}

.loading-dot:nth-child(2) {
  animation-delay: 0.2s;
}

.loading-dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes pulse {
  0%, 60%, 100% {
    transform: scale(0.6);
    opacity: 0.5;
  }
  30% {
    transform: scale(1);
    opacity: 1;
  }
}

/* 输入区域 */
.input-container {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #fff;
  border-top: 1rpx solid #e9ecef;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.input-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  background: #f8f9fa;
  border-radius: 30rpx;
  padding: 0 20rpx;
  margin-right: 15rpx;
}

.message-input {
  flex: 1;
  padding: 20rpx 0;
  font-size: 28rpx;
  background: transparent;
  border: none;
  outline: none;
}

.input-actions {
  display: flex;
  gap: 15rpx;
}

.action-btn {
  width: 50rpx;
  height: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #e9ecef;
  transition: all 0.3s ease;
}

.action-btn:hover {
  background: #dee2e6;
  transform: translateY(-2rpx);
}

.action-icon {
  font-size: 30rpx;
  color: #495057;
}

.send-btn {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #6c757d 0%, #495057 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s ease;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.send-btn:hover {
  transform: scale(1.05);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.send-icon {
  font-size: 36rpx;
  color: #fff;
  transform: rotate(45deg);
}

/* 快捷问题 */
.quick-questions {
  position: absolute;
  bottom: 140rpx;
  left: 30rpx;
  right: 30rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from { transform: translateY(50rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.quick-question {
  background: #f8f9fa;
  padding: 15rpx 25rpx;
  border-radius: 25rpx;
  font-size: 24rpx;
  color: #495057;
  cursor: pointer;
  transition: all 0.3s ease;
}

.quick-question:hover {
  background: #e9ecef;
  transform: translateY(-2rpx);
}

/* 设置弹窗 */
.settings-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  animation: fadeIn 0.3s ease;
}

.settings-content {
  background: #fff;
  border-radius: 20rpx;
  width: 80%;
  max-width: 500rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.2);
  animation: slideUp 0.3s ease;
}

.settings-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 25rpx 30rpx;
  border-bottom: 1rpx solid #e9ecef;
}

.settings-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #343a40;
}

.settings-close {
  font-size: 40rpx;
  color: #6c757d;
  cursor: pointer;
  transition: all 0.3s ease;
}

.settings-close:hover {
  color: #343a40;
  transform: rotate(90deg);
}

.settings-body {
  padding: 30rpx;
}

.setting-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 25rpx;
}

.setting-item:last-child {
  margin-bottom: 0;
}

.setting-label {
  font-size: 28rpx;
  color: #343a40;
}

/* 响应式设计 */
@media (max-width: 750rpx) {
  .message-content {
    max-width: 80%;
  }
  
  .header {
    padding: 15rpx 20rpx;
  }
  
  .header-title {
    font-size: 28rpx;
  }
  
  .chat-container {
    padding: 20rpx;
  }
  
  .input-container {
    padding: 15rpx 20rpx;
  }
  
  .message-input {
    font-size: 26rpx;
  }
}
