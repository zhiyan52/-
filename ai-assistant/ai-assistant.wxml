<view class="container">
  <view class="title">古建展厅AI助手</view>
  
  <!-- 输入框 -->
  <view class="input-area">
    <textarea 
      placeholder="请输入你想了解的古建筑问题..." 
      value="{{userInput}}" 
      bindinput="onInput"
      disabled="{{loading}}"
    />
    <button bindtap="sendQuestion" disabled="{{loading}}">
      {{loading ? "AI思考中..." : "发送问题"}}
    </button>
  </view>

  <!-- AI回答区域 -->
  <view class="answer-area" wx:if="{{answer}}">
    <view class="answer-title">AI回答：</view>
    <view class="answer-content">{{answer}}</view>
  </view>
</view>