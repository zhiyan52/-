    },
    {
      "root": "diancang/diancang",
      "pages": [
        "diancang",
        "diancang-detail"
      ]
    },
    {
      "root": "mingsu/mingsu",
      "pages": [
        "mingsu",
        "pages/categories/categories",
        "pages/categories/seasons",
        "pages/categories/regions",
        "pages/categories/intangible",
        "pages/categories/cakes",
        "pages/detail/detail",
        "pages/3d-model/3d-model",
        "pages/checkin/checkin",
        "pages/community/community",
        "pages/profile/profile",
        "pages/search/search",
        "pages/encyclopedia/encyclopedia",
        "pages/encyclopedia/course-detail"
      ],
      "name": "mingsu",
      "independent": false
    },
    {
      "root": "shuhua/shuhua",
      "pages": [
        "shuhua"
      ]
    },
    {
      "root": "gujianSub",
      "name": "gujianPackage",
      "pages": [
        "gujianSub",
        "discover/discover",
        "search/search",
        "checkinMap/checkinMap",
        "gongdian/gongdian",
        "gongdian/detail",
        "gongdian/placemap",
        "yuanlin/yuanlin",
        "yuanlin/detail",
        "yuanlin/placemap",
        "minju/minju",
        "minju/detail",
        "minju/placemap",
        "tage/tage",
        "tage/detail",
        "tage/placemap",
        "qiaoliang/qiaoliang",
        "qiaoliang/detail",
        "qiaoliang/placemap",
        "wenda1/wenda1",
        "wenda2/wenda2",
        "building3D/building3D"
      ],
      "preloadRule": {
        "pages/index/index": {
          "network": "all",
          "packages": [
            "feiyi",
            "diancang",
            "mingsu"
          ]
        }
      },
      "permission": {
        "scope.userLocation": {
          "desc": "你的位置信息将用于民居位置导航"
        }
      },
      "requiredPrivateInfos": [
        "getLocation",
        "openLocation"
      ]
    }
