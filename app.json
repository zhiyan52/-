      "name": "shufa",
      "independent": false
    },
    {
      "root": "gujian/gujian",
      "pages": [
        "gujian"
      ]
    },
    {
      "root": "pages/feiyi/",
      "pages": [
        "pages/index/index",
        "pages/detail/detail",
        "pages/inheritor/inheritor"
      ],
