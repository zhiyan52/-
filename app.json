{
  "pages": [
    "pages/index/index",
    "pages/example/index",
    "moudules/modules/modules",
    "profile/profile/profile",
    "pages/map/map",
    "cloudfunctions/getAudio"
  ],
  "subpackages": [
    {
      "root": "shufa/shufa",
      "pages": [
        "shufa",
        "pages/calligraphy/main",
        "pages/calligraphy/copybook",
        "pages/calligraphy/character",
