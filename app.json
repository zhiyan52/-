{
  "pages": [
    "pages/index/index",
    "pages/example/index",
    "moudules/modules/modules",
    "profile/profile/profile",
    "pages/map/map",
    "cloudfunctions/getAudio"
  ],
  "subpackages": [
    {
      "root": "gujian/gujian",
      "pages": [
        "gujian"
      ]
    },
    {
      "root": "pages/feiyi/",
      "pages": [
        "pages/index/index",
        "pages/detail/detail",
        "pages/inheritor/inheritor",
        "data/categories.js"
      ],
      "name": "feiyi",
      "independent": false
    },
    {
      "root": "diancang/diancang",
      "pages": [
        "diancang",
        "diancang-detail"
      ]
    },
    {
      "root": "mingsu/mingsu",
      "pages": [
        "mingsu"
      ]
    },
    {
      "root": "shuhua/shuhua",
      "pages": [
        "shuhua"
      ]
    },
    {
      "root": "gujianSub",
      "name": "gujianPackage",
      "pages": [
        "gongdian/gongdian",
        "gongdian/detail",
        "gongdian/placemap",
        "yuanlin/yuanlin",
        "yuanlin/detail",
        "yuanlin/placemap",
        "minju/minju",
        "minju/detail",
        "minju/placemap",
        "tage/tage",
        "tage/detail",
        "tage/placemap",
        "qiaoliang/qiaoliang",
        "qiaoliang/detail",
        "qiaoliang/placemap",
        "wenda1/wenda1",
        "wenda2/wenda2"
      ],
      "preloadRule": {
        "pages/index/index": {
          "network": "all",
          "packages": [
            "feiyi",
            "dianji",
            "minsu"
          ]
        }
      },
      "permission": {
        "scope.userLocation": {
          "desc": "你的位置信息将用于民居位置导航"
        }
      },
      "requiredPrivateInfos": [
        "getLocation",
        "openLocation"
      ]
    }
  ],
  "tabBar": {
    "list": [
      {
        "pagePath": "pages/index/index",
        "text": "首页",
        "iconPath": "/components/shou.png",
        "selectedIconPath": "/components/shou.png"
      },
      {
        "pagePath": "moudules/modules/modules",
        "text": "模块总览",
        "iconPath": "/components/zonglan.png",
        "selectedIconPath": "/components/zonglan.png"
      },
      {
        "pagePath": "profile/profile/profile",
        "text": "个人中心",
        "iconPath": "/components/yonghu.png",
        "selectedIconPath": "/components/yonghu.png"
      }
    ]
  },
  "window": {
    "navigationBarTitleText": "中国十大宫殿",
    "navigationBarBackgroundColor": "#2C2621",
    "navigationBarTextStyle": "white",
    "backgroundTextStyle": "dark"
  },
  "sitemapLocation": "sitemap.json",
  "style": "v2",
  "lazyCodeLoading": "requiredComponents",
  "permission": {
    "scope.userLocation": {
      "desc": "用于展示宫殿位置地图"
    }
  }
}