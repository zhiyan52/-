<!--shuhua/shuhua/shuhua.wxml-->
<view class="container">
  <!-- 主标题牌匾 -->
  <view class="main-title-bar">
    <image src="cloud://cloud1-8glc9jqob91870fc.636c-cloud1-8glc9jqob91870fc-1401141450/shuhua/ad44bcf5e09545bfbedb396f4f7ee88d.jpg" mode="aspectFit" class="title-img"></image>
  </view>

  <!-- 两个分类项 -->
  <view class="category-list">
    <view 
      class="category-item" 
      wx:for="{{categoryList}}" 
      wx:key="id"
      bindtap="onCategoryTap"
      data-id="{{item.id}}"
      style="background-color: {{item.bgColor}}">
      <image src="{{item.img}}" class="category-bg-img" mode="aspectFill"></image>
      <view class="category-overlay">
        <view class="category-icon">
          <text wx:if="{{item.id === 1}}">✏️</text>
          <text wx:else>🖼️</text>
        </view>
        <view class="category-title">{{item.name}}</view>
        <view class="category-desc">{{item.desc}}</view>
      </view>
    </view>
  </view>
</view>