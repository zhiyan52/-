<!-- 书画雅集 - 传统中国风 -->
<view class="home-container">
  <!-- 顶部标题栏 -->
  <view class="header-section">
    <view class="header-title">
      <view class="main-title">书画雅集</view>
    </view>
  </view>

  <!-- 搜索区域 -->
  <view class="search-section">
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <text class="search-placeholder">搜索书画作品、艺术家...</text>
    </view>
  </view>

  <!-- 主视觉区 -->
  <view class="hero">
    <swiper class="hero-swiper" indicator-dots="true" autoplay="true" interval="5000" duration="1000">
      <swiper-item wx:for="{{bannerList}}" wx:key="index">
        <image src="{{item.image}}" class="hero-image" mode="aspectFill"></image>
      </swiper-item>
    </swiper>
  </view>

  <!-- 书画分类 -->
  <view class="category-section">
    <view class="category-item">
      <image class="category-bg-img" src="https://636c-cloud1-8glc9jqob91870fc-1401141450.tcb.qcloud.la/shuhua/8eea8030d597d75ca17091f7ace26f5d.jpg?sign=b12162b9e3deb072134516573f116905&t=1776175850" mode="aspectFill"></image>
      <view class="category-overlay">
        <view class="category-icon">✍️</view>
        <view class="category-title">书法</view>
        <view class="category-desc">篆隶楷行草</view>
      </view>
    </view>
    <view class="category-item">
      <image class="category-bg-img" src="https://636c-cloud1-8glc9jqob91870fc-1401141450.tcb.qcloud.la/shuhua/9b8d237c51e3b922d16dc3eae5723004.jpg?sign=e74ddbadb70750b501ac085fe694804b&t=1776176161" mode="aspectFill"></image>
      <view class="category-overlay">
        <view class="category-icon">🖼️</view>
        <view class="category-title">国画</view>
        <view class="category-desc">山水·花鸟·人物</view>
      </view>
    </view>
  </view>

  <!-- 功能入口 -->
  <view class="features">
    <view class="feature-row">
      <view class="feature-item">
        <image src="https://636c-cloud1-8glc9jqob91870fc-1401141450.tcb.qcloud.la/shuhua/8eea8030d597d75ca17091f7ace26f5d.jpg?sign=b12162b9e3deb072134516573f116905&t=1776175850" class="feature-icon" mode="aspectFill"></image>
        <text>AR扫描</text>
      </view>
      <view class="feature-item">
        <image src="https://636c-cloud1-8glc9jqob91870fc-1401141450.tcb.qcloud.la/shuhua/9b8d237c51e3b922d16dc3eae5723004.jpg?sign=e74ddbadb70750b501ac085fe694804b&t=1776176161" class="feature-icon" mode="aspectFill"></image>
        <text>趣味问答</text>
      </view>
    </view>
    <view class="feature-row">
      <view class="feature-item">
        <image src="https://636c-cloud1-8glc9jqob91870fc-1401141450.tcb.qcloud.la/shuhua/fuchun.jpg?sign=xxx&t=xxx" class="feature-icon" mode="aspectFill"></image>
        <text>打卡地图</text>
      </view>
      <view class="feature-item">
        <image src="https://636c-cloud1-8glc9jqob91870fc-1401141450.tcb.qcloud.la/shuhua/qianli.jpg?sign=xxx&t=xxx" class="feature-icon" mode="aspectFill"></image>
        <text>智能导览</text>
      </view>
    </view>
  </view>

  <!-- 智能功能 -->
  <view class="smart-features">
    <view class="smart-feature-item">
      <text class="smart-feature-icon">🎨</text>
      <view class="smart-feature-content">
        <view class="smart-feature-title">智能导览</view>
        <view class="smart-feature-desc">AI驱动的书画作品讲解</view>
      </view>
      <text class="smart-feature-arrow">→</text>
    </view>
    <view class="smart-feature-item">
      <text class="smart-feature-icon">❓</text>
      <view class="smart-feature-content">
        <view class="smart-feature-title">文化问答</view>
        <view class="smart-feature-desc">关于书画艺术的智能问答</view>
      </view>
      <text class="smart-feature-arrow">→</text>
    </view>
    <view class="smart-feature-item">
      <text class="smart-feature-icon">📚</text>
      <view class="smart-feature-content">
        <view class="smart-feature-title">个性化推荐</view>
        <view class="smart-feature-desc">根据您的兴趣推荐作品</view>
      </view>
      <text class="smart-feature-arrow">→</text>
    </view>
  </view>

  <!-- 名家名作 -->
  <view class="section">
    <text class="section-title">名家名作</text>
    <view class="featured-list">
      <view class="featured-item">
        <image src="https://636c-cloud1-8glc9jqob91870fc-1401141450.tcb.qcloud.la/shuhua/fuchun.jpg?sign=xxx&t=xxx" mode="aspectFill" class="featured-image"></image>
        <view class="featured-overlay">
          <text class="featured-title">富春山居图</text>
          <text class="featured-author">黄公望 · 元代</text>
        </view>
      </view>
      <view class="featured-item">
        <image src="https://636c-cloud1-8glc9jqob91870fc-1401141450.tcb.qcloud.la/shuhua/qianli.jpg?sign=xxx&t=xxx" mode="aspectFill" class="featured-image"></image>
        <view class="featured-overlay">
          <text class="featured-title">千里江山图</text>
          <text class="featured-author">王希孟 · 北宋</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 快速入口 -->
  <view class="section">
    <text class="section-title">快速入口</text>
    <view class="quick-links">
      <view class="quick-link">
        <view class="quick-icon">📝</view>
        <text class="quick-name">单字精临</text>
      </view>
      <view class="quick-link">
        <view class="quick-icon">📚</view>
        <text class="quick-name">作品集</text>
      </view>
      <view class="quick-link">
        <view class="quick-icon">📖</view>
        <text class="quick-name">字帖</text>
      </view>
      <view class="quick-link">
        <view class="quick-icon">🎨</view>
        <text class="quick-name">创作</text>
      </view>
    </view>
  </view>

  <!-- 书法作品展示 -->
  <view class="section">
    <text class="section-title">书法作品</text>
    <view class="artworks-grid">
      <view class="artwork-item">
        <image src="https://636c-cloud1-8glc9jqob91870fc-1401141450.tcb.qcloud.la/shuhua/8eea8030d597d75ca17091f7ace26f5d.jpg?sign=b12162b9e3deb072134516573f116905&t=1776175850" class="artwork-image" />
        <view class="artwork-info">
          <view class="artwork-title">楷书经典</view>
          <view class="artwork-desc">端庄秀丽，笔法严谨</view>
        </view>
      </view>
      <view class="artwork-item">
        <image src="https://636c-cloud1-8glc9jqob91870fc-1401141450.tcb.qcloud.la/shuhua/8eea8030d597d75ca17091f7ace26f5d.jpg?sign=b12162b9e3deb072134516573f116905&t=1776175850" class="artwork-image" />
        <view class="artwork-info">
          <view class="artwork-title">行书作品</view>
          <view class="artwork-desc">行云流水，飘逸自然</view>
        </view>
      </view>
      <view class="artwork-item">
        <image src="https://636c-cloud1-8glc9jqob91870fc-1401141450.tcb.qcloud.la/shuhua/8eea8030d597d75ca17091f7ace26f5d.jpg?sign=b12162b9e3deb072134516573f116905&t=1776175850" class="artwork-image" />
        <view class="artwork-info">
          <view class="artwork-title">草书艺术</view>
          <view class="artwork-desc">龙飞凤舞，气势磅礴</view>
        </view>
      </view>
      <view class="artwork-item">
        <image src="https://636c-cloud1-8glc9jqob91870fc-1401141450.tcb.qcloud.la/shuhua/8eea8030d597d75ca17091f7ace26f5d.jpg?sign=b12162b9e3deb072134516573f116905&t=1776175850" class="artwork-image" />
        <view class="artwork-info">
          <view class="artwork-title">隶书作品</view>
          <view class="artwork-desc">古朴典雅，韵味十足</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 国画作品展示 -->
  <view class="section">
    <text class="section-title">国画作品</text>
    <view class="artworks-grid">
      <view class="artwork-item">
        <image src="https://636c-cloud1-8glc9jqob91870fc-1401141450.tcb.qcloud.la/shuhua/9b8d237c51e3b922d16dc3eae5723004.jpg?sign=e74ddbadb70750b501ac085fe694804b&t=1776176161" class="artwork-image" />
        <view class="artwork-info">
          <view class="artwork-title">山水画</view>
          <view class="artwork-desc">山清水秀，意境深远</view>
        </view>
      </view>
      <view class="artwork-item">
        <image src="https://636c-cloud1-8glc9jqob91870fc-1401141450.tcb.qcloud.la/shuhua/9b8d237c51e3b922d16dc3eae5723004.jpg?sign=e74ddbadb70750b501ac085fe694804b&t=1776176161" class="artwork-image" />
        <view class="artwork-info">
          <view class="artwork-title">花鸟画</view>
          <view class="artwork-desc">鸟语花香，生机盎然</view>
        </view>
      </view>
      <view class="artwork-item">
        <image src="https://636c-cloud1-8glc9jqob91870fc-1401141450.tcb.qcloud.la/shuhua/9b8d237c51e3b922d16dc3eae5723004.jpg?sign=e74ddbadb70750b501ac085fe694804b&t=1776176161" class="artwork-image" />
        <view class="artwork-info">
          <view class="artwork-title">人物画</view>
          <view class="artwork-desc">形神兼备，栩栩如生</view>
        </view>
      </view>
      <view class="artwork-item">
        <image src="https://636c-cloud1-8glc9jqob91870fc-1401141450.tcb.qcloud.la/shuhua/9b8d237c51e3b922d16dc3eae5723004.jpg?sign=e74ddbadb70750b501ac085fe694804b&t=1776176161" class="artwork-image" />
        <view class="artwork-info">
          <view class="artwork-title">水墨画</view>
          <view class="artwork-desc">水墨交融，意境悠远</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 国画欣赏 -->
  <view class="section">
    <text class="section-title">国画欣赏</text>
    <view class="appreciation-grid">
      <view class="appreciation-item">
        <image src="https://636c-cloud1-8glc9jqob91870fc-1401141450.tcb.qcloud.la/shuhua/fuchun.jpg?sign=xxx&t=xxx" class="appreciation-image" />
        <view class="appreciation-info">
          <view class="appreciation-title">富春山居图</view>
          <view class="appreciation-author">黄公望 · 元代</view>
          <view class="appreciation-desc">中国十大传世名画之一，以浙江富春江为背景，描绘了初秋时节的山光水色。</view>
          <view class="appreciation-btn">欣赏详情</view>
        </view>
      </view>
      <view class="appreciation-item">
        <image src="https://636c-cloud1-8glc9jqob91870fc-1401141450.tcb.qcloud.la/shuhua/qianli.jpg?sign=xxx&t=xxx" class="appreciation-image" />
        <view class="appreciation-info">
          <view class="appreciation-title">千里江山图</view>
          <view class="appreciation-author">王希孟 · 北宋</view>
          <view class="appreciation-desc">中国十大传世名画之一，以长卷形式展现了千里江山的壮丽景色。</view>
          <view class="appreciation-btn">欣赏详情</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 书画资讯 -->
