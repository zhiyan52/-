<!-- 书画雅韵 - 传统中国风 -->
<view class="shuhua-container">
  <!-- 顶部品牌 -->
  <view class="brand-header">
    <view class="brand-content">
      <image class="brand-bg" src="cloud://cloud1-8glc9jqob91870fc.636c-cloud1-8glc9jqob91870fc-1401141450/shuhua/lunbo1.jpg"></image>
      <view class="brand-title">
      </view>
    </view>
  </view>
  
  <!-- 功能模块 -->
  <view class="modules-section">
    <view class="section-title"><text>书画功能</text></view>
    <view class="modules-grid">
      <view class="module-card" wx:for="{{modules}}" wx:key="id" bindtap="navigateToModule" data-id="{{item.id}}">
        <image class="module-icon" src="{{item.icon}}" mode="aspectFit"></image>
        <text class="module-name">{{item.name}}</text>
        <text class="module-desc">{{item.desc}}</text>
      </view>
    </view>
  </view>
  
  <!-- 精选书画 -->
  <view class="featured-section">
    <view class="section-title"><text>精选书画</text></view>
    <view class="featured-grid">
      <view class="featured-card" wx:for="{{featuredArtworks}}" wx:key="id">
        <image class="featured-image" src="{{item.image}}" mode="aspectFill"></image>
        <text class="featured-name">{{item.name}}</text>
        <text class="featured-desc">{{item.author}}</text>
      </view>
    </view>
  </view>
  
  <!-- 智能功能 -->
  <view class="smart-section">
    <view class="section-title"><text>智能功能</text></view>
    <view class="smart-feature-item" bindtap="navigateToAI">
      <image class="smart-feature-icon" src="cloud://cloud1-8glc9jqob91870fc.636c-cloud1-8glc9jqob91870fc-1401141450/shuhua/icons/navigator.png" mode="aspectFit"></image>
      <view class="smart-feature-content">
        <text class="smart-feature-title">智能导览</text>
        <text class="smart-feature-desc">智能路线规划，深度解说</text>
      </view>
      <text class="smart-feature-arrow">→</text>
    </view>
    <view class="smart-feature-item" bindtap="navigateToQA">
      <image class="smart-feature-icon" src="cloud://cloud1-8glc9jqob91870fc.636c-cloud1-8glc9jqob91870fc-1401141450/shuhua/icons/qa.png" mode="aspectFit"></image>
      <view class="smart-feature-content">
        <text class="smart-feature-title">文化问答</text>
        <text class="smart-feature-desc">解答书画相关问题</text>
      </view>
      <text class="smart-feature-arrow">→</text>
    </view>
    <view class="smart-feature-item" bindtap="navigateToRecommend">
      <image class="smart-feature-icon" src="cloud://cloud1-8glc9jqob91870fc.636c-cloud1-8glc9jqob91870fc-1401141450/shuhua/icons/recommend.png" mode="aspectFit"></image>
      <view class="smart-feature-content">
        <text class="smart-feature-title">个性化推荐</text>
        <text class="smart-feature-desc">根据兴趣推荐书画作品</text>
      </view>
      <text class="smart-feature-arrow">→</text>
    </view>
    <view class="smart-feature-item" bindtap="navigateToVoice">
      <image class="smart-feature-icon" src="cloud://cloud1-8glc9jqob91870fc.636c-cloud1-8glc9jqob91870fc-1401141450/shuhua/icons/voice.png" mode="aspectFit"></image>
      <view class="smart-feature-content">
        <text class="smart-feature-title">语音讲解</text>
        <text class="smart-feature-desc">沉浸式语音导览体验</text>
      </view>
      <text class="smart-feature-arrow">→</text>
    </view>
  </view>
  
  <!-- 底部装饰 -->
  <view class="footer-section">
    <text class="footer-text">传承中华书画艺术</text>
    <text class="footer-subtext">品味传统美学之美</text>
    <text class="footer-copyright">© 2026 书画雅韵</text>
  </view>
</view>
