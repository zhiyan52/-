/* pages/shuhua/shuhua.wxss */
page {
  background-color: #f8f5f0; /* 仿古纸底色 */
  font-family :"PingFang SC", "Helvetica Neue", sans-serif;
}

.container {
  padding-bottom: 40rpx;
}

/* 主标题区域 */
.main-title-bar {
  padding: 0rpx 60rpx 10rpx;
  text-align: center;
  display: block;
  height: auto ;
  margin-top: -40rpx;
}
.title-img {
  width: 100%;
  height: 120rpx;
  /* 可选：添加文字阴影效果 */
  filter: drop-shadow(0rpx 2rpx 4rpx rgba(0, 0, 0, 0.1));
}

/* 总分类容器 */
.category-list {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
  padding: 20rpx 30rpx 60rpx;
}

/* 单个分类项 */
.category-item {
  position: relative;
  width: 100%;
  height: 360rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 12rpx 32rpx rgba(0, 0, 0, 0.15);
}

/* 分类背景图片 */
.category-bg-img {
  position: absolute;
  width: 100%;
  height: 100%;
  opacity: 0.4;
}

/* 分类遮罩层 */
.category-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  background: linear-gradient(to bottom, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0.6) 100%);
}

/* 分类图标 */
.category-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

/* 分类标题 */
.category-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  letter-spacing: 8rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

/* 分类描述 */
.category-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 12rpx;
  letter-spacing: 2rpx;
}

/* 作品展示区域通用样式 */
.works-area {
  margin: 0 30rpx 60rpx;
  background-color: #fff;
  border: 1rpx solid #e0e0e0;
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 分区标题 */
.section-title {
  font-size: 42rpx;
  font-weight: bold;
  color: #2c2c2c;
  text-align: center;
  margin-bottom: 40rpx;
  position: relative;
  padding-bottom: 20rpx;
}
/* 标题装饰线 */
.section-title::after {
  content: "";
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 120rpx;
  height: 6rpx;
  /* 区分书法和国画颜色 */
  background: linear-gradient(to right, #e6b861, #d4a660); /* 金石色 */
  border-radius: 3rpx;
}

/* 书法作品区特有的标题装饰 */
.works-area:nth-child(4) .section-title::after {
  background: linear-gradient(to right, #a02010, #c04020); /* 朱砂红 */
}

/* 作品列表网格 */
.works-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

/* 单个作品卡片 */
.work-item {
  width: 48%;
  margin-bottom: 30rpx;
  background-color: #fafafa;
  border-radius: 12rpx;
  overflow: hidden;
  border: 1rpx solid #eee;
  transition: all 0.3s ease;
}
.work-item:active {
  transform: scale(0.96);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

/* 作品封面图 */
.work-cover {
  width: 100%;
  height: 260rpx;
  border-bottom: 1rpx solid #eee;
}

/* 作品信息栏 */
.work-info {
  padding: 20rpx 16rpx;
  text-align: center;
}
.work-name {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}
.work-author {
  font-size: 24rpx;
  color: #888;
  font-style: italic; /* 斜体体现作者 */
}