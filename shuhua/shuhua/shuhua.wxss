/* pages/shuhua/shuhua.wxss */
page {
  background-color: #f8f5f0; /* 仿古纸底色 */
  font-family :"PingFang SC", "Helvetica Neue", sans-serif;
}

.container {
  padding-bottom: 40rpx;
}

/* 主标题区域 */
.main-title-bar {
  padding: 40rpx 60rpx 20rpx;
  text-align: center;
  display: block;
  height: auto ;
}
.title-img {
  width: 100%;
  height: 120rpx;
  /* 可选：添加文字阴影效果 */
  filter: drop-shadow(0rpx 2rpx 4rpx rgba(0, 0, 0, 0.1));
}

/* 总分类容器 */
.category-list {
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 20rpx 40rpx 60rpx;
}

/* 单个分类项 */
.category-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 30%;
}
.category-img {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%; /* 圆形图标 */
  border: 6rpx solid #d8be9a; /* 仿古边框 */
  background-color: #fff;
  box-shadow: 0 8rpx 16rpx rgba(0, 0, 0, 0.1);
}
.category-title {
  margin-top: 20rpx;
  font-size: 36rpx;
  font-weight: bold;
  color: #5c3a21; /* 深褐色字体 */
  letter-spacing: 4rpx; /* 字间距 */
}

/* 作品展示区域通用样式 */
.works-area {
  margin: 0 30rpx 60rpx;
  background-color: #fff;
  border: 1rpx solid #e0e0e0;
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 分区标题 */
.section-title {
  font-size: 42rpx;
  font-weight: bold;
  color: #2c2c2c;
  text-align: center;
  margin-bottom: 40rpx;
  position: relative;
  padding-bottom: 20rpx;
}
/* 标题装饰线 */
.section-title::after {
  content: "";
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 120rpx;
  height: 6rpx;
  /* 区分书法和国画颜色 */
  background: linear-gradient(to right, #e6b861, #d4a660); /* 金石色 */
  border-radius: 3rpx;
}

/* 书法作品区特有的标题装饰 */
.works-area:nth-child(4) .section-title::after {
  background: linear-gradient(to right, #a02010, #c04020); /* 朱砂红 */
}

/* 作品列表网格 */
.works-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

/* 单个作品卡片 */
.work-item {
  width: 48%;
  margin-bottom: 30rpx;
  background-color: #fafafa;
  border-radius: 12rpx;
  overflow: hidden;
  border: 1rpx solid #eee;
  transition: all 0.3s ease;
}
.work-item:active {
  transform: scale(0.96);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

/* 作品封面图 */
.work-cover {
  width: 100%;
  height: 260rpx;
  border-bottom: 1rpx solid #eee;
}

/* 作品信息栏 */
.work-info {
  padding: 20rpx 16rpx;
  text-align: center;
}
.work-name {
  display: block;
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}
.work-author {
  font-size: 24rpx;
  color: #888;
  font-style: italic; /* 斜体体现作者 */
}