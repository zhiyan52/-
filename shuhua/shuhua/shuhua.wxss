.shuhua-container {
  min-height: 100vh;
  background: #E8F5E8;
  font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif;
}

/* 顶部品牌 */
.brand-header {
  margin: 20rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  border: 2rpx solid #D4A017;
}

.brand-content {
  position: relative;
  height: 400rpx;
}

.brand-bg {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.brand-title {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: transparent;
  color: #D4A017;
}

.main-title {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.5);
  font-family: "STKaiti", "KaiTi", serif;
  letter-spacing: 8rpx;
}

.sub-title {
  font-size: 32rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.5);
  font-family: "STKaiti", "KaiTi", serif;
}

/* 通用标题样式 */
.section-title {
  text-align: center;
  margin: 40rpx 0 30rpx;
  position: relative;
}

.section-title text {
  font-size: 36rpx;
  font-weight: bold;
  color: #1A365D;
  position: relative;
  padding: 0 40rpx;
  font-family: "STKaiti", "KaiTi", serif;
}

.section-title::after {
  content: '';
  position: absolute;
  bottom: -10rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 100rpx;
  height: 4rpx;
  background: #D4A017;
  border-radius: 2rpx;
}

/* 功能模块 */
.modules-section {
  padding: 0 20rpx;
  margin-bottom: 50rpx;
}

.modules-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.module-card {
  background: #F8F0E3;
  border-radius: 24rpx;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  border: 2rpx solid #D4A017;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
}

.module-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.module-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #F8F0E3;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  border: 2rpx solid #D4A017;
}

.module-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #1A365D;
  margin-bottom: 8rpx;
  text-align: center;
  font-family: "STKaiti", "KaiTi", serif;
}

.module-desc {
  font-size: 20rpx;
  color: #666;
  text-align: center;
  line-height: 1.4;
  font-family: "STKaiti", "KaiTi", serif;
}

/* 精选书画 */
.featured-section {
  padding: 0 20rpx;
  margin-bottom: 50rpx;
}

.featured-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.featured-card {
  background: #F8F0E3;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  border: 2rpx solid #D4A017;
  transition: all 0.3s ease;
}

.featured-card:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.featured-image {
  width: 100%;
  height: 200rpx;
  object-fit: cover;
  border-bottom: 2rpx solid #D4A017;
}

.featured-name {
  font-size: 24rpx;
  font-weight: bold;
  color: #1A365D;
  padding: 16rpx 16rpx 8rpx;
  font-family: "STKaiti", "KaiTi", serif;
}

.featured-desc {
  font-size: 18rpx;
  color: #666;
  padding: 0 16rpx 16rpx;
  line-height: 1.4;
  font-family: "STKaiti", "KaiTi", serif;
}

/* 智能功能 */
.smart-section {
  padding: 0 20rpx;
  margin-bottom: 50rpx;
}

.smart-feature-item {
  background: #F8F0E3;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  border: 2rpx solid #D4A017;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
}

.smart-feature-item:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.smart-feature-icon {
  width: 60rpx;
  height: 60rpx;
  margin-right: 20rpx;
}

.smart-feature-content {
  flex: 1;
}

.smart-feature-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1A365D;
  margin-bottom: 5rpx;
  font-family: "STKaiti", "KaiTi", serif;
}

.smart-feature-desc {
  font-size: 24rpx;
  color: #666;
  font-family: "STKaiti", "KaiTi", serif;
}

.smart-feature-arrow {
  font-size: 32rpx;
  color: #D4A017;
  margin-left: 16rpx;
}

/* 底部装饰 */
.footer-section {
  text-align: center;
  padding: 40rpx 0;
  margin-top: 60rpx;
  background: linear-gradient(135deg, #1A365D 0%, #2C5282 100%);
  border-top: 2rpx solid #D4A017;
}

.footer-text {
  font-size: 24rpx;
  font-weight: bold;
  color: #D4A017;
  margin-bottom: 8rpx;
  font-family: "STKaiti", "KaiTi", serif;
}

.footer-subtext {
  font-size: 20rpx;
  color: #F8F0E3;
  margin-bottom: 16rpx;
  font-family: "STKaiti", "KaiTi", serif;
}

.footer-copyright {
  font-size: 18rpx;
  color: rgba(248, 240, 227, 0.8);
  font-family: "STKaiti", "KaiTi", serif;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .modules-grid {
    grid-template-columns: 1fr;
  }
  
  .featured-grid {
    grid-template-columns: 1fr;
  }
  
  .brand-content {
    height: 300rpx;
  }
  
  .main-title {
    font-size: 40rpx;
  }
  
  .sub-title {
    font-size: 28rpx;
  }
}