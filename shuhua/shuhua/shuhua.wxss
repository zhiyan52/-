/* 书画雅韵 - 传统中国风样式 */
.shuhua-container {
  background-color: #E8F5E8;
  min-height: 100vh;
  padding: 20rpx 30rpx;
  padding-bottom: 140rpx;
}

/* 主视觉区 */
.hero {
  margin: 20rpx 0 40rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
  border: 4rpx solid #D4A017;
}

.hero-swiper {
  width: 100%;
  height: 400rpx;
}

.hero-image {
  width: 100%;
  height: 100%;
  display: block;
}

/* 功能入口 */
.features {
  margin: 40rpx 0;
}

.feature-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 48%;
  background: #F8F0E3;
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  border: 2rpx solid #D4A017;
  transition: all 0.3s;
}

.feature-item:active {
  transform: translateY(-5rpx);
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.15);
}

.feature-icon {
  width: 180rpx;
  height: 180rpx;
  margin-bottom: 20rpx;
  border-radius: 50%;
  border: 2rpx solid #D4A017;
}

.feature-item text {
  font-size: 28rpx;
  color: #1A365D;
  font-weight: 500;
  font-family: "STKaiti", "KaiTi", serif;
}

/* 通用标题样式 */
.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1A365D;
  margin-bottom: 30rpx;
  display: block;
  text-align: center;
  font-family: "STKaiti", "KaiTi", serif;
  position: relative;
  padding-bottom: 15rpx;
}

.section-title::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 100rpx;
  height: 4rpx;
  background: #D4A017;
  border-radius: 2rpx;
}

/* 精选推荐 */
.section {
  margin-top: 50rpx;
}

.recommendations {
  display: flex;
  justify-content: space-between;
}

.recommend-item {
  width: 48%;
  background: #F8F0E3;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  border: 2rpx solid #D4A017;
  transition: all 0.3s;
}

.recommend-item:active {
  transform: translateY(-5rpx);
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.15);
}

.rec-image {
  width: 100%;
  height: 240rpx;
  border-radius: 8rpx;
  margin-bottom: 15rpx;
  border: 2rpx solid #D4A017;
}

.rec-title {
  font-size: 28rpx;
  color: #1A365D;
  text-align: center;
  font-family: "STKaiti", "KaiTi", serif;
  font-weight: 500;
  display: block;
}

.rec-desc {
  font-size: 24rpx;
  color: #666;
  text-align: center;
  font-family: "STKaiti", "KaiTi", serif;
  display: block;
  margin-top: 10rpx;
}

/* 智能功能按钮 */
.smart-features {
  margin: 40rpx 0;
}

.smart-feature-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #F8F0E3;
  border-radius: 16rpx;
  padding: 25rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  border: 2rpx solid #D4A017;
  transition: all 0.3s;
}

.smart-feature-item:active {
  transform: translateY(-5rpx);
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.15);
}

.smart-feature-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
  color: #1A365D;
}

.smart-feature-content {
  flex: 1;
}

.smart-feature-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1A365D;
  margin-bottom: 5rpx;
  font-family: "STKaiti", "KaiTi", serif;
}

.smart-feature-desc {
  font-size: 24rpx;
  color: #666;
  font-family: "STKaiti", "KaiTi", serif;
}

.smart-feature-arrow {
  font-size: 32rpx;
  color: #D4A017;
}

/* 底部信息 */
.footer {
  margin-top: 50rpx;
  padding: 30rpx;
  text-align: center;
  background: linear-gradient(135deg, #1A365D 0%, #2C5282 100%);
  border-radius: 16rpx 16rpx 0 0;
  border-top: 4rpx solid #D4A017;
}

.footer-text {
  font-size: 24rpx;
  color: #F8F0E3;
  margin-bottom: 10rpx;
  font-family: "STKaiti", "KaiTi", serif;
}

.footer-copyright {
  font-size: 20rpx;
  color: rgba(248, 240, 227, 0.8);
  font-family: "STKaiti", "KaiTi", serif;
}

/* 底部空间 */
.bottom-space {
  height: 40rpx;
}
