/* 名家详情页样式 */
.master-detail-container {
  background-color: #f5f2e9;
  min-height: 100vh;
  padding: 20rpx;
}

/* 名家信息 */
.master-info-section {
  text-align: center;
  margin-bottom: 30rpx;
  padding: 30rpx;
  background-color: rgba(255, 255, 255, 0.8);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.master-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  object-fit: cover;
  margin-bottom: 20rpx;
  border: 4rpx solid #8B4513;
}

.master-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #8B4513;
  margin-bottom: 10rpx;
  display: block;
  font-family: '楷体', 'KaiTi', serif;
}

.master-dynasty {
  font-size: 28rpx;
  color: #6b5344;
  display: block;
  background-color: rgba(139, 69, 19, 0.1);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  inline-size: fit-content;
  margin: 0 auto;
}

/* 详细介绍 */
.detail-section {
  margin-bottom: 30rpx;
  background-color: rgba(255, 255, 255, 0.8);
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #8B4513;
  margin-bottom: 20rpx;
  display: block;
  font-family: '楷体', 'KaiTi', serif;
  border-bottom: 2rpx solid rgba(139, 69, 19, 0.3);
  padding-bottom: 10rpx;
}

.detail-content {
  font-size: 24rpx;
  color: #6b5344;
  line-height: 1.6;
  text-align: justify;
}

/* 代表作品 */
.works-section {
  margin-bottom: 30rpx;
  background-color: rgba(255, 255, 255, 0.8);
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.works-list {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}

.work-item {
  background-color: rgba(139, 69, 19, 0.1);
  padding: 15rpx 25rpx;
  border-radius: 25rpx;
  font-size: 24rpx;
  color: #8B4513;
  font-family: '楷体', 'KaiTi', serif;
  transition: all 0.3s ease;
}

.work-item:hover {
  background-color: rgba(139, 69, 19, 0.2);
  transform: translateY(-2rpx);
}

/* 艺术风格 */
.style-section {
  margin-bottom: 30rpx;
  background-color: rgba(255, 255, 255, 0.8);
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.style-content {
  font-size: 24rpx;
  color: #6b5344;
  line-height: 1.6;
  text-align: justify;
}

/* 文化地位 */
.status-section {
  margin-bottom: 30rpx;
  background-color: rgba(255, 255, 255, 0.8);
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.status-content {
  font-size: 24rpx;
  color: #6b5344;
  line-height: 1.6;
  text-align: justify;
}

/* 底部装饰 */
.footer-section {
  text-align: center;
  padding: 20rpx 0;
}

.footer-text {
  font-size: 24rpx;
  color: #9e8b7c;
  font-family: '楷体', 'KaiTi', serif;
}