<!-- 临帖页面 -->
<view class="lintie-container">
  <!-- 顶部标题 -->
  <view class="page-header">
    <text class="page-title">AI临帖</text>
    <text class="page-subtitle">智能书法练习助手</text>
  </view>
  
  <!-- 选择书体 -->
  <view class="font-section">
    <view class="section-title">选择书体</view>
    <view class="font-grid">
      <view class="font-item {{selectedFont === 'regular' ? 'active' : ''}}" bindtap="selectFont" data-font="regular">
        <text class="font-name">楷书</text>
        <text class="font-sample">楷书示例</text>
      </view>
      <view class="font-item {{selectedFont === 'running' ? 'active' : ''}}" bindtap="selectFont" data-font="running">
        <text class="font-name">行书</text>
        <text class="font-sample">行书示例</text>
      </view>
      <view class="font-item {{selectedFont === 'cursive' ? 'active' : ''}}" bindtap="selectFont" data-font="cursive">
        <text class="font-name">草书</text>
        <text class="font-sample">草书示例</text>
      </view>
      <view class="font-item {{selectedFont === 'official' ? 'active' : ''}}" bindtap="selectFont" data-font="official">
        <text class="font-name">隶书</text>
        <text class="font-sample">隶书示例</text>
      </view>
    </view>
  </view>
  
  <!-- 选择字帖 -->
  <view class="copybook-section">
    <view class="section-title">选择字帖</view>
    <view class="copybook-list">
      <view class="copybook-item {{selectedCopybook === item.id ? 'active' : ''}}" wx:for="{{copybooks}}" wx:key="id" bindtap="selectCopybook" data-id="{{item.id}}">
        <image class="copybook-image" src="{{item.image}}" mode="aspectFit"></image>
        <text class="copybook-name">{{item.name}}</text>
        <text class="copybook-author">{{item.author}}</text>
      </view>
    </view>
  </view>
  
  <!-- 临帖区域 -->
  <view class="practice-section">
    <view class="section-title">临帖练习</view>
    <view class="practice-area">
      <view class="original-section">
        <text class="section-label">原帖</text>
        <image class="original-image" src="{{currentCopybook?.image}}" mode="aspectFit"></image>
      </view>
      <view class="practice-section">
        <text class="section-label">临帖</text>
        <canvas class="practice-canvas" canvas-id="practiceCanvas" bindtouchstart="startDrawing" bindtouchmove="draw" bindtouchend="endDrawing"></canvas>
      </view>
    </view>
  </view>
  
  <!-- 控制按钮 -->
  <view class="control-section">
    <button class="control-btn" bindtap="clearCanvas">清空</button>
    <button class="control-btn primary" bindtap="generateImage">生成图片</button>
    <button class="control-btn" bindtap="saveImage">保存</button>
  </view>
  
  <!-- 生成结果 -->
  <view class="result-section" wx:if="{{generatedImage}}">
    <view class="section-title">生成结果</view>
    <image class="result-image" src="{{generatedImage}}" mode="aspectFit"></image>
  </view>
</view>