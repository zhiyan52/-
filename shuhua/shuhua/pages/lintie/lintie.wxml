<!-- 临帖页面 -->
<view class="lintie-container">
  <!-- 顶部标题 -->
  <view class="page-header">
    <text class="page-title">AI临帖</text>
    <text class="page-subtitle">智能书法练习助手</text>
  </view>
  
  <!-- 自定义文字输入 -->
  <view class="text-input-section">
    <view class="section-title">自定义文字</view>
    <textarea 
      class="text-input" 
      placeholder="请输入单个汉字，支持简体中文" 
      maxlength="1" 
      value="{{customText}}" 
      bindinput="onTextInput"
    ></textarea>
    <text class="text-count">{{customText.length}}/1</text>
  </view>
  
  <!-- 选择书体 -->
  <view class="font-section">
    <view class="section-title">选择字体</view>
    <view class="font-grid">
      <view class="font-item {{selectedFont === 'regular' ? 'active' : ''}}" bindtap="selectFont" data-font="regular">
        <text class="font-name">楷书</text>
        <text class="font-sample">楷书示例</text>
      </view>
      <view class="font-item {{selectedFont === 'running' ? 'active' : ''}}" bindtap="selectFont" data-font="running">
        <text class="font-name">行书</text>
        <text class="font-sample">行书示例</text>
      </view>
      <view class="font-item {{selectedFont === 'song' ? 'active' : ''}}" bindtap="selectFont" data-font="song">
        <text class="font-name">仿宋</text>
        <text class="font-sample">仿宋示例</text>
      </view>
    </view>
  </view>
  
  <!-- 田字格预览 -->
  <view class="preview-section">
    <view class="section-title">田字格预览</view>
    <view class="preview-area">
      <canvas class="preview-canvas" canvas-id="previewCanvas"></canvas>
    </view>
  </view>
  
  <!-- 控制按钮 -->
  <view class="control-section">
    <button class="control-btn" bindtap="clearCanvas">清空</button>
    <button class="control-btn primary" bindtap="generateImage">生成字帖</button>
    <button class="control-btn" bindtap="saveImage">保存到相册</button>
  </view>
  
  <!-- 生成结果 -->
  <view class="result-section" wx:if="{{generatedImage}}">
    <view class="section-title">生成结果</view>
    <image class="result-image" src="{{generatedImage}}" mode="aspectFit"></image>
    <button class="save-btn" bindtap="saveToAlbum">保存到相册</button>
  </view>
  
  <!-- 生成用隐藏画布 -->
  <canvas canvas-id="practiceCanvas" class="hidden-canvas"></canvas>
</view>