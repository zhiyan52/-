/* 临帖页面样式 */
.lintie-container {
  min-height: 100vh;
  background: #F8F0E3;
  padding: 20rpx;
  font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif;
}

/* 顶部标题 */
.page-header {
  text-align: center;
  margin-bottom: 40rpx;
  padding-top: 20rpx;
}

.page-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #1A365D;
  margin-bottom: 8rpx;
  font-family: "STKaiti", "KaiTi", serif;
  letter-spacing: 8rpx;
}

.page-subtitle {
  font-size: 24rpx;
  color: #666;
  font-family: "STKaiti", "KaiTi", serif;
}

/* 通用标题样式 */
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1A365D;
  margin-bottom: 20rpx;
  font-family: "STKaiti", "KaiTi", serif;
  border-left: 4rpx solid #D4A017;
  padding-left: 16rpx;
}

/* 文字输入区域 */
.text-input-section {
  margin-bottom: 40rpx;
}

.text-input {
  width: 100%;
  min-height: 160rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 28rpx;
  font-family: "STKaiti", "KaiTi", serif;
  border: 2rpx solid #E0E0E0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  resize: none;
}

.text-count {
  font-size: 20rpx;
  color: #999;
  text-align: right;
  margin-top: 8rpx;
  font-family: "STKaiti", "KaiTi", serif;
}

/* 字体选择 */
.font-section {
  margin-bottom: 40rpx;
}

.font-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.font-item {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
  border: 2rpx solid #E0E0E0;
  transition: all 0.3s ease;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.font-item.active {
  border-color: #D4A017;
  background: #FFF9E6;
  box-shadow: 0 4rpx 12rpx rgba(212, 160, 23, 0.2);
}

.font-name {
  font-size: 28rpx;
  font-weight: bold;
  color: #1A365D;
  margin-bottom: 8rpx;
  font-family: "STKaiti", "KaiTi", serif;
}

.font-sample {
  font-size: 20rpx;
  color: #666;
  font-family: "STKaiti", "KaiTi", serif;
}

/* 行列布局设置 */
.layout-section {
  margin-bottom: 40rpx;
}

.layout-options {
  display: flex;
  gap: 20rpx;
  flex-wrap: wrap;
}

.layout-item {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 20rpx 30rpx;
  text-align: center;
  border: 2rpx solid #E0E0E0;
  transition: all 0.3s ease;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  font-size: 24rpx;
  font-weight: bold;
  color: #1A365D;
  font-family: "STKaiti", "KaiTi", serif;
}

.layout-item.active {
  border-color: #D4A017;
  background: #FFF9E6;
  box-shadow: 0 4rpx 12rpx rgba(212, 160, 23, 0.2);
}

/* 田字格预览 */
.preview-section {
  margin-bottom: 40rpx;
}

.preview-area {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  border: 2rpx solid #E0E0E0;
  display: flex;
  justify-content: center;
}

.preview-canvas {
  width: 300rpx;
  height: 400rpx;
  background: #FFFFFF !important;
  border-radius: 8rpx;
  border: 1rpx solid #E0E0E0;
}

/* 控制按钮 */
.control-section {
  display: flex;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.control-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
  font-family: "STKaiti", "KaiTi", serif;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid #D4A017;
  color: #D4A017;
  background: #FFFFFF;
  transition: all 0.3s ease;
}

.control-btn.primary {
  background: #D4A017;
  color: #FFFFFF;
}

.control-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

/* 生成结果 */
.result-section {
  margin-bottom: 40rpx;
}

.result-image {
  width: 100%;
  border-radius: 16rpx;
  border: 2rpx solid #E0E0E0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
  margin-bottom: 20rpx;
}

.save-btn {
  width: 100%;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: bold;
  font-family: "STKaiti", "KaiTi", serif;
  background: #D4A017;
  color: #FFFFFF;
  border: none;
  transition: all 0.3s ease;
}

.save-btn:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

/* 生成用隐藏画布 */
.hidden-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 750rpx;
  height: 1000rpx;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .font-grid {
    grid-template-columns: 1fr;
  }
  
  .control-section {
    flex-direction: column;
  }
  
  .control-btn {
    width: 100%;
  }
  
  .layout-options {
    justify-content: center;
  }
  
  .preview-canvas {
    width: 260rpx;
    height: 350rpx;
  }
}