/* 书画佳句卡片生成样式 */
.cards-container {
  background-color: #f5f2e9;
  min-height: 100vh;
  padding: 20rpx;
}

/* 顶部标题 */
.header-section {
  text-align: center;
  margin-bottom: 30rpx;
  padding: 30rpx 0;
  background-color: rgba(255, 255, 255, 0.7);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #8B4513;
  margin-bottom: 10rpx;
  display: block;
  font-family: '楷体', 'KaiTi', serif;
}

.header-subtitle {
  font-size: 24rpx;
  color: #6b5344;
  display: block;
}

/* 卡片预览 */
.card-preview {
  display: flex;
  justify-content: center;
  margin-bottom: 30rpx;
}

.card {
  width: 600rpx;
  height: 400rpx;
  border-radius: 20rpx;
  background-size: cover;
  background-position: center;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.15);
  position: relative;
}

.card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.3);
  border-radius: 20rpx;
  z-index: 1;
}

.card-text {
  font-size: 32rpx;
  color: #ffffff;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 30rpx;
  font-family: '楷体', 'KaiTi', serif;
  z-index: 2;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.5);
}

.card-author {
  font-size: 24rpx;
  color: #ffffff;
  font-family: '楷体', 'KaiTi', serif;
  z-index: 2;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.5);
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 20rpx;
  justify-content: center;
  margin-bottom: 40rpx;
}

.action-button {
  background-color: #8B4513;
  color: #ffffff;
  border-radius: 30rpx;
  padding: 20rpx 60rpx;
  font-size: 28rpx;
  font-family: '楷体', 'KaiTi', serif;
  box-shadow: 0 4rpx 12rpx rgba(139, 69, 19, 0.3);
  transition: all 0.3s ease;
  flex: 1;
  max-width: 250rpx;
}

.action-button.secondary {
  background-color: #9e8b7c;
}

.action-button:hover {
  transform: translateY(-3rpx);
  box-shadow: 0 6rpx 16rpx rgba(139, 69, 19, 0.4);
}

.button-text {
  font-family: '楷体', 'KaiTi', serif;
}

/* 佳句列表 */
.quotes-section {
  background-color: rgba(255, 255, 255, 0.8);
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #8B4513;
  margin-bottom: 20rpx;
  display: block;
  font-family: '楷体', 'KaiTi', serif;
  border-bottom: 2rpx solid rgba(139, 69, 19, 0.3);
  padding-bottom: 10rpx;
}

.quotes-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
  max-height: 400rpx;
  overflow-y: auto;
}

.quote-item {
  padding: 20rpx;
  background-color: rgba(245, 242, 233, 0.8);
  border-radius: 15rpx;
  transition: all 0.3s ease;
  cursor: pointer;
}

.quote-item:hover {
  background-color: rgba(245, 242, 233, 1);
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.quote-text {
  font-size: 24rpx;
  color: #6b5344;
  line-height: 1.4;
  margin-bottom: 8rpx;
  display: block;
  font-family: '楷体', 'KaiTi', serif;
}

.quote-author {
  font-size: 20rpx;
  color: #9e8b7c;
  display: block;
  font-family: '楷体', 'KaiTi', serif;
}

/* 底部装饰 */
.footer-section {
  text-align: center;
  padding: 20rpx 0;
}

.footer-text {
  font-size: 24rpx;
  color: #9e8b7c;
  font-family: '楷体', 'KaiTi', serif;
}

/* 滚动条样式 */
::-webkit-scrollbar {
  width: 4rpx;
  height: 4rpx;
}

::-webkit-scrollbar-track {
  background: rgba(139, 69, 19, 0.1);
  border-radius: 2rpx;
}

::-webkit-scrollbar-thumb {
  background: rgba(139, 69, 19, 0.3);
  border-radius: 2rpx;
}

::-webkit-scrollbar-thumb:hover {
  background: rgba(139, 69, 19, 0.5);
}