/* shuhua/shuhua/pages/masters/masters.wxss */
.masters-container {
  min-height: 100vh;
  background: #f5f1e8;
  font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif;
  padding-bottom: 40rpx;
}

/* 页面标题 */
.page-header {
  text-align: center;
  padding: 60rpx 0 40rpx;
  position: relative;
}

.header-title {
  font-size: 44rpx;
  font-weight: bold;
  color: #2c2419;
  font-family: "STKaiti", "KaiTi", serif;
  letter-spacing: 6rpx;
  display: block;
}

.header-subtitle {
  font-size: 24rpx;
  color: #8b7355;
  margin-top: 12rpx;
  font-family: "STKaiti", "KaiTi", serif;
  display: block;
}

/* 分类标签 */
.tab-container {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  margin: 0 40rpx 40rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #e8dfd0;
}

.tab-item {
  padding: 12rpx 32rpx;
  border-radius: 40rpx;
  transition: all 0.3s ease;
}

.tab-item.active {
  background: linear-gradient(135deg, #d4a76a 0%, #b8956a 100%);
  box-shadow: 0 4rpx 12rpx rgba(212, 167, 106, 0.3);
}

.tab-text {
  font-size: 26rpx;
  color: #8b7355;
  font-family: "STKaiti", "KaiTi", serif;
  font-weight: 500;
}

.tab-item.active .tab-text {
  color: white;
  font-weight: bold;
}

/* 名家列表 */
.masters-list {
  padding: 0 24rpx;
}

.master-item {
  background: white;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  border: 1rpx solid #e8dfd0;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  transition: all 0.3s ease;
  position: relative;
  overflow: hidden;
}

.master-item::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6rpx;
  background: linear-gradient(180deg, #d4a76a 0%, #b8956a 100%);
}

.master-item:active {
  transform: scale(0.99);
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.08);
}

.master-image {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  object-fit: cover;
  margin-right: 24rpx;
  border: 3rpx solid #d4a76a;
  background: #f5f1e8;
}

.master-info {
  flex: 1;
}

.master-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #2c2419;
  margin-bottom: 8rpx;
  font-family: "STKaiti", "KaiTi", serif;
  display: block;
}

.master-dynasty {
  font-size: 22rpx;
  color: #d4a76a;
  margin-bottom: 8rpx;
  font-family: "STKaiti", "KaiTi", serif;
  display: block;
}

.master-desc {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
  font-family: "STKaiti", "KaiTi", serif;
  display: block;
}

.master-arrow {
  font-size: 32rpx;
  color: #d4a76a;
  margin-left: 16rpx;
}

/* 底部装饰 */
.footer-section {
  text-align: center;
  padding: 60rpx 0 40rpx;
  margin-top: 40rpx;
}

.footer-text {
  font-size: 22rpx;
  color: #8b7355;
  font-family: "STKaiti", "KaiTi", serif;
  display: block;
}

.footer-subtext {
  font-size: 18rpx;
  color: #aaa;
  margin-top: 8rpx;
  font-family: "STKaiti", "KaiTi", serif;
  display: block;
}
