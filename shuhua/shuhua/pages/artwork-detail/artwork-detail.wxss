/* 作品详情页样式 */
.detail-container {
  background-color: #f5f2e9;
  min-height: 100vh;
  padding: 20rpx;
}

/* 作品图片 */
.image-section {
  margin-bottom: 30rpx;
  background-color: rgba(255, 255, 255, 0.8);
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  text-align: center;
}

.artwork-image {
  width: 100%;
  height: 400rpx;
  border-radius: 10rpx;
  object-fit: contain;
  background-color: #f8f5ef;
}

/* 作品信息 */
.info-section {
  background-color: rgba(255, 255, 255, 0.8);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  text-align: center;
}

.artwork-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #8B4513;
  margin-bottom: 15rpx;
  display: block;
  font-family: '楷体', 'KaiTi', serif;
}

.artwork-author {
  font-size: 28rpx;
  color: #6b5344;
  margin-bottom: 10rpx;
  display: block;
}

.artwork-category {
  font-size: 24rpx;
  color: #9e8b7c;
  display: block;
  background-color: rgba(139, 69, 19, 0.1);
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  inline-size: fit-content;
  margin: 0 auto;
}

/* 作品详情 */
.detail-section {
  background-color: rgba(255, 255, 255, 0.8);
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.detail-item {
  margin-bottom: 30rpx;
}

.detail-item:last-child {
  margin-bottom: 0;
}

.detail-label {
  font-size: 28rpx;
  font-weight: bold;
  color: #8B4513;
  margin-bottom: 10rpx;
  display: block;
  font-family: '楷体', 'KaiTi', serif;
  border-bottom: 2rpx solid rgba(139, 69, 19, 0.3);
  padding-bottom: 8rpx;
  margin-bottom: 15rpx;
}

.detail-content {
  font-size: 24rpx;
  color: #6b5344;
  line-height: 1.6;
  text-align: justify;
}

/* AI讲解按钮 */
.ai-section {
  display: flex;
  justify-content: center;
  margin-bottom: 40rpx;
}

.ai-button {
  background-color: #8B4513;
  color: #ffffff;
  border-radius: 30rpx;
  padding: 20rpx 60rpx;
  font-size: 28rpx;
  font-family: '楷体', 'KaiTi', serif;
  box-shadow: 0 4rpx 12rpx rgba(139, 69, 19, 0.3);
  transition: all 0.3s ease;
}

.ai-button:hover {
  background-color: #6b3410;
  transform: translateY(-3rpx);
  box-shadow: 0 6rpx 16rpx rgba(139, 69, 19, 0.4);
}

.ai-button-text {
  font-family: '楷体', 'KaiTi', serif;
}

/* 底部装饰 */
.footer-section {
  text-align: center;
  padding: 20rpx 0;
}

.footer-text {
  font-size: 24rpx;
  color: #9e8b7c;
  font-family: '楷体', 'KaiTi', serif;
}