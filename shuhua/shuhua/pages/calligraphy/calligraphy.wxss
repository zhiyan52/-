/* 书法字体科普样式 */
.calligraphy-container {
  background-color: #f5f2e9;
  min-height: 100vh;
  padding: 20rpx;
}

/* 顶部标题 */
.header-section {
  text-align: center;
  margin-bottom: 30rpx;
  padding: 30rpx 0;
  background-color: rgba(255, 255, 255, 0.7);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #8B4513;
  margin-bottom: 10rpx;
  display: block;
  font-family: '楷体', 'KaiTi', serif;
}

.header-subtitle {
  font-size: 24rpx;
  color: #6b5344;
  display: block;
}

/* 书体选择 */
.font-tabs {
  display: flex;
  justify-content: space-between;
  margin-bottom: 30rpx;
  padding: 20rpx;
  background-color: rgba(255, 255, 255, 0.8);
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  border: 2rpx solid #D4A017;
}

.tab {
  flex: 1;
  padding: 16rpx 10rpx;
  margin: 0 5rpx;
  background-color: #F8F0E3;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #8b7355;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
  border: 2rpx solid #d4a76a;
  transition: all 0.3s ease;
  text-align: center;
}

.tab:active {
  background: linear-gradient(135deg, #f4c430 0%, #d4a76a 100%);
  transform: scale(0.95);
}

.tab.active {
  background: linear-gradient(135deg, #d4a76a 0%, #b8956a 100%);
  color: white;
  border-color: #d4a76a;
  box-shadow: 0 4rpx 12rpx rgba(212, 167, 106, 0.3);
}

.tab-text {
  font-family: '楷体', 'KaiTi', serif;
  font-weight: 500;
}

/* 书体详情 */
.font-detail {
  background-color: rgba(255, 255, 255, 0.8);
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 30rpx;
}

.font-header {
  text-align: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid rgba(139, 69, 19, 0.3);
}

.font-name {
  font-size: 40rpx;
  font-weight: bold;
  color: #8B4513;
  margin-bottom: 10rpx;
  display: block;
  font-family: '楷体', 'KaiTi', serif;
}

.font-period {
  font-size: 24rpx;
  color: #6b5344;
  display: block;
}

/* 字体示例 */
.font-example {
  text-align: center;
  margin-bottom: 30rpx;
  padding: 20rpx;
  background-color: rgba(245, 242, 233, 0.8);
  border-radius: 15rpx;
  border: 2rpx solid #D4A017;
}

.example-title {
  font-size: 26rpx;
  color: #1A365D;
  margin-bottom: 15rpx;
  display: block;
  font-family: '楷体', 'KaiTi', serif;
  font-weight: 500;
}

.example-image {
  width: 100%;
  height: 280rpx;
  border-radius: 10rpx;
  background-color: #fff;
}

/* 特点对比 */
.font-features {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #8B4513;
  margin-bottom: 15rpx;
  display: block;
  font-family: '楷体', 'KaiTi', serif;
  border-bottom: 2rpx solid rgba(139, 69, 19, 0.3);
  padding-bottom: 8rpx;
}

.feature-text {
  font-size: 24rpx;
  color: #6b5344;
  line-height: 1.6;
  text-align: justify;
}

/* 起源与发展 */
.font-origin {
  margin-bottom: 30rpx;
}

.origin-text {
  font-size: 24rpx;
  color: #6b5344;
  line-height: 1.6;
  text-align: justify;
}

/* 代表人物与作品 */
.font-masters {
  margin-bottom: 30rpx;
}

.masters-list {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}

.master-item {
  background-color: rgba(139, 69, 19, 0.1);
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #8B4513;
  font-family: '楷体', 'KaiTi', serif;
  transition: all 0.3s ease;
}

.master-item:hover {
  background-color: rgba(139, 69, 19, 0.2);
  transform: translateY(-2rpx);
}

/* 简单辨识技巧 */
.font-tips {
  margin-bottom: 20rpx;
}

.tips-text {
  font-size: 24rpx;
  color: #6b5344;
  line-height: 1.6;
  text-align: justify;
}

/* 底部装饰 */
.footer-section {
  text-align: center;
  padding: 20rpx 0;
}

.footer-text {
  font-size: 24rpx;
  color: #9e8b7c;
  font-family: '楷体', 'KaiTi', serif;
}

/* 滚动条样式 */
::-webkit-scrollbar {
  width: 4rpx;
  height: 4rpx;
}

::-webkit-scrollbar-track {
  background: rgba(139, 69, 19, 0.1);
  border-radius: 2rpx;
}

::-webkit-scrollbar-thumb {
  background: rgba(139, 69, 19, 0.3);
  border-radius: 2rpx;
}

::-webkit-scrollbar-thumb:hover {
  background: rgba(139, 69, 19, 0.5);
}