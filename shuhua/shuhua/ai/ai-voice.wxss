.ai-voice-container {
  background-color: #f7f3e9;
  min-height: 100vh;
  padding: 20rpx;
  font-family: 'STKaiti', 'KaiTi', serif;
}

.header {
  text-align: center;
  margin-bottom: 30rpx;
  padding-top: 20rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.header-subtitle {
  font-size: 24rpx;
  color: #666;
}

.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 8rpx solid #f3f3f3;
  border-top: 8rpx solid #8b7355;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  font-size: 24rpx;
  color: #666;
}

.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
  text-align: center;
}

.error-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.error-text {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 30rpx;
  padding: 0 40rpx;
}

.voice-content {
  background-color: white;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.voice-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #e5e5e5;
}

.play-control {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.play-btn,
.stop-btn {
  background-color: #8b7355;
  color: white;
  font-size: 24rpx;
  padding: 20rpx 40rpx;
  border-radius: 50rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'STKaiti', 'KaiTi', serif;
  border: none;
}

.stop-btn {
  background-color: #999;
}

.play-icon,
.stop-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.play-text,
.stop-text {
  font-size: 24rpx;
}

.progress-container {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
  padding: 0 20rpx;
}

.current-time,
.total-time {
  font-size: 22rpx;
  color: #666;
  min-width: 90rpx;
}

.current-time {
  text-align: left;
}

.total-time {
  text-align: right;
}

.progress-bar {
  flex: 1;
  height: 8rpx;
  background-color: #e5e5e5;
  border-radius: 4rpx;
  margin: 0 15rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #8b7355, #a08060);
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.section-list {
  margin-bottom: 30rpx;
}

.section-item {
  margin-bottom: 30rpx;
  padding-bottom: 30rpx;
  border-bottom: 2rpx solid #f0f0f0;
}

.section-item:last-child {
  margin-bottom: 0;
  padding-bottom: 0;
  border-bottom: none;
}

.section-item.playing {
  background-color: #faf8f3;
  border-radius: 12rpx;
  padding: 20rpx;
  margin: 0 -20rpx 30rpx;
  border-bottom: none;
}

.section-item.playing .section-header {
  margin-bottom: 20rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #8b7355;
}

.section-duration {
  font-size: 20rpx;
  color: #999;
  background-color: #f5f0e6;
  padding: 5rpx 15rpx;
  border-radius: 15rpx;
}

.section-content {
  font-size: 24rpx;
  line-height: 1.6;
  color: #333;
  text-align: justify;
}

.section-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.play-indicator {
  display: flex;
  align-items: center;
  justify-content: center;
}

.play-indicator-icon {
  font-size: 36rpx;
  animation: pulse 1.5s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.refresh-btn {
  background-color: #8b7355;
  color: white;
  font-size: 24rpx;
  padding: 20rpx;
  border-radius: 10rpx;
  width: 100%;
  margin-top: 20rpx;
  font-family: 'STKaiti', 'KaiTi', serif;
}

.footer {
  text-align: center;
  margin-top: 40rpx;
  padding-bottom: 20rpx;
}

.footer-text {
  font-size: 20rpx;
  color: #999;
  font-style: italic;
}