.ai-guide-container {
  background-color: #f7f3e9;
  min-height: 100vh;
  padding: 20rpx;
  font-family: 'STKaiti', 'KaiTi', serif;
}

.header {
  text-align: center;
  margin-bottom: 30rpx;
  padding-top: 20rpx;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.header-subtitle {
  font-size: 24rpx;
  color: #666;
}

.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 8rpx solid #f3f3f3;
  border-top: 8rpx solid #8b7355;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  font-size: 24rpx;
  color: #666;
}

.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 60vh;
  text-align: center;
}

.error-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.error-text {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 30rpx;
  padding: 0 40rpx;
}

.guide-content {
  background-color: white;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.guide-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #e5e5e5;
}

.section-item {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #8b7355;
  margin-bottom: 15rpx;
}

.section-image {
  width: 100%;
  height: 300rpx;
  border-radius: 10rpx;
  margin-bottom: 15rpx;
  object-fit: cover;
}

.section-content {
  font-size: 24rpx;
  line-height: 1.6;
  color: #333;
  text-align: justify;
}

.refresh-btn {
  background-color: #8b7355;
  color: white;
  font-size: 24rpx;
  padding: 20rpx;
  border-radius: 10rpx;
  width: 100%;
  margin-top: 20rpx;
  font-family: 'STKaiti', 'KaiTi', serif;
}

.footer {
  text-align: center;
  margin-top: 40rpx;
  padding-bottom: 20rpx;
}

.footer-text {
  font-size: 20rpx;
  color: #999;
  font-style: italic;
}