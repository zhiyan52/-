<!-- 智能导览页面 -->
<view class="ai-guide-container">
  <!-- 顶部标题 -->
  <view class="header">
    <text class="header-title">智能导览</text>
    <text class="header-subtitle">书画艺术深度解析</text>
  </view>

  <!-- 加载状态 -->
  <view wx:if="{{loading}}" class="loading-container">
    <view class="loading-spinner"></view>
    <text class="loading-text">正在生成导览内容...</text>
  </view>

  <!-- 错误状态 -->
  <view wx:if="{{error}}" class="error-container">
    <text class="error-icon">⚠️</text>
    <text class="error-text">{{error}}</text>
    <button class="refresh-btn" bindtap="refreshGuide">重新生成</button>
  </view>

  <!-- 导览内容 -->
  <view wx:if="{{guideContent && !loading && !error}}" class="guide-content">
    <text class="guide-title">{{guideContent.title}}</text>
    
    <view wx:for="{{guideContent.sections}}" wx:key="index" class="section-item">
      <text class="section-title">{{item.title}}</text>
      <image class="section-image" src="{{item.image}}"></image>
      <text class="section-content">{{item.content}}</text>
    </view>

    <button class="refresh-btn" bindtap="refreshGuide">换一批内容</button>
  </view>

  <!-- 底部装饰 -->
  <view class="footer">
    <text class="footer-text">由文心先生为您导览</text>
  </view>
</view>