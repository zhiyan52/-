<!--youxi/puzzle/puzzle.wxml-->
<text>youxi/puzzle/puzzle.wxml</text><view class="container">
  <view class="info">
    <text>步数：{{steps}}</text>
    <text>时间：{{time}}</text>
  </view>

  <view class="title">{{msg}}</view>

  <view class="board">
    <view wx:for="{{pieces}}"
      wx:key="index"
      class="piece"
      style="background-position: {{item.x}}rpx {{item.y}}rpx;"
      data-index="{{index}}"
      bindtap="onTap"
    ></view>
  </view>

  <view class="btns">
    <view class="btn" bindtap="shuffle">重新开始</view>
  </view>
</view>