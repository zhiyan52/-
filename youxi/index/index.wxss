page {
  background-color: #F5F2EB;
  font-family: "PingFang SC", "Microsoft YaHei";
}
.container {
  padding: 20rpx 30rpx;
  min-height: 100vh;
  box-sizing: border-box;
}
/* 头部 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: #fff;
  padding: 20rpx 30rpx;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(139,69,19,0.2);
  margin-bottom: 30rpx;
}
.score, .countdown {
  font-size: 32rpx;
  font-weight: bold;
  color: #8B4513;
}
.countdown.over {
  color: #E63946;
}
/* 题目盒子 */
.question-box {
  background-color: #fff;
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(139,69,19,0.2);
}
.question-num {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 30rpx;
}
.question-content {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.5;
  margin-bottom: 40rpx;
}
/* 选项 */
.option-list {
  display: flex;
  flex-direction: column;
  gap: 25rpx;
  margin-bottom: 50rpx;
}
.option {
  font-size: 32rpx;
  padding: 30rpx 20rpx;
  border: 2rpx solid #E8D9C1;
  border-radius: 15rpx;
  color: #333;
  display: flex;
  align-items: center;
  justify-content: space-between;
  transition: all 0.3s;
}
.option:active {
  background-color: #F5F2EB;
}
.option.correct {
  background-color: #D4EDDA;
  border-color: #28A745;
  color: #28A745;
}
.option.wrong {
  background-color: #F8D7DA;
  border-color: #DC3545;
  color: #DC3545;
}
.icon {
  font-size: 36rpx;
  font-weight: bold;
}
/* 按钮 */
.next-btn, .result-btn {
  background-color: #8B4513;
  color: #fff;
  border: none;
  border-radius: 100rpx;
  padding: 25rpx 0;
  font-size: 32rpx;
  width: 100%;
}
.next-btn:active, .result-btn:active {
  background-color: #6D3310;
}
/* 结束盒子 */
.over-box {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 60vh;
  background-color: #fff;
  border-radius: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(139,69,19,0.2);
}