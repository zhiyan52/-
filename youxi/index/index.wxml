<view class="container">
  <!-- 答题头部：分数、倒计时 -->
  <view class="header">
    <view class="score">得分：{{score}}</view>
    <view class="countdown" wx:if="{{countdown>0}}">倒计时：{{countdown}}s</view>
    <view class="countdown over" wx:else>时间到！</view>
  </view>

  <!-- 题目区域 -->
  <view class="question-box" wx:if="{{!isOver}}">
    <view class="question-num">第{{currentQ+1}}题/{{totalQ}}题</view>
    <view class="question-content">{{questionList[currentQ].title}}</view>
    <!-- 选项区域：修正 wx:if 和 wx:else 同级结构 -->
    <view class="option-list">
      <!-- 未选择时：可点击选项 -->
      <view 
        class="option {{optionStatus[index]}}"
        wx:for="{{questionList[currentQ].options}}"
        wx:key="index"
        bindtap="selectOption"
        data-index="{{index}}"
        wx:if="{{!selectDone}}"
      >
        {{String.fromCharCode(65+index)}}. {{item}}
      </view>
      <!-- 已选择时：显示对错状态 -->
      <view 
        class="option {{index==questionList[currentQ].answer?'correct':'wrong'}}"
        wx:for="{{questionList[currentQ].options}}"
        wx:key="index"
        wx:else
      >
        {{String.fromCharCode(65+index)}}. {{item}}
        <text class="icon" wx:if="{{index==questionList[currentQ].answer}}">✓</text>
        <text class="icon" wx:if="{{index!=questionList[currentQ].answer && index==selectIndex}}">×</text>
      </view>
    </view>
    <!-- 下一题按钮 -->
    <button class="next-btn" bindtap="nextQuestion" wx:if="{{selectDone}}">
      {{currentQ==totalQ-1?'查看结果':'下一题'}}
    </button>
  </view>

  <!-- 答题结束占位 -->
  <view class="over-box" wx:else>
    <button class="result-btn" bindtap="toResult">查看我的答题结果</button>
  </view>
</view>