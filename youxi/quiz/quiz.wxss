page {
  background-color: #F5F2EB;
  font-family: "PingFang SC", "Microsoft YaHei";
}
.result-container {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 100vh;
  padding: 30rpx;
  box-sizing: border-box;
}
.result-card {
  background-color: #fff;
  border-radius: 30rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 5rpx 20rpx rgba(139,69,19,0.3);
  width: 100%;
  max-width: 600rpx;
  text-align: center;
}
.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #8B4513;
  margin-bottom: 40rpx;
}
.score-box {
  border: 3rpx dashed #E8D9C1;
  border-radius: 20rpx;
  padding: 40rpx 20rpx;
  margin-bottom: 40rpx;
}
.score-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 20rpx;
}
.score-num {
  font-size: 60rpx;
  font-weight: bold;
  color: #8B4513;
  margin-bottom: 20rpx;
}
.rate {
  font-size: 32rpx;
  color: #E63946;
  font-weight: bold;
}
.desc {
  font-size: 34rpx;
  color: #333;
  margin-bottom: 50rpx;
  line-height: 1.5;
}
.restart-btn, .back-btn {
  width: 100%;
  border-radius: 100rpx;
  padding: 25rpx 0;
  font-size: 32rpx;
  margin-bottom: 20rpx;
}
.restart-btn {
  background-color: #8B4513;
  color: #fff;
  border: none;
}
.restart-btn:active {
  background-color: #6D3310;
}
.back-btn {
  background-color: #fff;
  color: #8B4513;
  border: 2rpx solid #8B4513;
}
.back-btn:active {
  background-color: #F5F2EB;
}