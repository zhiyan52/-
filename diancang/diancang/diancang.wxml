<!-- 典藏拾珠 - 古雅文轩风格 -->
<view class="home-container">
  
  <!-- 主视觉区轮播图 -->
  <view class="hero">
    <swiper class="hero-swiper" indicator-dots="true" autoplay="true" interval="3000" duration="500" circular="true">
      <swiper-item>
        <image src="cloud://cloud1-8glc9jqob91870fc.636c-cloud1-8glc9jqob91870fc-1401141450/diancang/lunbo1.png" class="hero-image" />
      </swiper-item>
      <swiper-item>
        <image src="cloud://cloud1-8glc9jqob91870fc.636c-cloud1-8glc9jqob91870fc-1401141450/diancang/lunbo1.png" class="hero-image" />
      </swiper-item>
      <swiper-item>
        <image src="cloud://cloud1-8glc9jqob91870fc.636c-cloud1-8glc9jqob91870fc-1401141450/diancang/lunbo1.png" class="hero-image" />
      </swiper-item>
    </swiper>
  </view>
  
  <!-- 功能入口 -->
  <view class="features">
    <view class="feature-row">
      <navigator url="/diancang/diancang/diancang-list" class="feature-item">
        <image src="cloud://cloud1-8glc9jqob91870fc.636c-cloud1-8glc9jqob91870fc-1401141450/diancang/icons/classics.png" class="feature-icon" />
        <text>典籍文库</text>
      </navigator>
      <navigator url="/diancang/diancang/diancang-treasure-hunt" class="feature-item">
        <image src="cloud://cloud1-8glc9jqob91870fc.636c-cloud1-8glc9jqob91870fc-1401141450/diancang/icons/treasure.png" class="feature-icon" />
        <text>典藏寻宝</text>
      </navigator>
    </view>
    <view class="feature-row">
      <navigator url="/diancang/diancang/ai/ai-qa" class="feature-item">
        <image src="cloud://cloud1-8glc9jqob91870fc.636c-cloud1-8glc9jqob91870fc-1401141450/diancang/icons/ai.png" class="feature-icon" />
        <text>AI文心先生</text>
      </navigator>
      <navigator url="/diancang/diancang/pages/community/community" class="feature-item">
        <image src="cloud://cloud1-8glc9jqob91870fc.636c-cloud1-8glc9jqob91870fc-1401141450/diancang/icons/community.png" class="feature-icon" />
        <text>典藏社区</text>
      </navigator>
    </view>
    <view class="feature-row">
      <navigator url="/diancang/diancang/diancang-fill" class="feature-item">
        <image src="cloud://cloud1-8glc9jqob91870fc.636c-cloud1-8glc9jqob91870fc-1401141450/diancang/icons/fill.png" class="feature-icon" />
        <text>古文填空</text>
      </navigator>
      <navigator url="/diancang/diancang/diancang-card" class="feature-item">
        <image src="cloud://cloud1-8glc9jqob91870fc.636c-cloud1-8glc9jqob91870fc-1401141450/diancang/icons/card.png" class="feature-icon" />
        <text>名句卡片</text>
      </navigator>
    </view>
  </view>
  
  <!-- 精选推荐 -->
  <view class="section">
    <text class="section-title">精选典藏</text>
    <view class="recommendations">
      <view class="recommend-item">
        <image src="cloud://cloud1-8glc9jqob91870fc.636c-cloud1-8glc9jqob91870fc-1401141450/diancang/books/shijing.jpg" class="rec-image" />
        <text class="rec-title">《诗经》</text>
        <text class="rec-era">西周至春秋</text>
      </view>
      <view class="recommend-item">
        <image src="cloud://cloud1-8glc9jqob91870fc.636c-cloud1-8glc9jqob91870fc-1401141450/diancang/books/shiji.jpg" class="rec-image" />
        <text class="rec-title">《史记》</text>
        <text class="rec-era">西汉</text>
      </view>
    </view>
  </view>
  
  <!-- AI文心先生功能 -->
  <view class="section">
    <text class="section-title">AI文心先生</text>
    <view class="ai-features">
      <view class="ai-feature-grid">
        <view class="ai-feature-card" bindtap="navigateToFeature" data-url="/diancang/diancang/ai/ai-qa">
          <image src="cloud://cloud1-8glc9jqob91870fc.636c-cloud1-8glc9jqob91870fc-1401141450/diancang/icons/ai-qa.png" class="ai-feature-icon" />
          <text class="ai-feature-title">AI问答</text>
          <text class="ai-feature-desc">文心先生为您解答文化疑问</text>
        </view>
        <view class="ai-feature-card" bindtap="navigateToFeature" data-url="/diancang/diancang/ai/ai-guide">
          <image src="cloud://cloud1-8glc9jqob91870fc.636c-cloud1-8glc9jqob91870fc-1401141450/diancang/icons/ai-guide.png" class="ai-feature-icon" />
          <text class="ai-feature-title">智能导览</text>
          <text class="ai-feature-desc">文心先生带您探文脉</text>
        </view>
        <view class="ai-feature-card" bindtap="navigateToFeature" data-url="/diancang/diancang/ai/ai-recommend">
          <image src="cloud://cloud1-8glc9jqob91870fc.636c-cloud1-8glc9jqob91870fc-1401141450/diancang/icons/ai-recommend.png" class="ai-feature-icon" />
          <text class="ai-feature-title">智能推荐</text>
          <text class="ai-feature-desc">文心先生为您精选典籍</text>
        </view>
        <view class="ai-feature-card" bindtap="navigateToFeature" data-url="/diancang/diancang/ai/ai-voice">
          <image src="cloud://cloud1-8glc9jqob91870fc.636c-cloud1-8glc9jqob91870fc-1401141450/diancang/icons/ai-voice.png" class="ai-feature-icon" />
          <text class="ai-feature-title">智能语音</text>
          <text class="ai-feature-desc">与文心先生语音交流</text>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 互动竞赛 -->
  <view class="section">
    <text class="section-title">互动竞赛</text>
    <view class="competition-card" bindtap="startKnowledgeQuiz">
      <view class="competition-content">
        <view class="competition-title">知识竞赛中心</view>
        <view class="competition-desc">参与每日挑战，与好友PK</view>
      </view>
      <view class="competition-icon">🏆</view>
    </view>
  </view>
  
  <!-- 典藏资讯 -->
  <view class="news-section">
    <view class="news-title">典藏资讯</view>
    <view class="news-item">
      <text class="news-icon">📚</text>
      <view class="news-content">
        <view class="news-item-title">国家图书馆推出古籍数字化新成果</view>
        <view class="news-item-desc">包含1000部珍稀古籍的数字化版本</view>
      </view>
    </view>
    <view class="news-item">
      <text class="news-icon">🏺</text>
      <view class="news-content">
        <view class="news-item-title">故宫博物院文物修复技术取得新突破</view>
        <view class="news-item-desc">运用AI技术辅助修复古代书画</view>
      </view>
    </view>
    <view class="news-item">
      <text class="news-icon">📜</text>
      <view class="news-content">
        <view class="news-item-title">《永乐大典》残卷数字化工程启动</view>
        <view class="news-item-desc">计划三年内完成全部残卷的数字化</view>
      </view>
    </view>
  </view>
  
  <!-- 底部信息 -->
  <view class="footer">
    <view class="footer-text">传承中华文脉</view>
    <view class="footer-text">感受典藏之美</view>
    <view class="footer-copyright">© 2026 典藏拾珠</view>
  </view>
  
  <!-- 底部空间 -->
  <view class="bottom-space"></view>
  
  <!-- 底部导航 -->
  <view class="tab-bar">
    <navigator url="/pages/index/index" class="tab-item">
      <image src="/components/shou.png" class="tab-image"></image>
      <text>首页</text>
    </navigator>
    <view class="tab-item active">
      <image src="/components/zonglan.png" class="tab-image"></image>
      <text>分类</text>
    </view>
    <navigator url="/diancang/diancang/pages/profile/profile" class="tab-item">
      <image src="/components/yonghu.png" class="tab-image"></image>
      <text>我的</text>
    </navigator>
  </view>
</view>
