<view class="container">

  <!-- 轮播图 -->
  <view class="banner-section">
    <swiper class="banner-swiper" indicator-dots="true" autoplay="true" interval="4000" duration="600" circular="true" indicator-color="rgba(255,255,255,0.5)" indicator-active-color="#D4A017">
      <swiper-item wx:for="{{bannerList}}" wx:key="index">
        <image class="banner-image" src="{{item.image}}" mode="aspectFill" />
      </swiper-item>
    </swiper>
  </view>

  <!-- 搜索栏 -->
  <view class="search-bar">
    <view class="search-input-wrapper">
      <view class="search-icon-simple">
        <view class="icon-circle"></view>
        <view class="icon-handle"></view>
      </view>
      <input class="search-input" placeholder="搜索典籍、文物、历史人物..." placeholder-class="placeholder-style" />
    </view>
  </view>

  <!-- 分类标签 -->
  <view class="category-grid">
    <view class="category-grid-item {{currentCategory === 'all' ? 'active' : ''}}" data-category="all" bindtap="switchCategory">
      <text class="category-icon">📚</text>
      <text class="category-name">全部</text>
    </view>
    <view class="category-grid-item {{currentCategory === 'classics' ? 'active' : ''}}" data-category="classics" bindtap="switchCategory">
      <text class="category-icon">📜</text>
      <text class="category-name">经史子集</text>
    </view>
    <view class="category-grid-item {{currentCategory === 'artifacts' ? 'active' : ''}}" data-category="artifacts" bindtap="switchCategory">
      <text class="category-icon">🏺</text>
      <text class="category-name">珍贵文物</text>
    </view>
    <view class="category-grid-item {{currentCategory === 'calligraphy' ? 'active' : ''}}" data-category="calligraphy" bindtap="switchCategory">
      <text class="category-icon">✍️</text>
      <text class="category-name">书法碑帖</text>
    </view>
    <view class="category-grid-item {{currentCategory === 'paintings' ? 'active' : ''}}" data-category="paintings" bindtap="switchCategory">
      <text class="category-icon">🖼️</text>
      <text class="category-name">传世名画</text>
    </view>
    <view class="category-grid-item {{currentCategory === 'bamboo' ? 'active' : ''}}" data-category="bamboo" bindtap="switchCategory">
      <text class="category-icon">📖</text>
      <text class="category-name">简帛文献</text>
    </view>
  </view>

  <!-- 轮播推荐 -->
  <view class="featured-section">
    <swiper class="featured-swiper" indicator-dots="true" autoplay="true" interval="5000" duration="800" circular="true" indicator-color="rgba(255,255,255,0.6)" indicator-active-color="#8B4513">
      <swiper-item wx:for="{{featuredList}}" wx:key="id">
        <view class="featured-card" bindtap="goToDetail" data-id="{{item.id}}">
          <image class="featured-image" src="{{item.image}}" mode="aspectFill" />
          <view class="featured-overlay">
            <view class="featured-tag">{{item.tag}}</view>
            <text class="featured-title">{{item.title}}</text>
            <text class="featured-desc">{{item.description}}</text>
          </view>
          <view class="featured-corner top-left"></view>
          <view class="featured-corner top-right"></view>
          <view class="featured-corner bottom-left"></view>
          <view class="featured-corner bottom-right"></view>
        </view>
      </swiper-item>
    </swiper>
  </view>

  <!-- 今日典籍推荐 -->
  <view class="daily-section">
    <view class="section-header">
      <view class="section-icon">📜</view>
      <text class="section-title">今日典籍</text>
      <view class="section-line"></view>
      <text class="section-date">{{todayDate}}</text>
    </view>
    
    <view class="daily-card" bindtap="goToDetail" data-id="{{dailyBook.id}}">
      <view class="daily-book-cover">
        <image src="{{dailyBook.cover}}" mode="aspectFill" />
        <view class="book-spine"></view>
        <view class="seal-mark">珍藏</view>
      </view>
      <view class="daily-book-info">
        <view class="book-header">
          <text class="book-name">{{dailyBook.name}}</text>
          <view class="dynasty-tag">{{dailyBook.dynasty}}</view>
        </view>
        <text class="book-author">{{dailyBook.author}}</text>
        <text class="book-summary">{{dailyBook.summary}}</text>
        <view class="book-meta">
          <view class="meta-item">
            <text class="meta-icon">👁</text>
            <text>{{dailyBook.views}}次浏览</text>
          </view>
          <view class="meta-item">
            <text class="meta-icon">⭐</text>
            <text>{{dailyBook.favorites}}人收藏</text>
          </view>
        </view>
        <view class="read-btn">
          <text>立即品读</text>
          <view class="btn-arrow">→</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 互动活动区 -->
  <view class="activity-section">
    <view class="section-header">
      <view class="section-icon">🎯</view>
      <text class="section-title">互动活动</text>
      <view class="section-line"></view>
    </view>
    
    <view class="activity-grid">
      <view class="activity-card" bindtap="startKnowledgeQuiz">
        <view class="activity-icon">📚</view>
        <text class="activity-title">知识竞赛</text>
        <text class="activity-desc">每日挑战，赢取积分</text>
        <view class="activity-arrow">→</view>
      </view>
      <view class="activity-card" bindtap="startTreasureHunt">
        <view class="activity-icon">🔍</view>
        <text class="activity-title">典藏寻宝</text>
        <text class="activity-desc">寻找隐藏的文物</text>
        <view class="activity-arrow">→</view>
      </view>
      <view class="activity-card" bindtap="startArtifactRepair">
        <view class="activity-icon">🔧</view>
        <text class="activity-title">文物修复</text>
        <text class="activity-desc">虚拟修复珍贵文物</text>
        <view class="activity-arrow">→</view>
      </view>
      <view class="activity-card" bindtap="startPuzzleGame">
        <view class="activity-icon">🧩</view>
        <text class="activity-title">典籍拼图</text>
        <text class="activity-desc">拼出名画，赢取奖励</text>
        <view class="activity-arrow">→</view>
      </view>
      <view class="activity-card" bindtap="goToCommunity">
        <view class="activity-icon">💬</view>
        <text class="activity-title">典藏社区</text>
        <text class="activity-desc">分享交流，共同鉴赏</text>
        <view class="activity-arrow">→</view>
      </view>
    </view>
  </view>

  <!-- 典藏分类展示 -->
  <view class="collection-section">
    <view class="section-header">
      <view class="section-icon">🏛️</view>
      <text class="section-title">稀世珍藏</text>
      <view class="section-line"></view>
      <text class="view-more" bindtap="viewMore">查看更多 ></text>
    </view>

    <view class="collection-grid">
      <view class="collection-card {{item.size === 'large' ? 'large' : ''}}" wx:for="{{collectionList}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
        <view class="card-frame">
          <image class="collection-image" src="{{item.image}}" mode="aspectFill" />
          <view class="collection-overlay">
            <view class="collection-category">{{item.category}}</view>
            <text class="collection-name">{{item.name}}</text>
            <view class="collection-era">
              <text class="era-icon">◈</text>
              <text>{{item.era}}</text>
            </view>
          </view>
          <view class="card-border top"></view>
          <view class="card-border right"></view>
          <view class="card-border bottom"></view>
          <view class="card-border left"></view>
          <view class="corner-mark top-left">◆</view>
          <view class="corner-mark top-right">◆</view>
          <view class="corner-mark bottom-left">◆</view>
          <view class="corner-mark bottom-right">◆</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 名家手迹 -->
  <view class="calligraphy-section">
    <view class="section-header">
      <view class="section-icon">✒️</view>
      <text class="section-title">名家手迹</text>
      <view class="section-line"></view>
    </view>
    
    <scroll-view class="calligraphy-scroll" scroll-x="true" show-scrollbar="false">
      <view class="calligraphy-list">
        <view class="calligraphy-item" wx:for="{{calligraphyList}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
          <view class="scroll-frame">
            <image src="{{item.image}}" mode="aspectFill" />
            <view class="scroll-overlay">
              <text class="calligrapher">{{item.calligrapher}}</text>
              <text class="script-type">{{item.scriptType}}</text>
            </view>
            <view class="scroll-ends top"></view>
            <view class="scroll-ends bottom"></view>
          </view>
          <text class="calligraphy-title">{{item.title}}</text>
        </view>
      </view>
    </scroll-view>
  </view>

  <!-- 典籍知识卡片 -->
  <view class="knowledge-section">
    <view class="section-header">
      <view class="section-icon">💡</view>
      <text class="section-title">典藏小知识</text>
      <view class="section-line"></view>
    </view>
    
    <view class="knowledge-card">
      <view class="knowledge-icon">❝</view>
      <text class="knowledge-content">{{knowledgeContent}}</text>
      <view class="knowledge-source">—— {{knowledgeSource}}</view>
      <view class="knowledge-decoration">
        <view class="deco-circle"></view>
        <view class="deco-line"></view>
        <view class="deco-circle"></view>
      </view>
    </view>
  </view>

  <!-- 底部功能按钮 -->
  <view class="action-bar">
    <view class="action-btn primary" bindtap="openAR">
      <view class="btn-icon">📷</view>
      <text>AR识典</text>
    </view>
    <view class="action-btn secondary" bindtap="startQuiz">
      <view class="btn-icon">❓</view>
      <text>典籍问答</text>
    </view>
    <view class="action-btn secondary" bindtap="viewMap">
      <view class="btn-icon">🗺️</view>
      <text>藏馆地图</text>
    </view>
  </view>

  <!-- 底部留白 -->
  <view class="bottom-space"></view>

  <!-- 底部导航 -->
  <view class="tab-bar">
    <navigator url="/pages/index/index" class="tab-item {{activeTab === 0 ? 'active' : ''}}">
      <image src="/components/shou.png" class="tab-image"></image>
      <text>首页</text>
    </navigator>
    <view class="tab-item {{activeTab === 1 ? 'active' : ''}}" bindtap="switchTab" data-index="1">
      <image src="/components/zonglan.png" class="tab-image"></image>
      <text>分类</text>
    </view>
    <navigator url="/diancang/diancang/pages/profile/profile" class="tab-item {{activeTab === 2 ? 'active' : ''}}">
      <image src="/components/yonghu.png" class="tab-image"></image>
      <text>我的</text>
    </navigator>
  </view>
</view>
