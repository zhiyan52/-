<!-- 典藏文化问答页面 -->
<view class="qa-container">
  <view class="header">
    <text class="title">AI文心先生</text>
    <text class="subtitle">君子有酒，嘉宾式燕以敖。今日与君论何典？</text>
  </view>
  
  <view class="chat-area">
    <view class="chat-bubble ai" wx:if="{{showResponse}}">
      <view class="avatar ai-avatar">文心</view>
      <view class="message">欢迎来到古雅文轩，愿与君共探文脉。您有何疑问，尽管问我。</view>
    </view>
    <view class="chat-bubble user" wx:if="{{userQuestion}}">
      <view class="avatar user-avatar">我</view>
      <view class="message">{{userQuestion}}</view>
    </view>
    <view class="chat-bubble ai" wx:if="{{aiAnswer}}">
      <view class="avatar ai-avatar">文心</view>
      <view class="message">
        <text wx:if="{{loading}}">正在思考中...</text>
        <text wx:else>{{aiAnswer}}</text>
      </view>
    </view>
  </view>
  
  <view class="faq-section" wx:if="{{!showResponse}}">
    <text class="section-title">常见问题</text>
    <view class="faq-list">
      <view class="faq-item" wx:for="{{faqList}}" wx:key="index" bindtap="selectFAQ" data-question="{{item}}">
        <text class="faq-icon">💬</text>
        <text class="faq-text">{{item}}</text>
      </view>
    </view>
  </view>
  
  <view class="input-area">
    <input class="question-input" placeholder="输入您的问题..." value="{{userQuestion}}" bindinput="inputChange" />
    <view class="send-btn" bindtap="sendQuestion">
      <text>发送</text>
    </view>
  </view>
</view>