.guide-container {
  padding: 30rpx;
  background: linear-gradient(180deg, #f8f4eb 0%, #ebe3d5 100%);
  min-height: 100vh;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #5d4037;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #795548;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #4e342e;
  margin-bottom: 20rpx;
}

.book-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.book-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  border: 3rpx solid transparent;
}

.book-item.active {
  border-color: #5d4037;
  background: #fef9f0;
}

.book-cover {
  width: 120rpx;
  height: 160rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.book-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.book-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.book-author {
  font-size: 24rpx;
  color: #5d4037;
}

.guide-content {
  margin-top: 40rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
}

.content-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #ebe3d5;
}

.content-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #4e342e;
}

.guide-tag {
  background: linear-gradient(135deg, #5d4037 0%, #795548 100%);
  color: #fff;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.loading {
  text-align: center;
  padding: 60rpx 0;
  color: #5d4037;
  font-size: 28rpx;
}

.guide-text {
  font-size: 28rpx;
  line-height: 1.8;
  color: #444;
}

.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #5d4037 0%, #795548 100%);
  color: #fff;
  padding: 30rpx 20rpx;
  border-radius: 16rpx;
}

.btn-icon {
  font-size: 40rpx;
  margin-bottom: 10rpx;
}