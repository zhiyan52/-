.guide-container {
  padding: 30rpx;
  background-color: #E8F5E8;
  min-height: 100vh;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
  padding-top: 20rpx;
}

.title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #1A365D;
  margin-bottom: 10rpx;
  font-family: "STKaiti", "KaiTi", serif;
}

.subtitle {
  font-size: 24rpx;
  color: #4A5568;
  font-family: "STKaiti", "KaiTi", serif;
}

.section-title {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #1A365D;
  margin-bottom: 20rpx;
  font-family: "STKaiti", "KaiTi", serif;
}

.book-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.book-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  border: 3rpx solid transparent;
  transition: all 0.3s ease;
  cursor: pointer;
}

.book-item:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 16rpx rgba(0,0,0,0.1);
}

.book-item.active {
  border-color: #48BB78;
  background: #F0FFF4;
}

.book-cover {
  width: 120rpx;
  height: 160rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  object-fit: cover;
}

.book-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.book-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #1A365D;
  margin-bottom: 8rpx;
  font-family: "STKaiti", "KaiTi", serif;
}

.book-author {
  font-size: 24rpx;
  color: #48BB78;
  font-family: "STKaiti", "KaiTi", serif;
}

.guide-content {
  margin-top: 40rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
}

.content-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #A3D9A5;
}

.content-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1A365D;
  font-family: "STKaiti", "KaiTi", serif;
}

.guide-tag {
  background: linear-gradient(135deg, #48BB78 0%, #38A169 100%);
  color: #fff;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-family: "STKaiti", "KaiTi", serif;
}

.loading {
  text-align: center;
  padding: 60rpx 0;
  color: #48BB78;
  font-size: 28rpx;
  font-family: "STKaiti", "KaiTi", serif;
}

.guide-text {
  font-size: 28rpx;
  line-height: 1.8;
  color: #4A5568;
  font-family: "STKaiti", "KaiTi", serif;
}

.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #48BB78 0%, #38A169 100%);
  color: #fff;
  padding: 30rpx 20rpx;
  border-radius: 16rpx;
  transition: all 0.3s ease;
  cursor: pointer;
  font-family: "STKaiti", "KaiTi", serif;
}

.action-btn:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 16rpx rgba(0,0,0,0.15);
}

.btn-icon {
  font-size: 40rpx;
  margin-bottom: 10rpx;
}