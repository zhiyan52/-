/* 典藏文化问答页面样式 */
.qa-container {
  min-height: 100vh;
  background-color: #f5f0e6;
  padding: 20rpx;
  font-family: "STKaiti", "KaiTi", serif;
}

/* 顶部导航 */
.nav-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
  border: 2rpx solid #8b4513;
}

.back-btn text {
  font-size: 36rpx;
  color: #8b4513;
}

.nav-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #8b4513;
  font-family: "STKaiti", "KaiTi", serif;
}

.placeholder {
  width: 60rpx;
}

/* 进度条 */
.progress-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
  border: 2rpx solid #d2b48c;
}

.progress-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.progress-text {
  font-size: 24rpx;
  color: #8b4513;
  font-family: "STKaiti", "KaiTi", serif;
}

.score-text {
  font-size: 24rpx;
  font-weight: bold;
  color: #8b4513;
  font-family: "STKaiti", "KaiTi", serif;
}

.progress-bar {
  width: 100%;
  height: 10rpx;
  background: #d2b48c;
  border-radius: 5rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #8b4513 0%, #d2691e 100%);
  transition: width 0.5s;
}

/* 问答区域 */
.question-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
  border: 2rpx solid #d2b48c;
  text-align: center;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #8b4513;
  margin-bottom: 10rpx;
  font-family: "STKaiti", "KaiTi", serif;
}

.section-subtitle {
  font-size: 24rpx;
  color: #a0522d;
  margin-bottom: 30rpx;
  font-family: "STKaiti", "KaiTi", serif;
}

/* 计时器 */
.timer {
  display: flex;
  justify-content: center;
  margin-bottom: 30rpx;
}

.timer-circle {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #8b4513 0%, #d2691e 100%);
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(139, 69, 19, 0.3);
}

.timer-text {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  font-family: "STKaiti", "KaiTi", serif;
}

/* 题目 */
.question-content {
  margin-bottom: 30rpx;
}

.question-text {
  font-size: 28rpx;
  line-height: 1.6;
  color: #333;
  font-family: "STKaiti", "KaiTi", serif;
  text-align: left;
}

/* 选项 */
.options-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.option-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  border: 2rpx solid #d2b48c;
  transition: all 0.3s;
  text-align: left;
}

.option-item:hover {
  background: #f0e6d3;
  border-color: #8b4513;
}

.option-letter {
  width: 40rpx;
  height: 40rpx;
  background: #8b4513;
  color: #fff;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-right: 20rpx;
  font-size: 24rpx;
  font-weight: bold;
  font-family: "STKaiti", "KaiTi", serif;
}

.option-text {
  font-size: 26rpx;
  color: #333;
  font-family: "STKaiti", "KaiTi", serif;
}

/* 答案解析区域 */
.answer-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
  border: 2rpx solid #d2b48c;
}

.answer-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.answer-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #8b4513;
  font-family: "STKaiti", "KaiTi", serif;
}

.result {
  font-size: 24rpx;
  padding: 6rpx 15rpx;
  border-radius: 15rpx;
  font-family: "STKaiti", "KaiTi", serif;
}

.result.correct {
  background: #e8f5e8;
  color: #2e7d32;
  border: 1rpx solid #c8e6c9;
}

.result.wrong {
  background: #ffebee;
  color: #c62828;
  border: 1rpx solid #ffcdd2;
}

.answer-explanation {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 20rpx;
  font-family: "STKaiti", "KaiTi", serif;
}

/* AI解析 */
.ai-analysis {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #d2b48c;
}

.ai-analysis-title {
  font-size: 24rpx;
  font-weight: bold;
  color: #8b4513;
  margin-bottom: 10rpx;
  font-family: "STKaiti", "KaiTi", serif;
}

.ai-analysis-content {
  font-size: 22rpx;
  color: #666;
  line-height: 1.6;
  font-family: "STKaiti", "KaiTi", serif;
}

/* 操作按钮 */
.action-buttons {
  margin-bottom: 30rpx;
}

.submit-btn,
.next-btn {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #8b4513 0%, #d2691e 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 40rpx;
  border: none;
  display: flex;
  justify-content: center;
  align-items: center;
  font-family: "STKaiti", "KaiTi", serif;
  box-shadow: 0 4rpx 12rpx rgba(139, 69, 19, 0.3);
  transition: all 0.3s;
}

.submit-btn:hover,
.next-btn:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 16rpx rgba(139, 69, 19, 0.4);
}

/* 常见问题 */
.faq-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
  border: 2rpx solid #d2b48c;
}

.faq-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #8b4513;
  margin-bottom: 20rpx;
  font-family: "STKaiti", "KaiTi", serif;
}

.faq-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.faq-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  border: 2rpx solid #d2b48c;
  transition: all 0.3s;
}

.faq-item:hover {
  background: #f0e6d3;
  border-color: #8b4513;
}

.faq-icon {
  font-size: 24rpx;
  margin-right: 20rpx;
  color: #8b4513;
}

.faq-text {
  font-size: 26rpx;
  color: #333;
  font-family: "STKaiti", "KaiTi", serif;
}

/* 输入区域 */
.input-area {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  background-color: #fff;
  border-radius: 16rpx;
  border: 2rpx solid #d2b48c;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
}

.question-input {
  flex: 1;
  background-color: #f5f5f5;
  border-radius: 30rpx;
  padding: 20rpx 30rpx;
  margin-right: 20rpx;
  font-size: 28rpx;
  color: #333;
  min-height: 60rpx;
  max-height: 200rpx;
  overflow-y: auto;
  font-family: "STKaiti", "KaiTi", serif;
}

.send-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #8b4513 0%, #d2691e 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 24rpx;
  font-weight: bold;
  font-family: "STKaiti", "KaiTi", serif;
  box-shadow: 0 4rpx 12rpx rgba(139, 69, 19, 0.3);
  transition: all 0.3s;
}

.send-btn:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 16rpx rgba(139, 69, 19, 0.4);
}

/* 聊天区域 */
.chat-area {
  flex: 1;
  padding: 20rpx 0;
}

.chat-bubble {
  margin-bottom: 30rpx;
  display: flex;
  align-items: flex-start;
}

.user {
  flex-direction: row-reverse;
}

.avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin: 0 20rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-weight: bold;
  font-family: "STKaiti", "KaiTi", serif;
}

.ai-avatar {
  background: linear-gradient(135deg, #8b4513 0%, #d2691e 100%);
  color: #fff;
}

.user-avatar {
  background: #f0e6d3;
  color: #8b4513;
  border: 2rpx solid #d2b48c;
}

.message {
  max-width: 70%;
  padding: 20rpx;
  border-radius: 16rpx;
  line-height: 1.5;
  font-family: "STKaiti", "KaiTi", serif;
}

.ai .message {
  background-color: #f0e6d3;
  border-top-left-radius: 4rpx;
  color: #333;
  border: 1rpx solid #d2b48c;
}

.user .message {
  background-color: #e3f2fd;
  border-top-right-radius: 4rpx;
  color: #1a365d;
  border: 1rpx solid #bbdefb;
}

/* 加载动画 */
.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
}

.loading-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background-color: #8b4513;
  margin: 0 4rpx;
  animation: loading 1.4s infinite ease-in-out both;
}

.loading-dot:nth-child(1) {
  animation-delay: -0.32s;
}

.loading-dot:nth-child(2) {
  animation-delay: -0.16s;
}

@keyframes loading {
  0%, 80%, 100% {
    transform: scale(0);
  }
  40% {
    transform: scale(1);
  }
}