/* diancang/diancang/ai/ai-voice.wxss */

/* 页面容器 */
.container {
  background-color: #E8F5E8;
  min-height: 100vh;
  padding: 20rpx 30rpx;
}

/* 头部区域 */
.header {
  text-align: center;
  margin-bottom: 40rpx;
  padding-top: 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1A365D;
  margin-bottom: 10rpx;
  font-family: "STKaiti", "KaiTi", serif;
}

.subtitle {
  font-size: 24rpx;
  color: #4A5568;
  font-family: "STKaiti", "KaiTi", serif;
}

/* 语音交互区域 */
.voice-section {
  background-color: #FFFFFF;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 40rpx;
}

/* 录音按钮 */
.record-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 200rpx;
  height: 200rpx;
  background: linear-gradient(135deg, #48BB78 0%, #38A169 100%);
  border-radius: 50%;
  margin: 0 auto 40rpx;
  color: #FFFFFF;
  font-size: 28rpx;
  font-family: "STKaiti", "KaiTi", serif;
  cursor: pointer;
  transition: all 0.3s ease;
  box-shadow: 0 6rpx 20rpx rgba(72, 187, 120, 0.4);
}

.record-btn.recording {
  background: linear-gradient(135deg, #E53E3E 0%, #C53030 100%);
  animation: pulse 1.5s infinite;
}

.record-btn:hover {
  transform: scale(1.05);
  box-shadow: 0 8rpx 24rpx rgba(72, 187, 120, 0.5);
}

.record-btn.recording:hover {
  box-shadow: 0 8rpx 24rpx rgba(229, 62, 62, 0.5);
}

.btn-icon {
  font-size: 60rpx;
  margin-bottom: 15rpx;
}

/* 录音动画 */
@keyframes pulse {
  0% {
    transform: scale(1);
    box-shadow: 0 6rpx 20rpx rgba(229, 62, 62, 0.4);
  }
  50% {
    transform: scale(1.05);
    box-shadow: 0 8rpx 24rpx rgba(229, 62, 62, 0.6);
  }
  100% {
    transform: scale(1);
    box-shadow: 0 6rpx 20rpx rgba(229, 62, 62, 0.4);
  }
}

/* 识别结果区域 */
.recognized-section {
  margin-bottom: 40rpx;
}

.section-label {
  font-size: 28rpx;
  font-weight: bold;
  color: #1A365D;
  margin-bottom: 15rpx;
  font-family: "STKaiti", "KaiTi", serif;
}

.recognized-text {
  background-color: #F7FAFC;
  border: 2rpx solid #A3D9A5;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 24rpx;
  color: #4A5568;
  font-family: "STKaiti", "KaiTi", serif;
  min-height: 100rpx;
}

/* AI回复区域 */
.response-section {
  margin-bottom: 40rpx;
}

.response-content {
  background-color: #F0FFF4;
  border: 2rpx solid #A3D9A5;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 24rpx;
  color: #4A5568;
  font-family: "STKaiti", "KaiTi", serif;
  min-height: 150rpx;
  line-height: 1.5;
}

/* 加载状态 */
.loading {
  text-align: center;
  padding: 40rpx;
  font-size: 24rpx;
  color: #48BB78;
  font-family: "STKaiti", "KaiTi", serif;
}

/* 操作按钮区域 */
.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.action-btn {
  flex: 1;
  padding: 20rpx;
  background-color: #48BB78;
  color: #FFFFFF;
  border-radius: 10rpx;
  text-align: center;
  font-size: 28rpx;
  font-family: "STKaiti", "KaiTi", serif;
  cursor: pointer;
  transition: all 0.3s ease;
}

.action-btn:hover {
  background-color: #38A169;
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 12rpx rgba(72, 187, 120, 0.3);
}

.action-btn.secondary {
  background-color: #FFFFFF;
  color: #4A5568;
  border: 2rpx solid #A3D9A5;
}

.action-btn.secondary:hover {
  background-color: #F7FAFC;
  border-color: #48BB78;
}

/* 提示信息 */
.tip {
  text-align: center;
  font-size: 20rpx;
  color: #718096;
  margin-top: 20rpx;
  font-family: "STKaiti", "KaiTi", serif;
}