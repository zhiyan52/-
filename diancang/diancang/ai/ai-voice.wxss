/* diancang/diancang/ai/ai-voice.wxss */

/* 页面容器 */
.voice-container {
  background-color: #F5F5DC;
  min-height: 100vh;
  padding: 0rpx 30rpx 30rpx;
}

/* 顶部导航 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx 0;
  border-bottom: 2rpx solid #E5E5E5;
  margin-bottom: 30rpx;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #8B4513;
  cursor: pointer;
}

.nav-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #8B4513;
  font-family: "STKaiti", "KaiTi", serif;
}

.placeholder {
  width: 60rpx;
}

/* 语音讲解标题 */
.voice-header {
  text-align: center;
  margin-bottom: 40rpx;
  padding-top: 20rpx;
}

.voice-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #8B4513;
  margin-bottom: 10rpx;
  font-family: "STKaiti", "KaiTi", serif;
}

.voice-subtitle {
  font-size: 24rpx;
  color: #795548;
  font-family: "STKaiti", "KaiTi", serif;
}

/* 内容选择 */
.content-section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #8B4513;
  margin-bottom: 20rpx;
  font-family: "STKaiti", "KaiTi", serif;
}

.content-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.content-item {
  background-color: #FFFFFF;
  border: 2rpx solid #D2B48C;
  border-radius: 15rpx;
  padding: 25rpx;
  cursor: pointer;
  transition: all 0.3s ease;
}

.content-item:hover {
  transform: translateY(-5rpx);
  box-shadow: 0 5rpx 15rpx rgba(0, 0, 0, 0.1);
}

.content-item.active {
  background-color: #8B4513;
  border-color: #8B4513;
}

.content-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #8B4513;
  margin-bottom: 10rpx;
  font-family: "STKaiti", "KaiTi", serif;
}

.content-item.active .content-title {
  color: #FFFFFF;
}

.content-desc {
  font-size: 20rpx;
  color: #795548;
  font-family: "STKaiti", "KaiTi", serif;
}

.content-item.active .content-desc {
  color: #F5F5DC;
}

/* 播放器 */
.player-section {
  margin-bottom: 40rpx;
}

.player-card {
  background-color: #FFFFFF;
  border-radius: 15rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.player-info {
  margin-bottom: 30rpx;
}

.player-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #8B4513;
  margin-bottom: 10rpx;
  font-family: "STKaiti", "KaiTi", serif;
}

.player-desc {
  font-size: 22rpx;
  color: #795548;
  font-family: "STKaiti", "KaiTi", serif;
}

.player-controls {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.play-btn {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #8B4513;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  cursor: pointer;
  transition: all 0.3s ease;
  align-self: center;
}

.play-btn:hover {
  transform: scale(1.1);
}

.play-btn.playing {
  background-color: #6D4C41;
}

.progress-container {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.time {
  font-size: 20rpx;
  color: #795548;
  font-family: "STKaiti", "KaiTi", serif;
  min-width: 80rpx;
}

.progress-bar {
  flex: 1;
  height: 10rpx;
  background-color: #E5E5E5;
  border-radius: 5rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background-color: #8B4513;
  border-radius: 5rpx;
  transition: width 0.3s ease;
}

.volume-control {
  display: flex;
  align-items: center;
  gap: 15rpx;
}

.volume-icon {
  font-size: 24rpx;
}

.volume-bar {
  flex: 1;
  height: 8rpx;
  background-color: #E5E5E5;
  border-radius: 4rpx;
  overflow: hidden;
}

.volume-fill {
  height: 100%;
  background-color: #8B4513;
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

/* AI讲解内容 */
.ai-section {
  margin-bottom: 40rpx;
}

.ai-content {
  background-color: #FFFFFF;
  border-radius: 15rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.ai-text {
  font-size: 22rpx;
  color: #5D4037;
  line-height: 1.6;
  font-family: "STKaiti", "KaiTi", serif;
}

/* 使用提示 */
.tips-section {
  margin-bottom: 40rpx;
}

.tips-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  gap: 15rpx;
  background-color: #FFFFFF;
  border-radius: 15rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.tip-icon {
  font-size: 32rpx;
  margin-top: 5rpx;
}

.tip-text {
  flex: 1;
  font-size: 22rpx;
  color: #5D4037;
  line-height: 1.4;
  font-family: "STKaiti", "KaiTi", serif;
}
