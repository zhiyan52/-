/* diancang/diancang/ai/ai-recommend.wxss */

/* 页面容器 */
.container {
  background-color: #E8F5E8;
  min-height: 100vh;
  padding: 20rpx 30rpx;
}

/* 头部区域 */
.header {
  text-align: center;
  margin-bottom: 40rpx;
  padding-top: 20rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1A365D;
  margin-bottom: 10rpx;
  font-family: "STKaiti", "KaiTi", serif;
}

.subtitle {
  font-size: 24rpx;
  color: #4A5568;
  font-family: "STKaiti", "KaiTi", serif;
}

/* 兴趣选择区域 */
.preference-section {
  margin-bottom: 40rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #1A365D;
  margin-bottom: 20rpx;
  font-family: "STKaiti", "KaiTi", serif;
}

.interest-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}

.tag {
  padding: 15rpx 25rpx;
  background-color: #FFFFFF;
  border: 2rpx solid #A3D9A5;
  border-radius: 40rpx;
  font-size: 24rpx;
  color: #4A5568;
  font-family: "STKaiti", "KaiTi", serif;
  cursor: pointer;
  transition: all 0.3s ease;
}

.tag.active {
  background-color: #48BB78;
  color: #FFFFFF;
  border-color: #48BB78;
}

/* 按钮区域 */
.button-section {
  display: flex;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.recommend-btn {
  flex: 1;
  padding: 20rpx;
  background-color: #48BB78;
  color: #FFFFFF;
  border-radius: 10rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: bold;
  font-family: "STKaiti", "KaiTi", serif;
  cursor: pointer;
  transition: all 0.3s ease;
}

.recommend-btn:hover {
  background-color: #38A169;
}

.reset-btn {
  flex: 1;
  padding: 20rpx;
  background-color: #FFFFFF;
  color: #4A5568;
  border: 2rpx solid #A3D9A5;
  border-radius: 10rpx;
  text-align: center;
  font-size: 28rpx;
  font-family: "STKaiti", "KaiTi", serif;
  cursor: pointer;
  transition: all 0.3s ease;
}

.reset-btn:hover {
  background-color: #F7FAFC;
}

/* 加载状态 */
.loading {
  text-align: center;
  padding: 40rpx;
  font-size: 24rpx;
  color: #4A5568;
  font-family: "STKaiti", "KaiTi", serif;
}

/* 推荐结果区域 */
.recommendations {
  margin-top: 40rpx;
}

.recommendations-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #1A365D;
  margin-bottom: 20rpx;
  font-family: "STKaiti", "KaiTi", serif;
}

.books-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.book-card {
  background-color: #FFFFFF;
  border-radius: 15rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
  cursor: pointer;
}

.book-card:hover {
  transform: translateY(-5rpx);
  box-shadow: 0 5rpx 15rpx rgba(0, 0, 0, 0.15);
}

.book-cover {
  width: 100%;
  height: 240rpx;
  border-radius: 10rpx;
  margin-bottom: 15rpx;
  object-fit: cover;
}

.book-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #1A365D;
  margin-bottom: 5rpx;
  font-family: "STKaiti", "KaiTi", serif;
}

.book-author {
  font-size: 22rpx;
  color: #718096;
  margin-bottom: 10rpx;
  font-family: "STKaiti", "KaiTi", serif;
}

.book-description {
  font-size: 20rpx;
  color: #4A5568;
  line-height: 1.4;
  font-family: "STKaiti", "KaiTi", serif;
}

/* 无推荐结果 */
.no-results {
  text-align: center;
  padding: 60rpx;
  font-size: 24rpx;
  color: #718096;
  font-family: "STKaiti", "KaiTi", serif;
}