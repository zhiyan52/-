.fill-container {
  padding: 30rpx;
  background: #E8F5E8;
  min-height: 100vh;
  font-family: "STKaiti", "KaiTi", serif;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
  border: 2rpx solid #A3D9A5;
}

.back-btn text {
  font-size: 36rpx;
  color: #48BB78;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1A365D;
  font-family: "STKaiti", "KaiTi", serif;
}

.placeholder {
  width: 60rpx;
}

.question-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
  border: 2rpx solid #A3D9A5;
}

.question-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.question-number {
  font-size: 28rpx;
  font-weight: bold;
  color: #1A365D;
  font-family: "STKaiti", "KaiTi", serif;
}

.question-source {
  font-size: 24rpx;
  color: #48BB78;
  background: #E8F5E8;
  padding: 6rpx 15rpx;
  border-radius: 15rpx;
  font-family: "STKaiti", "KaiTi", serif;
  border: 1rpx solid #A3D9A5;
}

.question-content {
  font-size: 32rpx;
  line-height: 1.8;
  color: #333;
  text-align: justify;
  font-family: "STKaiti", "KaiTi", serif;
}

.content-item {
  display: inline;
}

.blank {
  display: inline-block;
  margin: 0 10rpx;
  padding: 10rpx 20rpx;
  background: #E8F5E8;
  border-radius: 8rpx;
  min-width: 120rpx;
  text-align: center;
  border: 2rpx solid #A3D9A5;
}

.blank-placeholder {
  color: #999;
  font-style: italic;
  font-family: "STKaiti", "KaiTi", serif;
}

.blank-answer {
  color: #48BB78;
  font-weight: bold;
  font-family: "STKaiti", "KaiTi", serif;
}

.options-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
  border: 2rpx solid #A3D9A5;
}

.options-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #1A365D;
  margin-bottom: 20rpx;
  font-family: "STKaiti", "KaiTi", serif;
}

.options-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.option-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  border: 2rpx solid #A3D9A5;
  transition: all 0.3s;
}

.option-item:hover {
  background: #E8F5E8;
  border-color: #48BB78;
}

.option-letter {
  width: 40rpx;
  height: 40rpx;
  background: #48BB78;
  color: #fff;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-right: 20rpx;
  font-size: 24rpx;
  font-weight: bold;
  font-family: "STKaiti", "KaiTi", serif;
}

.option-text {
  font-size: 26rpx;
  color: #333;
  font-family: "STKaiti", "KaiTi", serif;
}

.answer-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
  border: 2rpx solid #A3D9A5;
}

.answer-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.answer-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #1A365D;
  font-family: "STKaiti", "KaiTi", serif;
}

.result {
  font-size: 24rpx;
  padding: 6rpx 15rpx;
  border-radius: 15rpx;
  font-family: "STKaiti", "KaiTi", serif;
}

.result.correct {
  background: #E8F5E8;
  color: #48BB78;
  border: 1rpx solid #A3D9A5;
}

.result.wrong {
  background: #ffebee;
  color: #c62828;
  border: 1rpx solid #ffcdd2;
}

.answer-explanation {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
  font-family: "STKaiti", "KaiTi", serif;
}

.action-buttons {
  margin-bottom: 30rpx;
}

.submit-btn,
.next-btn {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #48BB78 0%, #38A169 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 40rpx;
  border: none;
  display: flex;
  justify-content: center;
  align-items: center;
  font-family: "STKaiti", "KaiTi", serif;
  box-shadow: 0 4rpx 12rpx rgba(72, 187, 120, 0.3);
  transition: all 0.3s;
}

.submit-btn:hover,
.next-btn:hover {
  transform: translateY(-2rpx);
  box-shadow: 0 6rpx 16rpx rgba(72, 187, 120, 0.4);
}

.progress-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.progress-bar {
  width: 100%;
  height: 10rpx;
  background: #A3D9A5;
  border-radius: 5rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #48BB78 0%, #38A169 100%);
  transition: width 0.5s;
}

.progress-text {
  font-size: 24rpx;
  color: #1A365D;
  font-weight: bold;
  font-family: "STKaiti", "KaiTi", serif;
}