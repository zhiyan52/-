.fill-container {
  padding: 30rpx;
  background: linear-gradient(180deg, #fef9f0 0%, #f5f0e6 100%);
  min-height: 100vh;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.back-btn text {
  font-size: 36rpx;
  color: #8b4513;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #8b4513;
}

.placeholder {
  width: 60rpx;
}

.question-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
}

.question-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.question-number {
  font-size: 28rpx;
  font-weight: bold;
  color: #5d4037;
}

.question-source {
  font-size: 24rpx;
  color: #a0522d;
  background: #f0e6d3;
  padding: 6rpx 15rpx;
  border-radius: 15rpx;
}

.question-content {
  font-size: 32rpx;
  line-height: 1.8;
  color: #333;
  text-align: justify;
}

.content-item {
  display: inline;
}

.blank {
  display: inline-block;
  margin: 0 10rpx;
  padding: 10rpx 20rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  min-width: 120rpx;
  text-align: center;
}

.blank-placeholder {
  color: #999;
  font-style: italic;
}

.blank-answer {
  color: #8b4513;
  font-weight: bold;
}

.options-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
}

.options-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #5d4037;
  margin-bottom: 20rpx;
}

.options-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.option-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  border: 2rpx solid #e0d5c5;
  transition: all 0.3s;
}

.option-item:hover {
  background: #f0e6d3;
  border-color: #8b4513;
}

.option-letter {
  width: 40rpx;
  height: 40rpx;
  background: #8b4513;
  color: #fff;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  margin-right: 20rpx;
  font-size: 24rpx;
  font-weight: bold;
}

.option-text {
  font-size: 26rpx;
  color: #333;
}

.answer-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
}

.answer-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.answer-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #5d4037;
}

.result {
  font-size: 24rpx;
  padding: 6rpx 15rpx;
  border-radius: 15rpx;
}

.result.correct {
  background: #e8f5e8;
  color: #2e7d32;
}

.result.wrong {
  background: #ffebee;
  color: #c62828;
}

.answer-explanation {
  font-size: 24rpx;
  color: #666;
  line-height: 1.6;
}

.action-buttons {
  margin-bottom: 30rpx;
}

.submit-btn,
.next-btn {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #8b4513 0%, #d2691e 100%);
  color: #fff;
  font-size: 30rpx;
  font-weight: bold;
  border-radius: 40rpx;
  border: none;
  display: flex;
  justify-content: center;
  align-items: center;
}

.progress-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.progress-bar {
  width: 100%;
  height: 10rpx;
  background: #e0d5c5;
  border-radius: 5rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #8b4513 0%, #d2691e 100%);
  transition: width 0.5s;
}

.progress-text {
  font-size: 24rpx;
  color: #8b4513;
  font-weight: bold;
}