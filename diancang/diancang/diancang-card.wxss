.card-container {
  padding: 30rpx;
  background: linear-gradient(180deg, #fef9f0 0%, #f5f0e6 100%);
  min-height: 100vh;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.back-btn text {
  font-size: 36rpx;
  color: #8b4513;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #8b4513;
}

.placeholder {
  width: 60rpx;
}

.card-section {
  display: flex;
  justify-content: center;
  margin-top: 150rpx;
  margin-bottom: 80rpx;
}

.card-preview {
  width: 600rpx;
  height: 400rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.card {
  width: 600rpx;
  height: 400rpx;
  border-radius: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  padding: 40rpx;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.15);
  position: relative;
  overflow: hidden;
}

.card-bg-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.card-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.3);
  border-radius: 20rpx;
  z-index: 1;
}

.card-text {
  font-size: 32rpx;
  color: #ffffff;
  text-align: center;
  line-height: 2.2;
  margin-bottom: 30rpx;
  font-family: '楷体', 'KaiTi', serif;
  z-index: 2;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.5);
}

.card-author {
  font-size: 24rpx;
  color: #ffffff;
  font-family: '楷体', 'KaiTi', serif;
  z-index: 2;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.5);
}

.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.generate-btn,
.save-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  border: none;
  font-size: 30rpx;
  font-weight: bold;
  display: flex;
  justify-content: center;
  align-items: center;
}

.generate-btn {
  background: linear-gradient(135deg, #8b4513 0%, #d2691e 100%);
  color: #fff;
}

.save-btn {
  background: #fff;
  color: #8b4513;
  border: 2rpx solid #8b4513;
}

.history-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
  margin-top: 60rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #5d4037;
  margin-bottom: 20rpx;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.history-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  border: 2rpx solid #e0d5c5;
}

.history-card {
  flex: 1;
  padding: 20rpx;
  background: #f0e6d3;
  border-radius: 12rpx;
}

.history-quote {
  font-size: 24rpx;
  color: #5d4037;
  line-height: 1.4;
  margin-bottom: 10rpx;
}

.history-source {
  font-size: 20rpx;
  color: #8b4513;
  font-style: italic;
}

.history-actions {
  display: flex;
  gap: 10rpx;
}

.history-btn {
  padding: 10rpx 20rpx;
  background: #8b4513;
  color: #fff;
  border-radius: 15rpx;
  font-size: 20rpx;
}
