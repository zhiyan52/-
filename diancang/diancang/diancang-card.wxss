.card-container {
  padding: 30rpx;
  background: linear-gradient(180deg, #fef9f0 0%, #f5f0e6 100%);
  min-height: 100vh;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 40rpx;
}

.back-btn {
  width: 60rpx;
  height: 60rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.back-btn text {
  font-size: 36rpx;
  color: #8b4513;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #8b4513;
}

.placeholder {
  width: 60rpx;
}

.card-section {
  display: flex;
  justify-content: center;
  margin-bottom: 40rpx;
}

.card-preview {
  width: 600rpx;
  height: 800rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.card-bg {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #f9f3e9 0%, #f0e6d3 100%);
  border-radius: 20rpx;
  padding: 60rpx;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.15);
  border: 2rpx solid #d2b48c;
  position: relative;
  overflow: hidden;
}

