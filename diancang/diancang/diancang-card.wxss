  opacity: 0.3;
}

.card-content {
  position: relative;
  z-index: 1;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
}

.card-quote {
  font-size: 40rpx;
  font-weight: bold;
  color: #5d4037;
  line-height: 1.6;
  margin-bottom: 40rpx;
  text-shadow: 1rpx 1rpx 2rpx rgba(0,0,0,0.1);
}

.card-source {
  font-size: 28rpx;
  color: #8b4513;
  font-style: italic;
}

.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.generate-btn,
.save-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 40rpx;
  border: none;
  font-size: 30rpx;
  font-weight: bold;
  display: flex;
  justify-content: center;
  align-items: center;
}

.generate-btn {
  background: linear-gradient(135deg, #8b4513 0%, #d2691e 100%);
  color: #fff;
}

.save-btn {
  background: #fff;
  color: #8b4513;
  border: 2rpx solid #8b4513;
}

.history-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
}

.section-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #5d4037;
  margin-bottom: 20rpx;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.history-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx;
  background: #f9f9f9;
  border-radius: 12rpx;
  border: 2rpx solid #e0d5c5;
}

.history-card {
  flex: 1;
  padding: 20rpx;
  background: #f0e6d3;
  border-radius: 12rpx;
}

.history-quote {
  font-size: 24rpx;
  color: #5d4037;
  line-height: 1.4;
  margin-bottom: 10rpx;
}

.history-source {
  font-size: 20rpx;
  color: #8b4513;
  font-style: italic;
}

.history-actions {
  display: flex;
  gap: 10rpx;
}

.history-btn {
  padding: 10rpx 20rpx;
  background: #8b4513;
  color: #fff;
  border-radius: 15rpx;
  font-size: 20rpx;
}
