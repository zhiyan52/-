/* 典藏列表页面样式 */
.list-container {
  background-color: #f7f5f0;
  min-height: 100vh;
  padding: 0 20rpx;
}

/* 顶部导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 90rpx;
  padding: 0 20rpx;
  background: #2C2621;
  color: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
}

.nav-left {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.back-icon {
  font-size: 32rpx;
  font-weight: bold;
}

.nav-title {
  font-size: 26rpx;
}

.nav-center {
  font-size: 30rpx;
  font-weight: 500;
  font-family: "STKaiti", "KaiTi", serif;
}

.nav-right {
  font-size: 28rpx;
  display: flex;
  gap: 20rpx;
}

.filter-icon {
  transition: all 0.3s ease;
}

.filter-icon:active {
  transform: scale(0.95);
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  gap: 15rpx;
  padding: 15rpx;
  background: #fff;
  border-radius: 0 0 16rpx 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  margin-bottom: 20rpx;
}

.filter-item {
  flex: 1;
  text-align: center;
  padding: 12rpx;
  border-radius: 20rpx;
  background: #f8f9fa;
  font-size: 22rpx;
  color: #666;
  font-family: "STKaiti", "KaiTi", serif;
  transition: all 0.3s ease;
}

.filter-item.active {
  background: #8B4513;
  color: #fff;
  box-shadow: 0 2rpx 6rpx rgba(139, 69, 19, 0.3);
}

.filter-item:active {
  transform: translateY(2rpx);
}

/* 藏品列表 */
.collection-list {
  background: #fff;
  border-radius: 16rpx;
  padding: 15rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  margin-bottom: 20rpx;
}

.collection-item {
  display: flex;
  gap: 16rpx;
  padding: 16rpx;
  border-bottom: 1rpx solid #f5f5f5;
  position: relative;
  transition: all 0.3s ease;
  border-radius: 12rpx;
}

.collection-item:last-child {
  border-bottom: none;
}

.collection-item:active {
  background: #f9f9f9;
  transform: translateX(4rpx);
}

.item-image {
  width: 140rpx;
  height: 180rpx;
  border-radius: 10rpx;
  object-fit: cover;
  border: 1rpx solid #f0f0f0;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.08);
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 180rpx;
}

.item-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
  display: block;
  font-family: "STKaiti", "KaiTi", serif;
  line-height: 1.3;
}

.item-pinyin {
  font-size: 18rpx;
  color: #a0522d;
  margin-bottom: 8rpx;
  font-style: italic;
}

.item-desc {
  font-size: 22rpx;
  color: #666;
  line-height: 1.4;
  margin-bottom: 12rpx;
  display: block;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  font-family: "STKaiti", "KaiTi", serif;
}

.favorite-btn {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 44rpx;
  height: 44rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 50%;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.1);
  z-index: 10;
  transition: all 0.3s ease;
}

.favorite-btn:active {
  transform: scale(1.1);
}

.favorite-icon {
  font-size: 28rpx;
  transition: all 0.3s ease;
}

.item-meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.meta-tag {
  background: #f0f4f8;
  color: #3498db;
  font-size: 18rpx;
  padding: 3rpx 10rpx;
  border-radius: 10rpx;
  font-family: "STKaiti", "KaiTi", serif;
}

.meta-era {
  font-size: 18rpx;
  color: #999;
  font-family: "STKaiti", "KaiTi", serif;
}

.meta-views {
  font-size: 18rpx;
  color: #999;
  margin-left: auto;
  font-family: "STKaiti", "KaiTi", serif;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 25rpx;
  margin-top: 16rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  font-size: 24rpx;
  color: #8B4513;
  font-weight: 500;
  font-family: "STKaiti", "KaiTi", serif;
  transition: all 0.3s ease;
}

.load-more:active {
  transform: scale(0.98);
  background: #f8f4e9;
}

/* 响应式调整 */
@media (max-width: 375px) {
  .item-image {
    width: 120rpx;
    height: 160rpx;
  }
  
  .item-title {
    font-size: 26rpx;
  }
  
  .item-desc {
    font-size: 20rpx;
  }
}
