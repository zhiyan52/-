/* 典藏寻宝页面样式 */
.treasure-hunt-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #f8f5f0 0%, #e8ddc3 50%, #f0e6d2 100%);
  font-family: 'PingFang SC', 'Microsoft YaHei', sans-serif;
  position: relative;
  overflow: hidden;
}

/* 背景装饰 */
.treasure-hunt-container::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: url('https://picsum.photos/1000/1000?random=100') repeat;
  background-size: 200rpx;
  opacity: 0.05;
  pointer-events: none;
  z-index: 0;
}

/* 顶部导航 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 100rpx;
  padding: 0 30rpx;
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  color: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
}

.nav-left {
  display: flex;
  align-items: center;
  gap: 10rpx;
  transition: all 0.3s ease;
}

.nav-left:hover {
  transform: translateX(-5rpx);
}

.back-icon {
  font-size: 36rpx;
  font-weight: bold;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.3);
}

.nav-title {
  font-size: 28rpx;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.3);
}

.nav-center {
  font-size: 36rpx;
  font-weight: bold;
  flex: 1;
  text-align: center;
  margin: 0 40rpx;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.3);
  letter-spacing: 4rpx;
}

.nav-right {
  display: flex;
  align-items: center;
}

.hint-btn {
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 25rpx;
  font-size: 24rpx;
  font-weight: bold;
  transition: all 0.3s ease;
  backdrop-filter: blur(10rpx);
}

.hint-btn:hover {
  background: rgba(255, 255, 255, 0.3);
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 12rpx rgba(255,255,255,0.2);
}

/* 游戏状态 */
.game-status {
  display: flex;
  justify-content: space-around;
  padding: 24rpx 30rpx;
  background: rgba(255, 255, 255, 0.9);
  margin: 24rpx 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 6rpx 18rpx rgba(0,0,0,0.08);
  backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(139, 69, 19, 0.1);
}

.status-item {
  text-align: center;
  transition: all 0.3s ease;
  padding: 10rpx;
  border-radius: 15rpx;
}

.status-item:hover {
  background: rgba(139, 69, 19, 0.05);
  transform: translateY(-2rpx);
}

.status-label {
  font-size: 22rpx;
  color: #8B4513;
  display: block;
  margin-bottom: 8rpx;
  font-weight: 500;
}

.status-value {
  font-size: 32rpx;
  font-weight: bold;
  color: #8B4513;
  display: block;
  text-shadow: 0 1rpx 2rpx rgba(139, 69, 19, 0.2);
  animation: glow 2s infinite;
}

/* 寻宝区域 */
.treasure-area {
  margin: 0 20rpx 30rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.12);
  background: rgba(255, 255, 255, 0.95);
  padding: 36rpx;
  backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(139, 69, 19, 0.1);
}

.scene-image {
  position: relative;
  width: 100%;
  height: 520rpx;
  border-radius: 20rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #f0f0f0 0%, #e0e0e0 100%);
  box-shadow: inset 0 0 30rpx rgba(0,0,0,0.1);
  transition: all 0.3s ease;
}

.scene-image:hover {
  transform: scale(1.02);
}

.scene-bg {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: all 0.5s ease;
}

.scene-image:hover .scene-bg {
  transform: scale(1.05);
}

.treasure {
  position: absolute;
  transform: translate(-50%, -50%);
  z-index: 10;
  cursor: pointer;
  transition: all 0.3s ease;
  animation: float 3s ease-in-out infinite;
}

.treasure:hover {
  transform: translate(-50%, -50%) scale(1.1);
  z-index: 20;
}

.treasure-icon {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FFD700 0%, #FFA500 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  box-shadow: 0 6rpx 18rpx rgba(255, 215, 0, 0.6);
  animation: pulse 2s infinite, rotate 4s linear infinite;
  border: 2rpx solid rgba(255, 255, 255, 0.8);
}

.treasure-icon.found {
  background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
  animation: none, bounce 0.5s ease;
  transform: scale(1.3);
  box-shadow: 0 8rpx 24rpx rgba(76, 175, 80, 0.6);
}

.treasure-name {
  position: absolute;
  top: 80rpx;
  left: 50%;
  transform: translateX(-50%);
  background: linear-gradient(135deg, rgba(0, 0, 0, 0.8) 0%, rgba(0, 0, 0, 0.6) 100%);
  color: white;
  padding: 10rpx 20rpx;
  border-radius: 25rpx;
  font-size: 26rpx;
  white-space: nowrap;
  opacity: 0;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.3);
}

.treasure:hover .treasure-name {
  opacity: 1;
  transform: translateX(-50%) translateY(-5rpx);
}

.scene-hint {
  position: absolute;
  bottom: 24rpx;
  left: 50%;
  transform: translateX(-50%);
  background: linear-gradient(135deg, rgba(0, 0, 0, 0.7) 0%, rgba(0, 0, 0, 0.5) 100%);
  color: white;
  padding: 14rpx 28rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  animation: fadeInOut 3s infinite, slideUp 2s ease-in-out infinite;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.3);
  backdrop-filter: blur(10rpx);
}

/* 场景选择 */
.scene-selector {
  margin: 0 20rpx 30rpx;
}

.selector-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #8B4513;
  margin-bottom: 20rpx;
  display: block;
  padding-left: 10rpx;
  text-shadow: 0 1rpx 2rpx rgba(139, 69, 19, 0.2);
  border-left: 6rpx solid #8B4513;
}

.scene-list {
  display: flex;
  gap: 24rpx;
  padding-bottom: 15rpx;
  padding-left: 10rpx;
}

.scene-item {
  width: 220rpx;
  border-radius: 20rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.9);
  box-shadow: 0 6rpx 18rpx rgba(0,0,0,0.08);
  transition: all 0.3s ease;
  backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(139, 69, 19, 0.1);
}

.scene-item:hover {
  transform: translateY(-5rpx);
  box-shadow: 0 10rpx 24rpx rgba(139, 69, 19, 0.15);
}

.scene-item.active {
  transform: translateY(-12rpx);
  box-shadow: 0 12rpx 30rpx rgba(139, 69, 19, 0.2);
  border: 2rpx solid #8B4513;
}

.scene-thumb {
  width: 100%;
  height: 140rpx;
  object-fit: cover;
  transition: all 0.3s ease;
}

.scene-item:hover .scene-thumb {
  transform: scale(1.05);
}

.scene-name {
  padding: 16rpx;
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  text-align: center;
  border-bottom: 1rpx solid rgba(139, 69, 19, 0.1);
  background: linear-gradient(135deg, #fff 0%, #f8f5f0 100%);
}

.scene-progress {
  padding: 12rpx 16rpx;
  font-size: 22rpx;
  color: #8B4513;
  text-align: center;
  background: linear-gradient(135deg, #f8f5f0 0%, #e8ddc3 100%);
  font-weight: 500;
}

/* 寻宝提示 */
.hint-section {
  margin: 0 20rpx 30rpx;
}

.hint-card {
  background: rgba(255, 255, 255, 0.9);
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 6rpx 18rpx rgba(0,0,0,0.08);
  display: flex;
  gap: 24rpx;
  backdrop-filter: blur(10rpx);
  border: 1rpx solid rgba(139, 69, 19, 0.1);
  transition: all 0.3s ease;
}

.hint-card:hover {
  transform: translateY(-5rpx);
  box-shadow: 0 10rpx 24rpx rgba(0,0,0,0.12);
}

.hint-icon {
  font-size: 56rpx;
  margin-top: 10rpx;
  animation: bounce 2s ease-in-out infinite;
}

.hint-content {
  flex: 1;
}

.hint-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #8B4513;
  margin-bottom: 18rpx;
  display: block;
  text-shadow: 0 1rpx 2rpx rgba(139, 69, 19, 0.2);
}

.hint-text {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
  display: block;
  line-height: 1.5;
  transition: all 0.3s ease;
}

.hint-text:hover {
  color: #8B4513;
  transform: translateX(5rpx);
}

/* 游戏结束弹窗 */
.game-over-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  animation: fadeIn 0.5s ease;
  backdrop-filter: blur(10rpx);
}

.modal-content {
  background: linear-gradient(135deg, #fff 0%, #f8f5f0 100%);
  border-radius: 24rpx;
  padding: 50rpx;
  text-align: center;
  box-shadow: 0 15rpx 50rpx rgba(0,0,0,0.3);
  width: 85%;
  max-width: 450rpx;
  border: 2rpx solid #8B4513;
  animation: zoomIn 0.3s ease;
  position: relative;
  overflow: hidden;
}

.modal-content::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: linear-gradient(45deg, transparent, rgba(139, 69, 19, 0.1), transparent);
  animation: rotate 6s linear infinite;
  z-index: 0;
}

.modal-icon {
  font-size: 100rpx;
  margin-bottom: 24rpx;
  animation: bounce 0.8s ease, glow 2s infinite;
  position: relative;
  z-index: 1;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #8B4513;
  margin-bottom: 20rpx;
  display: block;
  text-shadow: 0 2rpx 4rpx rgba(139, 69, 19, 0.2);
  position: relative;
  z-index: 1;
}

.modal-desc {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 15rpx;
  display: block;
  position: relative;
  z-index: 1;
}

.modal-reward {
  font-size: 32rpx;
  font-weight: bold;
  color: #FF6B6B;
  margin-bottom: 36rpx;
  display: block;
  text-shadow: 0 1rpx 2rpx rgba(255, 107, 107, 0.3);
  animation: pulse 1.5s infinite;
  position: relative;
  z-index: 1;
}

.modal-buttons {
  display: flex;
  gap: 24rpx;
  justify-content: center;
  position: relative;
  z-index: 1;
}

.modal-btn {
  padding: 18rpx 36rpx;
  border-radius: 35rpx;
  font-size: 26rpx;
  font-weight: bold;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
  border: 2rpx solid transparent;
}

.modal-btn.primary {
  background: linear-gradient(135deg, #8B4513 0%, #A0522D 100%);
  color: white;
}

.modal-btn.primary:hover {
  transform: translateY(-3rpx);
  box-shadow: 0 8rpx 24rpx rgba(139, 69, 19, 0.3);
}

.modal-btn.secondary {
  background: linear-gradient(135deg, #f0f0f0 0%, #e0e0e0 100%);
  color: #666;
  border: 2rpx solid #ddd;
}

.modal-btn.secondary:hover {
  transform: translateY(-3rpx);
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.15);
  border-color: #8B4513;
  color: #8B4513;
}

/* 场景名称覆盖层 */
.scene-name-overlay {
  position: absolute;
  top: 20rpx;
  left: 20rpx;
  background: linear-gradient(135deg, rgba(139, 69, 19, 0.8) 0%, rgba(160, 82, 45, 0.6) 100%);
  color: white;
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.3);
  backdrop-filter: blur(10rpx);
  animation: slideInLeft 0.5s ease;
}

.scene-name-text {
  font-size: 28rpx;
  font-weight: bold;
  text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.3);
}

/* 动画 */
@keyframes pulse {
  0%, 100% {
    transform: scale(1);
  }
  50% {
    transform: scale(1.1);
  }
}

@keyframes fadeInOut {
  0%, 100% {
    opacity: 0.6;
  }
  50% {
    opacity: 1;
  }
}

@keyframes fadeIn {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

@keyframes bounce {
  0%, 20%, 50%, 80%, 100% {
    transform: translateY(0);
  }
  40% {
    transform: translateY(-20rpx);
  }
  60% {
    transform: translateY(-10rpx);
  }
}

@keyframes glow {
  0%, 100% {
    text-shadow: 0 0 10rpx rgba(139, 69, 19, 0.3);
  }
  50% {
    text-shadow: 0 0 20rpx rgba(139, 69, 19, 0.6);
  }
}

@keyframes float {
  0%, 100% {
    transform: translate(-50%, -50%) translateY(0);
  }
  50% {
    transform: translate(-50%, -50%) translateY(-10rpx);
  }
}

@keyframes rotate {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

@keyframes slideUp {
  0%, 100% {
    transform: translateX(-50%) translateY(0);
  }
  50% {
    transform: translateX(-50%) translateY(-5rpx);
  }
}

@keyframes zoomIn {
  from {
    transform: scale(0.8);
    opacity: 0;
  }
  to {
    transform: scale(1);
    opacity: 1;
  }
}

@keyframes slideInLeft {
  from {
    transform: translateX(-100%);
    opacity: 0;
  }
  to {
    transform: translateX(0);
    opacity: 1;
  }
}

/* 响应式设计 */
@media (max-width: 375px) {
  .scene-image {
    height: 420rpx;
  }
  
  .scene-item {
    width: 190rpx;
  }
  
  .scene-thumb {
    height: 120rpx;
  }
  
  .nav-center {
    font-size: 32rpx;
  }
  
  .status-value {
    font-size: 28rpx;
  }
}

/* 底部留白 */
.bottom-space {
  height: 140rpx;
}