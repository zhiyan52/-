/* diancang/diancang/diancang-detail.wxss */
.container {
  padding: 20rpx;
  background-color: #f8f5f0;
  min-height: 100vh;
}

.book-header {
  margin-bottom: 40rpx;
  text-align: center;
}

.book-title {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.book-desc {
  font-size: 28rpx;
  color: #666;
}

.sentence-list {
  margin-bottom: 60rpx;
}

.sentence-item {
  background-color: #fff;
  border-radius: 15rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.original, .note, .translation {
  font-size: 30rpx;
  line-height: 1.8;
  margin-bottom: 15rpx;
}

.original {
  color: #333;
  font-weight: 500;
}

.note {
  color: #999;
  font-size: 26rpx;
}

.translation {
  color: #666;
}

.action-bar {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.action-btn {
  flex: 1;
  padding: 15rpx 0;
  font-size: 28rpx;
  border-radius: 30rpx;
  background-color: #c8b69e;
  color: #fff;
  border: none;
}

.action-btn.collected {
  background-color: #a67c52;
}

.quiz-section {
  background-color: #fff;
  border-radius: 15rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.quiz-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.quiz-question {
  display: block;
  font-size: 30rpx;
  color: #333;
  margin-bottom: 30rpx;
}

.quiz-options {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.quiz-option {
  padding: 20rpx;
  border: 2rpx solid #ddd;
  border-radius: 15rpx;
  font-size: 28rpx;
  color: #333;
}

.quiz-option.selected {
  border-color: #c8b69e;
  background-color: #f5f0e9;
}

.quiz-result {
  text-align: center;
  font-size: 30rpx;
}

.correct {
  color: #52c41a;
}

.wrong {
  color: #ff4d4f;
}