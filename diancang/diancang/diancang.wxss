 /* 典藏拾珠 - 传统中国风样式 */
.home-container {
  background-color: #E8F5E8;
  min-height: 100vh;
  padding: 20rpx 30rpx;
}

/* 主视觉区 */
.hero {
  margin: 20rpx 0 40rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.1);
  border: 4rpx solid #48BB78;
}

.hero-swiper {
  width: 100%;
  height: 400rpx;
}

.hero-image {
  width: 100%;
  height: 100%;
  display: block;
}

/* 功能入口 */
.features {
  margin: 40rpx 0;
}

.feature-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 48%;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  border: 2rpx solid #A3D9A5;
  transition: all 0.3s;
  cursor: pointer;
}

.feature-item:hover {
  transform: translateY(-5rpx);
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.15);
  border-color: #48BB78;
}

.feature-icon {
  width: 140rpx;
  height: 140rpx;
  margin-bottom: 20rpx;
  border-radius: 50%;
  border: 2rpx solid #A3D9A5;
  object-fit: cover;
}

.feature-icon-text {
  font-size: 80rpx;
  margin-bottom: 20rpx;
  color: #48BB78;
}

.feature-item text {
  font-size: 28rpx;
  color: #1A365D;
  font-weight: 500;
  font-family: "STKaiti", "KaiTi", serif;
}

/* 精选推荐 */
.section {
  margin-top: 50rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1A365D;
  margin-bottom: 30rpx;
  display: block;
  text-align: center;
  font-family: "STKaiti", "KaiTi", serif;
  position: relative;
  padding-bottom: 15rpx;
}

.section-title::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 100rpx;
  height: 4rpx;
  background: #48BB78;
  border-radius: 2rpx;
}

.recommendations {
  display: flex;
  justify-content: space-between;
}

.recommend-item {
  width: 48%;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  border: 2rpx solid #A3D9A5;
  transition: all 0.3s;
  cursor: pointer;
}

.recommend-item:hover {
  transform: translateY(-5rpx);
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.15);
  border-color: #48BB78;
}

.rec-image {
  width: 100%;
  height: 240rpx;
  border-radius: 8rpx;
  margin-bottom: 15rpx;
  border: 2rpx solid #A3D9A5;
  object-fit: cover;
}

.rec-title {
  font-size: 28rpx;
  color: #1A365D;
  text-align: center;
  font-family: "STKaiti", "KaiTi", serif;
  font-weight: 500;
  margin-bottom: 8rpx;
}

.rec-era {
  font-size: 24rpx;
  color: #718096;
  text-align: center;
  font-family: "STKaiti", "KaiTi", serif;
}

/* 底部导航 */
.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 120rpx;
  background: #FFFFFF;
  border-top: 2rpx solid #A3D9A5;
  display: flex;
  justify-content: space-around;
  align-items: center;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.1);
  z-index: 9999;
  pointer-events: auto;
}

/* 确保页面内容不被底部导航栏遮挡 */
.home-container {
  padding-bottom: 140rpx;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 33.33%;
  height: 100%;
  justify-content: center;
  cursor: pointer;
  user-select: none;
  transition: all 0.3s;
}

.tab-item:hover {
  background: rgba(72, 187, 120, 0.1);
}

.tab-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
  display: block;
  text-align: center;
  color: #1A365D;
}

.tab-image {
  width: 48rpx;
  height: 48rpx;
  margin-bottom: 8rpx;
  display: block;
}

.tab-item text {
  font-size: 24rpx;
  color: #718096;
  font-family: "STKaiti", "KaiTi", serif;
}

.tab-item.active text {
  color: #48BB78;
  font-weight: bold;
}

/* 竞赛中心卡片 */
.competition-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, #48BB78 0%, #38A169 100%);
  border-radius: 16rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(72, 187, 120, 0.3);
  transition: transform 0.2s ease;
  border: 2rpx solid #A3D9A5;
  cursor: pointer;
}

.competition-card:active {
  transform: scale(0.98);
}

.competition-content {
  flex: 1;
}

.competition-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 10rpx;
  font-family: "STKaiti", "KaiTi", serif;
  text-shadow: 2rpx 2rpx 4rpx rgba(0,0,0,0.2);
}

.competition-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  font-family: "STKaiti", "KaiTi", serif;
}

.competition-icon {
  font-size: 80rpx;
  margin-left: 20rpx;
  color: #FFFFFF;
}

/* 典藏资讯 */
.news-section {
  margin-top: 50rpx;
  padding: 30rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  border: 2rpx solid #A3D9A5;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}

.news-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1A365D;
  margin-bottom: 20rpx;
  text-align: center;
  font-family: "STKaiti", "KaiTi", serif;
  position: relative;
  padding-bottom: 15rpx;
}

.news-title::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 100rpx;
  height: 4rpx;
  background: #48BB78;
  border-radius: 2rpx;
}

.news-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #A3D9A5;
  transition: all 0.3s;
  cursor: pointer;
}

.news-item:last-child {
  border-bottom: none;
}

.news-item:hover {
  transform: translateX(10rpx);
}

.news-icon {
  font-size: 32rpx;
  margin-right: 20rpx;
  color: #48BB78;
}

.news-content {
  flex: 1;
}

.news-item-title {
  font-size: 28rpx;
  color: #1A365D;
  margin-bottom: 5rpx;
  font-family: "STKaiti", "KaiTi", serif;
}

.news-item-desc {
  font-size: 24rpx;
  color: #718096;
  font-family: "STKaiti", "KaiTi", serif;
}

/* 底部信息 */
.footer {
  margin-top: 50rpx;
  padding: 30rpx;
  text-align: center;
  background: linear-gradient(135deg, #1A365D 0%, #2C5282 100%);
  border-radius: 16rpx 16rpx 0 0;
  border-top: 4rpx solid #48BB78;
}

.footer-text {
  font-size: 24rpx;
  color: #E8F5E8;
  margin-bottom: 10rpx;
  font-family: "STKaiti", "KaiTi", serif;
}

.footer-copyright {
  font-size: 20rpx;
  color: rgba(232, 245, 232, 0.8);
  font-family: "STKaiti", "KaiTi", serif;
}

/* 底部空间 */
.bottom-space {
  height: 40rpx;
}

/* 智能功能按钮 */
.smart-features {
  margin: 40rpx 0;
}

.smart-feature-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 25rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  border: 2rpx solid #A3D9A5;
  transition: all 0.3s;
  cursor: pointer;
}

.smart-feature-item:hover {
  transform: translateY(-5rpx);
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.15);
  border-color: #48BB78;
}

.smart-feature-icon {
  font-size: 48rpx;
  margin-right: 20rpx;
  color: #48BB78;
}

.smart-feature-content {
  flex: 1;
}

.smart-feature-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1A365D;
  margin-bottom: 5rpx;
  font-family: "STKaiti", "KaiTi", serif;
}

.smart-feature-desc {
  font-size: 24rpx;
  color: #718096;
  font-family: "STKaiti", "KaiTi", serif;
}

.smart-feature-arrow {
  font-size: 32rpx;
  color: #48BB78;
}

/* AI功能入口 */
.ai-features {
  margin: 40rpx 0;
}

.ai-feature-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.ai-feature-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  border: 2rpx solid #A3D9A5;
  transition: all 0.3s;
  cursor: pointer;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.ai-feature-card:hover {
  transform: translateY(-5rpx);
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.15);
  border-color: #48BB78;
}

.ai-feature-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 15rpx;
  border-radius: 50%;
  border: 2rpx solid #A3D9A5;
  object-fit: cover;
}

.ai-feature-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #1A365D;
  margin-bottom: 8rpx;
  font-family: "STKaiti", "KaiTi", serif;
  text-align: center;
}

.ai-feature-desc {
  font-size: 22rpx;
  color: #718096;
  font-family: "STKaiti", "KaiTi", serif;
  text-align: center;
  line-height: 1.4;
}
