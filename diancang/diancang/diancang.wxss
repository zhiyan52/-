/* pages/classic/classic.wxss */
.container {
  padding: 20rpx;
  background-color: #f8f5f0;
  min-height: 100vh;
}

.tab-bar {
  white-space: nowrap;
  margin-bottom: 30rpx;
}

.tab-item {
  display: inline-block;
  padding: 15rpx 30rpx;
  margin-right: 20rpx;
  font-size: 30rpx;
  color: #666;
  border-radius: 30rpx;
  background-color: #fff;
}

.tab-item.active {
  background-color: #c8b69e;
  color: #fff;
}

.book-list {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
}

.book-card {
  width: 48%;
  margin-bottom: 30rpx;
  background-color: #fff;
  border-radius: 15rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.book-cover {
  width: 100%;
  height: 240rpx;
}

.book-name {
  display: block;
  padding: 20rpx;
  font-size: 32rpx;
  text-align: center;
  color: #333;
}

.cache-tip {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  margin-top: 20rpx;
}