<!-- 名句卡片生成页面 -->
<view class="card-container">
  <!-- 顶部标题 -->
  <view class="header">
    <view class="back-btn" bindtap="goBack">
      <text>←</text>
    </view>
    <text class="title">经典名句卡片</text>
    <view class="placeholder"></view>
  </view>
  
  <!-- 卡片生成区域 -->
  <view class="card-section">
    <view class="card-preview" id="cardCanvas">
      <view class="card-bg">
        <view class="card-content">
          <text class="card-quote">{{currentQuote.quote}}</text>
          <text class="card-source">{{currentQuote.source}}</text>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 操作按钮 -->
  <view class="action-buttons">
    <button bindtap="generateCard" class="generate-btn">生成新卡片</button>
    <button bindtap="saveCard" class="save-btn">保存卡片</button>
  </view>
  
  <!-- 历史卡片 -->
  <view class="history-section">
    <text class="section-title">历史卡片</text>
    <view class="history-list">
      <view class="history-item" wx:for="{{historyQuotes}}" wx:key="index">
        <view class="history-card">
          <text class="history-quote">{{item.quote}}</text>
          <text class="history-source">{{item.source}}</text>
        </view>
        <view class="history-actions">
          <view class="history-btn" bindtap="reuseCard" data-index="{{index}}">
            <text>使用</text>
          </view>
        </view>
      </view>
    </view>
  </view>
</view>