/* 典藏阅读器页面样式 */
.reader-container {
  background-color: #f8f4e9;
  min-height: 100vh;
  position: relative;
}

/* 顶部导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 100rpx;
  padding: 0 30rpx;
  background: #2C2621;
  color: #fff;
  position: sticky;
  top: 0;
  z-index: 100;
}

.nav-left {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.back-icon {
  font-size: 36rpx;
  font-weight: bold;
}

.nav-title {
  font-size: 28rpx;
}

.nav-center {
  font-size: 32rpx;
  font-weight: 500;
  flex: 1;
  text-align: center;
  margin: 0 40rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.nav-right {
  font-size: 36rpx;
}

/* 内容区域 */
.content-section {
  padding: 40rpx 30rpx;
  min-height: calc(100vh - 100rpx);
}

/* 书籍信息 */
.book-info {
  text-align: center;
  margin-bottom: 60rpx;
}

.book-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
  display: block;
}

.book-author {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 10rpx;
  display: block;
}

.book-era {
  font-size: 24rpx;
  color: #999;
  display: block;
}

/* 目录 */
.chapter-list {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.chapter-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 30rpx;
  display: block;
  text-align: center;
}

.chapter-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.chapter-item:last-child {
  border-bottom: none;
}

.chapter-number {
  width: 40rpx;
  font-size: 24rpx;
  color: #8B4513;
  font-weight: bold;
  margin-right: 20rpx;
}

.chapter-name {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

/* 阅读内容 */
.reading-content {
  background: #fff;
  border-radius: 20rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  line-height: 1.8;
}

.reading-content .chapter-title {
  text-align: left;
  margin-bottom: 40rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #e0e0e0;
}

.content {
  font-size: 28rpx;
  color: #333;
  text-align: justify;
}

/* 底部工具栏 */
.tool-bar {
  display: flex;
  justify-content: space-around;
  align-items: center;
  height: 100rpx;
  background: #2C2621;
  color: #fff;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 99;
}

.tool-item {
  flex: 1;
  text-align: center;
  padding: 20rpx;
}

.tool-icon {
  font-size: 24rpx;
  color: #fff;
}
