/* diancang/pages/heritage/heritage.wxss */

.container {
  min-height: 100vh;
  background-color: #f8f5f0;
  padding: 10rpx;
  position: relative;
  overflow-x: hidden;
}

/* 标题区域 */
.header {
  text-align: center;
  margin-bottom: 30rpx;
  padding-top: 20rpx;
  position: relative;
}

.title {
  font-size: 56rpx;
  font-weight: bold;
  color: #7a4a19;
  margin-bottom: 16rpx;
  font-family: 'STKaiti', 'KaiTi', serif;
  letter-spacing: 6rpx;
  position: relative;
  display: inline-block;
  animation: titleAppear 1s ease-out;
}

.title::after {
  content: '';
  position: absolute;
  bottom: -8rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 80%;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #d2b48c, transparent);
  animation: lineAppear 1.5s ease-out;
}

.subtitle {
  font-size: 28rpx;
  color: #a06a33;
  font-family: 'STKaiti', 'KaiTi', serif;
  opacity: 0.9;
  animation: subtitleAppear 1.2s ease-out;
  margin-bottom: 20rpx;
}

/* 典籍选择区域 */
.classic-selection {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #7a4a19;
  margin-bottom: 24rpx;
  font-family: 'STKaiti', 'KaiTi', serif;
  padding-left: 16rpx;
  border-left: 4rpx solid #d2b48c;
  animation: sectionTitleAppear 0.8s ease-out;
}

.classic-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.classic-item {
  background-color: #fff;
  border: 1rpx solid #e0d0b0;
  border-radius: 16rpx;
  padding: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(122, 74, 25, 0.08);
  transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
  position: relative;
  overflow: hidden;
  animation: classicItemAppear 0.6s ease-out;
}

.classic-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(210, 180, 140, 0.1), transparent);
  transition: left 0.6s ease;
}

.classic-item:hover {
  transform: translateY(-5rpx) scale(1.02);
  box-shadow: 0 8rpx 20rpx rgba(122, 74, 25, 0.15);
  border-color: #d2b48c;
}

.classic-item:hover::before {
  left: 100%;
}

.classic-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #7a4a19;
  margin-bottom: 16rpx;
  font-family: 'STKaiti', 'KaiTi', serif;
  position: relative;
  z-index: 1;
}

.classic-desc {
  font-size: 24rpx;
  color: #8a7a6a;
  font-family: 'STKaiti', 'KaiTi', serif;
  line-height: 1.4;
  position: relative;
  z-index: 1;
}

/* 时间轴区域 */
.time-period-section {
  margin-bottom: 30rpx;
}

.selected-classic {
  background-color: #fff;
  border: 1rpx solid #e0d0b0;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(122, 74, 25, 0.08);
  animation: selectedClassicAppear 0.8s ease-out;
}

.classic-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #7a4a19;
  margin-bottom: 16rpx;
  font-family: 'STKaiti', 'KaiTi', serif;
}

.change-classic-btn {
  margin-top: 24rpx;
  background-color: #d2b48c;
  color: #fff;
  border: none;
  border-radius: 10rpx;
  padding: 14rpx 24rpx;
  font-size: 22rpx;
  font-family: 'STKaiti', 'KaiTi', serif;
  transition: all 0.3s ease;
}

.change-classic-btn:hover {
  background-color: #c19a6b;
  transform: translateY(-2rpx);
}

.time-axis {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  position: relative;
}

.time-axis::before {
  content: '';
  position: absolute;
  left: 20rpx;
  top: 0;
  bottom: 0;
  width: 2rpx;
  background: linear-gradient(to bottom, #d2b48c, #e0d0b0);
  z-index: 0;
}

.time-period {
  background-color: #fff;
  border: 1rpx solid #e0d0b0;
  border-radius: 14rpx;
  padding: 20rpx;
  margin-left: 40rpx;
  cursor: pointer;
  transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
  position: relative;
  z-index: 1;
  animation: timePeriodAppear 0.6s ease-out;
}

.time-period::before {
  content: '';
  position: absolute;
  left: -30rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background-color: #fff;
  border: 2rpx solid #d2b48c;
  transition: all 0.3s ease;
}

.time-period.active {
  background-color: #d2b48c;
  color: #fff;
  border-color: #c19a6b;
  transform: translateX(10rpx);
}

.time-period.active::before {
  background-color: #7a4a19;
  border-color: #7a4a19;
  transform: translateY(-50%) scale(1.2);
}

.period-name {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
  font-family: 'STKaiti', 'KaiTi', serif;
}

.period-year {
  font-size: 22rpx;
  font-family: 'STKaiti', 'KaiTi', serif;
  opacity: 0.9;
}

/* 场景区域 */
.scene-section {
  background-color: #fff;
  border: 1rpx solid #e0d0b0;
  border-radius: 16rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 8rpx rgba(122, 74, 25, 0.08);
  animation: sceneSectionAppear 0.8s ease-out;
  position: relative;
  overflow: hidden;
}

.scene-section::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: linear-gradient(90deg, #d2b48c, #c19a6b, #d2b48c);
}

.scene-header {
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #e0d0b0;
}

.scene-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #7a4a19;
  margin-bottom: 16rpx;
  font-family: 'STKaiti', 'KaiTi', serif;
  animation: sceneTitleAppear 0.6s ease-out;
}

.scene-desc {
  font-size: 26rpx;
  color: #8a7a6a;
  font-family: 'STKaiti', 'KaiTi', serif;
  line-height: 1.5;
  animation: sceneDescAppear 0.8s ease-out;
  margin-bottom: 20rpx;
}

/* 问题区域 */
.question-section {
  margin-bottom: 24rpx;
}

.question-text {
  font-size: 32rpx;
  color: #7a4a19;
  margin-bottom: 24rpx;
  font-family: 'STKaiti', 'KaiTi', serif;
  line-height: 1.5;
  animation: questionAppear 0.6s ease-out;
}

.options-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.option-item {
  display: flex;
  align-items: center;
  background-color: #f8f5f0;
  border: 1rpx solid #e0d0b0;
  border-radius: 12rpx;
  padding: 24rpx;
  cursor: pointer;
  transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
  position: relative;
  overflow: hidden;
  animation: optionAppear 0.6s ease-out;
}

.option-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(210, 180, 140, 0.2), transparent);
  transition: left 0.6s ease;
}

.option-item:hover {
  transform: translateX(10rpx);
  border-color: #d2b48c;
}

.option-item:hover::before {
  left: 100%;
}

.option-item.selected {
  background-color: #d2b48c;
  color: #fff;
  border-color: #c19a6b;
  transform: translateX(15rpx);
  box-shadow: 0 4rpx 12rpx rgba(210, 180, 140, 0.3);
}

.option-letter {
  font-size: 28rpx;
  font-weight: bold;
  margin-right: 20rpx;
  font-family: 'STKaiti', 'KaiTi', serif;
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  border-radius: 50%;
  background-color: rgba(210, 180, 140, 0.2);
  transition: all 0.3s ease;
  position: relative;
  z-index: 1;
}

.option-item.selected .option-letter {
  background-color: rgba(255, 255, 255, 0.3);
}

.option-text {
  font-size: 26rpx;
  font-family: 'STKaiti', 'KaiTi', serif;
  flex: 1;
  line-height: 1.5;
  position: relative;
  z-index: 1;
}

.submit-btn {
  background-color: #7a4a19;
  color: #fff;
  border: none;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 26rpx;
  font-family: 'STKaiti', 'KaiTi', serif;
  width: 100%;
  transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
  position: relative;
  overflow: hidden;
}

.submit-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  transition: left 0.6s ease;
}

.submit-btn:hover {
  background-color: #6a3a09;
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 12rpx rgba(122, 74, 25, 0.3);
}

.submit-btn:hover::before {
  left: 100%;
}

.submit-btn:disabled {
  background-color: #c19a6b;
  opacity: 0.7;
  transform: none;
  box-shadow: none;
}

/* 反馈区域 */
.feedback-section {
  margin-top: 16rpx;
  animation: feedbackAppear 0.8s ease-out;
}

.ai-feedback {
  background-color: #f8f5f0;
  border: 1rpx solid #e0d0b0;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  position: relative;
  overflow: hidden;
}

.ai-feedback::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #d2b48c, transparent);
}

.feedback-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #7a4a19;
  margin-bottom: 16rpx;
  font-family: 'STKaiti', 'KaiTi', serif;
}

.feedback-content {
  font-size: 26rpx;
  color: #6a5a4a;
  font-family: 'STKaiti', 'KaiTi', serif;
  line-height: 1.5;
  animation: typing 2s steps(40, end);
  overflow: hidden;
  white-space: nowrap;
}

.reference-section {
  background-color: #f8f5f0;
  border: 1rpx solid #e0d0b0;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
  position: relative;
  overflow: hidden;
}

.reference-section::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #d2b48c, transparent);
}

.reference-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #7a4a19;
  margin-bottom: 16rpx;
  font-family: 'STKaiti', 'KaiTi', serif;
}

.reference-content {
  font-family: 'STKaiti', 'KaiTi', serif;
}

.original-text {
  display: block;
  font-size: 26rpx;
  color: #7a4a19;
  margin-bottom: 16rpx;
  line-height: 1.5;
  padding-left: 20rpx;
  border-left: 2rpx solid #d2b48c;
}

.translated-text {
  display: block;
  font-size: 24rpx;
  color: #8a7a6a;
  line-height: 1.5;
  padding-left: 20rpx;
}

.action-buttons {
  display: flex;
  gap: 16rpx;
}

.next-btn {
  flex: 1;
  background-color: #7a4a19;
  color: #fff;
  border: none;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 26rpx;
  font-family: 'STKaiti', 'KaiTi', serif;
  transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
  position: relative;
  overflow: hidden;
}

.next-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  transition: left 0.6s ease;
}

.next-btn:hover {
  background-color: #6a3a09;
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 12rpx rgba(122, 74, 25, 0.3);
}

.next-btn:hover::before {
  left: 100%;
}

.restart-btn {
  flex: 1;
  background-color: #d2b48c;
  color: #fff;
  border: none;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 26rpx;
  font-family: 'STKaiti', 'KaiTi', serif;
  transition: all 0.4s cubic-bezier(0.25, 0.8, 0.25, 1);
  position: relative;
  overflow: hidden;
}

.restart-btn::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
  transition: left 0.6s ease;
}

.restart-btn:hover {
  background-color: #c19a6b;
  transform: translateY(-2rpx);
  box-shadow: 0 4rpx 12rpx rgba(210, 180, 140, 0.3);
}

.restart-btn:hover::before {
  left: 100%;
}

/* 背景装饰 */
.background-decoration {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: -1;
  opacity: 0.05;
  animation: bgFloat 20s ease-in-out infinite;
}

.bg-image {
  width: 100%;
  height: 100%;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .title {
    font-size: 40rpx;
  }
  
  .subtitle {
    font-size: 20rpx;
  }
  
  .classic-item {
    padding: 24rpx;
  }
  
  .scene-section {
    padding: 24rpx;
  }
  
  .option-item {
    padding: 16rpx;
  }
}

/* 动画效果 */
@keyframes titleAppear {
  from {
    opacity: 0;
    transform: translateY(-20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes subtitleAppear {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes lineAppear {
  from {
    width: 0;
  }
  to {
    width: 80%;
  }
}

@keyframes sectionTitleAppear {
  from {
    opacity: 0;
    transform: translateX(-20rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

@keyframes classicItemAppear {
  from {
    opacity: 0;
    transform: translateY(20rpx) scale(0.95);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

@keyframes selectedClassicAppear {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes timePeriodAppear {
  from {
    opacity: 0;
    transform: translateX(-20rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

@keyframes sceneSectionAppear {
  from {
    opacity: 0;
    transform: scale(0.95);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

@keyframes sceneTitleAppear {
  from {
    opacity: 0;
    transform: translateY(-10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes sceneDescAppear {
  from {
    opacity: 0;
    transform: translateY(10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes questionAppear {
  from {
    opacity: 0;
    transform: translateY(10rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes optionAppear {
  from {
    opacity: 0;
    transform: translateX(-20rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

@keyframes feedbackAppear {
  from {
    opacity: 0;
    transform: translateY(20rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes typing {
  from {
    width: 0;
  }
  to {
    width: 100%;
  }
}

@keyframes bgFloat {
  0%, 100% {
    transform: translateY(0) rotate(0deg);
  }
  50% {
    transform: translateY(-20rpx) rotate(1deg);
  }
}

/* 滚动条样式 */
::-webkit-scrollbar {
  width: 8rpx;
}

::-webkit-scrollbar-track {
  background: #f8f5f0;
  border-radius: 4rpx;
}

::-webkit-scrollbar-thumb {
  background: #d2b48c;
  border-radius: 4rpx;
  transition: background 0.3s ease;
}

::-webkit-scrollbar-thumb:hover {
  background: #c19a6b;
}

/* 页面切换动画 */
.page-enter {
  animation: pageEnter 0.5s ease-out;
}

.page-leave {
  animation: pageLeave 0.5s ease-in;
}

@keyframes pageEnter {
  from {
    opacity: 0;
    transform: translateY(50rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

@keyframes pageLeave {
  from {
    opacity: 1;
    transform: translateY(0);
  }
  to {
    opacity: 0;
    transform: translateY(-50rpx);
  }
}
