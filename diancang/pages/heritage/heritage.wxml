<!-- diancang/pages/heritage/heritage.wxml -->
<view class="container">
  <!-- 标题区域 -->
  <view class="header">
    <text class="title">典籍时光机</text>
    <text class="subtitle">穿越式互动学习</text>
  </view>

  <!-- 典籍选择区域 -->
  <view class="classic-selection" wx:if="{{!selectedClassic}}">
    <text class="section-title">选择典籍</text>
    <view class="classic-list">
      <view 
        class="classic-item" 
        wx:for="{{classics}}" 
        wx:key="id"
        bindtap="selectClassic"
        data-id="{{item.id}}"
      >
        <text class="classic-name">{{item.name}}</text>
        <text class="classic-desc">{{item.description}}</text>
      </view>
    </view>
  </view>

  <!-- 时间轴区域 -->
  <view class="time-period-section" wx:if="{{selectedClassic && !showScene}}">
    <view class="selected-classic">
      <text class="classic-title">{{selectedClassic.name}}</text>
      <text class="classic-desc">{{selectedClassic.description}}</text>
      <button class="change-classic-btn" bindtap="changeClassic">切换典籍</button>
    </view>
    
    <text class="section-title">选择时间</text>
    <view class="time-axis">
      <view 
        class="time-period" 
        wx:for="{{timePeriods}}" 
        wx:key="id"
        bindtap="selectTimePeriod"
        data-id="{{item.id}}"
        class="{{selectedTimePeriod && selectedTimePeriod.id === item.id ? 'active' : ''}}"
      >
        <text class="period-name">{{item.name}}</text>
        <text class="period-year">{{item.year}}</text>
      </view>
    </view>
  </view>

  <!-- 场景区域 -->
  <view class="scene-section" wx:if="{{showScene && currentScene}}">
    <view class="scene-header">
      <text class="scene-title">{{currentScene.title}}</text>
      <text class="scene-desc">{{currentScene.description}}</text>
    </view>

    <!-- 问题区域 -->
    <view class="question-section" wx:if="{{!showFeedback}}">
      <text class="question-text">{{currentQuestion.question}}</text>
      <view class="options-list">
        <view 
          class="option-item" 
          wx:for="{{currentQuestion.options}}" 
          wx:key="index"
          bindtap="selectAnswer"
          data-index="{{index}}"
          class="{{selectedAnswer === index ? 'selected' : ''}}"
        >
          <text class="option-letter">{{String.fromCharCode(65 + index)}}</text>
          <text class="option-text">{{item}}</text>
        </view>
      </view>
      <button 
        class="submit-btn" 
        bindtap="submitAnswer"
        disabled="{{selectedAnswer === null}}">
        提交答案
      </button>
    </view>

    <!-- 反馈区域 -->
    <view class="feedback-section" wx:if="{{showFeedback}}">
      <view class="ai-feedback">
        <text class="feedback-title">AI反馈</text>
        <view class="feedback-content">
          <text wx:if="{{aiLoading}}">AI正在思考...</text>
          <text wx:else>{{aiFeedback}}</text>
        </view>
      </view>
      
      <!-- 真实对照 -->
      <view class="reference-section">
        <text class="reference-title">真实对照</text>
        <view class="reference-content">
          <text class="original-text">{{originalText}}</text>
          <text class="translated-text">{{translatedText}}</text>
        </view>
      </view>
      
      <view class="action-buttons">
        <button class="next-btn" bindtap="nextQuestion">下一题</button>
        <button class="restart-btn" bindtap="restartScene">重新开始</button>
      </view>
    </view>
  </view>

  <!-- 背景装饰 -->
  <view class="background-decoration">
    <image src="https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt=Chinese%20ancient%20classics%20pattern%2C%20traditional%20style%2C%20subtle%20background&image_size=square_hd" mode="aspectFill" class="bg-image"></image>
  </view>
</view>