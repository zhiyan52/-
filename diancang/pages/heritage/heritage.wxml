<!--diancang/pages/heritage/heritage.wxml-->
<view class="heritage-page">

  <!-- 顶部标题 -->
  <view class="header">
    <text class="treasure-name">{{galleryName}}</text>
    <text class="subtitle">典藏导览地图 · {{exhibits.length}}件文物</text>
  </view>

  <!-- 分区导航 -->
  <view class="nav-tabs">
    <view class="tab {{activeZone==='all'?'active':''}}" bindtap="switchZone" data-zone="all">
      <text class="icon">🏛️</text>
      <text>全部区域</text>
    </view>
    <view class="tab {{activeZone==='treasures'?'active':''}}" bindtap="switchZone" data-zone="treasures">
      <text class="icon">💎</text>
      <text>典藏精品区</text>
    </view>
    <view class="tab {{activeZone==='ancient'?'active':''}}" bindtap="switchZone" data-zone="ancient">
      <text class="icon">🏯</text>
      <text>古建构件</text>
    </view>
    <view class="tab {{activeZone==='intangible'?'active':''}}" bindtap="switchZone" data-zone="intangible">
      <text class="icon">🎭</text>
      <text>非遗文物</text>
    </view>
  </view>

  <!-- 游览路线选择 -->
  <view class="route-selector">
    <text class="route-label">游览路线：</text>
    <view class="route-options">
      <view class="route-option {{selectedRoute==='recommended'?'active':''}} {{routeLoading?'loading':''}}" bindtap="selectRoute" data-route="recommended">
        <text>{{routeLoading && selectedRoute==='recommended'?'生成中...':'推荐路线'}}</text>
      </view>
      <view class="route-option {{selectedRoute==='quick'?'active':''}} {{routeLoading?'loading':''}}" bindtap="selectRoute" data-route="quick">
        <text>{{routeLoading && selectedRoute==='quick'?'生成中...':'快速打卡'}}</text>
      </view>
      <view class="route-option {{selectedRoute==='deep'?'active':''}} {{routeLoading?'loading':''}}" bindtap="selectRoute" data-route="deep">
        <text>{{routeLoading && selectedRoute==='deep'?'生成中...':'深度研学'}}</text>
      </view>
      <view class="route-option {{selectedRoute==='family'?'active':''}} {{routeLoading?'loading':''}}" bindtap="selectRoute" data-route="family">
        <text>{{routeLoading && selectedRoute==='family'?'生成中...':'亲子路线'}}</text>
      </view>
    </view>
  </view>

  <!-- 路线信息 -->
  <view wx:if="showRoute" class="route-info">
    <view class="info-item">
      <text class="info-label">路线类型：</text>
      <text class="info-value">{{routeInfo.type}}</text>
    </view>
    <view class="info-item">
      <text class="info-label">预计时间：</text>
      <text class="info-value">{{routeInfo.duration}}</text>
    </view>
    <view class="info-item">
      <text class="info-label">展品数量：</text>
      <text class="info-value">{{routeInfo.exhibitCount}}件</text>
    </view>
  </view>

  <!-- 平面图上传 -->
  <view class="map-upload-section">
    <view class="upload-container">
      <text class="upload-title">平面图管理</text>
      <button class="upload-btn" bindtap="uploadMap">
        <text>上传平面图</text>
      </button>
      <text class="upload-hint">支持JPG、PNG格式，建议尺寸1200x800</text>
    </view>
  </view>

  <!-- 热区编辑 -->
  <view class="hotspot-edit-section">
    <view class="edit-container">
      <text class="edit-title">热区编辑</text>
      <button class="edit-btn" bindtap="toggleEditMode">
        <text>{{editMode ? '退出编辑' : '进入编辑模式'}}</text>
      </button>
      <text class="edit-hint">进入编辑模式后，可点击地图添加或调整热区位置</text>
    </view>
  </view>

  <!-- 典藏馆地图 -->
  <view class="gallery-map-container" bindtap="handleMapTap" bindtouchmove="dragHotspot" bindtouchend="endDrag">
    <!-- 平面图背景 -->
    <image class="gallery-map" src="{{galleryMapUrl}}" mode="aspectFit"/>

    <!-- 热区层 -->
    <view class="hotspots-layer" style="transform: scale({{mapScale}}); transform-origin: {{mapCenter.x}}px {{mapCenter.y}}px;">
      <!-- 文物热区 -->
      <view
        wx:for="{{filteredExhibits}}"
        wx:key="id"
        class="hotspot {{activeExhibitId===item.id?'active':''}} {{editMode?'edit-mode':''}}"
        style="left: {{item.position.x}}rpx; top: {{item.position.y}}rpx; width: {{item.position.width}}rpx; height: {{item.position.height}}rpx;"
        data-id="{{item.id}}"
        bindtap="{{editMode ? 'startDrag' : 'selectExhibit'}}"
      >
        <view class="hotspot-marker">
          <text class="hotspot-number">{{item.number}}</text>
        </view>
        <text class="hotspot-label">{{item.name}}</text>
      </view>

      <!-- 路线轨迹 -->
      <view wx:if="showRoute" class="route-path">
        <canvas canvas-id="routeCanvas" class="route-canvas"/>
      </view>
    </view>

    <!-- 地图控制 -->
    <view class="map-controls">
      <button class="map-btn" bindtap="resetMap">复位</button>
      <button class="map-btn" bindtap="toggleLabels">标签</button>
      <button class="map-btn" bindtap="toggleRoute">路线</button>
    </view>
  </view>

  <!-- 文物详情面板 -->
  <view class="exhibit-detail {{showDetail?'show':''}}">
    <view class="detail-header" bindtap="closeDetail">
      <text class="detail-title">{{selectedExhibit.name}}</text>
      <text class="close">✕</text>
    </view>

    <scroll-view class="detail-body" scroll-y>
      <!-- 文物图片 -->
      <image wx:if="{{selectedExhibit.image}}" src="{{selectedExhibit.image}}" mode="aspectFill" class="exhibit-image"/>

      <!-- 文物信息 -->
      <view class="exhibit-info">
        <text class="info-label">文物编号：</text>
        <text class="info-value">{{selectedExhibit.number}}</text>
      </view>
      <view class="exhibit-info">
        <text class="info-label">所属区域：</text>
        <text class="info-value">{{selectedExhibit.zoneName}}</text>
      </view>
      <view class="exhibit-info">
        <text class="info-label">年代：</text>
        <text class="info-value">{{selectedExhibit.era}}</text>
      </view>

      <!-- 文物描述 -->
      <view class="description-section">
        <text class="section-title">文物描述</text>
        <text class="description-text">{{selectedExhibit.description}}</text>
      </view>

      <!-- 历史价值 -->
      <view class="value-section" wx:if="{{selectedExhibit.value}}">
        <text class="section-title">历史价值</text>
        <text class="value-text">{{selectedExhibit.value}}</text>
      </view>

      <!-- AI 讲解入口 -->
      <view class="ai-section">
        <button class="ai-btn" bindtap="showAiExplanation">
          <text class="ai-icon">🤖</text>
          <text>AI智能讲解</text>
        </button>
      </view>
    </scroll-view>
  </view>

  <!-- AI 讲解弹窗 -->
  <view class="ai-modal {{showAiModal?'show':''}}">
    <view class="modal-mask" bindtap="hideAiModal"></view>
    <view class="modal-content">
      <text class="modal-title">AI智能讲解</text>
      <text class="modal-subtitle">{{selectedExhibit.name}}</text>

      <!-- 讲解内容 -->
      <view class="ai-content" wx:if="{{aiExplanation}}">
        <text class="ai-text">{{aiExplanation}}</text>
      </view>
      <view class="ai-loading" wx:else>
        <text class="loading-text">AI正在生成讲解...</text>
      </view>

      <button class="modal-btn" bindtap="hideAiModal">
        <text>关闭</text>
      </button>
    </view>
  </view>

  <!-- 底部操作 -->
  <view class="bottom-bar">
    <button class="action-btn" open-type="share">
      <text>分享</text>
    </button>
    <button class="action-btn" bindtap="showFullMap">
      <text>全屏地图</text>
    </button>
  </view>
</view>
