/* shufa/shufa/shufa.wxss */
.page-container {
  background: linear-gradient(180deg, #f8f4e9 0%, #ede8d0 100%);
  min-height: 100vh;
  font-family: "KaiTi", "STKaiti", "PingFang SC", sans-serif;
}

/* 顶部导航 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  position: sticky;
  top: 0;
  z-index: 100;
}

.header-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-btn {
  font-size: 36rpx;
  color: #333;
}

.header-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.header-right {
  display: flex;
  gap: 30rpx;
}

.message-btn, .my-btn {
  font-size: 28rpx;
  color: #666;
  padding: 10rpx 20rpx;
  border-radius: 20rpx;
  background: #f5f5f5;
}

/* 轮播Banner */
.banner-section {
  margin: 20rpx 0;
}

.banner-swiper {
  height: 300rpx;
  margin: 0 30rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.banner-image {
  width: 100%;
  height: 100%;
  border-radius: 20rpx;
}

.banner-title {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.7));
  color: white;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 0 0 20rpx 20rpx;
}

/* 书画分类 */
.category-section {
  padding: 20rpx 30rpx;
}

.category-grid {
  display: flex;
  gap: 20rpx;
}

.category-card {
  flex: 1;
  border-radius: 20rpx;
  padding: 40rpx 20rpx;
  text-align: center;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.15);
  transition: all 0.3s ease;
}

.category-card.calligraphy {
  background: linear-gradient(135deg, #2c3e50 0%, #34495e 100%);
}

.category-card.painting {
  background: linear-gradient(135deg, #8b4513 0%, #a0522d 100%);
}

.category-icon {
  font-size: 60rpx;
  margin-bottom: 20rpx;
}

.category-name {
  font-size: 36rpx;
  font-weight: bold;
  color: white;
  display: block;
  margin-bottom: 10rpx;
}

.category-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 功能入口 */
.function-section {
  padding: 30rpx;
}

.function-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.function-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background: white;
  border-radius: 15rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.function-icon {
  font-size: 28rpx;
  font-weight: bold;
  color: #b22222;
  margin-bottom: 10rpx;
}

.function-text {
  font-size: 24rpx;
  color: #666;
}

/* 通用区块样式 */
.section {
  margin: 30rpx 0;
  padding: 0 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  border-left: 8rpx solid #b22222;
  padding-left: 15rpx;
}

/* 最近临帖 */
.recent-copybooks {
  display: flex;
  gap: 20rpx;
  overflow-x: auto;
  padding-bottom: 20rpx;
}

.copybook-item {
  flex: 0 0 200rpx;
  background: white;
  border-radius: 15rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.copybook-image {
  width: 100%;
  height: 200rpx;
  border-radius: 15rpx 15rpx 0 0;
}

.copybook-info {
  padding: 15rpx;
}

.copybook-title {
  font-size: 24rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 5rpx;
}

.copybook-author {
  font-size: 20rpx;
  color: #666;
}

/* 推荐碑帖 */
.recommended-copybooks {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.recommended-item {
  background: white;
  border-radius: 15rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.recommended-image {
  width: 100%;
  height: 180rpx;
  border-radius: 15rpx 15rpx 0 0;
}

.recommended-info {
  padding: 15rpx;
}

.recommended-title {
  font-size: 24rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 5rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.recommended-meta {
  display: flex;
  justify-content: space-between;
  font-size: 20rpx;
  color: #666;
}

/* 国画作品 */
.painting-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-top: 20rpx;
}

.painting-item {
  background: white;
  border-radius: 15rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}

.painting-item:hover {
  transform: translateY(-5rpx);
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.15);
}

.painting-image {
  width: 100%;
  height: 200rpx;
  display: block;
}

.painting-info {
  padding: 15rpx;
}

.painting-title {
  font-size: 24rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 5rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.painting-author {
  font-size: 20rpx;
  color: #666;
  margin-bottom: 5rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.painting-category {
  font-size: 18rpx;
  color: #999;
}

/* 国画分类 */
.painting-categories {
  display: flex;
  justify-content: space-between;
  margin-top: 20rpx;
  gap: 20rpx;
}

.category-item {
  flex: 1;
  background: white;
  border-radius: 15rpx;
  padding: 30rpx 20rpx;
  text-align: center;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
  border: 2rpx solid #e0d8c0;
}

.category-item:hover {
  transform: translateY(-5rpx);
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.15);
  border-color: #c8b696;
}

.category-icon {
  font-size: 48rpx;
  margin-bottom: 15rpx;
  color: #8b7d6b;
}

.category-name {
  font-size: 24rpx;
  font-weight: bold;
  color: #333;
}

/* 雅集动态 */
.social-posts {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.social-post {
  background: white;
  border-radius: 15rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.post-header {
  display: flex;
  align-items: center;
  margin-bottom: 15rpx;
}

.user-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 15rpx;
}

.user-name {
  font-size: 24rpx;
  font-weight: bold;
  color: #333;
}

.post-content {
  font-size: 26rpx;
  color: #333;
  margin-bottom: 15rpx;
  line-height: 1.5;
}

.post-image {
  width: 100%;
  height: 300rpx;
  border-radius: 10rpx;
  margin-bottom: 15rpx;
}

.post-actions {
  display: flex;
  gap: 40rpx;
}

.action-item {
  display: flex;
  align-items: center;
  gap: 5rpx;
  font-size: 24rpx;
  color: #666;
}

.action-icon {
  font-size: 28rpx;
}

/* 底部Tab */
.tab-bar {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: white;
  border-top: 1rpx solid #e5e5e5;
  padding: 15rpx 0;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 99;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 5rpx;
  padding: 10rpx;
  color: #666;
}

.tab-item.tab-active {
  color: #b22222;
}

.tab-icon {
  font-size: 36rpx;
}

.tab-text {
  font-size: 20rpx;
}

.tab-create {
  background: linear-gradient(90deg, #b22222, #cd853f);
  color: white;
  border-radius: 50%;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(178, 34, 34, 0.3);
}

.tab-create .tab-icon {
  font-size: 48rpx;
  line-height: 1;
}

.tab-create .tab-text {
  font-size: 18rpx;
  margin-top: -5rpx;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .banner-swiper {
    height: 250rpx;
  }
  
  .function-icon {
    font-size: 24rpx;
  }
  
  .section-title {
    font-size: 28rpx;
  }
  
  .recommended-copybooks {
    grid-template-columns: repeat(2, 1fr);
  }
}
