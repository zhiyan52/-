/* 书画雅集社区页面样式 */
.community-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #F8F0E3 0%, #FFFBF5 100%);
  padding-bottom: 120rpx;
}

/* 顶部导航 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  background: linear-gradient(135deg, #1A365D 0%, #2C5282 100%);
  position: sticky;
  top: 0;
  z-index: 100;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #D4A017;
  font-family: "STKaiti", "KaiTi", serif;
}

.header-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  font-size: 28rpx;
  color: #D4A017;
  padding: 10rpx 20rpx;
  background: rgba(212, 160, 23, 0.2);
  border-radius: 20rpx;
}

/* 发帖入口 */
.post-entry {
  display: flex;
  align-items: center;
  padding: 30rpx;
  margin: 20rpx;
  background: #fff;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(26, 54, 93, 0.1);
  border: 2rpx solid #D4A017;
}

.user-avatar-small {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.post-input-placeholder {
  flex: 1;
  font-size: 28rpx;
  color: #999;
}

.post-icon {
  font-size: 40rpx;
}

/* Tab切换 */
.tab-bar {
  display: flex;
  background: #fff;
  margin: 0 20rpx;
  border-radius: 20rpx;
  padding: 10rpx;
  box-shadow: 0 2rpx 8rpx rgba(26, 54, 93, 0.1);
  border: 2rpx solid #D4A017;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 28rpx;
  color: #666;
  border-radius: 15rpx;
  transition: all 0.3s ease;
}

.tab-item.active {
  background: linear-gradient(135deg, #1A365D 0%, #2C5282 100%);
  color: #D4A017;
  font-weight: bold;
}

/* 帖子列表 */
.post-list {
  padding: 20rpx;
}

.post-item {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(26, 54, 93, 0.1);
  border: 2rpx solid #D4A017;
}

.post-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.post-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.post-user-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.post-username {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 5rpx;
  font-family: "STKaiti", "KaiTi", serif;
}

.post-time {
  font-size: 24rpx;
  color: #999;
}

.post-more {
  padding: 10rpx;
  color: #999;
  font-size: 32rpx;
}

.post-content {
  margin-bottom: 20rpx;
}

.post-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  display: block;
  margin-bottom: 15rpx;
  font-family: "STKaiti", "KaiTi", serif;
}

.post-images {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
}

.post-image {
  width: 100%;
  height: 200rpx;
  border-radius: 10rpx;
  object-fit: cover;
}

.post-image.single {
  grid-column: span 2;
  height: 300rpx;
}

.post-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 20rpx;
}

.tag {
  font-size: 24rpx;
  color: #D4A017;
  background: rgba(212, 160, 23, 0.1);
  padding: 5rpx 15rpx;
  border-radius: 15rpx;
  border: 1rpx solid #D4A017;
}

.post-actions {
  display: flex;
  justify-content: space-around;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.action-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 10rpx 20rpx;
}

.action-item.liked .action-icon,
.action-item.collected .action-icon {
  transform: scale(1.2);
}

.action-icon {
  font-size: 32rpx;
  transition: transform 0.3s ease;
}

.action-count {
  font-size: 24rpx;
  color: #666;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 30rpx;
  font-size: 28rpx;
  color: #D4A017;
}

/* 无数据提示 */
.no-data {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.no-data-icon {
  font-size: 100rpx;
  margin-bottom: 20rpx;
}

.no-data-text {
  font-size: 28rpx;
  color: #999;
}

/* 发帖按钮 */
.fab-btn {
  position: fixed;
  right: 30rpx;
  bottom: 150rpx;
  width: 100rpx;
  height: 100rpx;
  background: linear-gradient(135deg, #1A365D 0%, #2C5282 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(26, 54, 93, 0.3);
  border: 2rpx solid #D4A017;
  z-index: 99;
}

.fab-icon {
  font-size: 60rpx;
  color: #D4A017;
  font-weight: 300;
}

/* 评论弹窗 */
.comment-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.comment-content {
  width: 100%;
  max-height: 80vh;
  background: #fff;
  border-radius: 30rpx 30rpx 0 0;
  display: flex;
  flex-direction: column;
}

.comment-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.comment-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.comment-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.comment-list {
  flex: 1;
  padding: 20rpx 30rpx;
  max-height: 60vh;
}

.comment-item {
  display: flex;
  margin-bottom: 30rpx;
}

.comment-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  margin-right: 20rpx;
}

.comment-info {
  flex: 1;
}

.comment-username {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 5rpx;
  display: block;
}

.comment-text {
  font-size: 28rpx;
  color: #333;
  line-height: 1.5;
  margin-bottom: 10rpx;
  display: block;
}

.comment-footer {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.comment-time {
  font-size: 24rpx;
  color: #999;
}

.comment-reply {
  font-size: 24rpx;
  color: #D4A017;
}

.comment-input-bar {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  border-top: 1rpx solid #f0f0f0;
  background: #fff;
}

.comment-input {
  flex: 1;
  height: 70rpx;
  background: #f5f5f5;
  border-radius: 35rpx;
  padding: 0 30rpx;
  font-size: 28rpx;
}

.comment-send {
  margin-left: 20rpx;
  padding: 15rpx 30rpx;
  background: linear-gradient(135deg, #1A365D 0%, #2C5282 100%);
  color: #D4A017;
  border-radius: 30rpx;
  font-size: 28rpx;
}

/* 意见反馈弹窗 */
.feedback-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.feedback-content {
  width: 90%;
  max-width: 600rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  border: 2rpx solid #D4A017;
}

.feedback-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.feedback-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  font-family: "STKaiti", "KaiTi", serif;
}

.feedback-close {
  font-size: 48rpx;
  color: #999;
  line-height: 1;
}

.feedback-form {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.feedback-label {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
  display: block;
}

.type-options {
  display: flex;
  gap: 20rpx;
}

.type-option {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 10rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.3s ease;
}

.type-option.active {
  background: linear-gradient(135deg, #1A365D 0%, #2C5282 100%);
  color: #D4A017;
}

.feedback-textarea {
  position: relative;
}

.feedback-input {
  width: 100%;
  height: 200rpx;
  background: #f5f5f5;
  border-radius: 10rpx;
  padding: 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.feedback-count {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  font-size: 24rpx;
  color: #999;
}

.contact-input {
  width: 100%;
  height: 70rpx;
  background: #f5f5f5;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.feedback-submit {
  width: 100%;
  height: 80rpx;
  background: linear-gradient(135deg, #1A365D 0%, #2C5282 100%);
  color: #D4A017;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: bold;
  border: 2rpx solid #D4A017;
}
