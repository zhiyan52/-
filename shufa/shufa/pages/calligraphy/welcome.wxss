/* shufa/shufa/pages/calligraphy/welcome.wxss */
.welcome-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f0e6 0%, #e8e0d0 50%, #d4c8b8 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 40rpx;
}

.welcome-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.welcome-title-image {
  width: 450rpx;
  height: 300rpx;
  margin-bottom: 20rpx;
}

.category-container {
  display: flex;
  flex-direction: column;
  gap: 40rpx;
  width: 100%;
}

.category-card {
  position: relative;
  border-radius: 24rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  box-shadow: 0 8rpx 25rpx rgba(0, 0, 0, 0.15);
  transition: all 0.3s ease;
  overflow: hidden;
}

.category-card:active {
  transform: scale(0.98);
}

.card-bg-img {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  opacity: 0.35;
}

.card-overlay {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: linear-gradient(to bottom, rgba(44, 62, 80, 0.8) 0%, rgba(30, 41, 59, 0.9) 100%);
  border-radius: 24rpx;
  padding: 40rpx;
}

.category-card:nth-child(2) .card-overlay {
  background: linear-gradient(to bottom, rgba(139, 69, 19, 0.8) 0%, rgba(101, 67, 33, 0.9) 100%);
}

.category-icon {
  font-size: 80rpx;
  margin-bottom: 30rpx;
}

.category-name {
  font-size: 44rpx;
  font-weight: bold;
  color: white;
  display: block;
  margin-bottom: 15rpx;
}

.category-desc {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
}

.footer {
  margin-top: auto;
  padding: 40rpx 0;
}

.footer-text {
  font-size: 24rpx;
  color: #999;
}