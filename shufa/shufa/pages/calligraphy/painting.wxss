/* shufa/shufa/pages/calligraphy/painting.wxss */
.painting-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f0e6 0%, #e8e0d0 100%);
  padding-bottom: 30rpx;
}

.header {
  background: linear-gradient(90deg, #8b4513 0%, #a0522d 100%);
  padding: 60rpx 30rpx 40rpx;
  color: white;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 28rpx;
  opacity: 0.8;
}

.category-tabs {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  padding: 30rpx;
  background: rgba(255, 255, 255, 0.8);
  margin: 20rpx;
  border-radius: 15rpx;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  padding: 20rpx 30rpx;
  border-radius: 10rpx;
  transition: all 0.3s ease;
}

.tab-item.active {
  background: linear-gradient(90deg, #8b4513, #a0522d);
  color: white;
}

.tab-icon {
  font-size: 40rpx;
}

.tab-name {
  font-size: 26rpx;
  font-weight: bold;
}

.painting-list {
  padding: 0 20rpx;
}

.painting-card {
  background: white;
  border-radius: 15rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 15rpx rgba(0, 0, 0, 0.1);
}

.painting-image {
  width: 100%;
  height: 300rpx;
  overflow: hidden;
}

.painting-img {
  width: 100%;
  height: 100%;
}

.painting-info {
  padding: 25rpx;
}

.painting-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.painting-author {
  font-size: 24rpx;
  color: #8b4513;
  margin-bottom: 15rpx;
}

.painting-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.detail-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 1000;
}

.detail-content {
  width: 90%;
  max-height: 90vh;
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background: linear-gradient(90deg, #8b4513, #a0522d);
  color: white;
}

.detail-title {
  font-size: 36rpx;
  font-weight: bold;
}

.close-btn {
  font-size: 40rpx;
  opacity: 0.8;
  padding: 10rpx;
}

.detail-image {
  width: 100%;
  height: 400rpx;
  background: #f5f5f5;
}

.detail-img {
  width: 100%;
  height: 100%;
}

.detail-info {
  padding: 30rpx;
}

.detail-info .label {
  font-size: 26rpx;
  color: #8b4513;
  font-weight: bold;
}

.detail-info .value {
  font-size: 28rpx;
  color: #333;
}

.detail-author, .detail-dynasty {
  margin-bottom: 20rpx;
}

.detail-description {
  line-height: 1.8;
}

.detail-description .value {
  display: block;
  margin-top: 10rpx;
}
