/* shufa/shufa/pages/calligraphy/copybook.wxss */
.page-container {
  background: linear-gradient(180deg, #f8f4e9 0%, #ede8d0 100%);
  min-height: 100vh;
  font-family: "KaiTi", "STKaiti", "PingFang SC", sans-serif;
}

/* 顶部导航 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  position: sticky;
  top: 0;
  z-index: 100;
}

.header-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-btn {
  font-size: 36rpx;
  color: #333;
}

.header-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.header-right {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.more-btn {
  font-size: 36rpx;
  color: #333;
}

/* 书体分类 */
.category-section {
  margin: 20rpx 0;
  padding: 0 30rpx;
}

.category-scroll {
  white-space: nowrap;
}

.category-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  margin-right: 40rpx;
  padding: 20rpx;
  background: white;
  border-radius: 15rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  min-width: 120rpx;
}

.category-active {
  background: linear-gradient(135deg, #b22222, #cd853f);
  color: white;
}

.category-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.category-name {
  font-size: 24rpx;
  font-weight: bold;
}

/* 辅助线选择 */
.grid-section {
  margin: 20rpx 0;
  padding: 0 30rpx;
}

.grid-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
}

.grid-scroll {
  white-space: nowrap;
}

.grid-item {
  display: inline-block;
  padding: 15rpx 30rpx;
  background: white;
  border-radius: 25rpx;
  margin-right: 15rpx;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.1);
}

.grid-active {
  background: linear-gradient(90deg, #b22222, #cd853f);
  color: white;
}

.grid-name {
  font-size: 24rpx;
}

/* 碑帖列表 */
.copybook-section {
  margin: 30rpx 0;
  padding: 0 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  border-left: 8rpx solid #b22222;
  padding-left: 15rpx;
}

.copybook-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.copybook-item {
  background: white;
  border-radius: 15rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.copybook-image {
  width: 100%;
  height: 250rpx;
  border-radius: 15rpx 15rpx 0 0;
}

.copybook-info {
  padding: 20rpx;
}

.copybook-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.copybook-meta {
  display: flex;
  gap: 20rpx;
  margin-bottom: 10rpx;
  flex-wrap: wrap;
}

.copybook-author, .copybook-style, .copybook-dynasty {
  font-size: 20rpx;
  color: #666;
  background: #f5f5f5;
  padding: 5rpx 15rpx;
  border-radius: 15rpx;
}

.copybook-description {
  font-size: 22rpx;
  color: #666;
  line-height: 1.4;
}

/* 功能按钮 */
.action-section {
  margin: 30rpx 0;
  padding: 0 30rpx;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 25rpx 15rpx;
  background: white;
  border-radius: 15rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.action-icon {
  font-size: 40rpx;
  margin-bottom: 10rpx;
  color: #b22222;
}

.action-text {
  font-size: 20rpx;
  color: #666;
  text-align: center;
}

/* 底部Tab */
.tab-bar {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: white;
  border-top: 1rpx solid #e5e5e5;
  padding: 15rpx 0;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 99;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 5rpx;
  padding: 10rpx;
  color: #666;
}

.tab-item.tab-active {
  color: #b22222;
}

.tab-icon {
  font-size: 36rpx;
}

.tab-text {
  font-size: 20rpx;
}

.tab-create {
  background: linear-gradient(90deg, #b22222, #cd853f);
  color: white;
  border-radius: 50%;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(178, 34, 34, 0.3);
}

.tab-create .tab-icon {
  font-size: 48rpx;
  line-height: 1;
}

.tab-create .tab-text {
  font-size: 18rpx;
  margin-top: -5rpx;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .category-item {
    min-width: 100rpx;
    margin-right: 20rpx;
  }
  
  .copybook-image {
    height: 200rpx;
  }
  
  .action-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}
