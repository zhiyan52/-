/* shufa/shufa/pages/calligraphy/copybook.wxss */
.page-container {
  background: linear-gradient(180deg, #f8f4e9 0%, #ede8d0 100%);
  min-height: 100vh;
  font-family: "KaiTi", "STKaiti", "PingFang SC", sans-serif;
  padding-bottom: 130rpx;
}

/* 顶部导航 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 25rpx 30rpx;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 2rpx 15rpx rgba(0, 0, 0, 0.08);
  position: sticky;
  top: 0;
  z-index: 100;
  border-bottom: 2rpx solid #e0d8c0;
}

.header-left, .header-right {
  width: 80rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-btn, .more-btn {
  font-size: 36rpx;
  color: #8b4513;
  transition: all 0.3s ease;
}

.back-btn:hover, .more-btn:hover {
  transform: scale(1.1);
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #8b4513;
  letter-spacing: 10rpx;
  text-shadow: 1rpx 1rpx 2rpx rgba(139, 69, 19, 0.2);
}

/* 通用section样式 */
.section {
  margin: 30rpx 0;
  padding: 0 30rpx;
}

.section-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
  border-left: 6rpx solid #8b4513;
  font-weight: 500;
}

/* 书体分类 */
.category-section {
  margin: 30rpx 0;
  padding: 0 30rpx;
}

.category-scroll {
  white-space: nowrap;
  padding-bottom: 15rpx;
}

.category-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  margin-right: 25rpx;
  padding: 30rpx 25rpx;
  background: white;
  border-radius: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.08);
  min-width: 140rpx;
  transition: all 0.3s ease;
  border: 2rpx solid #f0e6d2;
}

.category-item:hover {
  transform: translateY(-5rpx);
  box-shadow: 0 8rpx 25rpx rgba(0, 0, 0, 0.12);
}

.category-item:active {
  transform: scale(0.95);
}

.category-active {
  background: linear-gradient(135deg, #8b4513, #cd853f);
  color: white;
  box-shadow: 0 8rpx 25rpx rgba(139, 69, 19, 0.35);
  border-color: #cd853f;
}

.category-icon {
  font-size: 56rpx;
  margin-bottom: 15rpx;
  transition: all 0.3s ease;
}

.category-active .category-icon {
  transform: scale(1.1);
}

.category-name {
  font-size: 28rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
  font-family: "STKaiti", "KaiTi", serif;
}

.category-desc {
  font-size: 20rpx;
  opacity: 0.8;
  font-family: "STKaiti", "KaiTi", serif;
}

/* 辅助线选择 */
.grid-section {
  margin: 30rpx 0;
  padding: 0 30rpx;
}

.grid-scroll {
  white-space: nowrap;
  padding-bottom: 10rpx;
}

.grid-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx 40rpx;
  background: white;
  border-radius: 35rpx;
  margin-right: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
  border: 2rpx solid #f0e6d2;
  min-width: 120rpx;
}

.grid-item:hover {
  transform: translateY(-3rpx);
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.1);
}

.grid-item:active {
  transform: scale(0.95);
}

.grid-active {
  background: linear-gradient(90deg, #8b4513, #cd853f);
  color: white;
  box-shadow: 0 6rpx 16rpx rgba(139, 69, 19, 0.3);
  border-color: #cd853f;
}

.grid-name {
  font-size: 26rpx;
  font-weight: 500;
  font-family: "STKaiti", "KaiTi", serif;
}

/* 当前选中信息 */
.info-bar {
  display: flex;
  justify-content: space-around;
  margin: 30rpx 30rpx;
  padding: 25rpx;
  background: white;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.08);
  border: 2rpx solid #f0e6d2;
}

.info-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.info-label {
  font-size: 26rpx;
  color: #666;
  font-family: "STKaiti", "KaiTi", serif;
}

.info-value {
  font-size: 26rpx;
  font-weight: bold;
  color: #8b4513;
  font-family: "STKaiti", "KaiTi", serif;
  background: #f8f4e9;
  padding: 6rpx 16rpx;
  border-radius: 15rpx;
  border: 1rpx solid #e0d8c0;
}

/* 碑帖列表 */
.copybook-section {
  margin: 40rpx 0;
  padding: 0 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 25rpx;
  padding-bottom: 15rpx;
  border-bottom: 2rpx solid #e0d8c0;
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #8b4513;
  border-left: 10rpx solid #8b4513;
  padding-left: 20rpx;
  font-family: "STKaiti", "KaiTi", serif;
}

.section-count {
  font-size: 24rpx;
  color: #999;
  background: #f8f4e9;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  border: 1rpx solid #e0d8c0;
}

.copybook-list {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.copybook-item {
  background: white;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
  border: 2rpx solid #f0e6d2;
}

.copybook-item:hover {
  transform: translateY(-5rpx);
  box-shadow: 0 8rpx 25rpx rgba(0, 0, 0, 0.12);
}

.copybook-item:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.copybook-cover {
  position: relative;
  width: 100%;
  height: 300rpx;
  overflow: hidden;
}

.copybook-image {
  width: 100%;
  height: 100%;
  border-radius: 24rpx 24rpx 0 0;
  transition: transform 0.5s ease;
}

.copybook-item:hover .copybook-image {
  transform: scale(1.05);
}

.difficulty-tag {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  padding: 10rpx 25rpx;
  border-radius: 25rpx;
  font-size: 22rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.2);
  transition: all 0.3s ease;
}

.copybook-item:hover .difficulty-tag {
  transform: scale(1.05);
}

.difficulty-medium {
  background: rgba(76, 175, 80, 0.95);
  color: white;
}

.difficulty-high {
  background: rgba(255, 152, 0, 0.95);
  color: white;
}

.difficulty-extreme {
  background: rgba(244, 67, 54, 0.95);
  color: white;
}

.copybook-info {
  padding: 30rpx;
}

.copybook-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2c2c2c;
  margin-bottom: 15rpx;
  font-family: "STKaiti", "KaiTi", serif;
  line-height: 1.3;
}

.copybook-meta {
  display: flex;
  gap: 15rpx;
  margin-bottom: 15rpx;
  flex-wrap: wrap;
}

.copybook-author, .copybook-dynasty {
  font-size: 24rpx;
  color: #666;
  background: #f8f4e9;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  border: 1rpx solid #e0d8c0;
  font-family: "STKaiti", "KaiTi", serif;
}

.copybook-description {
  font-size: 26rpx;
  color: #777;
  line-height: 1.6;
  font-family: "STKaiti", "KaiTi", serif;
}

/* 功能按钮 */
.action-section {
  margin: 40rpx 0;
  padding: 0 30rpx;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 25rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 35rpx 20rpx;
  background: white;
  border-radius: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
  border: 2rpx solid #f0e6d2;
  min-height: 180rpx;
  justify-content: center;
}

.action-item:hover {
  transform: translateY(-5rpx);
  box-shadow: 0 8rpx 25rpx rgba(0, 0, 0, 0.12);
  border-color: #e0d8c0;
}

.action-item:active {
  transform: scale(0.95);
}

.action-icon {
  font-size: 52rpx;
  margin-bottom: 15rpx;
  color: #8b4513;
  transition: all 0.3s ease;
}

.action-item:hover .action-icon {
  transform: scale(1.1);
}

.action-text {
  font-size: 24rpx;
  color: #555;
  text-align: center;
  font-family: "STKaiti", "KaiTi", serif;
  font-weight: 500;
}

/* 底部Tab */
.tab-bar {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: white;
  border-top: 2rpx solid #e0d8c0;
  padding: 20rpx 0;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 99;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx;
  color: #999;
  transition: all 0.3s ease;
  min-width: 100rpx;
}

.tab-item:hover {
  transform: translateY(-3rpx);
}

.tab-item.tab-active {
  color: #8b4513;
}

.tab-icon {
  font-size: 44rpx;
  transition: all 0.3s ease;
}

.tab-item.tab-active .tab-icon {
  transform: scale(1.1);
}

.tab-text {
  font-size: 24rpx;
  font-family: "STKaiti", "KaiTi", serif;
}

.tab-create {
  background: linear-gradient(135deg, #8b4513, #cd853f);
  color: white;
  border-radius: 50%;
  width: 100rpx;
  height: 100rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 25rpx rgba(139, 69, 19, 0.45);
  transition: all 0.3s ease;
  border: 3rpx solid rgba(255, 255, 255, 0.3);
}

.tab-create:hover {
  transform: scale(1.05) translateY(-5rpx);
  box-shadow: 0 10rpx 30rpx rgba(139, 69, 19, 0.5);
}

.tab-create .tab-icon {
  font-size: 48rpx;
  line-height: 1;
  color: white;
}

.tab-create .tab-text {
  font-size: 20rpx;
  margin-top: -3rpx;
  color: white;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .header-title {
    font-size: 32rpx;
    letter-spacing: 8rpx;
  }
  
  .category-item {
    min-width: 120rpx;
    margin-right: 15rpx;
    padding: 25rpx 20rpx;
  }
  
  .category-icon {
    font-size: 48rpx;
  }
  
  .category-name {
    font-size: 26rpx;
  }
  
  .grid-item {
    padding: 18rpx 35rpx;
    min-width: 100rpx;
  }
  
  .grid-name {
    font-size: 24rpx;
  }
  
  .copybook-cover {
    height: 260rpx;
  }
  
  .copybook-info {
    padding: 25rpx;
  }
  
  .copybook-title {
    font-size: 30rpx;
  }
  
  .action-grid {
    gap: 20rpx;
  }
  
  .action-item {
    padding: 30rpx 15rpx;
    min-height: 160rpx;
  }
  
  .action-icon {
    font-size: 48rpx;
  }
  
  .action-text {
    font-size: 22rpx;
  }
  
  .tab-create {
    width: 90rpx;
    height: 90rpx;
    margin-bottom: 25rpx;
  }
  
  .tab-create .tab-icon {
    font-size: 44rpx;
  }
}

/* 滚动条样式 */
::-webkit-scrollbar {
  height: 6rpx;
}

::-webkit-scrollbar-track {
  background: #f1f1f1;
  border-radius: 3rpx;
}

::-webkit-scrollbar-thumb {
  background: #8b4513;
  border-radius: 3rpx;
}

::-webkit-scrollbar-thumb:hover {
  background: #cd853f;
}
