/* shufa/shufa/pages/calligraphy/copybook.wxss */
.page-container {
  background: linear-gradient(180deg, #f5f0e6 0%, #e8dfc4 100%);
  min-height: 100vh;
  font-family: "KaiTi", "STKaiti", "PingFang SC", sans-serif;
  padding-bottom: 120rpx;
}

/* 顶部导航 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 2rpx 15rpx rgba(0, 0, 0, 0.08);
  position: sticky;
  top: 0;
  z-index: 100;
}

.header-left, .header-right {
  width: 80rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-btn, .more-btn {
  font-size: 36rpx;
  color: #333;
}

.header-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #2c2c2c;
  letter-spacing: 8rpx;
}

/* 书体分类 */
.category-section {
  margin: 20rpx 0;
  padding: 0 30rpx;
}

.section-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 15rpx;
  padding-left: 10rpx;
}

.category-scroll {
  white-space: nowrap;
}

.category-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  margin-right: 25rpx;
  padding: 25rpx 20rpx;
  background: white;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  min-width: 130rpx;
  transition: all 0.3s ease;
}

.category-item:active {
  transform: scale(0.95);
}

.category-active {
  background: linear-gradient(135deg, #8b4513, #cd853f);
  color: white;
  box-shadow: 0 6rpx 20rpx rgba(139, 69, 19, 0.3);
}

.category-icon {
  font-size: 52rpx;
  margin-bottom: 12rpx;
}

.category-name {
  font-size: 26rpx;
  font-weight: bold;
  margin-bottom: 6rpx;
}

.category-desc {
  font-size: 18rpx;
  opacity: 0.7;
}

/* 辅助线选择 */
.grid-section {
  margin: 20rpx 0;
  padding: 0 30rpx;
}

.grid-scroll {
  white-space: nowrap;
}

.grid-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 18rpx 35rpx;
  background: white;
  border-radius: 30rpx;
  margin-right: 18rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
}

.grid-item:active {
  transform: scale(0.95);
}

.grid-active {
  background: linear-gradient(90deg, #8b4513, #cd853f);
  color: white;
  box-shadow: 0 4rpx 12rpx rgba(139, 69, 19, 0.25);
}

.grid-name {
  font-size: 24rpx;
}

/* 当前选中信息 */
.info-bar {
  display: flex;
  justify-content: space-around;
  margin: 20rpx 30rpx;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.8);
  border-radius: 15rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.info-item {
  display: flex;
  align-items: center;
}

.info-label {
  font-size: 24rpx;
  color: #666;
}

.info-value {
  font-size: 24rpx;
  font-weight: bold;
  color: #8b4513;
}

/* 碑帖列表 */
.copybook-section {
  margin: 30rpx 0;
  padding: 0 30rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2c2c2c;
  border-left: 8rpx solid #8b4513;
  padding-left: 15rpx;
}

.section-count {
  font-size: 24rpx;
  color: #999;
}

.copybook-list {
  display: flex;
  flex-direction: column;
  gap: 25rpx;
}

.copybook-item {
  background: white;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
}

.copybook-item:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.copybook-cover {
  position: relative;
  width: 100%;
  height: 280rpx;
}

.copybook-image {
  width: 100%;
  height: 100%;
  border-radius: 20rpx 20rpx 0 0;
}

.difficulty-tag {
  position: absolute;
  top: 15rpx;
  right: 15rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  font-weight: bold;
}

.difficulty-medium {
  background: rgba(76, 175, 80, 0.9);
  color: white;
}

.difficulty-high {
  background: rgba(255, 152, 0, 0.9);
  color: white;
}

.difficulty-extreme {
  background: rgba(244, 67, 54, 0.9);
  color: white;
}

.copybook-info {
  padding: 25rpx;
}

.copybook-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #2c2c2c;
  margin-bottom: 12rpx;
}

.copybook-meta {
  display: flex;
  gap: 20rpx;
  margin-bottom: 12rpx;
}

.copybook-author, .copybook-dynasty {
  font-size: 22rpx;
  color: #666;
  background: #f5f5f5;
  padding: 6rpx 18rpx;
  border-radius: 15rpx;
}

.copybook-description {
  font-size: 24rpx;
  color: #888;
  line-height: 1.5;
}

/* 功能按钮 */
.action-section {
  margin: 30rpx 0;
  padding: 0 30rpx;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 15rpx;
  background: white;
  border-radius: 18rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
  transition: all 0.3s ease;
}

.action-item:active {
  transform: scale(0.95);
}

.action-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.action-text {
  font-size: 22rpx;
  color: #555;
  text-align: center;
}

/* 底部Tab */
.tab-bar {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: white;
  border-top: 1rpx solid #e8e8e8;
  padding: 15rpx 0;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 99;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 5rpx;
  padding: 10rpx;
  color: #999;
  transition: all 0.3s ease;
}

.tab-item.tab-active {
  color: #8b4513;
}

.tab-icon {
  font-size: 40rpx;
}

.tab-text {
  font-size: 22rpx;
}

.tab-create {
  background: linear-gradient(135deg, #8b4513, #cd853f);
  color: white;
  border-radius: 50%;
  width: 90rpx;
  height: 90rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 25rpx;
  box-shadow: 0 6rpx 20rpx rgba(139, 69, 19, 0.4);
}

.tab-create .tab-icon {
  font-size: 44rpx;
  line-height: 1;
}

.tab-create .tab-text {
  font-size: 18rpx;
  margin-top: -3rpx;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .category-item {
    min-width: 110rpx;
    margin-right: 15rpx;
    padding: 20rpx 15rpx;
  }
  
  .category-icon {
    font-size: 44rpx;
  }
  
  .copybook-cover {
    height: 240rpx;
  }
  
  .action-grid {
    gap: 15rpx;
  }
  
  .action-icon {
    font-size: 40rpx;
  }
}
