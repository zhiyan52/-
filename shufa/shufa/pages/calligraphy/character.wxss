/* shufa/shufa/pages/calligraphy/character.wxss */
.page-container {
  background: linear-gradient(180deg, #f8f4e9 0%, #ede8d0 100%);
  min-height: 100vh;
  font-family: "KaiTi", "STKaiti", "PingFang SC", sans-serif;
}

/* 顶部导航 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  position: sticky;
  top: 0;
  z-index: 100;
}

.header-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-btn {
  font-size: 36rpx;
  color: #333;
}

.header-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.header-right {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.info-btn {
  font-size: 32rpx;
  color: #666;
}

/* 单字信息 */
.character-info {
  margin: 30rpx;
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.character-main {
  display: flex;
  align-items: center;
  gap: 40rpx;
}

.character-display {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.character-char {
  font-size: 120rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  font-family: "KaiTi", "STKaiti", serif;
}

.character-meta {
  display: flex;
  gap: 20rpx;
  flex-wrap: wrap;
  justify-content: center;
}

.character-style, .character-author, .character-copybook {
  font-size: 24rpx;
  color: #666;
  background: #f5f5f5;
  padding: 5rpx 15rpx;
  border-radius: 15rpx;
}

.character-details {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.detail-item {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
}

.detail-label {
  font-size: 24rpx;
  font-weight: bold;
  color: #333;
  min-width: 80rpx;
}

.detail-value {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

/* 通用区块样式 */
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  border-left: 8rpx solid #b22222;
  padding-left: 15rpx;
}

/* 笔画顺序 */
.stroke-section {
  margin: 30rpx 0;
  padding: 0 30rpx;
}

.stroke-display {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.stroke-canvas {
  background: white;
  border-radius: 15rpx;
  padding: 40rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  display: flex;
  justify-content: center;
}

.stroke-grid {
  width: 300rpx;
  height: 300rpx;
  position: relative;
  border: 2rpx solid #333;
}

.stroke-grid.mizi {
  background: 
    linear-gradient(to right, transparent 49.5%, #ccc 49.5%, #ccc 50.5%, transparent 50.5%),
    linear-gradient(to bottom, transparent 49.5%, #ccc 49.5%, #ccc 50.5%, transparent 50.5%),
    linear-gradient(to top right, transparent 49.5%, #ccc 49.5%, #ccc 50.5%, transparent 50.5%),
    linear-gradient(to top left, transparent 49.5%, #ccc 49.5%, #ccc 50.5%, transparent 50.5%);
  background-size: 100% 100%;
}

.stroke-grid.tianzi {
  background: 
    linear-gradient(to right, transparent 49.5%, #ccc 49.5%, #ccc 50.5%, transparent 50.5%),
    linear-gradient(to bottom, transparent 49.5%, #ccc 49.5%, #ccc 50.5%, transparent 50.5%);
  background-size: 100% 100%;
}

.character-stroke {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-size: 180rpx;
  font-weight: bold;
  color: #333;
  font-family: "KaiTi", "STKaiti", serif;
}

.stroke-order {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
}

.stroke-line {
  position: absolute;
  background: #b22222;
  height: 4rpx;
  border-radius: 2rpx;
  transition: all 0.5s ease;
  opacity: 0;
}

.stroke-line.stroke-active {
  opacity: 1;
}

.stroke-controls {
  display: flex;
  justify-content: center;
}

.control-btn {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 15rpx 30rpx;
  background: linear-gradient(90deg, #b22222, #cd853f);
  color: white;
  border-radius: 25rpx;
  font-size: 24rpx;
  font-weight: bold;
  box-shadow: 0 2rpx 8rpx rgba(178, 34, 34, 0.3);
}

.control-icon {
  font-size: 28rpx;
}

/* 辅助线选择 */
.grid-section {
  margin: 30rpx 0;
  padding: 0 30rpx;
}

.grid-scroll {
  white-space: nowrap;
}

.grid-item {
  display: inline-block;
  padding: 15rpx 30rpx;
  background: white;
  border-radius: 25rpx;
  margin-right: 15rpx;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.1);
  font-size: 24rpx;
  color: #333;
}

.grid-item.grid-active {
  background: linear-gradient(90deg, #b22222, #cd853f);
  color: white;
}

/* 临摹区域 */
.practice-section {
  margin: 30rpx 0;
  padding: 0 30rpx;
}

.practice-canvas {
  background: white;
  border-radius: 15rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  margin-bottom: 20rpx;
}

.practice-grid {
  width: 100%;
  height: 400rpx;
  position: relative;
  border: 2rpx solid #333;
}

.practice-grid.mizi {
  background: 
    linear-gradient(to right, transparent 49.5%, #ccc 49.5%, #ccc 50.5%, transparent 50.5%),
    linear-gradient(to bottom, transparent 49.5%, #ccc 49.5%, #ccc 50.5%, transparent 50.5%),
    linear-gradient(to top right, transparent 49.5%, #ccc 49.5%, #ccc 50.5%, transparent 50.5%),
    linear-gradient(to top left, transparent 49.5%, #ccc 49.5%, #ccc 50.5%, transparent 50.5%);
  background-size: 100% 100%;
}

.practice-grid.tianzi {
  background: 
    linear-gradient(to right, transparent 49.5%, #ccc 49.5%, #ccc 50.5%, transparent 50.5%),
    linear-gradient(to bottom, transparent 49.5%, #ccc 49.5%, #ccc 50.5%, transparent 50.5%);
  background-size: 100% 100%;
}

.drawing-area {
  width: 100%;
  height: 100%;
  position: relative;
}

.drawing-canvas {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.practice-controls {
  display: flex;
  gap: 20rpx;
  justify-content: center;
}

/* 字符导航 */
.navigation-section {
  margin: 30rpx;
  display: flex;
  justify-content: space-between;
}

.nav-btn {
  display: flex;
  align-items: center;
  gap: 10rpx;
  padding: 20rpx 40rpx;
  background: white;
  border-radius: 30rpx;
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.nav-icon {
  font-size: 32rpx;
}

/* 评测结果弹窗 */
.evaluation-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 200;
}

.evaluation-content {
  background: white;
  border-radius: 20rpx;
  width: 80%;
  max-width: 600rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.3);
}

.evaluation-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 30rpx;
}

.evaluation-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.evaluation-close {
  font-size: 36rpx;
  color: #999;
  cursor: pointer;
}

.evaluation-score {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-bottom: 30rpx;
}

.score-number {
  font-size: 80rpx;
  font-weight: bold;
  color: #b22222;
}

.score-label {
  font-size: 32rpx;
  color: #666;
  margin-left: 10rpx;
}

.evaluation-suggestions {
  margin-bottom: 30rpx;
}

.suggestion-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
}

.suggestion-item {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
  margin-bottom: 10rpx;
}

.evaluation-actions {
  display: flex;
  gap: 20rpx;
}

.eval-btn {
  flex: 1;
  padding: 20rpx;
  border-radius: 10rpx;
  font-size: 24rpx;
  font-weight: bold;
  text-align: center;
  background: linear-gradient(90deg, #b22222, #cd853f);
  color: white;
}

/* 底部Tab */
.tab-bar {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: white;
  border-top: 1rpx solid #e5e5e5;
  padding: 15rpx 0;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 99;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 5rpx;
  padding: 10rpx;
  color: #666;
}

.tab-item.tab-active {
  color: #b22222;
}

.tab-icon {
  font-size: 36rpx;
}

.tab-text {
  font-size: 20rpx;
}

.tab-create {
  background: linear-gradient(90deg, #b22222, #cd853f);
  color: white;
  border-radius: 50%;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(178, 34, 34, 0.3);
}

.tab-create .tab-icon {
  font-size: 48rpx;
  line-height: 1;
}

.tab-create .tab-text {
  font-size: 18rpx;
  margin-top: -5rpx;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .character-main {
    flex-direction: column;
    text-align: center;
  }
  
  .practice-grid {
    height: 300rpx;
  }
  
  .stroke-grid {
    width: 250rpx;
    height: 250rpx;
  }
  
  .character-char {
    font-size: 100rpx;
  }
}
