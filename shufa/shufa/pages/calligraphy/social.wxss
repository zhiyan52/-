/* shufa/shufa/pages/calligraphy/social.wxss */
.page-container {
  background: linear-gradient(180deg, #f8f4e9 0%, #ede8d0 100%);
  min-height: 100vh;
  font-family: "KaiTi", "STKaiti", "PingFang SC", sans-serif;
}

/* 顶部导航 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  position: sticky;
  top: 0;
  z-index: 100;
}

.header-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-btn {
  font-size: 36rpx;
  color: #333;
}

.header-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.header-right {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.publish-btn {
  font-size: 28rpx;
  color: #b22222;
  font-weight: bold;
  padding: 10rpx 15rpx;
  border-radius: 15rpx;
  background: #f5f5f5;
}

/* 每日一题 */
.daily-topic {
  margin: 30rpx;
  background: white;
  border-radius: 20rpx;
  padding: 25rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.topic-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.topic-icon {
  font-size: 40rpx;
  margin-right: 15rpx;
}

.topic-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.topic-content {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.topic-image {
  width: 100%;
  height: 200rpx;
  border-radius: 15rpx;
  object-fit: cover;
}

.topic-main-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.4;
}

.topic-description {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
}

.topic-stats {
  display: flex;
  gap: 30rpx;
  font-size: 20rpx;
  color: #999;
  margin: 10rpx 0;
}

.topic-action {
  display: flex;
  justify-content: center;
  margin-top: 10rpx;
}

.join-btn {
  background: linear-gradient(90deg, #b22222, #cd853f);
  color: white;
  padding: 20rpx 60rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 12rpx rgba(178, 34, 34, 0.3);
}

/* 雅集动态 */
.social-section {
  margin: 30rpx 0;
  padding: 0 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  border-left: 8rpx solid #b22222;
  padding-left: 15rpx;
}

.social-posts {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.social-post {
  background: white;
  border-radius: 20rpx;
  padding: 25rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.post-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  cursor: pointer;
}

.user-avatar {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  margin-right: 20rpx;
  object-fit: cover;
}

.user-name {
  font-size: 26rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 5rpx;
}

.post-time {
  font-size: 20rpx;
  color: #999;
}

.post-content {
  font-size: 26rpx;
  color: #333;
  line-height: 1.5;
  margin-bottom: 20rpx;
}

.post-image {
  width: 100%;
  height: 400rpx;
  border-radius: 15rpx;
  object-fit: cover;
  margin-bottom: 20rpx;
}

.post-actions {
  display: flex;
  gap: 40rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #e5e5e5;
}

.action-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 24rpx;
  color: #666;
  cursor: pointer;
}

.action-icon {
  font-size: 32rpx;
}

/* 评论弹窗 */
.comments-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  z-index: 200;
}

.comments-content {
  background: white;
  border-radius: 20rpx 20rpx 0 0;
  width: 100%;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.3);
}

.comments-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 25rpx;
  border-bottom: 1rpx solid #e5e5e5;
}

.comments-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.comments-close {
  font-size: 36rpx;
  color: #999;
  cursor: pointer;
}

.comments-list {
  flex: 1;
  padding: 25rpx;
  overflow-y: auto;
}

.comment-item {
  margin-bottom: 30rpx;
}

.comment-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 10rpx;
}

.comment-user {
  font-size: 24rpx;
  font-weight: bold;
  color: #333;
}

.comment-time {
  font-size: 20rpx;
  color: #999;
}

.comment-content {
  font-size: 24rpx;
  color: #333;
  line-height: 1.5;
  background: #f5f5f5;
  padding: 15rpx;
  border-radius: 10rpx;
}

.comments-input {
  display: flex;
  align-items: center;
  padding: 20rpx 25rpx;
  border-top: 1rpx solid #e5e5e5;
  background: white;
}

.comment-input {
  flex: 1;
  padding: 15rpx 20rpx;
  border: 1rpx solid #e5e5e5;
  border-radius: 25rpx;
  font-size: 24rpx;
  margin-right: 15rpx;
}

.comment-submit {
  padding: 15rpx 30rpx;
  background: linear-gradient(90deg, #b22222, #cd853f);
  color: white;
  border-radius: 25rpx;
  font-size: 24rpx;
  font-weight: bold;
}

/* 底部Tab */
.tab-bar {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: white;
  border-top: 1rpx solid #e5e5e5;
  padding: 15rpx 0;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 99;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 5rpx;
  padding: 10rpx;
  color: #666;
}

.tab-item.tab-active {
  color: #b22222;
}

.tab-icon {
  font-size: 36rpx;
}

.tab-text {
  font-size: 20rpx;
}

.tab-create {
  background: linear-gradient(90deg, #b22222, #cd853f);
  color: white;
  border-radius: 50%;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(178, 34, 34, 0.3);
}

.tab-create .tab-icon {
  font-size: 48rpx;
  line-height: 1;
}

.tab-create .tab-text {
  font-size: 18rpx;
  margin-top: -5rpx;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .post-image {
    height: 300rpx;
  }
  
  .topic-image {
    height: 150rpx;
  }
}
