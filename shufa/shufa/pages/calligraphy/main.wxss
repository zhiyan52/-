/* shufa/shufa/pages/calligraphy/main.wxss */
.main-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f0e6 0%, #e8e0d0 100%);
  padding-bottom: 30rpx;
}

.banner {
  background: linear-gradient(135deg, #8b4513 0%, #a0522d 50%, #cd853f 100%);
  padding: 80rpx 40rpx 60rpx;
  text-align: center;
}

.banner-title {
  font-size: 56rpx;
  font-weight: bold;
  color: white;
  display: block;
  margin-bottom: 15rpx;
  text-shadow: 2rpx 2rpx 4rpx rgba(0, 0, 0, 0.3);
}

.banner-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.section {
  padding: 30rpx 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
  border-left: 6rpx solid #8b4513;
}

.category-grid {
  display: flex;
  gap: 20rpx;
}

.category-card {
  flex: 1;
  background: white;
  border-radius: 20rpx;
  padding: 40rpx 20rpx;
  text-align: center;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.1);
  transition: all 0.3s ease;
}

.category-card.calligraphy {
  background: linear-gradient(135deg, #2c3e50 0%, #34495e 100%);
}

.category-card.painting {
  background: linear-gradient(135deg, #8b4513 0%, #a0522d 100%);
}

.category-icon {
  font-size: 60rpx;
  margin-bottom: 20rpx;
}

.category-name {
  font-size: 36rpx;
  font-weight: bold;
  color: white;
  display: block;
  margin-bottom: 10rpx;
}

.category-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.featured-list {
  display: flex;
  gap: 20rpx;
}

.featured-item {
  flex: 1;
  height: 280rpx;
  border-radius: 15rpx;
  overflow: hidden;
  position: relative;
}

.featured-image {
  width: 100%;
  height: 100%;
}

.featured-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.7));
  padding: 30rpx 20rpx 20rpx;
}

.featured-title {
  font-size: 28rpx;
  font-weight: bold;
  color: white;
  display: block;
  margin-bottom: 8rpx;
}

.featured-author {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
}

.quick-links {
  display: flex;
  justify-content: space-between;
}

.quick-link {
  flex: 1;
  background: white;
  border-radius: 15rpx;
  padding: 30rpx 20rpx;
  text-align: center;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.08);
  margin-right: 15rpx;
}

.quick-link:last-child {
  margin-right: 0;
}

.quick-icon {
  font-size: 48rpx;
  margin-bottom: 15rpx;
}

.quick-name {
  font-size: 26rpx;
  color: #333;
  font-weight: bold;
}
