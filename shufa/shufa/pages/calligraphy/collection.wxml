<!-- shufa/shufa/pages/calligraphy/collection.wxml -->
<view class="page-container">
  <!-- 顶部导航 -->
  <view class="header">
    <view class="header-left">
      <view class="back-btn" bindtap="goBack">←</view>
    </view>
    <view class="header-title">墨宝阁</view>
    <view class="header-right">
      <view class="settings-btn" bindtap="editSettings">⚙️</view>
    </view>
  </view>

  <!-- 学习统计 -->
  <view class="stats-section">
    <view class="stats-header">
      <view class="stats-title">学习档案</view>
      <view class="stats-subtitle">我的书法学习记录</view>
    </view>
    <view class="stats-grid">
      <view class="stats-item">
        <view class="stats-value">{{learningStats.totalDays}}</view>
        <view class="stats-label">总学习天数</view>
      </view>
      <view class="stats-item">
        <view class="stats-value">{{learningStats.continuousDays}}</view>
        <view class="stats-label">连续打卡</view>
      </view>
      <view class="stats-item">
        <view class="stats-value">{{learningStats.totalCopybooks}}</view>
        <view class="stats-label">临帖总数</view>
      </view>
      <view class="stats-item">
        <view class="stats-value">{{learningStats.totalCreations}}</view>
        <view class="stats-label">创作作品</view>
      </view>
    </view>
  </view>

  <!-- 学习进度 -->
  <view class="progress-section">
    <view class="section-title">学习进度</view>
    <view class="progress-chart">
      <view class="progress-item" wx:for="{{progressChart}}" wx:key="month">
        <view class="progress-month">{{item.month}}</view>
        <view class="progress-bar">
          <view class="progress-fill" style="height: {{(item.days/31)*100}}%"></view>
        </view>
        <view class="progress-days">{{item.days}}天</view>
      </view>
    </view>
  </view>

  <!-- 我的书架 -->
  <view class="bookshelf-section">
    <view class="section-title">我的书架</view>
    <view class="bookshelf-list">
      <view class="bookshelf-item" wx:for="{{myCopybooks}}" wx:key="id" bindtap="goToCopybookDetail" data-id="{{item.id}}">
        <image class="bookshelf-image" src="{{item.image}}" mode="aspectFill"></image>
        <view class="bookshelf-info">
          <view class="bookshelf-title">{{item.title}}</view>
          <view class="bookshelf-author">{{item.author}}</view>
          <view class="bookshelf-time">最近练习：{{item.lastPractice}}</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 我的创作 -->
  <view class="creations-section">
    <view class="section-title">我的创作</view>
    <view class="creations-grid">
      <view class="creation-item" wx:for="{{myCreations}}" wx:key="id" bindtap="goToCreationDetail" data-id="{{item.id}}">
        <image class="creation-image" src="{{item.image}}" mode="aspectFill"></image>
        <view class="creation-info">
          <view class="creation-title">{{item.title}}</view>
          <view class="creation-style">{{item.style}}</view>
          <view class="creation-time">{{item.createTime}}</view>
        </view>
      </view>
    </view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-section">
    <view class="action-grid">
      <view class="action-btn" bindtap="exportData">
        <view class="action-icon">📤</view>
        <view class="action-text">导出数据</view>
      </view>
      <view class="action-btn" bindtap="editSettings">
        <view class="action-icon">⏰</view>
        <view class="action-text">练字提醒</view>
      </view>
      <view class="action-btn">
        <view class="action-icon">🔄</view>
        <view class="action-text">云端同步</view>
      </view>
      <view class="action-btn">
        <view class="action-icon">🏆</view>
        <view class="action-text">成就徽章</view>
      </view>
    </view>
  </view>

  <!-- 底部Tab -->
  <view class="tab-bar">
    <view class="tab-item">
      <text class="tab-icon">🏠</text>
      <text class="tab-text">首页</text>
    </view>
    <view class="tab-item">
      <text class="tab-icon">🔍</text>
      <text class="tab-text">发现</text>
    </view>
    <view class="tab-item tab-create">
      <text class="tab-icon">+</text>
      <text class="tab-text">创作</text>
    </view>
    <view class="tab-item">
      <text class="tab-icon">📚</text>
      <text class="tab-text">雅集</text>
    </view>
    <view class="tab-item tab-active">
      <text class="tab-icon">👤</text>
      <text class="tab-text">我的</text>
    </view>
  </view>
</view>
