/* shufa/shufa/pages/calligraphy/collection.wxss */
.page-container {
  background: linear-gradient(180deg, #f8f4e9 0%, #ede8d0 100%);
  min-height: 100vh;
  font-family: "KaiTi", "STKaiti", "PingFang SC", sans-serif;
}

/* 顶部导航 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 30rpx;
  background: rgba(255, 255, 255, 0.95);
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  position: sticky;
  top: 0;
  z-index: 100;
}

.header-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-btn {
  font-size: 36rpx;
  color: #333;
}

.header-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.header-right {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.settings-btn {
  font-size: 32rpx;
  color: #666;
}

/* 学习统计 */
.stats-section {
  margin: 30rpx;
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.stats-header {
  margin-bottom: 30rpx;
}

.stats-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.stats-subtitle {
  font-size: 24rpx;
  color: #666;
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 15rpx;
}

.stats-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #b22222;
  margin-bottom: 10rpx;
}

.stats-label {
  font-size: 20rpx;
  color: #666;
  text-align: center;
}

/* 通用区块样式 */
.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  border-left: 8rpx solid #b22222;
  padding-left: 15rpx;
}

/* 学习进度 */
.progress-section {
  margin: 30rpx 0;
  padding: 0 30rpx;
}

.progress-chart {
  display: flex;
  gap: 20rpx;
  padding: 20rpx;
  background: white;
  border-radius: 15rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.progress-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.progress-month {
  font-size: 20rpx;
  font-weight: bold;
  color: #333;
}

.progress-bar {
  width: 40rpx;
  height: 150rpx;
  background: #f5f5f5;
  border-radius: 20rpx;
  overflow: hidden;
  position: relative;
}

.progress-fill {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: linear-gradient(180deg, #b22222, #cd853f);
  border-radius: 20rpx;
  transition: height 0.5s ease;
}

.progress-days {
  font-size: 18rpx;
  color: #666;
}

/* 我的书架 */
.bookshelf-section {
  margin: 30rpx 0;
  padding: 0 30rpx;
}

.bookshelf-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.bookshelf-item {
  display: flex;
  background: white;
  border-radius: 15rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.bookshelf-image {
  width: 120rpx;
  height: 120rpx;
  object-fit: cover;
}

.bookshelf-info {
  flex: 1;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 10rpx;
}

.bookshelf-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.bookshelf-author {
  font-size: 24rpx;
  color: #666;
}

.bookshelf-time {
  font-size: 20rpx;
  color: #999;
}

/* 我的创作 */
.creations-section {
  margin: 30rpx 0;
  padding: 0 30rpx;
}

.creations-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.creation-item {
  background: white;
  border-radius: 15rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.creation-image {
  width: 100%;
  height: 200rpx;
  object-fit: cover;
  border-radius: 15rpx 15rpx 0 0;
}

.creation-info {
  padding: 15rpx;
  display: flex;
  flex-direction: column;
  gap: 5rpx;
}

.creation-title {
  font-size: 24rpx;
  font-weight: bold;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.creation-style {
  font-size: 20rpx;
  color: #666;
}

.creation-time {
  font-size: 18rpx;
  color: #999;
}

/* 操作按钮 */
.action-section {
  margin: 30rpx;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 20rpx;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 25rpx 15rpx;
  background: white;
  border-radius: 15rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.action-icon {
  font-size: 40rpx;
  margin-bottom: 10rpx;
  color: #b22222;
}

.action-text {
  font-size: 20rpx;
  color: #666;
  text-align: center;
}

/* 底部Tab */
.tab-bar {
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: white;
  border-top: 1rpx solid #e5e5e5;
  padding: 15rpx 0;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 99;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 5rpx;
  padding: 10rpx;
  color: #666;
}

.tab-item.tab-active {
  color: #b22222;
}

.tab-icon {
  font-size: 36rpx;
}

.tab-text {
  font-size: 20rpx;
}

.tab-create {
  background: linear-gradient(90deg, #b22222, #cd853f);
  color: white;
  border-radius: 50%;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(178, 34, 34, 0.3);
}

.tab-create .tab-icon {
  font-size: 48rpx;
  line-height: 1;
}

.tab-create .tab-text {
  font-size: 18rpx;
  margin-top: -5rpx;
}

/* 响应式设计 */
@media (max-width: 375px) {
  .stats-grid {
    grid-template-columns: repeat(2, 1fr);
  }
  
  .creations-grid {
    grid-template-columns: 1fr;
  }
  
  .action-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}
