<!-- 书画文化问答页面 -->
<view class="ai-qa-container">
  <view class="header">
    <text class="title">书画文化问答</text>
    <text class="subtitle">AI为你解答书画艺术疑问</text>
  </view>
  
  <view class="qa-section">
    <text class="section-title">常见问题</text>
    <view class="faq-list">
      <view class="faq-item" bindtap="selectFaq" data-question="王羲之的书法风格是什么？">
        <text class="faq-question">王羲之的书法风格是什么？</text>
      </view>
      <view class="faq-item" bindtap="selectFaq" data-question="国画的基本技法有哪些？">
        <text class="faq-question">国画的基本技法有哪些？</text>
      </view>
      <view class="faq-item" bindtap="selectFaq" data-question="《清明上河图》的作者是谁？">
        <text class="faq-question">《清明上河图》的作者是谁？</text>
      </view>
      <view class="faq-item" bindtap="selectFaq" data-question="书法的五种书体是什么？">
        <text class="faq-question">书法的五种书体是什么？</text>
      </view>
    </view>
  </view>
  
  <view class="input-section">
    <text class="section-title">提出问题</text>
    <view class="input-container">
      <input 
        class="input" 
        placeholder="输入您的问题..."
        placeholder-class="input-placeholder"
        bindinput="bindInput"
        value="{{inputValue}}"
      />
      <button class="send-button" bindtap="sendMessage">
        <text>发送</text>
      </button>
    </view>
  </view>
  
  <view class="response-section" wx:if="{{showResponse}}">
    <text class="response-title">AI回答</text>
    <view class="response-content">
      <view class="loading" wx:if="{{loading}}">
        <text>AI正在思考...</text>
      </view>
      <view wx:else>
        <text class="user-question">Q: {{userQuestion}}</text>
        <text class="ai-answer">A: {{aiAnswer}}</text>
      </view>
    </view>
  </view>
</view>