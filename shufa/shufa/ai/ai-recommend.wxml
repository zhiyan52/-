<!-- 个性化推荐页面 -->
<view class="ai-recommend-container">
  <view class="header">
    <text class="title">个性化推荐</text>
    <text class="subtitle">根据你的兴趣推荐书画作品</text>
  </view>
  
  <view class="history-section">
    <text class="section-title">浏览历史</text>
    <view class="history-list" wx:if="{{historyList.length > 0}}">
      <view class="history-item" wx:for="{{historyList}}" wx:key="index">
        <image class="history-image" src="{{item.image}}" mode="aspectFill" />
        <view class="history-info">
          <text class="history-title">{{item.title}}</text>
          <text class="history-time">{{item.time}}</text>
        </view>
      </view>
    </view>
    <view class="empty-history" wx:else>
      <text>暂无浏览历史</text>
    </view>
  </view>
  
  <view class="recommend-section">
    <text class="section-title">为你推荐</text>
    <view class="recommend-list">
      <view class="recommend-item" wx:for="{{recommendList}}" wx:key="id">
        <image class="recommend-image" src="{{item.image}}" mode="aspectFill" />
        <text class="recommend-title">{{item.title}}</text>
        <text class="recommend-desc">{{item.description}}</text>
        <view class="recommend-tags">
          <view class="tag" wx:for="{{item.tags}}" wx:key="index">{{item}}</view>
        </view>
      </view>
    </view>
  </view>
  
  <!-- 视觉参考图 -->
  <view class="visual-section" wx:if="{{visualReferences.length > 0}}">
    <text class="section-title">视觉参考</text>
    <view class="visual-list">
      <view class="visual-item" wx:for="{{visualReferences}}" wx:key="index">
        <image class="visual-image" src="{{item.image}}" mode="aspectFill" />
        <text class="visual-desc">{{item.description}}</text>
      </view>
    </view>
  </view>
  
  <view class="refresh-section">
    <view class="refresh-button" bindtap="refreshRecommend">刷新推荐</view>
  </view>
  
  <view class="loading" wx:if="{{loading}}">
    <text>AI正在为你推荐...</text>
  </view>
</view>