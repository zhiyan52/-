/* 智能导览页面样式 - 传统温暖风格 */
.ai-guide-container {
  background-color: #f5f0e6;
  min-height: 100vh;
  padding: 20rpx 30rpx;
  font-family: 'KaiTi', 'STKaiti', 'PingFang SC', sans-serif;
}

.header {
  text-align: center;
  padding: 40rpx 0 50rpx;
  position: relative;
}

.title {
  font-size: 48rpx;
  font-weight: 600;
  color: #5c3a21;
  letter-spacing: 8rpx;
  display: inline-block;
  background: #fff;
  padding: 20rpx 60rpx;
  border-radius: 56rpx;
  border: 2rpx solid #d4af37;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
}

.subtitle {
  font-size: 28rpx;
  color: #8b7355;
  margin-top: 20rpx;
  display: block;
}

.header::after {
  content: '';
  position: absolute;
  bottom: 20rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 120rpx;
  height: 4rpx;
  background: linear-gradient(90deg, #d4af37, #b8860b, #d4af37);
  border-radius: 2rpx;
}

.building-list {
  margin-top: 40rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #5c3a21;
  margin-bottom: 30rpx;
  display: block;
  text-align: center;
  letter-spacing: 4rpx;
  position: relative;
  padding-bottom: 16rpx;
}

.section-title::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 100rpx;
  height: 4rpx;
  background: linear-gradient(90deg, #d4af37, #b8860b, #d4af37);
  border-radius: 2rpx;
}

.building-items {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 24rpx;
}

.building-item {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
  padding: 0;
  text-align: center;
  border: 2rpx solid #d4af37;
}

.building-image {
  width: 100%;
  height: 200rpx;
  border-radius: 0;
  margin-bottom: 0;
}

.building-name {
  font-size: 30rpx;
  color: #5c3a21;
  font-weight: 600;
  padding: 20rpx;
  letter-spacing: 2rpx;
}

.ai-content {
  margin-top: 50rpx;
  background: rgba(255, 255, 255, 0.85);
  border-radius: 24rpx;
  padding: 36rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
  border: 2rpx solid #d4af37;
}

.content-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #5c3a21;
  margin-bottom: 24rpx;
  display: block;
  letter-spacing: 2rpx;
}

.ai-response {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  min-height: 200rpx;
  margin-bottom: 30rpx;
  border: 1rpx solid #e8dcc8;
}

.loading {
  text-align: center;
  color: #8b7355;
  padding: 40rpx 0;
  font-size: 28rpx;
}

.ai-text {
  font-size: 28rpx;
  color: #5c3a21;
  line-height: 1.7;
}

.control-buttons {
  display: flex;
  gap: 24rpx;
}

.button {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  text-align: center;
  letter-spacing: 2rpx;
  transition: all 0.3s ease;
}

.button:first-child {
  background: linear-gradient(135deg, #d4af37 0%, #b8860b 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(212, 175, 55, 0.4);
}

.button:last-child {
  background: #faf8f5;
  color: #5c3a21;
  border: 2rpx solid #d4af37;
}

.button:active {
  transform: scale(0.96);
}