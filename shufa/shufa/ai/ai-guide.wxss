.guide-container {
  padding: 30rpx;
  background: linear-gradient(180deg, #f3e5f5 0%, #e1bee7 100%);
  min-height: 100vh;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #6a1b9a;
  margin-bottom: 10rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #8e24aa;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #4a148c;
  margin-bottom: 20rpx;
}

.art-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.art-item {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  border: 3rpx solid transparent;
}

.art-item.active {
  border-color: #6a1b9a;
  background: #f3e5f5;
}

.art-image {
  width: 140rpx;
  height: 100rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.art-info {
  flex: 1;
  display: flex;
  flex-direction: column;
}

.art-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.art-artist {
  font-size: 24rpx;
  color: #6a1b9a;
}

.guide-content {
  margin-top: 40rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.1);
}

.content-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid #e1bee7;
}

.content-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #4a148c;
}

.guide-tag {
  background: linear-gradient(135deg, #6a1b9a 0%, #8e24aa 100%);
  color: #fff;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.loading {
  text-align: center;
  padding: 60rpx 0;
  color: #6a1b9a;
  font-size: 28rpx;
}

.guide-text {
  font-size: 28rpx;
  line-height: 1.8;
  color: #444;
}

.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #6a1b9a 0%, #8e24aa 100%);
  color: #fff;
  padding: 30rpx 20rpx;
  border-radius: 16rpx;
}

.btn-icon {
  font-size: 40rpx;
  margin-bottom: 10rpx;
}