/* 个性化推荐页面 - 传统中国风样式 */
.recommend-container {
  padding: 30rpx;
  background-color: #E8F5E8;
  min-height: 100vh;
}

/* 顶部标题栏 */
.header {
  text-align: center;
  margin: 20rpx 0 40rpx;
  position: relative;
}

.title {
  background: linear-gradient(135deg, #1A365D 0%, #2C5282 100%);
  padding: 20rpx 60rpx;
  border-radius: 50rpx;
  position: relative;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
  display: inline-block;
  font-size: 48rpx;
  font-weight: bold;
  color: #D4A017;
  font-family: "STKaiti", "KaiTi", serif;
  letter-spacing: 8rpx;
  text-shadow: 2rpx 2rpx 4rpx rgba(0,0,0,0.2);
}

.title::before,
.title::after {
  content: '';
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 40rpx;
  height: 40rpx;
  background: #D4A017;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #1A365D;
  font-weight: bold;
}

.title::before {
  left: -20rpx;
  content: '卍';
}

.title::after {
  right: -20rpx;
  content: '卍';
}

.subtitle {
  font-size: 28rpx;
  color: #2C5282;
  font-family: "STKaiti", "KaiTi", serif;
  margin-top: 20rpx;
  display: block;
}

.filter-section {
  margin-bottom: 40rpx;
}

.filter-tabs {
  display: flex;
  background: #F8F0E3;
  border-radius: 16rpx;
  padding: 10rpx;
  border: 2rpx solid #D4A017;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
}

.filter-tab {
  flex: 1;
  text-align: center;
  padding: 15rpx 0;
  border-radius: 12rpx;
  transition: all 0.3s ease;
  font-family: "STKaiti", "KaiTi", serif;
  font-size: 28rpx;
  color: #1A365D;
  font-weight: 500;
}

.filter-tab.active {
  background: linear-gradient(135deg, #1A365D 0%, #2C5282 100%);
  color: #D4A017;
  box-shadow: 0 2rpx 8rpx rgba(26, 54, 93, 0.3);
}

.recommend-list {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.recommend-item {
  background: #F8F0E3;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.08);
  border: 2rpx solid #D4A017;
  transition: all 0.3s ease;
  display: flex;
  gap: 20rpx;
  padding: 20rpx;
}

.recommend-item:hover {
  transform: translateY(-5rpx);
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.15);
}

.recommend-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  border: 2rpx solid #D4A017;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.recommend-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.recommend-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1A365D;
  margin-bottom: 8rpx;
  font-family: "STKaiti", "KaiTi", serif;
}

.recommend-artist {
  font-size: 26rpx;
  color: #D4A017;
  margin-bottom: 12rpx;
  font-family: "STKaiti", "KaiTi", serif;
}

.recommend-description {
  font-size: 24rpx;
  line-height: 1.6;
  color: #444;
  margin-bottom: 16rpx;
  font-family: "STKaiti", "KaiTi", serif;
}

.recommend-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 16rpx;
}

.tag {
  background: #F8F0E3;
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  font-size: 20rpx;
  color: #1A365D;
  border: 1rpx solid #D4A017;
  font-family: "STKaiti", "KaiTi", serif;
}

.recommend-actions {
  display: flex;
  gap: 15rpx;
}

.action-btn {
  flex: 1;
  padding: 12rpx 0;
  border-radius: 12rpx;
  text-align: center;
  font-size: 24rpx;
  font-family: "STKaiti", "KaiTi", serif;
  font-weight: 500;
  transition: all 0.3s ease;
}

.action-btn:not(.secondary) {
  background: linear-gradient(135deg, #1A365D 0%, #2C5282 100%);
  color: #D4A017;
  border: 2rpx solid #D4A017;
  box-shadow: 0 2rpx 8rpx rgba(26, 54, 93, 0.3);
}

.action-btn.secondary {
  background: #F8F0E3;
  color: #1A365D;
  border: 2rpx solid #D4A017;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
}

.action-btn:hover {
  transform: translateY(-3rpx);
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.15);
}

.loading {
  text-align: center;
  padding: 80rpx 0;
  font-size: 32rpx;
  color: #1A365D;
  font-family: "STKaiti", "KaiTi", serif;
}
